@using System.Globalization
@using System.Linq
@model HNB.Areas.WW.Models.HistoryIndexModel

@{
    var records = Model?.Records ?? [];
    var monthOutfitCount = records.Count;
    var avgTempText = "—";
    var topOccasionText = records
        .Where(r => !string.IsNullOrWhiteSpace(r.BadgeText))
        .GroupBy(r => r.BadgeText!)
        .OrderByDescending(g => g.Count())
        .Select(g => g.Key)
        .FirstOrDefault() ?? "—";
    var firstRecord = records.FirstOrDefault();
}

<div class="cols">
    <div class="cal-col">
        <div class="month-summary">
            <div class="ms-stat">
                <div class="ms-num">@monthOutfitCount</div>
                <div class="ms-label">Outfits</div>
            </div>
            <div class="ms-stat">
                <div class="ms-num">@avgTempText</div>
                <div class="ms-label">Avg Temp</div>
            </div>
            <div class="ms-stat">
                <div class="ms-num orange">@topOccasionText</div>
                <div class="ms-label">Top Occ.</div>
            </div>
        </div>

        <div class="cal-wrap">
            <div class="cal-grid" id="cal-grid"></div>
        </div>

        <div class="sec-label">Recent Logs</div>
        <div class="recent-strip">
            @for (var index = 0; index < records.Count; index++)
            {
                var record = records[index];
                var dateText = record.CreatedAt.ToString("MMM dd", CultureInfo.InvariantCulture);
                var weekdayText = record.CreatedAt.ToString("dddd", CultureInfo.InvariantCulture);
                var occasionText = record.BadgeText ?? "";
                var weatherText = record.TypeName ?? "";
                var itemClass = index == 0 ? "recent-item js-recent-item active" : "recent-item js-recent-item";
                <div class="@itemClass"
                     data-date="@dateText"
                     data-weekday="@weekdayText"
                     data-weather="@weatherText"
                     data-occ="@occasionText"
                     data-name="@record.Title"
                     data-summary="@record.Description">
                    <div class="ri-date">@dateText</div>
                    <div class="ri-name">@record.Title</div>
                    <div class="ri-occ">@occasionText</div>
                    <div class="ri-weather">@weatherText</div>
                </div>
            }
        </div>
    </div>

    <div class="log-col">
        @if (firstRecord == null)
        {
            <div class="log-empty">
                <div class="log-empty-ico">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>
                </div>
                <div class="log-empty-title">No outfit history yet</div>
                <div class="log-empty-sub">Save your first daily look and your calendar timeline will appear here.</div>
            </div>
        }
        else
        {
            <div class="log-detail">
                <div class="log-topbar">
                    <div>
                        <div class="log-date-big" id="log-date-big">@firstRecord.CreatedAt.ToString("dddd, MMMM dd", CultureInfo.InvariantCulture)</div>
                        <div class="log-pills">
                            <div class="log-weather-pill" id="log-weather">@(firstRecord.TypeName ?? "")</div>
                            <div class="log-occ-pill" id="log-occ">@(firstRecord.BadgeText ?? "")</div>
                        </div>
                    </div>
                    <div class="log-icons">
                        <button type="button" id="like-btn" class="log-icon-btn" onclick="wwCalendarToggleLike()" aria-label="Like">
                            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                        </button>
                    </div>
                </div>

                <div class="log-scroll">
                    <div class="outfit-hero">
                        <div class="hero-badge" id="hero-badge">@(firstRecord.BadgeText ?? "")</div>
                        <div class="hero-weather" id="hero-weather">@(firstRecord.TypeName ?? "")</div>
                        <div class="full-look">
                            <div class="look-item"><div class="look-box" style="width:46px;height:58px;"><svg width="22" height="22" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z" /></svg></div><span class="look-lbl">Top</span></div>
                            <div class="look-item"><div class="look-box" style="width:38px;height:66px;"><svg width="18" height="18" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z" /></svg></div><span class="look-lbl">Bottom</span></div>
                            <div class="look-item"><div class="look-box" style="width:50px;height:62px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M3 5c0-1 .7-2 2-2l4 3 3-3 3 3 4-3c1.3 0 2 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z" /></svg></div><span class="look-lbl">Outerwear</span></div>
                            <div class="look-item"><div class="look-box" style="width:42px;height:34px;"><svg width="20" height="14" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5" /><ellipse cx="24" cy="14" rx="7" ry="5" /><path d="M1 14V8a6 6 0 0 1 12 0v2h6V8a6 6 0 0 1 12 0v6" /></svg></div><span class="look-lbl">Shoes</span></div>
                        </div>
                    </div>

                    <div class="ai-summary">
                        <div class="ai-summary-name" id="ai-summary-name">@firstRecord.Title</div>
                        <div class="ai-summary-text" id="ai-summary-text">@firstRecord.Description</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
