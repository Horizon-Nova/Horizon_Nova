@{
    Layout = null;
}

<style>
/* Today：以藍圖 wtw_today_v4.html 為準（只內嵌 TOPBAR/COLS/LEFT/RIGHT 的 CSS，不含 body/app/sidebar）。 */

/* ── TOPBAR ── */
.tb {
  height: 54px; flex-shrink: 0;
  background: rgba(217,212,192,0.75);
  backdrop-filter: blur(14px);
  border-bottom: 0.5px solid rgba(0,0,0,0.07);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 28px;
}
.tb-brand {
  font-family: var(--font-sans); font-weight: 900;
  font-size: 15px; color: var(--ink); letter-spacing: 0.1px;
}
.tb-brand em {
  font-family: var(--font-serif); font-style: italic;
  font-weight: 500; color: var(--orange);
}
.tb-r { display: flex; align-items: center; gap: 12px; }

.av {
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: 1.5px solid rgba(255,255,255,0.15);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.7);
  cursor: pointer;
}

/* Location pill (clickable) */
.loc-pill {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.6);
  border: 0.5px solid rgba(0,0,0,0.08);
  border-radius: 20px; padding: 6px 12px;
  cursor: pointer; transition: all 0.15s;
  position: relative;
}
.loc-pill:hover { background: rgba(255,255,255,0.85); border-color: var(--orange); }
.loc-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); animation: pdot 2s infinite; }
@@keyframes pdot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.75)} }
.loc-text { font-size: 12px; color: var(--ink2); font-weight: 700; }
.loc-edit { font-size: 10px; color: var(--orange); font-weight: 700; opacity: 0; transition: opacity 0.15s; }
.loc-pill:hover .loc-edit { opacity: 1; }
.loc-svg { width: 11px; height: 11px; stroke: var(--orange); fill: none; stroke-width: 2.2; }

/* Location edit popup */
.loc-popup {
  position: absolute; top: 42px; right: 0;
  background: #fff; border-radius: 14px;
  border: 0.5px solid rgba(0,0,0,0.1);
  box-shadow: 0 12px 40px rgba(0,0,0,0.14);
  padding: 14px 16px; width: 260px;
  z-index: 100;
  display: none;
}
.loc-popup.open { display: block; animation: fadeUp 0.18s ease; }
.loc-popup-label { font-size: 10px; font-weight: 700; color: var(--ink3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
.loc-inp-row { display: flex; gap: 6px; align-items: center; }
.loc-inp {
  flex: 1; border: 1.5px solid var(--beige); border-radius: 9px;
  padding: 8px 11px; font-size: 13px; font-family: var(--font-sans);
  color: var(--ink); outline: none; background: #faf9f6;
}
.loc-inp:focus { border-color: var(--orange); }
.loc-confirm {
  background: var(--orange); color: #fff; border: none;
  border-radius: 9px; padding: 8px 13px;
  font-size: 12px; font-weight: 700; font-family: var(--font-sans);
  cursor: pointer;
}
.loc-confirm:hover { background: var(--orange-d); }

/* ── COLS ── */
.cols { flex: 1; display: flex; overflow: hidden; }

/* ── LEFT PANEL ── */
.lp {
  width: 310px; flex-shrink: 0;
  border-right: 0.5px solid rgba(0,0,0,0.07);
  display: flex; flex-direction: column; overflow: hidden;
}
.lp-scroll { flex: 1; overflow-y: auto; padding: 22px 20px 0; display: flex; flex-direction: column; gap: 16px; }
.lp-scroll::-webkit-scrollbar { display: none; }
.lp-foot { padding: 14px 20px 20px; flex-shrink: 0; }

/* Weather card */
.wcard {
  background: var(--orange); border-radius: 18px;
  padding: 18px 20px;
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0; position: relative; overflow: hidden;
  box-shadow: 0 8px 28px rgba(215,103,54,0.35);
}
.wcard::before {
  content: ''; position: absolute;
  top: -30px; right: -30px;
  width: 130px; height: 130px; border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.wcard::after {
  content: ''; position: absolute;
  bottom: -40px; right: 50px;
  width: 100px; height: 100px; border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.wl .city { font-size: 9.5px; color: rgba(255,255,255,0.6); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.wl .tmp { font-size: 44px; font-weight: 900; color: #fff; line-height: 1; margin: 3px 0; }
.wl .desc { font-size: 12px; color: rgba(255,255,255,0.82); }
.wr .ico { font-size: 38px; }
.wr .feel { font-size: 10px; color: rgba(255,255,255,0.5); margin-top: 5px; text-align: right; }

/* 7-day strip */
.week-strip {
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(10px);
  border-radius: 16px; padding: 13px 13px;
  flex-shrink: 0;
  border: 0.5px solid rgba(255,255,255,0.8);
  box-shadow: 0 4px 16px rgba(0,0,0,0.05);
}
.week-hdr { font-size: 9px; color: var(--ink3); letter-spacing: 0.1em; font-weight: 700; margin-bottom: 11px; text-transform: uppercase; }
.week-row { display: flex; gap: 3px; overflow-x: auto; }
.week-row::-webkit-scrollbar { display: none; }
.wday {
  flex-shrink: 0; width: 38px;
  display: flex; flex-direction: column; align-items: center;
  gap: 4px; padding: 8px 4px; border-radius: 12px;
  cursor: pointer; transition: background 0.15s;
}
.wday:hover { background: var(--orange-l); }
.wday.sel { background: var(--orange-l); outline: 2px solid var(--orange); }
.wday.today { background: var(--orange); box-shadow: 0 3px 10px rgba(215,103,54,0.35); }
.wday.today:hover { background: var(--orange-d); }
.wd-lbl { font-size: 9px; color: var(--ink3); font-weight: 700; text-transform: uppercase; }
.wday.today .wd-lbl { color: rgba(255,255,255,0.8); }
.wday.sel .wd-lbl { color: var(--orange); }
.wd-ico { font-size: 15px; line-height: 1; }
.wd-circle { width: 7px; height: 7px; border-radius: 50%; border: 1.5px solid var(--ink3); opacity: 0.3; }
.wday.today .wd-circle { border-color: rgba(255,255,255,0.5); opacity: 1; }
.wday.sel .wd-circle { border-color: var(--orange); opacity: 1; }
.wd-circle.filled { background: var(--orange); border-color: var(--orange); opacity: 1; }
.wday.today .wd-circle.filled { background: #fff; border-color: #fff; }

/* Occasion pick */
.occ-section { display: flex; flex-direction: column; gap: 12px; }
.occ-title { font-size: 12px; font-weight: 900; color: var(--ink); letter-spacing: 0.2px; }
.occ-sub { font-size: 11px; color: var(--ink3); margin-top: 3px; }
.occ-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.ocard {
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(8px);
  border-radius: 13px;
  padding: 12px 13px;
  border: 1.5px solid rgba(255,255,255,0.7);
  cursor: pointer;
  transition: all 0.15s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.ocard:hover { border-color: var(--orange); background: var(--orange-l); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(215,103,54,0.15); }
.ocard.on { border-color: var(--orange); background: var(--orange-l); }
.ocard .em { font-size: 20px; margin-bottom: 4px; }
.ocard .nm { font-size: 12.5px; font-weight: 700; color: var(--ink); }
.ocard .ht { font-size: 10px; color: var(--ink3); margin-top: 1px; }

/* Free text */
.free-block {
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(8px);
  border-radius: 16px;
  padding: 13px;
  border: 0.5px solid rgba(255,255,255,0.85);
}
.free-block-label { font-size: 10px; color: var(--ink3); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }
.free-inp {
  width: 100%;
  resize: none;
  border: 1.5px solid rgba(0,0,0,0.08);
  border-radius: 13px;
  padding: 12px 12px;
  font-size: 12.5px;
  font-family: var(--font-sans);
  outline: none;
  color: var(--ink);
  background: rgba(255,255,255,0.75);
  line-height: 1.55;
}
.free-inp:focus { border-color: var(--orange); }
.free-examples { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
.free-ex {
  font-size: 10.5px;
  background: rgba(255,255,255,0.7);
  border: 0.5px solid rgba(0,0,0,0.08);
  color: var(--ink2);
  padding: 6px 10px;
  border-radius: 999px;
  cursor: pointer;
  font-weight: 700;
  transition: all 0.12s;
}
.free-ex:hover { background: var(--orange-l); border-color: var(--orange); color: var(--orange); }

/* Generate button */
.gbtn {
  width: 100%;
  background: var(--orange);
  color: #fff;
  border: none;
  border-radius: 14px;
  padding: 15px;
  font-size: 14.5px;
  font-weight: 900;
  font-family: var(--font-sans);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  letter-spacing: 0.3px;
  transition: all 0.15s;
  box-shadow: 0 6px 20px rgba(215,103,54,0.4);
}
.gbtn:hover { background: var(--orange-d); transform: translateY(-2px); box-shadow: 0 10px 28px rgba(215,103,54,0.45); }
.gbtn:active { transform: translateY(0); }
.gbtn:disabled { opacity: 0.3; cursor: default; transform: none; box-shadow: none; }
.gbtn svg { width: 15px; height: 15px; stroke: #fff; fill: none; stroke-width: 2.5; }

/* ── RIGHT PANEL ── */
.rp {
  flex: 1; background: rgba(255,255,255,0.38);
  backdrop-filter: blur(14px);
  display: flex; flex-direction: column; overflow: hidden;
}

.r-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; padding: 40px; }
.r-empty-ico { width: 72px; height: 72px; border-radius: 50%; background: rgba(255,255,255,0.7); border: 0.5px solid rgba(0,0,0,0.07); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
.r-empty-ico svg { width: 32px; height: 32px; stroke: var(--ink3); fill: none; stroke-width: 1.2; }
.r-empty-title { font-size: 26px; font-weight: 500; font-family: var(--font-serif); font-style: italic; color: var(--ink); text-align: center; }
.r-empty-sub { font-size: 13px; color: var(--ink3); text-align: center; line-height: 1.75; max-width: 240px; }

.r-gen { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px; padding: 40px; }
.gcircle { width: 74px; height: 74px; border-radius: 50%; background: rgba(255,255,255,0.8); border: 0.5px solid rgba(0,0,0,0.07); box-shadow: 0 6px 20px rgba(0,0,0,0.08); display: flex; align-items: center; justify-content: center; position: relative; }
.sring { position: absolute; width: 64px; height: 64px; border-radius: 50%; border: 2.5px solid transparent; border-top-color: var(--orange); animation: spin 0.85s linear infinite; }
@@keyframes spin { to { transform: rotate(360deg); } }
.gsteps { display: flex; flex-direction: column; gap: 10px; width: 240px; }
.gstep { display: flex; align-items: center; gap: 10px; }
.sd { width: 8px; height: 8px; border-radius: 50%; background: rgba(0,0,0,0.1); flex-shrink: 0; transition: background 0.3s; }
.sd.done { background: var(--orange); }
.sd.cur { background: var(--orange); animation: pulse 0.8s infinite; }
@@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
.st { font-size: 12.5px; color: var(--ink3); transition: color 0.3s; }
.st.done { color: var(--ink); }
.st.cur { color: var(--orange); font-weight: 700; }

.r-items { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px; padding: 40px; }
.items-row { display: flex; gap: 16px; align-items: flex-end; }
.icard { display: flex; flex-direction: column; align-items: center; gap: 7px; opacity: 0; transform: translateY(14px) scale(0.9); transition: opacity 0.32s ease, transform 0.32s ease; }
.icard.show { opacity: 1; transform: translateY(0) scale(1); }
.ibox { border-radius: 13px; background: rgba(211,206,184,0.8); display: flex; align-items: center; justify-content: center; position: relative; }
.ibox svg { stroke: rgba(0,0,0,0.22); fill: none; stroke-width: 1.3; }
.ichk { position: absolute; top: -7px; right: -7px; width: 18px; height: 18px; border-radius: 50%; background: var(--orange); display: flex; align-items: center; justify-content: center; opacity: 0; transform: scale(0); transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1); }
.ichk.show { opacity: 1; transform: scale(1); }
.ichk svg { width: 9px; height: 9px; stroke: #fff; fill: none; stroke-width: 2.5; }
.ilbl { font-size: 10.5px; color: var(--ink3); font-weight: 700; letter-spacing: 0.3px; text-transform: uppercase; }

.r-result { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.r-topbar { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; border-bottom: 0.5px solid rgba(0,0,0,0.07); flex-shrink: 0; }
.r-topbar-l { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--ink2); font-weight: 700; }
.r-topbar-l svg { width: 14px; height: 14px; stroke: var(--ink3); fill: none; stroke-width: 2; }
.rtb-actions { display: flex; gap: 10px; }
.rtb-ic { width: 34px; height: 34px; border-radius: 12px; background: rgba(255,255,255,0.65); border: 0.5px solid rgba(0,0,0,0.07); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.15s; }
.rtb-ic:hover { border-color: var(--orange); transform: translateY(-1px); }
.rtb-ic svg { width: 16px; height: 16px; stroke: var(--ink3); fill: none; stroke-width: 1.8; }

.r-scroll { flex: 1; overflow-y: auto; padding: 22px 26px; display: flex; flex-direction: column; gap: 16px; }
.r-scroll::-webkit-scrollbar { display: none; }
.outfit-hero {
  border-radius: 18px;
  background: linear-gradient(150deg,rgba(242,224,213,0.9),rgba(211,206,184,0.75));
  height: 210px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  flex-shrink: 0;
  border: 0.5px solid rgba(255,255,255,0.7);
}
.obadge { position: absolute; top: 13px; left: 13px; background: rgba(215,103,54,0.15); border: 0.5px solid rgba(215,103,54,0.3); border-radius: 20px; padding: 4px 12px; font-size: 11px; color: var(--orange); font-weight: 700; }
.owbadge { position: absolute; top: 13px; right: 13px; background: rgba(255,255,255,0.88); border-radius: 20px; padding: 4px 12px; font-size: 11px; color: var(--ink2); }
.outfit-full { display: flex; gap: 13px; align-items: flex-end; opacity: 0; transform: scale(0.92); transition: all 0.55s cubic-bezier(0.34,1.2,0.64,1); }
.outfit-full.show { opacity: 1; transform: scale(1); }
.of-item { display: flex; flex-direction: column; align-items: center; gap: 5px; }
.of-box { border-radius: 11px; background: rgba(200,194,170,0.85); display: flex; align-items: center; justify-content: center; }
.of-box svg { stroke: rgba(0,0,0,0.2); fill: none; stroke-width: 1.3; }
.of-lbl { font-size: 10px; color: var(--ink3); font-weight: 700; letter-spacing: 0.3px; text-transform: uppercase; }

.ai-name { font-size: 26px; font-family: var(--font-serif); font-style: italic; font-weight: 500; color: var(--ink); opacity: 0; }
.ai-text { font-size: 14px; color: var(--ink2); line-height: 1.75; }
.cursor { display: inline-block; width: 2px; height: 13px; background: var(--orange); margin-left: 1px; animation: blink 0.7s infinite; vertical-align: middle; }
@@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.r-actions { display: flex; gap: 10px; opacity: 0; transition: opacity 0.4s; }
.rab {
  flex: 1;
  background: rgba(255,255,255,0.65);
  border: 0.5px solid rgba(0,0,0,0.07);
  border-radius: 14px;
  padding: 12px 14px;
  font-size: 13px;
  font-weight: 900;
  color: var(--ink);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.15s;
}
.rab:hover { border-color: var(--orange); transform: translateY(-1px); }
.rab svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 1.8; }

.r-tweak { opacity: 0; transition: opacity 0.4s; background: rgba(255,255,255,0.6); border-radius: 16px; padding: 12px 14px; border: 0.5px solid rgba(255,255,255,0.85); flex-shrink: 0; backdrop-filter: blur(8px); }
.chips { display: flex; gap: 7px; margin-bottom: 10px; flex-wrap: wrap; }
.chip { padding: 5px 11px; border-radius: 20px; background: rgba(255,255,255,0.8); border: 0.5px solid rgba(0,0,0,0.08); font-size: 11.5px; color: var(--ink2); cursor: pointer; font-weight: 700; transition: all 0.13s; }
.chip:hover { background: var(--orange-l); border-color: var(--orange); color: var(--orange); }
.tinp-row { display: flex; gap: 9px; align-items: center; }
.tinp { flex: 1; border: none; outline: none; font-size: 12.5px; font-family: var(--font-sans); color: var(--ink); background: transparent; }
.tinp::placeholder { color: var(--ink3); }
.tsend { width: 30px; height: 30px; border-radius: 50%; background: var(--orange); border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.15s; }
.tsend:hover { background: var(--orange-d); }
.tsend svg { width: 11px; height: 11px; stroke: #fff; fill: none; stroke-width: 2.5; }

.shop-wrap { opacity: 0; transition: opacity 0.4s; flex-shrink: 0; }
.shop-divider { height: 0.5px; background: rgba(0,0,0,0.07); margin-bottom: 13px; }
.shop-hdr { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 11px; }
.shop-title { font-size: 14px; font-weight: 900; color: var(--ink); }
.shop-sub { font-size: 11px; color: var(--ink3); }
.shop-row { display: flex; gap: 9px; overflow-x: auto; padding-bottom: 3px; }
.shop-row::-webkit-scrollbar { height: 2px; }
.shop-row::-webkit-scrollbar-thumb { background: var(--beige); }
.pcard { width: 118px; flex-shrink: 0; background: rgba(255,255,255,0.75); border-radius: 13px; border: 0.5px solid rgba(0,0,0,0.07); overflow: hidden; cursor: pointer; transition: all 0.15s; backdrop-filter: blur(4px); }
.pcard:hover { border-color: var(--orange); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
.pimg { height: 82px; background: linear-gradient(135deg,rgba(242,224,213,0.9),rgba(211,206,184,0.8)); display: flex; align-items: center; justify-content: center; position: relative; }
.pimg svg { width: 30px; height: 30px; stroke: rgba(0,0,0,0.18); fill: none; stroke-width: 1.3; }
.ptag { position: absolute; top: 7px; left: 7px; background: var(--orange); color: #fff; font-size: 8px; padding: 2px 7px; border-radius: 6px; font-weight: 700; }
.pinfo { padding: 9px 10px; }
.pname { font-size: 12px; font-weight: 700; color: var(--ink); }
.pwhy { font-size: 10px; color: var(--ink3); margin-top: 1px; line-height: 1.3; }
.pprice { font-size: 12px; font-weight: 700; color: var(--orange); margin-top: 5px; }

.r-record { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.rec-topbar { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; border-bottom: 0.5px solid rgba(0,0,0,0.07); flex-shrink: 0; }
.rec-date { font-size: 14px; font-weight: 700; color: var(--ink); }
.rec-meta { font-size: 11.5px; color: var(--ink3); }
.rec-scroll { flex: 1; overflow-y: auto; padding: 22px 26px; display: flex; flex-direction: column; gap: 16px; }
.rec-hero { border-radius: 18px; background: linear-gradient(150deg,rgba(242,224,213,0.9),rgba(211,206,184,0.75)); height: 210px; display: flex; align-items: center; justify-content: center; position: relative; flex-shrink: 0; border: 0.5px solid rgba(255,255,255,0.7); }
.rec-name { font-size: 17px; font-weight: 500; color: var(--ink); font-family: var(--font-serif); font-style: italic; }
.rec-reason { font-size: 12.5px; color: var(--ink2); line-height: 1.75; }

.r-future { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.fut-topbar { padding: 14px 24px; border-bottom: 0.5px solid rgba(0,0,0,0.07); flex-shrink: 0; }
.fut-date { font-size: 14px; font-weight: 700; color: var(--ink); }
.fut-weather { font-size: 12px; color: var(--ink2); margin-top: 3px; display: flex; align-items: center; gap: 6px; }
.fut-scroll { flex: 1; overflow-y: auto; padding: 22px 26px; display: flex; flex-direction: column; gap: 14px; }
.fut-occ-title { font-size: 15px; font-weight: 900; color: var(--ink); }
.fut-occ-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.fut-note { background: var(--orange-l); border-left: 3px solid var(--orange); border-radius: 0 12px 12px 0; padding: 12px 15px; font-size: 12.5px; color: #7a4020; line-height: 1.65; }
.fut-gbtn { background: var(--orange); color: #fff; border: none; border-radius: 13px; padding: 14px; font-size: 13.5px; font-weight: 700; font-family: var(--font-sans); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 7px; box-shadow: 0 6px 20px rgba(215,103,54,0.35); }
