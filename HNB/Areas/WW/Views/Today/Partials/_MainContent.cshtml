@using System.Linq
@model HNB.Areas.WW.Models.TodayIndexModel

@{
    var todayForecast = Model?.WeatherDays?.FirstOrDefault(day => day.IsToday);
    var todayIcon = todayForecast?.WeatherIconEmoji ?? Model?.CurrentWeatherEmoji ?? "☀️";
    var futureDays = Model?.WeatherDays?.Where(day => day.IsToday == false).ToList() ?? [];
}

<div class="cols flex flex-1 overflow-hidden flex-col md:flex-row">

    <!-- LEFT PANEL -->
    <div class="lp w-full md:w-[310px] md:flex-shrink-0 md:border-r-[0.5px] md:border-black/10 flex flex-col overflow-hidden">
        <div class="lp-scroll scrollbar-none flex-1 overflow-y-auto pt-[22px] px-[20px] pb-0 flex flex-col gap-4">

            <!-- Weather -->
            <div class="wcard relative overflow-hidden shrink-0 flex items-center justify-between rounded-[18px] bg-[var(--orange)] px-[20px] py-[18px] shadow-[0_8px_28px_rgba(215,103,54,0.35)]">
                <div class="wl">
                    <div class="city text-[9.5px] text-white/60 font-bold tracking-[0.08em] uppercase">@(Model?.CurrentLocationText ?? "Now · Auto-detected")</div>
                    <div class="tmp text-[44px] font-black text-white leading-none my-[3px]">@(Model?.CurrentTemperatureText ?? "—")</div>
                    <div class="desc text-[12px] text-white/80">@(Model?.CurrentWeatherSummaryText ?? "")</div>
                </div>
                <div class="wr text-right">
                    <div class="ico text-[38px]">@(Model?.CurrentWeatherEmoji ?? "⛅")</div>
                    <div class="feel text-[10px] text-white/50 mt-[5px]">@(Model?.CurrentWindSpeedText ?? "")</div>
                </div>
            </div>

            <!-- Week strip -->
            <div class="week-strip shrink-0 bg-white/55 backdrop-blur-[10px] rounded-[16px] p-[13px] border-[0.5px] border-white/80 shadow-[0_4px_16px_rgba(0,0,0,0.05)]">
                <div class="week-hdr text-[9px] text-[var(--ink3)] tracking-[0.1em] font-bold mb-[11px] uppercase">This Week</div>
                <div class="week-row scrollbar-none flex gap-[3px] overflow-x-auto">
                    <div class="wday"
                         data-type="past"
                         data-date="Apr 17"
                         data-occ="Casual"
                         data-name="Weekend Easy"
                         data-temp="25°"
                         data-ico="☀️"
                         onclick="clickDay(this)">
                        <div class="wd-lbl">Fri</div>
                        <div class="wd-ico">☀️</div>
                        <div class="wd-circle filled"></div>
                    </div>
                    <div class="wday"
                         data-type="past"
                         data-date="Apr 18"
                         data-occ="Date"
                         data-name="Evening Chic"
                         data-temp="21°"
                         data-ico="🌙"
                         onclick="clickDay(this)">
                        <div class="wd-lbl">Sat</div>
                        <div class="wd-ico">🌤️</div>
                        <div class="wd-circle filled"></div>
                    </div>
                    <div class="wday"
                         data-type="past"
                         data-date="Apr 19"
                         data-occ="Work"
                         data-name="Smart Casual"
                         data-temp="23°"
                         data-ico="⛅"
                         onclick="clickDay(this)">
                        <div class="wd-lbl">Sun</div>
                        <div class="wd-ico">⛅</div>
                        <div class="wd-circle filled"></div>
                    </div>

                    <div class="wday today sel" id="day-today" data-type="today" onclick="clickDay(this)">
                        <div class="wd-lbl">Today</div>
                        <div class="wd-ico">@todayIcon</div>
                        <div class="wd-circle"></div>
                    </div>

                    @foreach (var weatherDay in futureDays)
                    {
                        <div class="wday"
                             data-type="future"
                             data-date="@weatherDay.DateFullText"
                             data-temp="@weatherDay.TemperatureText"
                             data-ico="@weatherDay.WeatherIconEmoji"
                             data-desc="@weatherDay.WeatherDescriptionText"
                             onclick="clickDay(this)">
                            <div class="wd-lbl">@weatherDay.WeekdayText</div>
                            <div class="wd-ico">@weatherDay.WeatherIconEmoji</div>
                            <div class="wd-circle"></div>
                        </div>
                    }
                </div>
            </div>

            <!-- Occasion -->
            <div class="occ-section flex flex-col gap-3" id="occ-section">
                <div>
                    <div class="occ-title text-[15px] font-black text-[var(--ink)]" id="occ-title">What's today about?</div>
                    <div class="occ-sub text-[11px] text-[var(--ink3)] mt-[2px]">Quick pick, or describe below</div>
                </div>
                <div class="occ-grid grid grid-cols-2 gap-2">
                    <div class="ocard bg-white/60 backdrop-blur-[8px] rounded-[13px] px-[13px] py-[12px] border-[1.5px] border-white/70 cursor-pointer transition-all duration-150 shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:border-[var(--orange)] hover:bg-[var(--orange-l)] hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(215,103,54,0.15)]" onclick="pickOcc(this,'Work')"><div class="em text-[20px] mb-1">💼</div><div class="nm text-[12.5px] font-bold text-[var(--ink)]">Work</div><div class="ht text-[10px] text-[var(--ink3)] mt-px">Office or meetings</div></div>
                    <div class="ocard bg-white/60 backdrop-blur-[8px] rounded-[13px] px-[13px] py-[12px] border-[1.5px] border-white/70 cursor-pointer transition-all duration-150 shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:border-[var(--orange)] hover:bg-[var(--orange-l)] hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(215,103,54,0.15)]" onclick="pickOcc(this,'Casual')"><div class="em text-[20px] mb-1">☕</div><div class="nm text-[12.5px] font-bold text-[var(--ink)]">Casual</div><div class="ht text-[10px] text-[var(--ink3)] mt-px">Errands or chill</div></div>
                    <div class="ocard bg-white/60 backdrop-blur-[8px] rounded-[13px] px-[13px] py-[12px] border-[1.5px] border-white/70 cursor-pointer transition-all duration-150 shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:border-[var(--orange)] hover:bg-[var(--orange-l)] hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(215,103,54,0.15)]" onclick="pickOcc(this,'Date')"><div class="em text-[20px] mb-1">✨</div><div class="nm text-[12.5px] font-bold text-[var(--ink)]">Date</div><div class="ht text-[10px] text-[var(--ink3)] mt-px">Dinner or night out</div></div>
                    <div class="ocard bg-white/60 backdrop-blur-[8px] rounded-[13px] px-[13px] py-[12px] border-[1.5px] border-white/70 cursor-pointer transition-all duration-150 shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:border-[var(--orange)] hover:bg-[var(--orange-l)] hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(215,103,54,0.15)]" onclick="pickOcc(this,'Outdoor')"><div class="em text-[20px] mb-1">🌿</div><div class="nm text-[12.5px] font-bold text-[var(--ink)]">Outdoor</div><div class="ht text-[10px] text-[var(--ink3)] mt-px">Parks or activities</div></div>
                </div>

                <!-- BIG INPUT -->
                <div class="free-block bg-white/70 backdrop-blur-[10px] rounded-[16px] border-2 border-white/80 px-[16px] pt-[16px] pb-[14px] flex flex-col gap-[10px] shadow-[0_4px_20px_rgba(0,0,0,0.06)] transition-[border-color,box-shadow] duration-150 focus-within:border-[var(--orange)] focus-within:shadow-[0_4px_24px_rgba(215,103,54,0.18)]">
                    <div class="free-block-label text-[10px] font-bold text-[var(--ink3)] uppercase tracking-[0.08em]">Or describe your day</div>
                    <textarea class="free-inp w-full min-h-[42px] resize-none bg-transparent border-none outline-none text-[14px] font-bold text-[var(--ink)] leading-[1.5] placeholder:text-[var(--ink3)] placeholder:font-normal" id="free-occ" rows="2" placeholder='e.g. "rooftop dinner date", "startup job interview"' oninput="handleFree(this)"></textarea>
                    <div class="free-examples flex flex-wrap gap-[5px]">
                        <span class="free-ex cursor-pointer text-[10.5px] font-bold text-[var(--ink2)] px-[10px] py-[6px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]" onclick="setEx('beach wedding as a guest')">👰 Beach wedding</span>
                        <span class="free-ex cursor-pointer text-[10.5px] font-bold text-[var(--ink2)] px-[10px] py-[6px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]" onclick="setEx('casual Friday at the office')">💻 Casual Friday</span>
                        <span class="free-ex cursor-pointer text-[10.5px] font-bold text-[var(--ink2)] px-[10px] py-[6px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]" onclick="setEx('first date at a rooftop bar')">✨ Rooftop date</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- Generate -->
        <div class="lp-foot px-[20px] pt-[14px] pb-[20px] shrink-0">
            <button class="gbtn w-full bg-[var(--orange)] text-white border-none rounded-[14px] p-[15px] text-[14.5px] font-black cursor-pointer flex items-center justify-center gap-[9px] tracking-[0.3px] transition-all duration-150 shadow-[0_6px_20px_rgba(215,103,54,0.4)] hover:bg-[var(--orange-d)] hover:-translate-y-0.5 hover:shadow-[0_10px_28px_rgba(215,103,54,0.45)] active:translate-y-0 disabled:opacity-30 disabled:cursor-default disabled:translate-y-0 disabled:shadow-none" id="gbtn" disabled onclick="startGen()">
                <svg class="w-[15px] h-[15px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                <span id="gbtn-label">Style me today</span>
            </button>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="rp flex-1 bg-white/40 backdrop-blur-[14px] flex flex-col overflow-hidden">

        <!-- Empty -->
        <div class="r-empty flex-1 flex flex-col items-center justify-center gap-4 p-[40px]" id="r-empty">
            <div class="r-empty-ico w-[72px] h-[72px] rounded-full bg-white/70 border-[0.5px] border-black/10 flex items-center justify-center shadow-[0_4px_16px_rgba(0,0,0,0.06)]">
                <svg viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z" /></svg>
            </div>
            <div class="r-empty-title text-[26px] font-medium text-[var(--ink)] font-serif italic text-center">Your outfit will appear here</div>
            <div class="r-empty-sub text-[13px] text-[var(--ink3)] text-center leading-[1.75] max-w-[240px]">Pick an occasion or describe your day — then tap Style me today</div>
        </div>

        <!-- Gen loader -->
        <div class="r-gen hidden flex-1 flex flex-col items-center justify-center gap-[18px] p-[40px]" id="r-gen">
            <div class="gcircle w-[64px] h-[64px] rounded-full bg-[var(--orange-l)] border-2 border-[var(--orange-m)] flex items-center justify-center relative"><div class="sring"></div><span class="text-[20px] text-[var(--orange)]">✦</span></div>
            <div class="text-[16px] font-medium text-[var(--ink)] font-serif italic">Finding your look...</div>
            <div class="text-[12.5px] text-[var(--ink3)]">Matching your closet with today's weather</div>
            <div class="gsteps">
                <div class="gstep"><div class="sd done"></div><span class="st done">Weather · 22° light rain ✓</span></div>
                <div class="gstep"><div class="sd done"></div><span class="st done">Occasion · <span id="g-occ">Work</span> ✓</span></div>
                <div class="gstep"><div class="sd" id="sd3"></div><span class="st" id="st3">Scanning closet for rain-safe pieces...</span></div>
                <div class="gstep"><div class="sd" id="sd4"></div><span class="st" id="st4">Checking colour harmony</span></div>
                <div class="gstep"><div class="sd" id="sd5"></div><span class="st" id="st5">Assembling your look</span></div>
            </div>
        </div>

        <!-- Item assembly -->
        <div class="r-items hidden flex-1 flex flex-col items-center justify-center gap-[18px]" id="r-items">
            <div class="text-[12.5px] text-[var(--ink3)] font-bold tracking-[0.05em] uppercase" id="items-lbl">Picking items...</div>
            <div class="items-row">
                <div class="icard" id="ic0"><div class="ibox" style="width:54px;height:66px;"><svg width="27" height="27" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z" /></svg><div class="ichk" id="ck0"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg></div></div><span class="ilbl">Shirt</span></div>
                <div class="icard" id="ic1"><div class="ibox" style="width:46px;height:78px;"><svg width="23" height="23" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z" /></svg><div class="ichk" id="ck1"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg></div></div><span class="ilbl">Trousers</span></div>
                <div class="icard" id="ic2"><div class="ibox" style="width:62px;height:74px;"><svg width="30" height="30" viewBox="0 0 24 24"><path d="M3 5c0-1 .7-2 2-2l4 3 3-3 3 3 4-3c1.3 0 2 1 2 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" /></svg><div class="ichk" id="ck2"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg></div></div><span class="ilbl">Jacket</span></div>
                <div class="icard" id="ic3"><div class="ibox" style="width:54px;height:42px;"><svg width="27" height="19" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5" /><ellipse cx="24" cy="14" rx="7" ry="5" /><path d="M1 14V8a6 6 0 0112 0v2h6V8a6 6 0 0112 0v6" /></svg><div class="ichk" id="ck3"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg></div></div><span class="ilbl">Shoes</span></div>
            </div>
        </div>

        <!-- Result -->
        <div class="r-result hidden flex-1 flex flex-col overflow-hidden" id="r-result">
            <div class="r-topbar flex items-center justify-between px-[24px] py-[14px] border-b-[0.5px] border-black/10 shrink-0">
                <div class="r-back text-[12px] text-[var(--ink3)] cursor-pointer flex items-center gap-[5px] font-bold transition-colors duration-150 hover:text-[var(--orange)]" onclick="backToEmpty()"><svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="15 18 9 12 15 6" /></svg>Change occasion</div>
                <div class="r-icons flex gap-[14px]">
                    <svg class="w-[18px] h-[18px] text-[var(--ink3)] fill-none cursor-pointer transition-colors duration-150 hover:text-[var(--orange)]" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" /></svg>
                    <svg class="w-[18px] h-[18px] text-[var(--ink3)] fill-none cursor-pointer transition-colors duration-150 hover:text-[var(--orange)]" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" /><line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" /></svg>
                </div>
            </div>
            <div class="r-scroll flex-1 overflow-y-auto px-[26px] pt-[22px] pb-[22px] flex flex-col gap-4 scrollbar-none">
                <div class="outfit-hero rounded-[18px] bg-[linear-gradient(150deg,rgba(242,224,213,0.9)_0%,rgba(211,206,184,0.75)_100%)] h-[210px] flex items-center justify-center relative overflow-hidden shrink-0 border-[0.5px] border-white/70 shadow-[0_6px_24px_rgba(0,0,0,0.08)]">
                    <div class="obadge" id="r-occ-badge">Work</div>
                    <div class="owbadge">22° 🌧️</div>
                    <div class="outfit-full" id="outfit-full">
                        <div class="of-item"><div class="of-box" style="width:48px;height:60px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z" /></svg></div><span class="of-lbl">Top</span></div>
                        <div class="of-item"><div class="of-box" style="width:40px;height:70px;"><svg width="20" height="20" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z" /></svg></div><span class="of-lbl">Bottom</span></div>
                        <div class="of-item"><div class="of-box" style="width:56px;height:68px;"><svg width="27" height="27" viewBox="0 0 24 24"><path d="M3 5c0-1 .7-2 2-2l4 3 3-3 3 3 4-3c1.3 0 2 1 2 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" /></svg></div><span class="of-lbl">Jacket</span></div>
                        <div class="of-item"><div class="of-box" style="width:44px;height:34px;"><svg width="22" height="15" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5" /><ellipse cx="24" cy="14" rx="7" ry="5" /><path d="M1 14V8a6 6 0 0112 0v2h6V8a6 6 0 0112 0v6" /></svg></div><span class="of-lbl">Shoes</span></div>
                    </div>
                </div>
                <div>
                    <div class="ai-name text-[18px] font-medium text-[var(--ink)] font-serif italic opacity-0 transition-opacity duration-300" id="ai-name">Polished Rain-Ready</div>
                    <div class="ai-text text-[12.5px] text-[var(--ink2)] leading-[1.75] min-h-[28px]" id="ai-text"></div>
                </div>
                <div class="ractions flex gap-[9px] opacity-0 transition-opacity duration-300 shrink-0" id="r-actions">
                    <button class="rab flex-1 px-[8px] py-[11px] rounded-[12px] border border-black/10 bg-white/65 text-[12.5px] text-[var(--ink2)] font-bold cursor-pointer flex items-center justify-center gap-[6px] transition-all duration-150 backdrop-blur-[4px] hover:border-[var(--orange)] hover:text-[var(--orange)] hover:-translate-y-px"><svg viewBox="0 0 24 24"><path d="M1 4v6h6M23 20v-6h-6" /><path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15" /></svg>Redo</button>
                    <button class="rab pri flex-1 px-[8px] py-[11px] rounded-[12px] border border-[var(--orange)] bg-[var(--orange)] text-[12.5px] text-white font-bold cursor-pointer flex items-center justify-center gap-[6px] transition-all duration-150 backdrop-blur-[4px] shadow-[0_4px_14px_rgba(215,103,54,0.3)] hover:bg-[var(--orange-d)]"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" /></svg>Save look</button>
                </div>
                <div class="tweak bg-white/55 rounded-[15px] border-[0.5px] border-black/10 px-[15px] py-[13px] opacity-0 transition-opacity duration-300 shrink-0 backdrop-blur-[8px]" id="r-tweak">
                    <div class="chips flex gap-[7px] mb-[10px] flex-wrap"><div class="chip px-[11px] py-[5px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 text-[11.5px] text-[var(--ink2)] cursor-pointer font-bold transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]">Warmer</div><div class="chip px-[11px] py-[5px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 text-[11.5px] text-[var(--ink2)] cursor-pointer font-bold transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]">More formal</div><div class="chip px-[11px] py-[5px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 text-[11.5px] text-[var(--ink2)] cursor-pointer font-bold transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]">No jacket</div><div class="chip px-[11px] py-[5px] rounded-[20px] bg-white/80 border-[0.5px] border-black/10 text-[11.5px] text-[var(--ink2)] cursor-pointer font-bold transition-all duration-150 hover:bg-[var(--orange-l)] hover:border-[var(--orange)] hover:text-[var(--orange)]">Swap shoes</div></div>
                    <div class="tinp-row flex gap-[9px] items-center"><input class="tinp flex-1 border-none outline-none text-[12.5px] text-[var(--ink)] bg-transparent placeholder:text-[var(--ink3)]" placeholder="Or ask anything..." /><button class="tsend w-[30px] h-[30px] rounded-full bg-[var(--orange)] border-none flex items-center justify-center cursor-pointer transition-colors duration-150 hover:bg-[var(--orange-d)]"><svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg></button></div>
                </div>
                <div class="shop-wrap opacity-0 transition-opacity duration-300 shrink-0" id="shop-wrap">
                    <div class="shop-divider h-[0.5px] bg-black/10 mb-[13px]"></div>
                    <div class="shop-hdr flex items-baseline justify-between mb-[11px]"><div class="shop-title text-[14px] font-black text-[var(--ink)]">Shop this look</div><div class="shop-sub text-[11px] text-[var(--ink3)]">Items that complete this outfit</div></div>
                    <div class="shop-row flex gap-[9px] overflow-x-auto pb-[3px] scrollbar-none">
                        <div class="pcard"><div class="pimg"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg><div class="ptag">Completes look</div></div><div class="pinfo"><div class="pname">Oxford Loafer</div><div class="pwhy">Water-resistant sole</div><div class="pprice">$89 · Cole Haan</div></div></div>
                        <div class="pcard"><div class="pimg"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /></svg></div><div class="pinfo"><div class="pname">Canvas Tote</div><div class="pwhy">Waterproof canvas</div><div class="pprice">$45 · Muji</div></div></div>
