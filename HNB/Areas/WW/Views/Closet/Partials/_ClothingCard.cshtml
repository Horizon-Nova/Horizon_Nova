@model (HNB.Areas.WW.Models.WardrobeItemModel Item, string Cat, string Tag, string Gradient)

@{
    var item = Model.Item;
    var cat = Model.Cat;
    var tag = Model.Tag;
    var gradient = Model.Gradient;
}

<div class="ccard overflow-hidden rounded-[18px] border border-white/80 bg-white/55 shadow-[0_8px_22px_rgba(0,0,0,0.06)] backdrop-blur-[10px] transition hover:-translate-y-[2px] hover:border-[#d76736]/25 hover:shadow-[0_12px_28px_rgba(0,0,0,0.09)]"
     data-cat="@cat">
    <div class="relative flex h-[120px] items-center justify-center" style="background:linear-gradient(145deg,#@gradient);">
        @if (cat == "bottoms")
        {
            <svg class="h-[34px] w-[34px] fill-none stroke-black/20 stroke-[1.3] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z" /></svg>
        }
        else if (cat == "outerwear")
        {
            <svg class="h-[34px] w-[34px] fill-none stroke-black/20 stroke-[1.3] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><path d="M3 5c0-1 .7-2 2-2l4 3 3-3 3 3 4-3c1.3 0 2 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z" /></svg>
        }
        else if (cat == "shoes")
        {
            <svg class="h-[34px] w-[34px] fill-none stroke-black/20 stroke-[1.3] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5" /><ellipse cx="24" cy="14" rx="7" ry="5" /><path d="M1 14V8a6 6 0 0 1 12 0v2h6V8a6 6 0 0 1 12 0v6" /></svg>
        }
        else if (cat == "accessories")
        {
            <svg class="h-[34px] w-[34px] fill-none stroke-black/20 stroke-[1.3] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></svg>
        }
        else
        {
            <svg class="h-[34px] w-[34px] fill-none stroke-black/20 stroke-[1.3] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z" /></svg>
        }

        <div class="absolute left-[10px] top-[10px] rounded-full border border-black/10 bg-white/75 px-[9px] py-1 text-[10px] font-black text-black/55">@tag</div>
        @if (item.IsPendingReview)
        {
            <div class="absolute right-[10px] top-[10px] rounded-full border border-[#d76736]/25 bg-[#d76736]/15 px-[9px] py-1 text-[10px] font-black text-[#d76736]">Needs review</div>
        }
        <button type="button"
                class="absolute bottom-[10px] right-[10px] flex h-[26px] w-[26px] items-center justify-center rounded-[10px] border border-black/10 bg-white/65 transition hover:-translate-y-px hover:border-[#d76736]/40"
                onclick="event.stopPropagation()"
                aria-label="Remove">
            <svg class="h-[14px] w-[14px] fill-none stroke-black/45 stroke-[2] [stroke-linecap:round]" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
    </div>
    <div class="px-3 pb-[13px] pt-3">
        <div class="text-[13px] font-black text-[#1e1b18]">@item.Name</div>
        <div class="mt-2 flex flex-wrap gap-[6px]">
            @if (!string.IsNullOrWhiteSpace(item.PrimaryColor))
            {
                <span class="rounded-full border border-black/10 bg-white/75 px-2 py-1 text-[10px] font-black text-black/55">@item.PrimaryColor</span>
            }
            @if (!string.IsNullOrWhiteSpace(item.Season))
            {
                <span class="rounded-full border border-black/10 bg-white/75 px-2 py-1 text-[10px] font-black text-black/55">@item.Season</span>
            }
            @if (!string.IsNullOrWhiteSpace(item.Occasion))
            {
                <span class="rounded-full border border-black/10 bg-white/75 px-2 py-1 text-[10px] font-black text-black/55">@item.Occasion</span>
            }
            @if (item.IsPendingReview)
            {
                <span class="rounded-full border border-[#d76736]/25 bg-[#d76736]/15 px-2 py-1 text-[10px] font-black text-[#d76736]">Needs review</span>
            }
        </div>
    </div>
</div>
