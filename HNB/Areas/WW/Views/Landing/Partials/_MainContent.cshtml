<section class="hero">
  <div class="blob hero-b1"></div><div class="blob hero-b2"></div><div class="blob hero-b3"></div>
  <div class="hero-pill"><div class="hero-pill-dot"></div>AI-Powered Personal Styling</div>
  <h1 class="hero-title">Whatever the<br><em>Weather.</em></h1>
  <p class="hero-sub">Your AI stylist that knows your wardrobe, reads the weather, and puts together the <strong>perfect outfit every morning.</strong></p>
  <div class="hero-btns">
    <button class="btn-primary"><svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>Try it for Free</button>
    <button class="btn-ghost">See how it works ↓</button>
  </div>
  <div class="hero-steps">
    <div class="hs-step"><div class="hs-num">1</div><div><div class="hs-title">Upload your clothes</div><div class="hs-desc">AI scans your photos and builds your digital wardrobe automatically</div></div></div>
    <div class="hs-step"><div class="hs-num">2</div><div><div class="hs-title">Tell us your day</div><div class="hs-desc">Type anything — "rooftop dinner" or "startup interview" — or quick pick</div></div></div>
    <div class="hs-step"><div class="hs-num">3</div><div><div class="hs-title">Get your perfect outfit</div><div class="hs-desc">AI picks from your actual wardrobe, weather-aware, with a full explanation</div></div></div>
  </div>
</section>
<section class="closet-sec">
  <div class="blob closet-b1"></div><div class="blob closet-b2"></div>
  <div class="closet-inner">
    <div class="closet-text">
      <div class="section-eyebrow">Smart Wardrobe</div>
      <h2 class="section-title">Manage your Closet<br>with <em>AI-power.</em></h2>
      <p class="section-sub">Just upload photos from your phone. AI instantly detects every item, assigns categories, and builds your digital wardrobe — no manual tagging needed.</p>
      <div class="check-list">
        <div class="check-item"><div class="check-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>Auto category & colour detection</div>
        <div class="check-item"><div class="check-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>Works with any photo — no styling needed</div>
        <div class="check-item"><div class="check-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>Learns your personal style over time</div>
      </div>
    </div>
    <div class="closet-visual">
      <div class="ai-badge"><div class="ai-badge-dot"></div>AI scanning your wardrobe</div>
      <div class="closet-demo">
        <div class="cd-topbar"><div class="cd-topbar-title">My Closet</div><div class="cd-topbar-stat"><strong>24</strong> items · <strong>6</strong> categories</div></div>
        <div class="cd-bubbles">
          <div class="cd-bubble on"><div class="cd-bubble-c">👔</div><div class="cd-bubble-l">All 24</div></div>
          <div class="cd-bubble"><div class="cd-bubble-c">👕</div><div class="cd-bubble-l">Tops 6</div></div>
          <div class="cd-bubble"><div class="cd-bubble-c">👖</div><div class="cd-bubble-l">Bottoms 5</div></div>
