          <div class="cd-bubble"><div class="cd-bubble-c">👟</div><div class="cd-bubble-l">Shoes 5</div></div>
          <div class="cd-bubble"><div class="cd-bubble-c">👜</div><div class="cd-bubble-l">Acc 4</div></div>
        </div>
      </div>
    </div>
  </div>
</section>
