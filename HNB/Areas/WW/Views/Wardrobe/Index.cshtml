@using System.Text.Json
@model HNB.Areas.WW.Models.WardrobeIndexModel

@{
    Layout = "~/Areas/WW/Views/Shared/_Layout.cshtml";
}

<div class="flex flex-1 overflow-hidden">

    <!-- LEFT PANEL -->
    <section class="w-[270px] shrink-0 border-r border-[#D4CCBF] flex flex-col overflow-hidden bg-[#EDE8DF]">
        <div class="flex-1 overflow-y-auto px-[14px] pt-[14px] flex flex-col gap-[11px] ww-scroll">

            <!-- 向量查詢 -->
            <div class="bg-white rounded-[12px] p-[10px] border border-[rgba(0,0,0,0.07)]">
                <div class="text-[9px] text-[#A89F96] tracking-[0.05em] mb-2">向量查詢</div>
                <div class="flex items-center gap-2 bg-[#FBF0E8] rounded-[10px] border border-[#F5D5BC] px-[10px] py-[8px]">
                    <i data-lucide="search" class="w-[14px] h-[14px] text-[#E8763A]"></i>
                    <input id="ww-wardrobe-query"
                           type="text"
                           class="flex-1 bg-transparent outline-none text-[11px] text-[#1A1714]"
                           placeholder="例如：防潑水外套、上班、米色" />
                    <button type="button" class="text-[10px] text-[#A89F96] hover:text-[#E8763A]" onclick="wwWardrobeClearQuery()">清除</button>
                </div>
                <div class="flex gap-[5px] mt-[8px] flex-wrap">
                    <button type="button" class="ww-chip" onclick="wwWardrobeApplyQuery('防潑水')">防潑水</button>
                    <button type="button" class="ww-chip" onclick="wwWardrobeApplyQuery('上班')">上班</button>
                    <button type="button" class="ww-chip" onclick="wwWardrobeApplyQuery('百搭')">百搭</button>
                    <button type="button" class="ww-chip" onclick="wwWardrobeApplyQuery('秋冬')">秋冬</button>
                </div>
            </div>

            <!-- 分類 -->
            <div class="bg-white rounded-[12px] p-[10px] border border-[rgba(0,0,0,0.07)]">
                <div class="text-[9px] text-[#A89F96] tracking-[0.05em] mb-2">分類</div>
                <div class="flex flex-col gap-[6px]">
                    <button type="button" class="ww-filter js-wardrobe-filter" data-filter="all" onclick="wwWardrobePickFilter('all')">
                        <span class="flex items-center gap-2">
                            <i data-lucide="grid-2x2" class="w-[14px] h-[14px]"></i>
                            <span>全部</span>
                        </span>
                        <span class="ww-badge" id="ww-count-all">0</span>
                    </button>

                    <button type="button" class="ww-filter js-wardrobe-filter" data-filter="pending" onclick="wwWardrobePickFilter('pending')">
                        <span class="flex items-center gap-2">
                            <i data-lucide="badge-alert" class="w-[14px] h-[14px]"></i>
                            <span>待確認</span>
                        </span>
                        <span class="ww-badge" id="ww-count-pending">0</span>
                    </button>

                    <button type="button" class="ww-filter js-wardrobe-filter" data-filter="uncategorized" onclick="wwWardrobePickFilter('uncategorized')">
                        <span class="flex items-center gap-2">
                            <i data-lucide="layers" class="w-[14px] h-[14px]"></i>
                            <span>未分類</span>
                        </span>
                        <span class="ww-badge" id="ww-count-uncategorized">0</span>
                    </button>
                </div>

                <div class="h-px bg-[rgba(0,0,0,0.07)] my-[10px]"></div>

                <div class="flex flex-col gap-[6px]" id="ww-category-list">
                    @foreach (var category in Model.Categories)
                    {
                        var categoryIconName = category.Key switch
                        {
                            "tops" => "shirt",
                            "bottoms" => "columns-2",
                            "outerwear" => "cloud",
                            "shoes" => "footprints",
                            "accessories" => "sparkles",
                            _ => "tag"
                        };

                        <button type="button"
                                class="ww-filter js-wardrobe-filter"
                                data-filter="category:@category.Key"
                                onclick="wwWardrobePickFilter('category:@category.Key')">
                            <span class="flex items-center gap-2">
                                <i data-lucide="@categoryIconName" class="w-[14px] h-[14px]"></i>
                                <span>@category.Name</span>
                            </span>
                            <span class="ww-badge" id="ww-count-category-@category.Key">@category.Count</span>
                        </button>
                    }
                </div>
            </div>

            <!-- 匯入與提取 -->
            <div class="bg-white rounded-[12px] p-[10px] border border-[rgba(0,0,0,0.07)]">
                <div class="text-[9px] text-[#A89F96] tracking-[0.05em] mb-2">匯入與提取</div>

                <label class="ww-upload">
                    <input id="ww-wardrobe-import-input" type="file" accept="image/*" multiple class="hidden" />
                    <span class="flex items-center gap-2">
                        <i data-lucide="image-plus" class="w-[14px] h-[14px]"></i>
                        <span class="text-[11px]">選擇照片</span>
                    </span>
                    <span class="text-[10px] text-[#A89F96]">可多選</span>
                </label>

                <div class="mt-[8px] flex flex-col gap-[6px]" id="ww-import-queue"></div>

                <button type="button" class="ww-primary-btn mt-[10px]" id="ww-extract-btn" onclick="wwWardrobeExtract()" disabled>
                    <i data-lucide="wand-2" class="w-[14px] h-[14px]"></i>
                    <span>開始提取</span>
                </button>

                <div class="mt-[8px] text-[10px] text-[#A89F96]" id="ww-extract-hint">
                    提示：提取後會進入「待確認」，你可以逐筆調整分類與標籤再入庫。
                </div>
            </div>

        </div>
    </section>

    <!-- RIGHT PANEL -->
    <section class="flex-1 min-w-0 bg-white flex flex-col overflow-hidden">
        <div class="px-4 py-[10px] border-b border-[rgba(0,0,0,0.07)] flex items-center justify-between">
            <div>
                <div class="text-[12px] font-medium text-[#1A1714]">服裝</div>
                <div class="text-[10px] text-[#A89F96]" id="ww-result-subtitle">以「全部」顯示</div>
            </div>
            <div class="flex items-center gap-2">
                <button type="button" class="ww-icon-btn" onclick="wwWardrobeToggleView()">
                    <i data-lucide="layout-grid" class="w-[16px] h-[16px]"></i>
                </button>
                <button type="button" class="ww-icon-btn" onclick="wwWardrobeReset()">
                    <i data-lucide="rotate-ccw" class="w-[16px] h-[16px]"></i>
                </button>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto px-4 py-[14px] ww-scroll" id="ww-wardrobe-canvas">
            <div class="grid gap-[10px] ww-grid" id="ww-wardrobe-grid"></div>

            <div class="hidden" id="ww-wardrobe-empty">
                <div class="flex flex-col items-center justify-center gap-3 py-16">
                    <div class="w-[52px] h-[52px] rounded-full bg-[#EDE8DF] flex items-center justify-center">
                        <i data-lucide="shirt" class="w-[24px] h-[24px] text-[#A89F96]"></i>
                    </div>
                    <div class="text-[13px] font-medium text-[#6B6460]">目前沒有符合條件的服裝</div>
                    <div class="text-[11px] text-[#A89F96] text-center leading-[1.6]">
                        你可以調整分類、清除查詢，或匯入新的照片進行提取。
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

@section Styles {
    <link rel="stylesheet" href="~/ww/css/Wardrobe.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.__wwWardrobeBootstrap = {
            categories: @Html.Raw(JsonSerializer.Serialize(Model.Categories)),
            items: @Html.Raw(JsonSerializer.Serialize(Model.Items))
        };
    </script>
    <script src="~/ww/js/Wardrobe.js" asp-append-version="true"></script>
}
