@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Whatever the Weather";
    var pageTitle = ViewData["PageTitle"] as string ?? ViewData["Title"] as string ?? string.Empty;

    var currentArea = (ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    bool IsWwController(string controller)
        => currentArea == "ww" && currentController == controller.ToLowerInvariant();

    var navActiveClass =
        "flex h-12 w-12 flex-col items-center justify-center gap-1 rounded-[13px] bg-[#d76736] text-white shadow-[0_4px_12px_rgba(215,103,54,0.4)] transition-colors hover:bg-[#d76736] hover:text-white hover:shadow-[0_4px_12px_rgba(215,103,54,0.4)]";
    var navInactiveClass =
        "flex h-12 w-12 flex-col items-center justify-center gap-1 rounded-[13px] text-white/35 transition-colors hover:bg-[#d76736] hover:text-white hover:shadow-[0_4px_12px_rgba(215,103,54,0.4)]";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/ww/image/logo.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/ww/image/logo.png" asp-append-version="true" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Bodoni+Moda:ital,wght@1,500&display=swap" rel="stylesheet">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide / 其他庫 -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  
    <!-- 自訂樣式 -->
    <script src="~/ww/js/Layout.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/ww/css/Layout.css" asp-append-version="true" />

    <!-- 全域 Lucide 初始化 -->
    <script>
        $(window).on('load', function() {
            if (typeof lucide !== 'undefined' && typeof lucide.createIcons === 'function') {
                lucide.createIcons();
            }
        });
        (function () {

        function queryById(id) {
            return document.getElementById(id);
        }

        function closeLocationPopup() {
            var popup = queryById("location-popup");
            popup ? popup.classList.remove("open") : null;
        }

        window.wwToggleLocPopup = function () {
            var popup = queryById("location-popup");
            if (!popup) {
                return;
            }

            popup.classList.toggle("open");

            if (popup.classList.contains("open")) {
                window.setTimeout(function () {
                    var input = queryById("location-input");
                    input ? input.focus() : null;
                }, 50);
            }
        };

        window.wwConfirmLoc = function () {
            var input = queryById("location-input");
            var text = queryById("location-text");

            if (!input || !text) {
                return;
            }

            var value = (input.value || "").trim();

            if (value) {
                text.textContent = value;
            }

            input.value = "";
            closeLocationPopup();
        };

        function initializeLayout() {
            window.lucide?.createIcons?.();

            var toggleElements = document.querySelectorAll('[data-action="toggle-location-popup"]');
            toggleElements.forEach(function (element) {
                element.addEventListener("click", function () {
                    window.wwToggleLocPopup();
                });
            });

            var confirmButton = document.querySelector('[data-action="confirm-location"]');
            if (confirmButton) {
                confirmButton.addEventListener("click", function () {
                    window.wwConfirmLoc();
                });
            }

            var locationInput = document.querySelector('[data-action="confirm-location-on-enter"]');
            if (locationInput) {
                locationInput.addEventListener("keydown", function (event) {
                    if (event.key === "Enter") {
                        window.wwConfirmLoc();
                    }
                });
            }

            document.addEventListener("click", function (event) {
                var pill = queryById("location-pill");
                var popup = queryById("location-popup");

                if (!pill || !popup) {
                    return;
                }

                pill.contains(event.target) ? null : popup.classList.remove("open");
            });

            // Profile drawer
            function byId(id) { return document.getElementById(id); }

            function openProfileDrawer() {
                var overlay = byId("ww-profile-overlay");
                var drawer = byId("ww-profile-drawer");
                if (!overlay || !drawer) return;
                overlay.classList.remove("opacity-0", "pointer-events-none");
                overlay.classList.add("opacity-100", "pointer-events-auto");
                drawer.classList.remove("translate-x-full");
                drawer.classList.add("translate-x-0");
                overlay.setAttribute("aria-hidden", "false");
                drawer.setAttribute("aria-hidden", "false");
                window.lucide?.createIcons?.();
            }

            function closeProfileDrawer() {
                var overlay = byId("ww-profile-overlay");
                var drawer = byId("ww-profile-drawer");
                if (!overlay || !drawer) return;
                overlay.classList.add("opacity-0", "pointer-events-none");
                overlay.classList.remove("opacity-100", "pointer-events-auto");
                drawer.classList.add("translate-x-full");
                drawer.classList.remove("translate-x-0");
                overlay.setAttribute("aria-hidden", "true");
                drawer.setAttribute("aria-hidden", "true");
            }

            document.querySelectorAll('[data-action="open-profile-drawer"]').forEach(function (btn) {
                btn.addEventListener("click", function () { openProfileDrawer(); });
            });

            document.querySelectorAll('[data-action="close-profile-drawer"]').forEach(function (btn) {
                btn.addEventListener("click", function () { closeProfileDrawer(); });
            });

            document.addEventListener("keydown", function (event) {
                if (event && event.key === "Escape") {
                    closeProfileDrawer();
                }
            });
        }

        document.readyState === "loading"
            ? document.addEventListener("DOMContentLoaded", initializeLayout)
            : initializeLayout();

    })();

    </script>

    @RenderSection("Head", required: false)
</head>

<body class="relative flex h-[100dvh] overflow-hidden">
    <div class="blobs fixed inset-0 z-0">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="blob blob-4"></div>
    </div>
    <!-- Sidebar -->
    <nav class="group relative z-10 flex h-full w-[68px] shrink-0 flex-col items-center gap-1 overflow-hidden bg-[#141210]/80 pb-[18px] pt-[22px] backdrop-blur-[14px] transition-[width] duration-300 ease-[cubic-bezier(.4,0,.2,1)] hover:w-[224px]" aria-label="WW navigation">
            <a href="#" class="mb-5 flex h-[38px] w-[38px] items-center justify-center rounded-[11px] border border-white/15 bg-white/10 shadow-[0_2px_10px_rgba(0,0,0,0.25)] transition-colors hover:bg-white/20" aria-label="Whatever the Weather 首頁">
                <img class="block h-[26px] w-[26px] object-contain" src="~/ww/image/logo.png" alt="" width="26" height="26" asp-append-version="true" />
            </a>

            <a href="@Url.Action("Index", "Today", new { area = "WW" })"
               class="@(IsWwController("Today") ? navActiveClass : navInactiveClass) group-hover:w-[204px] group-hover:flex-row group-hover:justify-start group-hover:gap-[11px] group-hover:px-[10px]"
               aria-label="Today" aria-current="@(IsWwController("Today") ? "page" : null)">
                <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[9px] @(IsWwController("Today") ? "bg-white/15" : "")">
                    <i data-lucide="sun" class="h-[18px] w-[18px] opacity-90" aria-hidden="true"></i>
                </span>
                <span class="text-[7.5px] font-bold uppercase tracking-[0.3px] group-hover:hidden">Today</span>
                <span class="hidden min-w-0 flex-1 group-hover:block">
                    <span class="block text-[13px] font-black leading-[1.1] text-white">Today</span>
                    <span class="mt-[2px] block text-[10.5px] leading-[1.3] text-white/35">Weather and occasion</span>
                </span>
            </a>

            <a href="@Url.Action("Index", "Closet", new { area = "WW" })"
               class="@(IsWwController("Closet") ? navActiveClass : navInactiveClass) group-hover:w-[204px] group-hover:flex-row group-hover:justify-start group-hover:gap-[11px] group-hover:px-[10px]"
               aria-label="Closet" aria-current="@(IsWwController("Closet") ? "page" : null)">
                <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[9px] @(IsWwController("Closet") ? "bg-white/15" : "")">
                    <i data-lucide="shirt" class="h-[18px] w-[18px] opacity-90" aria-hidden="true"></i>
                </span>
                <span class="text-[7.5px] font-bold uppercase tracking-[0.3px] group-hover:hidden">Closet</span>
                <span class="hidden min-w-0 flex-1 group-hover:block">
                    <span class="block text-[13px] font-black leading-[1.1] text-white">Closet</span>
                    <span class="mt-[2px] block text-[10.5px] leading-[1.3] text-white/35">Import and review items</span>
                </span>
            </a>

            <a href="@Url.Action("Index", "Calendar", new { area = "WW" })"
               class="@(IsWwController("Calendar") ? navActiveClass : navInactiveClass) group-hover:w-[204px] group-hover:flex-row group-hover:justify-start group-hover:gap-[11px] group-hover:px-[10px]"
               aria-label="Calendar" aria-current="@(IsWwController("Calendar") ? "page" : null)">
                <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[9px] @(IsWwController("Calendar") ? "bg-white/15" : "")">
                    <i data-lucide="calendar-days" class="h-[18px] w-[18px] opacity-90" aria-hidden="true"></i>
                </span>
                <span class="text-[7.5px] font-bold uppercase tracking-[0.3px] group-hover:hidden">Cal</span>
                <span class="hidden min-w-0 flex-1 group-hover:block">
                    <span class="block text-[13px] font-black leading-[1.1] text-white">Outfit Log</span>
                    <span class="mt-[2px] block text-[10.5px] leading-[1.3] text-white/35">History and stats</span>
                </span>
            </a>

            <div class="flex-1"></div>

            <div class="my-2 h-px w-[28px] bg-white/10 group-hover:w-[188px] transition-[width] duration-300"></div>

            <button type="button"
                    class="mb-[2px] flex h-[32px] w-[32px] items-center justify-center rounded-full border border-white/20 bg-[#d76736] text-[12px] font-black text-white shadow-[0_4px_14px_rgba(215,103,54,0.35)] transition hover:shadow-[0_0_0_3px_rgba(215,103,54,0.30)]"
                    data-action="open-profile-drawer"
                    aria-label="Open profile">
                J
            </button>
    </nav>

    <!-- 主要內容 -->
    <div class="MainBody relative z-10 flex min-h-0 h-full w-full flex-col overflow-hidden bg-[#d9d4c0]/45 backdrop-blur-[14px]">
        @RenderSection("Topbar", required: false)
        <div class="min-h-0 flex-1 overflow-y-auto">
            @RenderBody()
        </div>
    </div>

    <!-- Profile Drawer Overlay -->
    <div class="fixed inset-0 z-[60] bg-black/20 opacity-0 pointer-events-none backdrop-blur-[3px] transition-opacity duration-200"
         id="ww-profile-overlay"
         data-action="close-profile-drawer"
         aria-hidden="true"></div>

    <!-- Profile Drawer -->
    <aside class="fixed right-0 top-0 z-[70] flex h-[100dvh] w-[320px] translate-x-full flex-col overflow-hidden border-l border-black/10 bg-[rgba(250,248,244,0.97)] backdrop-blur-[20px] transition-transform duration-300 ease-[cubic-bezier(.4,0,.2,1)]"
           id="ww-profile-drawer"
           aria-label="My Profile"
           aria-hidden="true">
        <div class="flex items-center justify-between border-b border-black/10 px-5 pb-4 pt-5">
            <div class="text-[15px] font-black text-[#1e1b18]">My Profile</div>
            <button type="button"
                    class="flex h-[30px] w-[30px] items-center justify-center rounded-[9px] bg-black/5 text-black/45 transition hover:bg-[#f2e0d5]"
                    data-action="close-profile-drawer"
                    aria-label="Close profile">
                <i data-lucide="x" class="h-[14px] w-[14px]" aria-hidden="true"></i>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto">
            <div class="flex items-center gap-3 bg-[linear-gradient(150deg,rgba(240,221,212,0.90),rgba(211,206,184,0.70))] px-5 py-5">
                <div class="flex h-[52px] w-[52px] items-center justify-center rounded-full border-[3px] border-white/80 bg-[linear-gradient(135deg,rgba(232,184,158,1),rgba(215,103,54,1))] text-[20px] font-black text-white shadow-[0_6px_20px_rgba(215,103,54,0.30)]">
                    J
                </div>
                <div class="min-w-0">
                    <div class="truncate text-[16px] font-black text-[#1e1b18]">Jamie Chen</div>
                    <div class="mt-[2px] truncate text-[11.5px] text-black/35">jamie@email.com</div>
                    <div class="mt-[2px] text-[11px] text-black/35">Member since April 2026</div>
                </div>
            </div>

            <div class="grid grid-cols-3 border-b border-black/10">
                <div class="py-[11px] text-center">
                    <div class="text-[18px] font-black text-[#d76736]">12</div>
                    <div class="mt-[2px] text-[9px] font-bold uppercase tracking-[0.04em] text-black/35">Outfits</div>
                </div>
                <div class="border-l border-black/10 py-[11px] text-center">
                    <div class="text-[18px] font-black text-[#d76736]">24</div>
                    <div class="mt-[2px] text-[9px] font-bold uppercase tracking-[0.04em] text-black/35">Items</div>
                </div>
                <div class="border-l border-black/10 py-[11px] text-center">
                    <div class="text-[18px] font-black text-[#d76736]">3</div>
                    <div class="mt-[2px] text-[9px] font-bold uppercase tracking-[0.04em] text-black/35">Weeks</div>
                </div>
            </div>

            <div class="px-5 py-4">
                <div class="text-[11px] font-black uppercase tracking-[0.08em] text-black/35">Style DNA</div>
                <div class="mt-3 flex flex-wrap gap-2">
                    <span class="rounded-full border border-black/5 bg-white/70 px-3 py-[7px] text-[11px] font-bold text-black/45">Minimal</span>
                    <span class="rounded-full border border-black/5 bg-white/70 px-3 py-[7px] text-[11px] font-bold text-black/45">Neutral Palette</span>
                    <span class="rounded-full border border-black/5 bg-white/70 px-3 py-[7px] text-[11px] font-bold text-black/45">Smart Casual</span>
                    <span class="rounded-full border border-black/5 bg-white/70 px-3 py-[7px] text-[11px] font-bold text-black/45">Work-Ready</span>
                </div>

                <div class="my-4 h-px bg-black/10"></div>

                <div class="rounded-[16px] border border-black/10 bg-white/70 p-4 shadow-[0_10px_26px_rgba(0,0,0,0.06)]">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <div class="inline-flex rounded-full border border-[#d76736]/20 bg-[#f2e0d5] px-[10px] py-[4px] text-[10px] font-black text-[#d76736]">Pro Plan</div>
                            <div class="mt-[6px] text-[14px] font-black text-[#1e1b18]">200 Credits left</div>
                            <div class="mt-[2px] text-[11px] text-black/35">Renews May 1, 2026</div>
                        </div>
                        <div class="text-right">
                            <div class="text-[18px] font-black leading-none text-[#d76736]">200</div>
                            <div class="mt-[2px] text-[9px] font-bold uppercase tracking-[0.04em] text-black/35">Credits</div>
                        </div>
                    </div>
                </div>

                <div class="my-4 h-px bg-black/10"></div>

                <div class="text-[11px] font-black uppercase tracking-[0.08em] text-black/35">Account</div>
                <div class="mt-3 flex flex-col gap-2">
                    <button type="button" class="flex w-full items-center justify-between rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-left transition hover:-translate-y-px hover:bg-white/85">
                        <span class="flex items-center gap-3">
                            <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[12px] bg-black/5 text-black/45">
                                <i data-lucide="user" class="h-[16px] w-[16px]" aria-hidden="true"></i>
                            </span>
                            <span>
                                <span class="block text-[13px] font-black text-[#1e1b18]">Edit Profile</span>
                                <span class="mt-[2px] block text-[11px] text-black/35">Name, photo, preferences</span>
                            </span>
                        </span>
                        <i data-lucide="chevron-right" class="h-[16px] w-[16px] text-black/25" aria-hidden="true"></i>
                    </button>

                    <button type="button" class="flex w-full items-center justify-between rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-left transition hover:-translate-y-px hover:bg-white/85">
                        <span class="flex items-center gap-3">
                            <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[12px] bg-black/5 text-black/45">
                                <i data-lucide="bell" class="h-[16px] w-[16px]" aria-hidden="true"></i>
                            </span>
                            <span>
                                <span class="block text-[13px] font-black text-[#1e1b18]">Notifications</span>
                                <span class="mt-[2px] block text-[11px] text-black/35">Morning reminders and alerts</span>
                            </span>
                        </span>
                        <i data-lucide="chevron-right" class="h-[16px] w-[16px] text-black/25" aria-hidden="true"></i>
                    </button>

                    <button type="button" class="flex w-full items-center justify-between rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-left transition hover:-translate-y-px hover:bg-white/85">
                        <span class="flex items-center gap-3">
                            <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[12px] bg-black/5 text-black/45">
                                <i data-lucide="lock" class="h-[16px] w-[16px]" aria-hidden="true"></i>
                            </span>
                            <span>
                                <span class="block text-[13px] font-black text-[#1e1b18]">Privacy</span>
                                <span class="mt-[2px] block text-[11px] text-black/35">Data usage and permissions</span>
                            </span>
                        </span>
                        <i data-lucide="chevron-right" class="h-[16px] w-[16px] text-black/25" aria-hidden="true"></i>
                    </button>

                    <button type="button" class="flex w-full items-center justify-between rounded-[14px] border border-[#d76736]/15 bg-[#d76736]/10 px-4 py-[12px] text-left transition hover:-translate-y-px hover:bg-[#d76736]/15">
                        <span class="flex items-center gap-3">
                            <span class="flex h-[34px] w-[34px] items-center justify-center rounded-[12px] bg-[#d76736]/10 text-[#d76736]">
                                <i data-lucide="log-out" class="h-[16px] w-[16px]" aria-hidden="true"></i>
                            </span>
                            <span class="block text-[13px] font-black text-[#d76736]">Log Out</span>
                        </span>
                        <i data-lucide="chevron-right" class="h-[16px] w-[16px] text-[#d76736]/45" aria-hidden="true"></i>
                    </button>
                </div>

                <div class="mt-5 pb-5 text-center text-[11px] text-black/25">Whatever the Weather · v1.0.0</div>
            </div>
        </div>
    </aside>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
