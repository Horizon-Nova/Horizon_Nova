@{
    Layout = null;

    var title = ViewData["Title"] as string ?? "WW";
    var topbarBrandPrefix = ViewData["TopbarBrandPrefix"] as string ?? "Whatever the ";
    var topbarBrandEmphasis = ViewData["TopbarBrandEmphasis"] as string ?? "Weather.";
    var topbarLocation = ViewData["TopbarLocation"] as string ?? "New York · Mon Apr 21";
    var avatarText = ViewData["AvatarText"] as string ?? "J";
    var isPreview = string.Equals(Context?.Request?.Query["preview"].ToString(), "1", StringComparison.Ordinal);

    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var navTodayClass = controller == "Today" ? "ni on" : "ni";
    var navClosetClass = controller == "Closet" ? "ni on" : "ni";
    var navCalendarClass = controller == "Calendar" ? "ni on" : "ni";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link rel="icon" type="image/png" href="~/ww/image/logo.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/ww/image/logo.png" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Bodoni+Moda:ital,wght@1,500&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/ww/css/ww.tailwind.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/ww/css/Layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="@(isPreview ? "ww-preview" : "")">
    <div class="ww-stage">
    <div class="app">
        <div class="blobs">
            @if (IsSectionDefined("Blobs"))
            {
                @await RenderSectionAsync("Blobs", required: false)
            }
            else
            {
                <div class="blob blob-1"></div>
                <div class="blob blob-2"></div>
                <div class="blob blob-3"></div>
                <div class="blob blob-4"></div>
            }
        </div>

        <!-- Sidebar -->
        <nav class="sb" aria-label="WW navigation">
            <a asp-area="WW" asp-controller="Today" asp-action="Index" class="logo" aria-label="Whatever the Weather 首頁">
                <img class="logo-img" src="~/ww/image/logo.png" alt="" width="26" height="26" asp-append-version="true" />
            </a>

            <a asp-area="WW" asp-controller="Today" asp-action="Index" class="@navTodayClass" aria-label="Today">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" /><path d="M3 12h1m16 0h1M12 3v1m0 16v1m-7.07-14.07.7.7m12.74 12.74.7.7m0-14.14-.7.7m-12.74 12.74-.7.7" /></svg>
                <span>Today</span>
            </a>

            <a asp-area="WW" asp-controller="Closet" asp-action="Index" class="@navClosetClass" aria-label="Closet">
                <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="18" rx="2" /><line x1="12" y1="3" x2="12" y2="21" /></svg>
                <span>Closet</span>
            </a>

            <a asp-area="WW" asp-controller="Calendar" asp-action="Index" class="@navCalendarClass" aria-label="Calendar">
                <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                <span>Cal</span>
            </a>

            <div class="sb-spacer"></div>
        </nav>

        <!-- 主要內容 -->
        <div class="body">
            @if (IsSectionDefined("Topbar"))
            {
                @await RenderSectionAsync("Topbar", required: true)
            }
            else
            {
                <div class="tb">
                    <div class="tb-brand-row">
                        <img class="tb-logo-mark" src="~/ww/image/logo.png" alt="" width="28" height="28" asp-append-version="true" />
                        <span class="tb-brand" id="tb-title">@topbarBrandPrefix<em>@topbarBrandEmphasis</em></span>
                    </div>
                    <div class="tb-r">
                        <div class="loc-pill" id="loc-pill" onclick="wwToggleLocPopup()">
                            <div class="loc-dot"></div>
                            <svg class="loc-svg" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            <span class="loc-text" id="loc-text">@topbarLocation</span>
                            <span class="loc-edit">Edit</span>
                            <div class="loc-popup" id="loc-popup" onclick="event.stopPropagation()">
                                <div class="loc-popup-label">Change Location</div>
                                <div class="loc-inp-row">
                                    <input class="loc-inp" id="loc-inp" placeholder="City, State or ZIP" onkeydown="if(event.key==='Enter')wwConfirmLoc()" />
                                    <button type="button" class="loc-confirm" onclick="wwConfirmLoc()">Set</button>
                                </div>
                            </div>
                        </div>
                        <div class="av" onclick="wwToggleLocPopup()">@avatarText</div>
                    </div>
                </div>
            }

            <div class="body-canvas">
                @RenderBody()
            </div>
        </div>
    </div>
    </div>

    <script src="~/ww/js/Layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
