@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] as string ?? "WW Auth")</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Bodoni+Moda:ital,wght@1,500&display=swap" rel="stylesheet">
    <style>
        :root {
            --orange: #d76736;
            --orange-d: #b8522a;
            --orange-l: #f2e0d5;
            --orange-m: #e8b89e;
            --beige: #d3ceb8;
            --bg: #d9d4c0;
            --peach: #d3a38c;
            --teal: #9dbab5;
            --black: #141210;
            --ink: #1e1b18;
            --ink2: #5a534c;
            --ink3: #9a9188;
            --font-sans: "Lato", sans-serif;
            --font-serif: "Bodoni Moda", serif;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: var(--font-sans); min-height: 100vh; display: flex; overflow: hidden; }

        .left-panel {
            width: 480px; flex-shrink: 0;
            background: var(--black);
            display: flex; flex-direction: column;
            padding: 48px;
            position: relative; overflow: hidden;
        }
        .lp-blob { position: absolute; pointer-events: none; }
        .lp-b1 { width: 340px; height: 320px; background: rgba(215,103,54,0.18); top: -80px; right: -60px; border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%; }
        .lp-b2 { width: 280px; height: 300px; background: rgba(157,186,181,0.12); bottom: -60px; left: -40px; border-radius: 44% 56% 38% 62% / 58% 42% 58% 42%; }
        .lp-b3 { width: 200px; height: 180px; background: rgba(215,103,54,0.1); top: 40%; left: 30%; border-radius: 52% 48% 62% 38% / 42% 58% 42% 58%; }

        .lp-brand { position: relative; z-index: 1; margin-bottom: auto; display: flex; align-items: center; gap: 10px; }
        .lp-logo { width: 36px; height: 36px; border-radius: 10px; background: var(--orange); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(215,103,54,0.5); }
        .lp-logo-text { font-weight: 900; font-size: 11px; color: #fff; }
        .lp-logo-i { font-family: var(--font-serif); font-style: italic; font-weight: 500; }
        .lp-brand-name { font-weight: 900; font-size: 18px; color: #fff; }
        .lp-brand-name em { font-family: var(--font-serif); font-style: italic; font-weight: 500; color: var(--orange); }

        .lp-content { position: relative; z-index: 1; }
        .lp-headline { font-size: 42px; font-weight: 900; color: #fff; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 16px; }
        .lp-headline em { font-family: var(--font-serif); font-style: italic; font-weight: 500; color: var(--orange); }
        .lp-sub { font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 40px; }

        .lp-features { display: flex; flex-direction: column; gap: 16px; }
        .lp-feat { display: flex; align-items: center; gap: 14px; }
        .lp-feat-ico { width: 38px; height: 38px; border-radius: 11px; background: rgba(255,255,255,0.06); border: 0.5px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .lp-feat-ico svg { width: 17px; height: 17px; stroke: var(--orange); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
        .lp-feat-title { font-size: 13.5px; font-weight: 700; color: #fff; }
        .lp-feat-sub { font-size: 12px; color: rgba(255,255,255,0.38); margin-top: 1px; }
        .lp-footer { position: relative; z-index: 1; margin-top: 48px; font-size: 11.5px; color: rgba(255,255,255,0.2); }

        .right-panel { flex: 1; background: var(--bg); display: flex; align-items: center; justify-content: center; padding: 48px; position: relative; overflow: hidden; }
        .rp-blob { position: absolute; pointer-events: none; }
        .rp-b1 { width: 380px; height: 340px; background: var(--peach); top: -80px; right: -60px; border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; opacity: 0.6; }
        .rp-b2 { width: 300px; height: 320px; background: var(--teal); bottom: -70px; left: -40px; border-radius: 44% 56% 38% 62% / 58% 42% 58% 42%; opacity: 0.5; }
        .rp-b3 { width: 220px; height: 200px; background: var(--orange-l); top: 35%; left: 20%; border-radius: 52% 48% 62% 38% / 42% 58% 42% 58%; opacity: 0.45; }

        .auth-card {
            background: rgba(255,255,255,0.65);
            backdrop-filter: blur(18px);
            border-radius: 24px;
            border: 0.5px solid rgba(255,255,255,0.9);
            box-shadow: 0 24px 64px rgba(0,0,0,0.12);
            width: 100%;
            max-width: 420px;
            padding: 40px;
            position: relative;
            z-index: 1;
        }

        .auth-tabs { display: flex; background: rgba(0,0,0,0.06); border-radius: 12px; padding: 4px; margin-bottom: 32px; }
        .auth-tab { flex: 1; padding: 9px; border-radius: 9px; font-size: 13px; font-weight: 700; color: var(--ink3); text-align: center; cursor: pointer; transition: all 0.18s; user-select: none; }
        .auth-tab.active { background: #fff; color: var(--ink); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }

        .auth-title { font-size: 24px; font-weight: 900; color: var(--ink); letter-spacing: -0.02em; margin-bottom: 6px; }
        .auth-title em { font-family: var(--font-serif); font-style: italic; font-weight: 500; color: var(--orange); }
        .auth-sub { font-size: 13px; color: var(--ink3); margin-bottom: 28px; line-height: 1.55; }

        .social-btns { display: flex; flex-direction: column; gap: 10px; margin-bottom: 22px; }
        .social-btn {
            width: 100%;
            padding: 12px 12px;
            border-radius: 14px;
            background: rgba(255,255,255,0.8);
            border: 0.5px solid rgba(0,0,0,0.1);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 12.5px;
            font-weight: 900;
            color: var(--ink);
            transition: all 0.14s;
        }
        .social-btn:hover { border-color: rgba(215,103,54,0.25); background: rgba(255,255,255,0.95); transform: translateY(-1px); }
        .social-btn svg { width: 16px; height: 16px; stroke: var(--ink3); fill: none; stroke-width: 2; }

        .sep { display: flex; align-items: center; gap: 12px; margin: 14px 0 16px; }
        .sep-line { flex: 1; height: 0.5px; background: rgba(0,0,0,0.12); }
        .sep-text { font-size: 11px; color: var(--ink3); font-weight: 700; }

        .form { display: flex; flex-direction: column; gap: 10px; }
        .inp { width: 100%; border: 0.5px solid rgba(0,0,0,0.12); background: rgba(255,255,255,0.8); border-radius: 14px; padding: 12px 14px; font-size: 12.5px; outline: none; }
        .inp:focus { border-color: rgba(215,103,54,0.35); box-shadow: 0 0 0 3px rgba(215,103,54,0.12); }

        .auth-cta { margin-top: 10px; background: var(--orange); color: #fff; border: none; border-radius: 14px; padding: 13px 14px; font-size: 13px; font-weight: 900; cursor: pointer; transition: all 0.15s; box-shadow: 0 10px 32px rgba(215,103,54,0.32); }
        .auth-cta:hover { background: var(--orange-d); transform: translateY(-1px); }

        .terms { margin-top: 14px; font-size: 11px; color: var(--ink3); line-height: 1.6; }
        .terms a { color: var(--orange); text-decoration: none; font-weight: 900; }
        .terms a:hover { text-decoration: underline; }

        .hidden { display: none !important; }

        @@media (max-width: 980px) {
            body { flex-direction: column; overflow: auto; }
            .left-panel { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="left-panel">
        <div class="lp-blob lp-b1"></div>
        <div class="lp-blob lp-b2"></div>
        <div class="lp-blob lp-b3"></div>

        <div class="lp-brand">
            <div class="lp-logo"><span class="lp-logo-text">W<span class="lp-logo-i">w</span></span></div>
            <div class="lp-brand-name">Whatever the <em>Weather.</em></div>
        </div>

        <div class="lp-content">
            <div class="lp-headline">Your AI <em>stylist</em> is waiting.</div>
            <div class="lp-sub">Upload your clothes once. Get a perfect outfit every morning — weather-aware, occasion-perfect, from your actual wardrobe.</div>

            <div class="lp-features">
                <div class="lp-feat">
                    <div class="lp-feat-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
                    <div>
                        <div class="lp-feat-title">Upload once, styled forever</div>
                        <div class="lp-feat-sub">AI builds your digital closet automatically</div>
                    </div>
                </div>
                <div class="lp-feat">
                    <div class="lp-feat-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
                    <div>
                        <div class="lp-feat-title">Weather-aware every day</div>
                        <div class="lp-feat-sub">Auto-detects your location and live conditions</div>
                    </div>
                </div>
                <div class="lp-feat">
                    <div class="lp-feat-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
                    <div>
                        <div class="lp-feat-title">Gets smarter every use</div>
                        <div class="lp-feat-sub">Learns your style, preferences, and lifestyle</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="lp-footer">© 2026 Whatever the Weather. All rights reserved.</div>
    </div>

    <div class="right-panel">
        <div class="rp-blob rp-b1"></div>
        <div class="rp-blob rp-b2"></div>
        <div class="rp-blob rp-b3"></div>

        <div class="auth-card">
            <div class="auth-tabs">
                <div class="auth-tab active" id="tab-signup" onclick="wwAuthSwitch('signup')">Create account</div>
                <div class="auth-tab" id="tab-login" onclick="wwAuthSwitch('login')">Log in</div>
            </div>

            <div id="signup-panel">
                <div class="auth-title">Start for <em>free.</em></div>
                <div class="auth-sub">No credit card required. Cancel anytime.</div>

                <div class="social-btns">
                    <button class="social-btn" type="button">
                        <svg viewBox="0 0 24 24"><path d="M20 12.2a8 8 0 10-9.3 7.9v-5.6H8.1v-2.3h2.6V10.4c0-2.6 1.6-4 3.9-4 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.5v1.8h2.7l-.4 2.3h-2.3v5.6A8 8 0 0020 12.2z"/></svg>
                        Continue with Google
                    </button>
                    <button class="social-btn" type="button">
                        <svg viewBox="0 0 24 24"><path d="M16.4 13.2c0-2.2 1.8-3.3 1.9-3.4-1-1.5-2.6-1.7-3.2-1.7-1.4-.1-2.7.8-3.4.8-.7 0-1.8-.8-2.9-.8-1.5 0-2.9.9-3.6 2.2-1.6 2.7-.4 6.7 1.1 8.9.8 1.1 1.7 2.4 2.9 2.3 1.2-.1 1.6-.7 3.1-.7 1.4 0 1.8.7 3.1.7 1.3 0 2.1-1.1 2.9-2.3.9-1.3 1.2-2.6 1.2-2.6-.1 0-2.1-.8-2.1-3.7z"/><path d="M14.7 6.5c.7-.9 1.2-2.1 1.1-3.3-1 .1-2.2.7-2.9 1.6-.6.7-1.2 2-1.1 3.2 1.1.1 2.2-.6 2.9-1.5z"/></svg>
                        Continue with Apple
                    </button>
                </div>

                <div class="sep"><div class="sep-line"></div><div class="sep-text">or sign up with email</div><div class="sep-line"></div></div>

                <div class="form">
                    <input class="inp" placeholder="Email address" />
                    <input class="inp" placeholder="Password" type="password" />
                    <input class="inp" placeholder="Confirm password" type="password" />
                    <button class="auth-cta" type="button">Create my account</button>
                </div>

                <div class="terms">By creating an account you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.</div>
            </div>

            <div id="login-panel" class="hidden">
                <div class="auth-title">Welcome <em>back.</em></div>
                <div class="auth-sub">Log in to continue.</div>
                <div class="form">
                    <input class="inp" placeholder="Email address" />
                    <input class="inp" placeholder="Password" type="password" />
                    <button class="auth-cta" type="button">Log in</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function wwAuthSwitch(mode) {
            var tabSignup = document.getElementById("tab-signup");
            var tabLogin = document.getElementById("tab-login");
            var signupPanel = document.getElementById("signup-panel");
            var loginPanel = document.getElementById("login-panel");

            if (mode === "login") {
                tabSignup.classList.remove("active");
                tabLogin.classList.add("active");
                signupPanel.classList.add("hidden");
                loginPanel.classList.remove("hidden");
                return;
            }

            tabLogin.classList.remove("active");
            tabSignup.classList.add("active");
            loginPanel.classList.add("hidden");
            signupPanel.classList.remove("hidden");
        }
    </script>
</body>
</html>
