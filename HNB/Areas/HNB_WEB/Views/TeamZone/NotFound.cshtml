@{
    ViewData["Title"] = "404 Not Found";
    Layout = "~/Areas/HNB_WEB/Views/Shared/_Layout.cshtml";
}
<div class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-gray-50 to-blue-50 p-6 text-center">
    <div class="space-y-6 max-w-md">
        <div class="space-y-3">
            <div class="text-8xl font-bold text-blue-600">404</div>
            <h2 class="text-2xl font-semibold text-gray-800">Page Not Found</h2>
            <p class="text-gray-500">The page you're looking for doesn't exist or may have been moved.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a class="inline-flex items-center justify-center px-6 py-3 rounded-md border hover:bg-gray-50" href="@Url.Action("Portfolio", "TeamZone", new { area = "HNB_WEB" })">Return Home</a>
        </div>
    </div>
</div>
