@using Models.Hnbdata
@{
    ViewData["Title"] = "作品集 Portfolio - Horizon Nova";
    Layout = "_Layout";
    var tabs = ViewBag.PortfolioTabsMap as List<project_tag> ?? new List<project_tag>();
    var projects = ViewBag.PortfolioDataMap as List<project> ?? new List<project>();
    var teamMembers = ViewBag.TeamMemberInfo as List<team_member> ?? new List<team_member>();
}


<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
    <!-- Header -->
    <header class="border-b bg-white/80 backdrop-blur-sm sticky top-0 z-50">
        <div class="container mx-auto px-3 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href='@Url.Action("NovaHome", "TeamZone", new { area = "HNB_WEB" })'
                   class="inline-flex items-center gap-2 text-gray-700 hover:bg-gray-100 px-3 py-2 rounded-md transition">
                    <i data-lucide="arrow-left" class="h-4 w-4"></i>
                    <span>返回首頁</span>
                </a>
                <div class="h-8 border-l border-gray-300"></div>
                <div class="flex items-center space-x-2">
                    <div class="h-10 w-10 rounded-lg flex items-center justify-center">
                        <img src="~/HNB_WEB/image/Horizon Nova Icon.png" alt="HN" class="h-10 w-10 rounded-lg object-cover" />
                    </div>
                    <span class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                        Horizon-Nova
                    </span>
                </div>
            </div>
        </div>
    </header>

    <div class="container mx-auto px-4 py-12">
        <div class="max-w-6xl mx-auto">
            <!-- Title -->
            <div class="text-center mb-12">
                <h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                    專案作品展示
                </h1>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    我們的專業團隊致力於創造創新的技術解決方案，以下是我們的精選作品
                </p>
            </div>

            <!-- Statistics（2秒緩出動畫） -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
                <div class="text-center">
                    <div class="text-3xl font-bold text-blue-600 mb-2" data-count-target="6+">0</div>
                    <div class="text-gray-600">完成專案</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl font-bold text-green-600 mb-2" data-count-target="3">0</div>
                    <div class="text-gray-600">技術領域</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl font-bold text-purple-600 mb-2" data-count-target="15+">0</div>
                    <div class="text-gray-600">核心技術</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl font-bold text-orange-600 mb-2" data-count-target="100%">0</div>
                    <div class="text-gray-600">客戶滿意度</div>
                </div>
            </div>

            <div class="w-full">
                @if (!tabs.Any())
                {
                    <div class="rounded-2xl border border-dashed border-blue-200 bg-white/70 p-12 text-center text-gray-500">
                        尚未設定任何作品分類。
                    </div>
                }
                else
                {
                    <!-- Segmented Tabs -->
                    <div class="mb-8 grid grid-cols-3 gap-2 bg-gray-100 p-1 rounded-xl">
                        @for (var i = 0; i < tabs.Count; i++)
                        {
                            var t = tabs[i];
                            var isActive = i == 0;
                            <text>
                                <button type="button"
                                        data-tab="@t.code"
                                        class="tab-btn w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg
                                   text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500
                                   @(isActive ? "bg-white text-blue-600" : string.Empty)">
                                    <i data-lucide="@t.icon" class="h-4 w-4"></i>
                                    <span>@t.category</span>
                                </button>
                            </text>
                        }
                    </div>

                    <div id="tab-panes" class="space-y-8">
                        @for (var i = 0; i < tabs.Count; i++)
                        {
                            var t = tabs[i];
                            var code = string.IsNullOrWhiteSpace(t.code)
                                ? (t.category ?? string.Empty).Trim().ToLower().Replace(" ", "-")
                                : t.code.Trim().ToLower();
                            var items = projects.Where(p => p.category == t.category).ToList();
                            var isActive = i == 0;

                            <text>
                                <section id="tab-@code" class="tab-pane @(isActive ? string.Empty : "hidden") space-y-6" aria-hidden="@(isActive ? "false" : "true")">
                                    <div class="flex items-center space-x-3 mb-2">
                                        <i data-lucide="@t.icon" class="h-6 w-6 text-@(t.icon_color)-600"></i>
                                        <h2 class="text-2xl font-bold text-gray-800">@t.category</h2>
                                        <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-@(t.icon_color)-100 text-@(t.icon_color)-800">
                                            @items.Count 個專案
                                        </span>
                                    </div>


                                    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-2 gap-6 ">
                                        @foreach (var p in items)
                                        {
                                            <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                                                <header class="p-6 pb-0">
                                                    <div class="flex items-start gap-3">
                                                        <div class="p-2 rounded-lg bg-blue-50">
                                                            <i data-lucide="@(string.IsNullOrWhiteSpace(p.icon) ? "file-text" : p.icon)" class="h-8 w-8 text-@(p.icon_color)-600"></i>
                                                        </div>
                                                        <div>
                                                            <h3 class="text-xl font-bold text-gray-800">@p.name</h3>
                                                            @if (!string.IsNullOrWhiteSpace(p.summary))
                                                            {
                                                                <p class="text-gray-600 mt-1">@p.summary</p>
                                                            }
                                                        </div>
                                                    </div>
                                                </header>

                                                <div class="p-6 space-y-4">
                                                    <!-- 專案亮點 -->
                                                    @if (p.highlight?.Any() == true)
                                                    {
                                                        <div>
                                                            <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                                            <div class="flex flex-wrap gap-2">
                                                                @foreach (var h in p.highlight)
                                                                {
                                                                    <span class="inline-flex font-bold items-center rounded-full px-3 py-1 text-sm bg-@(t.icon_color)-100 text-@(p.icon_color)-800 hover:bg-blue-200">
                                                                        @h
                                                                    </span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }

                                                    <!-- 技術棧 -->
                                                    @if (p.tech_stack?.Any() == true)
                                                    {
                                                        <div>
                                                            <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                                            <div class="flex flex-wrap gap-2">
                                                                @foreach (var tech in p.tech_stack)
                                                                {
                                                                    <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">
                                                                        @tech
                                                                    </span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }


                                                    <!-- 主要功能 -->
                                                    @if (p.features?.Any() == true)
                                                    {
                                                        <div>
                                                            <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                                            <div class="grid grid-cols-1 gap-1">
                                                                @foreach (var f in p.features)
                                                                {
                                                                    <div class="flex items-center text-sm text-gray-600">
                                                                        <div class="h-1.5 w-1.5 rounded-full bg-blue-500 mr-2"></div>@f
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }

                                                    <div class="pt-2">
                                                        <a href='@Url.Action("ProjectDetail", "TeamZone", new { area = "HNB_WEB", id = p.id })'
                                                           class="w-full inline-flex items-center justify-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300">
                                                            <i data-lucide="eye" class="h-4 w-4"></i> 查看詳細資訊 <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                                        </a>
                                                    </div>
                                                </div>

                                            </article>
                                        }
                                    </div>
                                </section>
                            </text>
                        }
                    </div>
                }

            </div>

            <!-- Team -->
            @if (teamMembers.Any())
            {
                <section class="mt-16 mb-16">
                    <div class="text-center mb-12">
                        <h2 class="text-3xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                            專業團隊
                        </h2>
                        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                            我們的團隊由經驗豐富的專業人士組成，致力於為客戶提供最優質的技術解決方案
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
                        @foreach (var member in teamMembers)
                        {
                            <article class="h-full flex flex-col hover:shadow-lg transition-all duration-300 text-center group rounded-xl bg-white border-0 shadow-md">
                                <header class="p-6 pb-4">
                                    <div class="mb-4 flex justify-center">
                                        @if (!string.IsNullOrWhiteSpace(member.avatar_url))
                                        {
                                            <img src="@member.avatar_url"
                                                 alt="@member.name"
                                                 class="w-20 h-20 rounded-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                        }
                                        else
                                        {
                                            var color = string.IsNullOrWhiteSpace(member.color) ? "#2563eb" : member.color;
                                            var initials = !string.IsNullOrWhiteSpace(member.avatar_text)
                                                ? member.avatar_text
                                                : (!string.IsNullOrWhiteSpace(member.name)
                                                    ? new string(member.name.Where(char.IsLetter).Take(2).ToArray()).ToUpperInvariant()
                                                    : "TM");
                                            <div class="w-20 h-20 rounded-full flex items-center justify-center text-white font-bold text-xl group-hover:scale-105 transition-transform duration-300"
                                                 style="background:@color;">
                                                @initials
                                            </div>
                                        }
                                    </div>
                                    <h3 class="text-xl text-gray-800 font-bold">@member.name</h3>
                                    <p class="text-blue-600 font-medium">@member.role</p>
                                </header>

                                <!-- 內容 + 底部社群：用 flex-col 撐滿，社群 mt-auto 貼底 -->
                                <div class="px-6 pb-6 flex-1 flex flex-col">
                                    <div class="space-y-4">
                                        @if (!string.IsNullOrWhiteSpace(member.bio))
                                        {
                                            <p class="text-gray-600 text-sm leading-relaxed">@member.bio</p>
                                        }

                                        @if (member.skills != null && member.skills.Any(skill => !string.IsNullOrWhiteSpace(skill)))
                                        {
                                            <div class="flex flex-wrap gap-1 justify-center">
                                                @foreach (var skill in member.skills.Where(x => !string.IsNullOrWhiteSpace(x)))
                                                {
                                                    <span class="inline-flex items-center rounded-full px-2 py-1 text-xs bg-blue-100 text-blue-800">@skill</span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <!-- 社群連結區塊：一定在底部 -->
                                    <div class="flex justify-center space-x-3 pt-2 mt-auto">
                                        @if (!string.IsNullOrWhiteSpace(member.github))
                                        {
                                            <a class="h-8 w-8 inline-flex items-center justify-center rounded-md hover:bg-gray-100"
                                               href="@member.github" target="_blank" rel="noopener">
                                                <i data-lucide="github" class="h-4 w-4 text-gray-600"></i>
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(member.linkedin))
                                        {
                                            <a class="h-8 w-8 inline-flex items-center justify-center rounded-md hover:bg-blue-100"
                                               href="@member.linkedin" target="_blank" rel="noopener">
                                                <i data-lucide="linkedin" class="h-4 w-4 text-blue-600"></i>
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(member.twitter))
                                        {
                                            <a class="h-8 w-8 inline-flex items-center justify-center rounded-md hover:bg-blue-100"
                                               href="@member.twitter" target="_blank" rel="noopener">
                                                <i data-lucide="twitter" class="h-4 w-4 text-blue-500"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            }

            <!-- CTA -->
            <section class="text-center mt-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 text-white">
                <h3 class="text-2xl font-bold mb-4">有興趣了解更多？</h3>
                <p class="text-lg mb-6 opacity-90">我們很樂意為您介紹這些專案的詳細技術實作和解決方案</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href='@Url.Action("Consultation", "TeamZone", new { area = "HNB_WEB" })'
                       class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-white text-blue-600 hover:bg-gray-100">
                        立即諮詢
                    </a>
                    <a href='@Url.Action("Consultation", "TeamZone", new { area = "HNB_WEB" })'
                       class="inline-flex items-center justify-center px-6 py-3 rounded-md border-2 border-white text-white hover:bg-white hover:text-blue-600">
                        聯絡我們
                    </a>
                </div>
            </section>
        </div>
    </div>
</div>

