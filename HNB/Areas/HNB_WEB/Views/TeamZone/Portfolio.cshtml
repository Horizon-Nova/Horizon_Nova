@{
    ViewData["Title"] = "專案作品展示 - Horizon-Nova";
    Layout = "~/Areas/HNB_WEB/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
    <!-- Header -->
    <header class="border-b bg-white/80 backdrop-blur-sm sticky top-0 z-50">
        <div class="container mx-auto px-3 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href='@Url.Action("NovaHome", "TeamZone", new { area = "HNB_WEB" })'
                   class="inline-flex items-center gap-2 text-gray-700 hover:bg-gray-100 px-3 py-2 rounded-md transition">
                    <i data-lucide="arrow-left" class="h-4 w-4"></i>
                    <span>返回首頁</span>
                </a>
                <div class="h-8 border-l border-gray-300"></div>
                <div class="flex items-center space-x-2">
                    <div class="h-10 w-10 rounded-lg flex items-center justify-center">
                        <img src="~/image/Horizon Nova Logo1.png" alt="HN" class="h-10 w-10 rounded-lg object-cover" />
                    </div>
                    <span class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                        Horizon-Nova
                    </span>
                </div>
            </div>
        </div>
    </header>

    <div class="container mx-auto px-4 py-12">
        <div class="max-w-6xl mx-auto">
            <!-- Title -->
            <div class="text-center mb-12">
                <h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                    專案作品展示
                </h1>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    我們的專業團隊致力於創造創新的技術解決方案，以下是我們的精選作品
                </p>
            </div>

            <!-- Statistics（2秒緩出動畫） -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
                <div class="text-center">
                    <div class="text-3xl font-bold text-blue-600 mb-2" data-count-target="6+">0</div>
                    <div class="text-gray-600">完成專案</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl font-bold text-green-600 mb-2" data-count-target="3">0</div>
                    <div class="text-gray-600">技術領域</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl font-bold text-purple-600 mb-2" data-count-target="15+">0</div>
                    <div class="text-gray-600">核心技術</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl font-bold text-orange-600 mb-2" data-count-target="100%">0</div>
                    <div class="text-gray-600">客戶滿意度</div>
                </div>
            </div>

            <!-- Tabs（手機APP / 軟體系統 / Web系統） -->
            <div class="w-full">
                <!-- Segmented Tabs -->
                <div class="mb-8 grid grid-cols-3 gap-2 bg-gray-100 p-1 rounded-xl">
                    <button type="button" data-tab="mobile"
                            class="tab-btn w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg
                 text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <i data-lucide="smartphone" class="h-4 w-4"></i><span>手機APP</span>
                    </button>

                    <button type="button" data-tab="software"
                            class="tab-btn w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg
                 text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <i data-lucide="code" class="h-4 w-4"></i><span>軟體系統</span>
                    </button>

                    <button type="button" data-tab="web"
                            class="tab-btn w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg
                 text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <i data-lucide="globe" class="h-4 w-4"></i><span>Web系統</span>
                    </button>
                </div>


                <!-- Mobile -->
                <section id="tab-mobile" class="tab-pane space-y-6">
                    <div class="flex items-center space-x-3 mb-2">
                        <i data-lucide="smartphone" class="h-6 w-6 text-blue-600"></i>
                        <h2 class="text-2xl font-bold text-gray-800">手機APP開發</h2>
                        <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-blue-100 text-blue-800">2 個專案</span>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- 智慧查表 -->
                        <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                            <header class="p-6 pb-0">
                                <div class="flex items-start gap-3">
                                    <div class="p-2 rounded-lg bg-blue-50">
                                        <i data-lucide="camera" class="h-8 w-8 text-blue-600"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800">智慧查表</h3>
                                        <p class="text-gray-600 mt-1">
                                            透過AI基本訓練加上即時的物件偵測，用戶只要對準即可不需要拍照app會自動擷取
                                        </p>
                                    </div>
                                </div>
                            </header>
                            <div class="p-6 space-y-4">
                                <!-- 亮點 -->
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var h in new[] { "免拍照自動擷取", "即時調整界面", "成本效益高" })
                                        {
                                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-blue-100 text-blue-800 hover:bg-blue-200">@h</span>
                                        }
                                    </div>
                                </div>
                                <!-- 技術棧 -->
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var t in new[] { "AI/ML", "物件偵測", "WebView", "數據分析" })
                                        {
                                            <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">@t</span>
                                        }
                                    </div>
                                </div>
                                <!-- 功能 -->
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                    <div class="grid grid-cols-1 gap-1">
                                        @foreach (var f in new[] { "AI物件偵測技術", "自動數據擷取", "數字AI辨識", "即時數據顯示" })
                                        {
                                            <div class="flex items-center text-sm text-gray-600">
                                                <div class="h-1.5 w-1.5 rounded-full bg-blue-500 mr-2"></div>@f
                                            </div>
                                        }
                                        <div class="text-sm text-gray-500 mt-1">+2 項功能...</div>
                                    </div>
                                </div>
                                <div class="pt-2">
                                    <a href='@Url.Action("ProjectDetail", "TeamZone", new { area = "HNB_WEB", id = "smart-meter" })'
                                       class="w-full inline-flex items-center justify-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300">
                                        <i data-lucide="eye" class="h-4 w-4"></i> 查看詳細資訊 <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                    </a>
                                </div>
                            </div>
                        </article>

                        <!-- TAGV -->
                        <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                            <header class="p-6 pb-0">
                                <div class="flex items-start gap-3">
                                    <div class="p-2 rounded-lg bg-blue-50">
                                        <i data-lucide="scan-line" class="h-8 w-8 text-green-600"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800">TAGV</h3>
                                        <p class="text-gray-600 mt-1">
                                            使用AprilTag技術做出快速ID掃描以取代QRCode，用戶可透過特定ID申請對應資料或懸浮廣告螢幕
                                        </p>
                                    </div>
                                </div>
                            </header>
                            <div class="p-6 space-y-4">
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var h in new[] { "比QRCode更快速", "懸浮廣告功能", "高精度識別" })
                                        {
                                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-blue-100 text-blue-800 hover:bg-blue-200">@h</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var t in new[] { "AprilTag", "ID識別", "廣告系統", "掃描技術" })
                                        {
                                            <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">@t</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                    <div class="grid grid-cols-1 gap-1">
                                        @foreach (var f in new[] { "AprilTag技術", "快速ID掃描", "取代QRCode", "特定ID申請系統" })
                                        {
                                            <div class="flex items-center text-sm text-gray-600">
                                                <div class="h-1.5 w-1.5 rounded-full bg-blue-500 mr-2"></div>@f
                                            </div>
                                        }
                                        <div class="text-sm text-gray-500 mt-1">+2 項功能...</div>
                                    </div>
                                </div>
                                <div class="pt-2">
                                    <a href='@Url.Action("ProjectDetail", "TeamZone", new { area = "HNB_WEB", id = "tagv" })'
                                       class="w-full inline-flex items-center justify-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300">
                                        <i data-lucide="eye" class="h-4 w-4"></i> 查看詳細資訊 <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                </section>

                <!-- Software -->
                <section id="tab-software" class="tab-pane hidden space-y-6">
                    <div class="flex items-center space-x-3 mb-2">
                        <i data-lucide="code" class="h-6 w-6 text-purple-600"></i>
                        <h2 class="text-2xl font-bold text-gray-800">軟體系統開發</h2>
                        <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-purple-100 text-purple-800">1 個專案</span>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- 監控AI Server -->
                        <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                            <header class="p-6 pb-0">
                                <div class="flex items-start gap-3">
                                    <div class="p-2 rounded-lg bg-purple-50">
                                        <i data-lucide="server" class="h-8 w-8 text-purple-600"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800">監控AI Server</h3>
                                        <p class="text-gray-600 mt-1">專業的AI數據監控系統，提供即時監控和數據分析功能</p>
                                    </div>
                                </div>
                            </header>
                            <div class="p-6 space-y-4">
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var h in new[] { "24/7即時監控", "智能異常偵測", "完整數據追蹤" })
                                        {
                                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-purple-100 text-purple-800 hover:bg-purple-200">@h</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var t in new[] { "AI監控", "數據分析", "即時追蹤", "警報系統" })
                                        {
                                            <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">@t</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                    <div class="grid grid-cols-1 gap-1">
                                        @foreach (var f in new[] { "即時AI數據監控", "系統效能追蹤", "異常警報系統", "數據視覺化" })
                                        {
                                            <div class="flex items-center text-sm text-gray-600">
                                                <div class="h-1.5 w-1.5 rounded-full bg-purple-500 mr-2"></div>@f
                                            </div>
                                        }
                                        <div class="text-sm text-gray-500 mt-1">+2 項功能...</div>
                                    </div>
                                </div>
                                <div class="pt-2">
                                    <a href='@Url.Action("ProjectDetail", "TeamZone", new { area = "HNB_WEB", id = "ai-monitor" })'
                                       class="w-full inline-flex items-center justify-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300">
                                        <i data-lucide="eye" class="h-4 w-4"></i> 查看詳細資訊 <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                </section>

                <!-- Web -->
                <section id="tab-web" class="tab-pane hidden space-y-6">
                    <div class="flex items-center space-x-3 mb-2">
                        <i data-lucide="globe" class="h-6 w-6 text-green-600"></i>
                        <h2 class="text-2xl font-bold text-gray-800">Web網站系統</h2>
                        <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-green-100 text-green-800">3 個專案</span>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
                        <!-- Missa -->
                        <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                            <header class="p-6 pb-0">
                                <div class="flex items-start gap-3">
                                    <div class="p-2 rounded-lg bg-green-50">
                                        <i data-lucide="file-text" class="h-8 w-8 text-orange-600"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800">Missa</h3>
                                        <p class="text-gray-600 mt-1">用於處理簽核和一般文書系統，內置完整的企業管理功能</p>
                                    </div>
                                </div>
                            </header>
                            <div class="p-6 space-y-4">
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var h in new[] { "完整企業解決方案", "高度安全性", "彈性權限控制" })
                                        {
                                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-green-100 text-green-800 hover:bg-green-200">@h</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var t in new[] { "簽核系統", "API", "資料庫", "權限管理" })
                                        {
                                            <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">@t</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                    <div class="grid grid-cols-1 gap-1">
                                        @foreach (var f in new[] { "簽核流程管理", "文書處理系統", "人員管理", "API整合" })
                                        {
                                            <div class="flex items-center text-sm text-gray-600">
                                                <div class="h-1.5 w-1.5 rounded-full bg-green-500 mr-2"></div>@f
                                            </div>
                                        }
                                        <div class="text-sm text-gray-500 mt-1">+4 項功能...</div>
                                    </div>
                                </div>
                                <div class="pt-2">
                                    <a href='@Url.Action("ProjectDetail", "TeamZone", new { area = "HNB_WEB", id = "missa" })'
                                       class="w-full inline-flex items-center justify-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300">
                                        <i data-lucide="eye" class="h-4 w-4"></i> 查看詳細資訊 <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                    </a>
                                </div>
                            </div>
                        </article>

                        <!-- 倉儲管理系統 -->
                        <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                            <header class="p-6 pb-0">
                                <div class="flex items-start gap-3">
                                    <div class="p-2 rounded-lg bg-green-50">
                                        <i data-lucide="database" class="h-8 w-8 text-red-600"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800">倉儲管理系統</h3>
                                        <p class="text-gray-600 mt-1">支援倉庫地圖繪製、表單管理，並結合AprilTag實現快速盤點與定位</p>
                                    </div>
                                </div>
                            </header>
                            <div class="p-6 space-y-4">
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var h in new[] { "視覺化倉庫管理", "AprilTag智能盤點", "高效定位追蹤" })
                                        {
                                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-green-100 text-green-800 hover:bg-green-200">@h</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var t in new[] { "倉儲管理", "AprilTag", "地圖繪製", "定位系統" })
                                        {
                                            <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">@t</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                    <div class="grid grid-cols-1 gap-1">
                                        @foreach (var f in new[] { "倉庫地圖繪製", "表單管理系統", "AprilTag快速盤點", "貨物定位追蹤" })
                                        {
                                            <div class="flex items-center text-sm text-gray-600">
                                                <div class="h-1.5 w-1.5 rounded-full bg-green-500 mr-2"></div>@f
                                            </div>
                                        }
                                        <div class="text-sm text-gray-500 mt-1">+2 項功能...</div>
                                    </div>
                                </div>
                                <div class="pt-2">
                                    <a href='@Url.Action("ProjectDetail", "TeamZone", new { area = "HNB_WEB", id = "warehouse" })'
                                       class="w-full inline-flex items-center justify-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300">
                                        <i data-lucide="eye" class="h-4 w-4"></i> 查看詳細資訊 <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                    </a>
                                </div>
                            </div>
                        </article>

                        <!-- EOS -->
                        <article class="hover:shadow-lg transition-all duration-300 border-0 shadow-md group hover:scale-105 rounded-xl bg-white">
                            <header class="p-6 pb-0">
                                <div class="flex items-start gap-3">
                                    <div class="p-2 rounded-lg bg-green-50">
                                        <i data-lucide="server" class="h-8 w-8 text-indigo-600"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800">EOS系統</h3>
                                        <p class="text-gray-600 mt-1">主要控管AI叢集監控設定和監控伺服器狀況</p>
                                    </div>
                                </div>
                            </header>
                            <div class="p-6 space-y-4">
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">專案亮點</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var h in new[] { "AI叢集管理", "即時狀況監控", "智能運維自動化" })
                                        {
                                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm bg-green-100 text-green-800 hover:bg-green-200">@h</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">技術棧</h4>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var t in new[] { "EOS", "AI叢集", "伺服器監控", "系統運維" })
                                        {
                                            <span class="inline-flex items-center rounded px-2 py-1 text-xs border text-gray-600">@t</span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-sm text-gray-700 mb-2">主要功能</h4>
                                    <div class="grid grid-cols-1 gap-1">
                                        @foreach (var f in new[] { "AI叢集監控設定", "伺服器狀況監控", "效能指標追蹤", "資源使用分析" })
