@{
    ViewData["Title"] = "作品集 Portfolio - Horizon Nova";
    Layout = "~/Areas/HNB_WEB/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
<header class="border-bottom bg-white sticky-top">
    <div class="p-3">
        <div class="d-flex align-items-center gap-3">
            <a asp-area="HNB_WEB" asp-controller="TeamZone" asp-action="NovaHome"
               class="btn btn-sm text-dark d-flex align-items-center shadow-none border-0 bg-transparent">
                <i data-lucide="arrow-left" class="icon-md me-2"></i>返回首頁
            </a>
            <div class="vr"></div>
            <div class="d-flex align-items-center gap-2">
                <div class="logo-nova">
                    <img src="~/image/Horizon Nova Logo1.png" alt="HN" />
                </div>
                <span class="fw-bold fs-5 text-gradient-nova">Horizon-Nova</span>

            </div>
        </div>
    </div>
</header>

<section class="py-5">
    <div class="container">
        <!-- Title Section -->
        <div class="text-center mb-5">
            <h1 class="fw-bold mb-3 fs-1 text-gradient-nova">
                專案作品展示
            </h1>
            <p class="fs-5 text-muted mx-auto" style="max-width: 40rem;">
                我們的專業團隊致力於創造創新的技術解決方案，以下是我們的精選作品
            </p>
        </div>

        <!-- Statistics -->
        <div class="row text-center g-4 mb-5">
            <div class="col-6 col-md-3">
                <div class="fs-2 fw-bold text-primary mb-2">25+</div>
                <div class="text-muted">完成專案</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fs-2 fw-bold text-success mb-2">12</div>
                <div class="text-muted">技術領域</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fs-2 fw-bold text-purple mb-2">30+</div>
                <div class="text-muted">核心技術</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fs-2 fw-bold text-warning mb-2">98%</div>
                <div class="text-muted">客戶滿意度</div>
            </div>
        </div>
    </div>
</section>
