@section Scripts {
    <script>
        // ---- Animated numbers (2s, ease-out cubic)
        (function animateCounters(){
          const DURATION = 2000;         // 動畫 2 秒
          const FPS = 60;
          const STEP = 1000 / FPS;

          document.querySelectorAll('[data-count-target]').forEach(el => {
            const raw = (el.getAttribute('data-count-target') || '').trim();

            // 解析： [prefix][number][suffix]  e.g. "" + "100" + "%"  /  "" + "15" + "+"
            const m = raw.match(/^(\D*?)(-?\d+(?:\.\d+)?)(.*)$/);
            const prefix  = m ? m[1] : '';
            const targetN = m ? parseFloat(m[2]) : 0;
            const suffix  = m ? m[3] : '';

            const fromN   = parseFloat(el.getAttribute('data-count-from') || 0);
            const decimals = parseInt(el.getAttribute('data-count-decimals') || 0, 10);

            let frame = 0, total = Math.round(DURATION / STEP);
            const timer = setInterval(() => {
              frame++;
              const p = frame / total;
              const t = 1 - Math.pow(1 - p, 3); // ease-out cubic
              const val = fromN + (targetN - fromN) * t;
              el.textContent = `${prefix}${val.toFixed(decimals)}${suffix}`;

              if (frame >= total) {
                el.textContent = `${prefix}${targetN.toFixed(decimals)}${suffix}`;
                clearInterval(timer);
              }
            }, STEP);
          });
        })();

        // ---- Tabs
        (function tabs(){
          const btns = document.querySelectorAll('.tab-btn');
          const panes = {
            mobile: document.getElementById('tab-mobile'),
            software: document.getElementById('tab-software'),
            web: document.getElementById('tab-web')
          };
          function activate(name){
            // buttons
            btns.forEach(b => {
              const active = b.getAttribute('data-tab') === name;
              b.classList.toggle('bg-white', active);
              b.classList.toggle('border-blue-600', active);
              b.classList.toggle('text-blue-600', active);
            });
            // panes
            Object.keys(panes).forEach(k => panes[k].classList.toggle('hidden', k !== name));
            window.lucide?.createIcons();
          }
          btns.forEach(b => b.addEventListener('click', () => activate(b.getAttribute('data-tab'))));
          activate('mobile'); // default
        })();
        window.lucide?.createIcons();
    </script>
}
