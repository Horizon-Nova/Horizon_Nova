        document.addEventListener('DOMContentLoaded', () => {
            const prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            document.querySelectorAll('[data-hn-typewriter]').forEach(el => {
                const text = el.dataset.hnTypewriter || '';
                if (!text) return;
                const parent = el.parentElement;
                if (prefersReducedMotion) {
                    el.textContent = text;
                    if (parent) parent.classList.add('hn-typewriter-done');
                    return;
                }
                el.textContent = '';
                const chars = [...text];
                let i = 0;
                const next = () => {
                    if (i < chars.length) {
                        el.textContent += chars[i];
                        i++;
                        setTimeout(next, 90 + Math.random() * 40);
                    } else if (parent) {
                        parent.classList.add('hn-typewriter-done');
                    }
                };
                setTimeout(next, 600);
            });
        });
    </script>

