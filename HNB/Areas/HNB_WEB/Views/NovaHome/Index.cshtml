@model Models.HnbWeb.NovaHomeIndexModel
@{
    ViewData["Title"] = "軟體開發外包公司｜網站開發・系統整合・AI 應用";
    ViewData["Description"] = "Horizon Nova Technology（Horizon Nova）是軟體開發外包公司，提供網站開發、系統整合與 AI 技術應用服務；從需求分析、設計開發到上線部署與維運，以可驗收里程碑與可交接文件協助你把想法落地。";
    ViewData["Keywords"] = "軟體開發外包,外包公司,網站開發,系統整合,AI 應用,企業系統,維運,Horizon Nova Technology,Horizon Nova";
    ViewData["Canonical"] = "/";
    Layout = "_Layout";
}

<!-- DarkVeil CSS（Hero 背景用） -->
<link rel="stylesheet" href="~/HNB_WEB/css/DarkVeil.css" asp-append-version="true" />

<div class="min-h-screen bg-transparent">
    <!-- 頂置選單（深銀色半透明、圓角膠囊） -->
    <nav class="fixed inset-x-0 top-6 z-50">
        <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between gap-6 rounded-full border border-white/10 bg-slate-950/35 px-6 py-4 shadow-[0_20px_60px_rgba(0,0,0,0.45)] backdrop-blur-xl sm:px-8">
                <a href="#top"
                   class="flex min-w-0 items-center gap-3 rounded-full px-2 py-1 text-white/90 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30">
                    <img src="~/HNB_WEB/image/Horizon Nova Icon.png"
                         alt="Horizon Nova"
                         class="h-7 w-7 rounded-lg object-cover" />
                    <span class="truncate text-lg font-semibold">Horizon Nova</span>
                </a>

                <div class="hidden items-center gap-2 md:flex">
                    <a href="#services"
                       class="rounded-full px-4 py-2 text-sm font-semibold text-white/85 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30">
                        服務項目
                    </a>
                    <a href="#about"
                       class="rounded-full px-4 py-2 text-sm font-semibold text-white/85 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30">
                        關於我們
                    </a>
                    <a href="#flow"
                       class="rounded-full px-4 py-2 text-sm font-semibold text-white/85 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30">
                        合作流程
                    </a>
                    <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                       class="rounded-full bg-slate-100 px-5 py-2 text-sm font-semibold text-slate-900 shadow-[0_18px_50px_rgba(0,0,0,0.35)] hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-white/30">
                        立即諮詢
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="top" class="relative flex min-h-screen items-center overflow-hidden bg-black px-4 pt-32 pb-20 sm:pt-36 sm:pb-24">
        <!-- DarkVeil 背景 -->
        <div id="darkveil-container" class="absolute inset-0"></div>
        <div class="absolute inset-0 bg-black/60"></div>

        <div class="container mx-auto relative z-10 w-full">
            <div class="grid grid-cols-1 gap-12 items-center">
                <div class="text-center">
                    <div class="animate-in fade-in slide-in-from-left duration-1000">
                        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-white drop-shadow-lg">
                            Horizon Nova
                        </h1>
                        <p class="text-xl md:text-2xl text-white/80 mb-6 max-w-2xl mx-auto drop-shadow min-h-[1.5em]">
                            <span data-hn-typewriter="開發只是開始，未來由我們領航"></span><span class="hn-typewriter-cursor" aria-hidden="true">|</span>
                        </p>
                        <p class="text-lg text-white/70 mb-8 max-w-xl mx-auto leading-relaxed drop-shadow">
                            Horizon Nova Technology（Horizon Nova）是專業的軟體開發外包公司，承接網站開發、系統整合與 AI 技術應用等資訊服務專案；從需求分析到上線部署與維運，協助你把想法落地成可交付、可交接、可長期演進的系統。
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                               class="inline-flex items-center justify-center px-10 py-3 rounded-full text-slate-900 bg-slate-100 hover:bg-slate-200 transform hover:scale-105 transition-all duration-300 shadow-[0_18px_50px_rgba(0,0,0,0.35)] focus:outline-none focus:ring-2 focus:ring-white/30">
                                立即諮詢
                                <i data-lucide="arrow-right" class="ml-2 h-5 w-5"></i>
                            </a>
                            <a href='@Url.Action("Index", "Portfolio", new { area = "HNB_WEB" })'
                               class="inline-flex items-center justify-center px-10 py-3 rounded-full border border-white/10 bg-white/5 text-white/90 hover:bg-white/10 transform hover:scale-105 transition-all duration-300 shadow-[0_18px_50px_rgba(0,0,0,0.25)] backdrop-blur-xl focus:outline-none focus:ring-2 focus:ring-white/30">
                                查看作品
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    @await Html.PartialAsync("Partials/_Styles")
    @await Html.PartialAsync("Partials/_Showcase", Model)

    <!-- About Section -->
    <section id="about" class="relative overflow-hidden py-20 bg-slate-950">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0">
            <div class="absolute top-0 right-0 h-80 w-96 rounded-full blur-3xl opacity-20"
                 style="background: radial-gradient(circle at center, rgba(99,102,241,.5), transparent 70%);">
            </div>
            <div class="absolute inset-0 opacity-[0.08]"
                 style="background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px); background-size: 20px 20px;">
            </div>
        </div>

        <div class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
                <div>
                    <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold tracking-widest text-white/80">
                        關於我們
                    </span>
                    <h2 class="mt-4 text-4xl font-extrabold tracking-tight text-white">開發只是開始，未來由我們領航</h2>
                    <div class="mt-6 h-1 w-24 rounded-full bg-gradient-to-r from-indigo-500/80 to-transparent"></div>

                    <p class="mt-6 text-lg leading-relaxed text-white/70">
                        Horizon Nova 起步於社群與合作夥伴的長期協作：多位工程師與設計夥伴在不同專案反覆並肩作戰，逐步建立同一套溝通節奏與交付標準，最後組成現在的工作室。
                    </p>
                    <p class="mt-4 text-lg leading-relaxed text-white/70">
                        客戶最在意的往往不是「會不會做」，而是「好不好合作」：需求能否釐清、範圍能否對齊、溝通是否順暢、進度是否可預期。為此，合作過程以里程碑與驗收標準做共識基準，搭配快速回應與固定節奏回報，讓每一步都可追蹤、可確認、可放心。
                    </p>

                    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
                        @{
                            var aboutFeatures = new[]
                            {
                                ("需求釐清", "把目標、範圍、里程碑與驗收標準先對齊", "clipboard-check"),
                                ("溝通順暢", "固定節奏回報與快速回應，降低反覆與等待", "message-square"),
                                ("可驗收交付", "每個節點可驗收，進度與品質清楚可見", "check-circle"),
                                ("可交接可維運", "程式碼、文件、權限與部署流程一併提供", "package")
                            };
                        }
                        @foreach (var (title, desc, icon) in aboutFeatures)
                        {
                            <div class="rounded-2xl border border-white/10 bg-slate-950 p-4 shadow-[0_18px_60px_rgba(2,6,23,0.35)]">
                                <div class="flex items-start gap-3">
                                    <span class="mt-0.5 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-500/20 ring-1 ring-indigo-500/30">
                                        <i data-lucide="@icon" class="h-5 w-5 text-indigo-300"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <div class="text-sm font-bold text-white">@title</div>
                                        <div class="mt-1 text-sm leading-relaxed text-white/65">@desc</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="rounded-3xl border border-white/10 bg-slate-950 p-6 text-white shadow-[0_18px_60px_rgba(2,6,23,0.45)] sm:p-8">
                        <h3 class="text-xl font-bold tracking-tight text-white">為什麼選擇我們？</h3>
                        <ul class="mt-6 space-y-4">
                            @{
                                var points = new[] {
                                    ("先把需求說清楚：範圍、風險與交付標準先對齊", "target"),
                                    ("每個里程碑可驗收：讓進度與品質看得見", "check-circle"),
                                    ("交付能交接：程式碼、文件、權限與部署流程一併提供", "package"),
                                    ("上線不是結束：可維護、可擴充、可持續迭代", "refresh-cw")
                                };
                            }
                            @foreach (var (text, icon) in points)
                            {
                                <li class="flex items-start gap-3">
                                    <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-500/20 ring-1 ring-indigo-500/30">
                                        <i data-lucide="@icon" class="h-4 w-4 text-indigo-300"></i>
                                    </span>
                                    <span class="text-white/85">@text</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Flow Section -->
    <section id="flow" class="relative overflow-hidden py-20 bg-slate-950">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0">
            <div class="absolute -top-24 left-1/2 h-72 w-[60rem] -translate-x-1/2 rounded-full blur-3xl opacity-20"
                 style="background: radial-gradient(circle at center, rgba(99,102,241,.55), transparent 65%);">
            </div>
            <div class="absolute inset-0 opacity-[0.08]"
                 style="background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px); background-size: 20px 20px; background-position: center;">
            </div>
        </div>

        <div class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold tracking-widest text-white/80">
                    合作流程
                </span>
                <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">交流 → 盤點 → 提案 → 確認 → 啟動 → 交案</h2>
                <p class="mt-4 text-white/70">讓每一步都有共識、可追蹤、可驗收</p>
                <p class="mt-3 text-sm leading-relaxed text-white/60">
                    我們把「合作的關鍵問題」提早解決：範圍怎麼界定、交付怎麼驗收、里程碑怎麼走、風險怎麼控。
                </p>
            </div>

            <!-- HN：互動式流程圖（n8n / Railway 風格） -->
            <div id="hn-flow" class="mt-10" style="--hn-flow-accent-rgb:99,102,241;">
                <div class="hn-flow-surface relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-4">
                    <div class="hn-flow-viewport">
                        <div class="hn-flow-stage">
                            <svg class="absolute inset-0 h-full w-full" viewBox="0 0 1000 400" preserveAspectRatio="none" fill="none" aria-hidden="true">
                                <path class="hn-flow-edge" data-hn-flow-edge="0" d="M140 270 C210 270 230 130 300 130" />
                                <path class="hn-flow-edge" data-hn-flow-edge="1" d="M300 130 C370 130 390 270 460 270" />
                                <path class="hn-flow-edge" data-hn-flow-edge="2" d="M460 270 C530 270 550 130 620 130" />
                                <path class="hn-flow-edge" data-hn-flow-edge="3" d="M620 130 C690 130 710 270 780 270" />
                                <path class="hn-flow-edge" data-hn-flow-edge="4" d="M780 270 C820 270 840 130 880 130" />
                            </svg>

                            <button type="button"
                                    class="hn-flow-node is-active"
                                    data-hn-flow-step="0"
                                    style="left:14%; top:68%;"
                                    aria-pressed="true">
                                <span class="hn-flow-badge">
                                    <i data-lucide="message-square" class="h-4 w-4"></i>
                                </span>
                                <span class="hn-flow-text">
                                    <span class="hn-flow-title">交流</span>
                                    <span class="hn-flow-sub">初談與需求入口</span>
                                </span>
                            </button>

                            <button type="button"
                                    class="hn-flow-node"
                                    data-hn-flow-step="1"
                                    style="left:30%; top:32%;"
                                    aria-pressed="false">
                                <span class="hn-flow-badge">
                                    <i data-lucide="clipboard-list" class="h-4 w-4"></i>
                                </span>
                                <span class="hn-flow-text">
                                    <span class="hn-flow-title">盤點</span>
                                    <span class="hn-flow-sub">目標/範圍/驗收</span>
                                </span>
                            </button>

                            <button type="button"
                                    class="hn-flow-node"
                                    data-hn-flow-step="2"
                                    style="left:46%; top:68%;"
                                    aria-pressed="false">
                                <span class="hn-flow-badge">
                                    <i data-lucide="monitor" class="h-4 w-4"></i>
                                </span>
                                <span class="hn-flow-text">
                                    <span class="hn-flow-title">提案</span>
                                    <span class="hn-flow-sub">方案/估時/估價</span>
                                </span>
                            </button>

                            <button type="button"
                                    class="hn-flow-node"
                                    data-hn-flow-step="3"
                                    style="left:62%; top:32%;"
                                    aria-pressed="false">
                                <span class="hn-flow-badge">
                                    <i data-lucide="calendar" class="h-4 w-4"></i>
                                </span>
                                <span class="hn-flow-text">
                                    <span class="hn-flow-title">確認</span>
                                    <span class="hn-flow-sub">合作與排程</span>
                                </span>
                            </button>

                            <button type="button"
                                    class="hn-flow-node"
                                    data-hn-flow-step="4"
                                    style="left:78%; top:68%;"
                                    aria-pressed="false">
                                <span class="hn-flow-badge">
                                    <i data-lucide="credit-card" class="h-4 w-4"></i>
                                </span>
                                <span class="hn-flow-text">
                                    <span class="hn-flow-title">啟動</span>
                                    <span class="hn-flow-sub">付款與開工</span>
                                </span>
                            </button>

                            <button type="button"
                                    class="hn-flow-node"
                                    data-hn-flow-step="5"
                                    style="left:88%; top:32%;"
                                    aria-pressed="false">
                                <span class="hn-flow-badge">
                                    <i data-lucide="package" class="h-4 w-4"></i>
                                </span>
                                <span class="hn-flow-text">
                                    <span class="hn-flow-title">交案</span>
                                    <span class="hn-flow-sub">驗收與交接</span>
                                </span>
                            </button>
                        </div>

                        <div id="hn-flow-popover" class="hn-flow-popover" aria-live="polite" aria-atomic="true">
                            <div class="text-xs font-semibold tracking-widest text-white/70">目前步驟</div>
                            <div id="hn-flow-popover-title" class="mt-2 text-base font-extrabold text-white">交流（初談與需求入口）</div>
                            <div id="hn-flow-popover-desc" class="mt-2 text-sm leading-relaxed text-white/75">
                                你可以主動發起，也可以由我們引導。重點是先把「問題、目標、限制」說清楚，讓後續交流更有效率。
                            </div>

                            <div id="hn-flow-popover-tags" class="mt-3 flex flex-wrap gap-2"></div>

                            <div class="mt-4 grid gap-4">
                                <div>
                                    <div class="text-xs font-extrabold tracking-widest text-white/70">你要怎麼做</div>
                                    <ul id="hn-flow-popover-you" class="mt-2 space-y-2 text-sm text-white/70"></ul>
                                </div>
                                <div>
                                    <div class="text-xs font-extrabold tracking-widest text-white/70">我們會怎麼做</div>
                                    <ul id="hn-flow-popover-we" class="mt-2 space-y-2 text-sm text-white/70"></ul>
                                </div>

                                <details class="hn-flow-popover-details">
                                    <summary class="hn-flow-popover-summary">更多細節</summary>
                                    <div class="mt-3 grid gap-4">
                                        <div>
                                            <div class="text-xs font-extrabold tracking-widest text-white/70">溝通方式與節奏</div>
                                            <ul id="hn-flow-popover-comm" class="mt-2 space-y-2 text-sm text-white/70"></ul>
                                        </div>
                                        <div>
                                            <div class="text-xs font-extrabold tracking-widest text-white/70">交付物</div>
                                            <ul id="hn-flow-popover-deliver" class="mt-2 space-y-2 text-sm text-white/70"></ul>
                                        </div>
                                    </div>
                                </details>
                            </div>

                            <div class="mt-5 flex items-center gap-3">
                                <button type="button" data-hn-flow-replay
                                        class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/10">
                                    重新播放
                                    <i data-lucide="rotate-ccw" class="ml-2 h-4 w-4"></i>
                                </button>
                                <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                                   class="inline-flex flex-1 items-center justify-center rounded-full bg-slate-100 px-5 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-white/30">
                                    立即諮詢
                                    <i data-lucide="arrow-right" class="ml-2 h-4 w-4"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-wrap gap-2 text-xs text-white/60">
                        <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">會自動播放，你也可以點選節點跳轉</span>
                        <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">聚焦節點時會顯示該步驟的溝通方式與交付</span>
                    </div>
                </div>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                    <div class="text-sm font-extrabold text-white">你會得到什麼</div>
                    <ul class="mt-3 space-y-2 text-sm text-white/70">
                        <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>每一步的交付物與驗收點清楚可見</span></li>
                        <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>里程碑節奏明確，避免「做到一半才發現方向不對」</span></li>
                        <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>交付可交接：程式碼、文件、部署與權限流程一併整理</span></li>
                    </ul>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                    <div class="text-sm font-extrabold text-white">你需要準備什麼</div>
                    <ul class="mt-3 space-y-2 text-sm text-white/70">
                        <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>需求背景：你想解決什麼問題、目前卡在哪</span></li>
                        <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>期望結果：你希望交付後做到什麼程度</span></li>
                        <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>時程與預算範圍：用來規劃可落地的里程碑</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-950 text-white py-12 px-4">
        <div class="container mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div>
                    <div class="flex items-center space-x-2 mb-4">
                        <div class="h-10 w-10 rounded-lg flex items-center justify-center ring-1 ring-white/10 bg-white/5">
                            <img src="~/HNB_WEB/image/Horizon Nova Icon.png" alt="HN" class="h-10 w-10 rounded-lg object-cover" />
                        </div>
                        <span class="text-xl font-bold">Horizon-Nova</span>
                    </div>
                    <p class="text-white/60">
                        開發只是開始，未來由我們領航
                    </p>
                </div>

                <div>
                    <h3 class="text-lg font-semibold mb-4">服務項目</h3>
                    <ul class="space-y-2 text-white/60">
                        <li>軟體開發</li>
                        <li>Web系統</li>
                        <li>手機APP</li>
                        <li>資料庫</li>
                        <li>AIoT</li>
                    </ul>
