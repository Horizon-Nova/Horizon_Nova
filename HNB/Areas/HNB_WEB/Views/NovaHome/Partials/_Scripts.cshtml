            },
            {
                title: '啟動（付款與開工）',
                desc: '以里程碑啟動開發，先把環境與基本流程建好，讓後續交付可驗收、可追蹤。',
                accentRgb: '217,70,239',
                bullets: [
                    '依里程碑付款與排程啟動',
                    '建立開發/測試環境與權限（依需求）',
                    '把回報與驗收節奏跑起來，讓進度看得見',
                    '優先交付可用版本，快速收斂方向'
                ],
                tags: ['里程碑啟動', '環境建置', '進度同步', '可用版本'],
                youDo: ['完成啟動所需流程：付款、對接窗口、權限提供', '確認優先順序：先交付哪個功能最有價值', '配合驗收節奏提供回饋'],
                weDo: ['建立版本與環境，確保可以交付與驗收', '提供階段性成果並回報狀態', '將問題與風險透明化並提出解法'],
                comm: ['固定節奏回報：完成項目/進行中/阻塞點', '每次交付都帶驗收說明與操作方式'],
                deliverables: ['可驗收的階段成果（依里程碑）', '回報紀錄與問題清單（依需求）']
            },
            {
                title: '交案（驗收與交接）',
                desc: '依驗收清單完成測試與交付，並把交接資訊整理到位，確保後續可交接、可維護、可延伸。',
                accentRgb: '100,116,139',
                bullets: [
                    '依驗收清單完成測試，修正並確認結果',
                    '交付程式碼與文件：部署、權限、操作、維護',
                    '提供交接說明，確保接手者知道怎麼維護',
                    '整理後續迭代建議：下一步做什麼最有效'
                ],
                tags: ['驗收清單', '程式碼交付', '文件交接', '迭代建議'],
                youDo: ['依驗收清單逐項確認結果', '提供最終驗收回饋與必要資料（例如正式環境）', '安排內部交接與上線窗口（若需要）'],
                weDo: ['交付程式碼與文件並完成交接說明', '依驗收結果修正並回覆', '整理可維運資訊：部署、權限、常見問題'],
                comm: ['驗收以清單逐項確認，避免漏項', '交接以文件＋示範為主，確保可接手'],
                deliverables: ['最終交付包（程式碼/文件/部署說明）', '驗收紀錄與交接摘要', '後續迭代建議（依需求）']
            }
        ];

        const nodes = Array.from(root.querySelectorAll('[data-hn-flow-step]'));
        const edges = Array.from(root.querySelectorAll('[data-hn-flow-edge]'));
        if (!nodes.length) return;

        let activeIndex = 0;
        let autoTimer = null;
        let camera = { scale: 1, tx: 0, ty: 0 };

        const listHtml = (items, iconClass) => (items || []).map(t => `
            <li class="flex items-start gap-2">
                <i data-lucide="check" class="mt-0.5 h-4 w-4 ${iconClass}"></i>
                <span>${t}</span>
            </li>
        `).join('');

        const clamp = (v, min, max) => Math.max(min, Math.min(max, v));

        const setCamera = ({ scale, centerX, centerY }) => {
            const vpW = viewport.clientWidth;
            const vpH = viewport.clientHeight;
            const tx = (vpW / 2) - (centerX * scale);
            const ty = (vpH / 2) - (centerY * scale);
            camera = { scale, tx, ty };
            stage.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
        };

        const setOverview = () => {
            const vpW = viewport.clientWidth;
            const vpH = viewport.clientHeight;
            setCamera({ scale: 0.92, centerX: vpW / 2, centerY: vpH / 2 });
        };

        const setPopoverPosition = (node) => {
            const vpW = viewport.clientWidth;
            const vpH = viewport.clientHeight;

            const centerX = node.offsetLeft + (node.offsetWidth / 2);
            const centerY = node.offsetTop + (node.offsetHeight / 2);
            const screenX = (centerX * camera.scale) + camera.tx;
            const screenY = (centerY * camera.scale) + camera.ty;

            const pad = 12;
            const preferX = screenX + 22;
            const preferY = screenY - 18;

            const popW = popover.offsetWidth || 360;
            const popH = popover.offsetHeight || 240;

            const left = clamp(preferX, pad, vpW - popW - pad);
            const top = clamp(preferY, pad, vpH - popH - pad);

            popover.style.left = `${left}px`;
            popover.style.top = `${top}px`;
        };

        const applyActiveState = (i) => {
            activeIndex = i;
            const step = steps[i];
            root.style.setProperty('--hn-flow-accent-rgb', step.accentRgb);

            for (const node of nodes) {
                const n = Number(node.dataset.hnFlowStep);
                const active = n === i;
                node.classList.toggle('is-active', active);
                node.setAttribute('aria-pressed', active ? 'true' : 'false');
            }
            for (const edge of edges) {
                const e = Number(edge.dataset.hnFlowEdge);
                edge.classList.toggle('is-active', e < i);
            }

            popTitle.textContent = step.title;
            popDesc.textContent = step.desc;
            popTags.innerHTML = (step.tags || []).map(t => `
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/70">${t}</span>
            `).join('');

            popYou.innerHTML = listHtml(step.youDo, 'text-white/55');
            popWe.innerHTML = listHtml(step.weDo, 'text-white/55');
            popComm.innerHTML = listHtml(step.comm, 'text-white/55');
            popDeliver.innerHTML = listHtml(step.deliverables, 'text-white/55');

            if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
        };

        const focusStep = (index, { userInitiated }) => {
            const i = clamp(Number(index), 0, steps.length - 1);
            const node = nodes[i];
            if (!node) return;

            applyActiveState(i);

            if (!prefersReducedMotion) {
                const centerX = node.offsetLeft + (node.offsetWidth / 2);
                const centerY = node.offsetTop + (node.offsetHeight / 2);
                setCamera({ scale: 1.15, centerX, centerY });
            } else {
                setCamera({ scale: 1, centerX: viewport.clientWidth / 2, centerY: viewport.clientHeight / 2 });
            }

            // 等鏡頭轉場後再定位浮層，避免抖動
            window.setTimeout(() => setPopoverPosition(node), prefersReducedMotion ? 0 : 220);

            if (userInitiated) stopAuto();
        };

        const stopAuto = () => {
            if (autoTimer) window.clearTimeout(autoTimer);
            autoTimer = null;
        };

        const startAuto = () => {
            stopAuto();
            if (prefersReducedMotion) {
                focusStep(0, { userInitiated: false });
                return;
            }

            setOverview();
            autoTimer = window.setTimeout(() => {
                let i = 0;
                const next = () => {
                    focusStep(i, { userInitiated: false });
                    i++;
                    if (i >= steps.length) return;
                    autoTimer = window.setTimeout(next, 5600);
                };
                next();
            }, 900);
        };

        for (const node of nodes) {
            node.addEventListener('click', () => focusStep(node.dataset.hnFlowStep, { userInitiated: true }));
        }
        if (replayBtn) replayBtn.addEventListener('click', () => startAuto());

        // resize 重新定位（避免鏡頭偏移）
        let resizeTimer = null;
        window.addEventListener('resize', () => {
            window.clearTimeout(resizeTimer);
            resizeTimer = window.setTimeout(() => focusStep(activeIndex, { userInitiated: false }), 120);
        });

        applyActiveState(0);
        startAuto();
    });
</script>

