<!-- 參考 React Bits：Card Swap（以 GSAP 實作），用於專業服務項目展示 -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const showcaseRoot = document.getElementById('hn-services-showcase');
        const swapRoot = document.getElementById('hn-card-swap');
        if (!swapRoot) return;
        if (!showcaseRoot) return;
        if (!window.gsap) {
            console.warn('找不到 GSAP（gsap）');
            return;
        }

        const prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const cards = Array.from(swapRoot.querySelectorAll('[data-hn-swap-card]'));
        if (cards.length < 2) return;

        const getNumber = (v, fallback) => {
            const n = Number(v);
            return Number.isFinite(n) ? n : fallback;
        };

        const cardDistance = getNumber(swapRoot.dataset.cardDistance, 56);
        const verticalDistance = getNumber(swapRoot.dataset.verticalDistance, 64);
        const delay = getNumber(swapRoot.dataset.delay, 5200);
        const dropDistance = getNumber(swapRoot.dataset.dropDistance, 500);
        const skewAmount = getNumber(swapRoot.dataset.skew, 6);
        const easing = (swapRoot.dataset.easing || 'elastic').toLowerCase();
        const pauseOnHover = (swapRoot.dataset.pauseOnHover || 'true').toLowerCase() === 'true';

        const config = easing === 'elastic'
            ? {
                ease: 'elastic.out(0.6,0.9)',
                durDrop: 1.8,
                durMove: 1.8,
                durReturn: 1.8,
                promoteOverlap: 0.9,
                returnDelay: 0.05
            }
            : {
                ease: 'power1.inOut',
                durDrop: 0.75,
                durMove: 0.75,
                durReturn: 0.75,
                promoteOverlap: 0.45,
                returnDelay: 0.2
            };

        const makeSlot = (i, distX, distY, total) => ({
            x: i * distX,
            y: -i * distY,
            z: -i * distX * 1.5,
            zIndex: total - i
        });

        const placeNow = (el, slot, skew) => {
            window.gsap.set(el, {
                x: slot.x,
                y: slot.y,
                z: slot.z,
                xPercent: -50,
                yPercent: -50,
                skewY: skew,
                transformOrigin: 'center center',
                zIndex: slot.zIndex,
                force3D: true
            });
        };

        let order = Array.from({ length: cards.length }, (_, i) => i);
        let tl = null;
        let autoCall = null;

        const updateFrontState = () => {
            const frontEl = cards[order[0]];
            const accent = frontEl.dataset.accent || '#6366F1';
            showcaseRoot.style.setProperty('--hn-accent', accent);
            for (let i = 0; i < cards.length; i++) cards[i].classList.toggle('is-front', i === order[0]);
            if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
        };

        const layoutAllNow = () => {
            const total = cards.length;
            for (let pos = 0; pos < order.length; pos++) {
                const idx = order[pos];
                const slot = makeSlot(pos, cardDistance, verticalDistance, total);
                placeNow(cards[idx], slot, skewAmount);
            }
            updateFrontState();
        };

        // 讓 GSAP 自己把狀態「走完」再接下一個動作，避免用一堆判斷硬擋造成順序錯亂
        const finishInFlight = () => {
            if (!tl) return;
            tl.progress(1);
            tl.kill();
            tl = null;
        };

        const stopAuto = () => {
            if (!autoCall) return;
            autoCall.kill();
            autoCall = null;
        };

        const scheduleAuto = () => {
            stopAuto();
            autoCall = window.gsap.delayedCall(delay / 1000, () => swapOnce({ userInitiated: false }));
        };

        const pauseAuto = () => {
            if (tl) tl.pause();
            if (autoCall) autoCall.pause();
        };

        const resumeAuto = () => {
            if (tl) tl.play();
            if (autoCall) autoCall.resume();
            if (!autoCall) scheduleAuto();
        };

        const swapOnce = ({ userInitiated }) => {
            if (cards.length < 2) return;
            finishInFlight();
            stopAuto();

            const [front, ...rest] = order;
            const elFront = cards[front];

            if (prefersReducedMotion) {
                order = [...rest, front];
                layoutAllNow();
                scheduleAuto();
                return;
            }

            const timeline = window.gsap.timeline();
            tl = timeline;

            timeline.to(elFront, {
                y: `+=${dropDistance}`,
                duration: config.durDrop,
                ease: config.ease
            });

            timeline.addLabel('promote', `-=${config.durDrop * config.promoteOverlap}`);
            rest.forEach((idx, i) => {
                const el = cards[idx];
                const slot = makeSlot(i, cardDistance, verticalDistance, cards.length);
                timeline.set(el, { zIndex: slot.zIndex }, 'promote');
                timeline.to(
                    el,
                    {
                        x: slot.x,
                        y: slot.y,
                        z: slot.z,
                        duration: config.durMove,
                        ease: config.ease
                    },
                    `promote+=${i * 0.15}`
                );
            });

            const backSlot = makeSlot(cards.length - 1, cardDistance, verticalDistance, cards.length);
            timeline.addLabel('return', `promote+=${config.durMove * config.returnDelay}`);
            timeline.call(() => {
                window.gsap.set(elFront, { zIndex: backSlot.zIndex });
            }, undefined, 'return');
            timeline.to(
                elFront,
                {
                    x: backSlot.x,
                    y: backSlot.y,
                    z: backSlot.z,
                    duration: config.durReturn,
                    ease: config.ease
                },
                'return'
            );

            timeline.call(() => {
                order = [...rest, front];
                updateFrontState();
                tl = null;
                scheduleAuto();
            });
        };

        const promoteToFront = (targetIdx) => {
            if (cards.length < 2) return;
            finishInFlight();
            stopAuto();

            const pos = order.indexOf(targetIdx);
            if (pos <= 0) {
                swapOnce({ userInitiated: true });
                return;
            }

            // 以「旋轉」方式把點到的卡片移到最前面，避免原本的 front 被插到第二張造成視覺/狀態不一致
            // 例：order = [3,0,1,2]，點 0（pos=1）→ [0,1,2,3]（原本 front 3 會回到最後）
            const newOrder = [...order.slice(pos), ...order.slice(0, pos)];

            if (prefersReducedMotion) {
                order = newOrder;
                layoutAllNow();
                return;
            }

            const timeline = window.gsap.timeline();
            tl = timeline;

            newOrder.forEach((idx, i) => {
                const el = cards[idx];
                const slot = makeSlot(i, cardDistance, verticalDistance, cards.length);
                timeline.set(el, { zIndex: slot.zIndex }, 0);
                timeline.to(
                    el,
                    {
                        x: slot.x,
                        y: slot.y,
                        z: slot.z,
                        duration: easing === 'elastic' ? 1.2 : 0.85,
                        ease: config.ease
                    },
                    0
                );
            });

            timeline.call(() => {
                order = newOrder;
                updateFrontState();
                tl = null;
                scheduleAuto();
            });
        };

        // 初始化排版
        layoutAllNow();
        // 先跑一次，讓狀態與動畫立即進入節奏（對齊範例行為）
        swapOnce({ userInitiated: false });

        // hover 暫停/恢復
        if (pauseOnHover) {
            const pause = () => pauseAuto();
            const resume = () => resumeAuto();
            swapRoot.addEventListener('mouseenter', pause);
            swapRoot.addEventListener('mouseleave', resume);
        }

        // 點擊切換（避免點到連結時誤觸）
        swapRoot.addEventListener('click', (e) => {
            const target = e.target;
            if (!target) return;
            if (target.closest('a')) return;
            if (target.closest('.hn-swap-next')) {
                swapOnce({ userInitiated: true });
                return;
            }

            const cardEl = target.closest('[data-hn-swap-card]');
            if (!cardEl) return;

            const idx = cards.indexOf(cardEl);
            if (idx < 0) return;

            promoteToFront(idx);
        });

        // resize 重新定位（避免卡片跑版）
        let resizeTimer = null;
        window.addEventListener('resize', () => {
            window.clearTimeout(resizeTimer);
            resizeTimer = window.setTimeout(() => layoutAllNow(), 120);
        });
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        document.querySelectorAll('[data-hn-typewriter]').forEach(el => {
            const text = el.dataset.hnTypewriter || '';
            if (!text) return;
            const parent = el.parentElement;
            if (prefersReducedMotion) {
                el.textContent = text;
                if (parent) parent.classList.add('hn-typewriter-done');
                return;
            }
            el.textContent = '';
            const chars = [...text];
            let i = 0;
            const next = () => {
                if (i < chars.length) {
                    el.textContent += chars[i];
                    i++;
                    setTimeout(next, 90 + Math.random() * 40);
                } else if (parent) {
                    parent.classList.add('hn-typewriter-done');
                }
            };
            setTimeout(next, 600);
        });
    });
</script>

