@using HNB.Models

@{
    ViewBag.Title = "Horizon Nova 工作區";
    Layout = "~/Areas/HNB_WEB/Views/Shared/_LayoutDashboard.cshtml";

    var menuList = (List<SysMenu>)ViewBag.MenuList;
}
<div id="sidebar-wrapper" class="sidebar-wrapper d-flex position-relative">
    <!-- 側欄 -->
    <nav id="sidebar" class="sidebar-collapse p-3 min-vh-100 collapsed sidebar-mini">
        <div class="d-flex align-items-center mb-4">
            <img src="~/image/Team_introduction/UnkonwUser.png"
                 alt="Profile"
                 class="profile-img rounded-circle me-2"
                 style="width:50px;height:50px;">
            <div class="profile-text">
                <h5 class="mb-0 text-light" style="white-space:nowrap;">Horizon-Nova</h5>
                <small class="text-light">管理系统</small>
            </div>
        </div>

        <ul class="nav flex-column">
            @foreach (var menu in menuList.Where(m => m.ParentId == 0))
            {
                var hasChildren = menuList.Any(m => m.ParentId == menu.Id);
                var collapseId = $"collapse-{menu.Id}";

                <li class="nav-item">
                    <a href="#@collapseId"
                       class="nav-link d-flex justify-content-between align-items-center"
                       data-bs-toggle="collapse"
                       aria-expanded="false"
                       aria-controls="@collapseId">
                        <span><i class="@menu.MenuIcon me-2"></i></span>
                        <span class="menu-text">@menu.MenuName</span>
                        <i class="fa fa-angle-down menu-text"></i>
                    </a>

                    <div class="collapse" id="@collapseId">
                        <ul class="nav flex-column ms-3">
                            @foreach (var child in menuList.Where(c => c.ParentId == menu.Id))
                            {
                                <li class="nav-item">
                                    <a href="@child.MenuUrl" target="@child.MenuTarget" class="nav-link text-white-50 menu-text">
                                        <i class="@child.MenuIcon me-2"></i> @child.MenuName
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </li>
            }
        </ul>
    </nav>

    <!-- 右側主區域 -->
    <div id="mainContentWrapper" class="flex-grow-1 d-flex flex-column">

        <div id="Togglebg" class="text-white p-2 w-100 h-auto">
            <!-- 三槓按鈕 -->
            <button id="sidebarToggle" class="btn btn-sm btn-outline-light border-0">
                <i class="fa fa-bars"></i>
            </button>
        </div>

        <!-- 頁籤區域 -->
