@{
    ViewData["Title"] = "立即諮詢｜需求釐清與合作評估";
    ViewData["Description"] = "聯繫 Horizon Nova Technology（Horizon Nova），提交需求與時程/預算範圍，我們會協助釐清目標、範圍與驗收標準，並提供可落地的合作建議。";
    ViewData["Keywords"] = "立即諮詢,需求釐清,合作流程,軟體開發外包,外包公司,網站開發,系統整合,AI 應用,Horizon Nova Technology";
    ViewData["Canonical"] = "/HNB_WEB/Consultation";
    Layout = "_Layout";
}

@{
    var interestOptions = new[]
    {
        "網站與平台",
        "行動應用",
        "企業系統",
        "架構與基礎設施",
        "其他"
    };

    var countryOptions = new[]
    {
        "台灣",
        "日本",
        "香港",
        "新加坡",
        "韓國",
        "越南",
        "泰國",
        "馬來西亞",
        "印尼",
        "菲律賓",
        "澳洲",
        "美國",
        "加拿大",
        "英國",
        "德國",
        "法國",
        "其他"
    };
}

<div class="relative min-h-screen overflow-hidden bg-black text-white">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0">
        <div class="absolute -top-24 left-1/2 h-72 w-[60rem] -translate-x-1/2 rounded-full blur-3xl opacity-20"
             style="background: radial-gradient(circle at center, rgba(99,102,241,.55), transparent 65%);">
        </div>
        <div class="absolute inset-0 opacity-[0.08]"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px); background-size: 22px 22px; background-position: center;">
        </div>
    </div>

    <!-- Header（對齊 NovaHome 膠囊導覽風格） -->
    <nav class="fixed inset-x-0 top-6 z-50">
        <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between gap-6 rounded-full border border-white/10 bg-slate-950/35 px-6 py-4 shadow-[0_20px_60px_rgba(0,0,0,0.45)] backdrop-blur-xl sm:px-8">
                <a href='@Url.Action("Index", "NovaHome", new { area = "HNB_WEB" })'
                   class="flex min-w-0 items-center gap-3 rounded-full px-2 py-1 text-white/90 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30">
                    <img src="@Url.Content("~/HNB_WEB/image/horizon-nova.svg")"
                         alt="Horizon Nova"
                         class="h-7 w-7 rounded-lg object-cover ring-1 ring-white/10 bg-white/5" />
                    <span class="truncate text-lg font-semibold">Horizon Nova</span>
                </a>

                <div class="flex items-center gap-2">
                    <a href="mailto:hiaconde@gmail.com"
                       class="hidden rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm font-semibold text-white/85 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30 sm:inline-flex">
                        寄信聯絡
                    </a>
                    <a href='@Url.Action("Index", "NovaHome", new { area = "HNB_WEB" })'
                       class="rounded-full bg-slate-100 px-5 py-2 text-sm font-semibold text-slate-900 shadow-[0_18px_50px_rgba(0,0,0,0.35)] hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-white/30">
                        返回首頁
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="relative z-10 mx-auto w-full max-w-7xl px-4 pt-32 pb-16 sm:px-6 sm:pt-36 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1fr_560px] lg:items-start">
            <!-- Left：文案與流程（參考 Vercel Demo 的左側說明） -->
            <div class="text-white">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold tracking-widest text-white/80">
                    立即諮詢
                </span>

                <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
                    申請專案諮詢
                </h1>
                <div class="mt-6 h-px w-24 bg-white/35"></div>
                <p class="mt-4 text-lg leading-relaxed text-white/70">
                    告訴我們你想解決的問題與期望交付，我們會協助釐清目標、範圍與驗收標準，並在評估後提供可落地的合作建議。
                </p>

                <div class="mt-6 flex flex-wrap gap-2 text-xs text-white/70">
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">回覆時間：24 小時內</span>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">里程碑交付</span>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">可驗收與可交接</span>
                </div>

                <div class="mt-8 rounded-2xl border border-white/10 bg-white/5 p-6">
                    <div class="text-sm font-extrabold tracking-widest text-white/80">合作流程</div>
                    <p class="mt-2 text-sm leading-relaxed text-white/60">
                        以下為主要里程碑，確保每一步都有共識與可驗收成果。
                    </p>
                    <ol class="mt-4 space-y-3 text-sm text-white/70">
                        <li class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-xs font-extrabold text-white/80">1</span><span><span class="font-semibold text-white/80">評估</span>：需求釐清與可行性評估</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-xs font-extrabold text-white/80">2</span><span><span class="font-semibold text-white/80">開案</span>：確認範圍、時程與報價</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-xs font-extrabold text-white/80">3</span><span><span class="font-semibold text-white/80">設計</span>：提供 Demo／原型確認方向</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-xs font-extrabold text-white/80">4</span><span><span class="font-semibold text-white/80">製作</span>：依里程碑交付可用版本</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-xs font-extrabold text-white/80">5</span><span><span class="font-semibold text-white/80">驗證</span>：依驗收清單逐項確認成果</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-xs font-extrabold text-white/80">6</span><span><span class="font-semibold text-white/80">導入</span>：正式上線與交接</span></li>
                    </ol>
                </div>

                <div class="mt-8 grid gap-4 sm:grid-cols-2">
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                        <div class="text-sm font-extrabold text-white">你會得到什麼</div>
                        <ul class="mt-3 space-y-2 text-sm text-white/70">
                            <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>可交付、可驗收：每一步的交付物與驗收點清楚</span></li>
                            <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>可交接：程式碼、文件、權限與部署流程一併整理</span></li>
                            <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>可追蹤：里程碑節奏明確，風險透明化</span></li>
                        </ul>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                        <div class="text-sm font-extrabold text-white">你需要準備什麼</div>
                        <ul class="mt-3 space-y-2 text-sm text-white/70">
                            <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>需求背景：目前卡點、目標與限制</span></li>
                            <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>期望結果：交付後希望達成的狀態</span></li>
                            <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/55"></i><span>時程/預算：可先給區間，方便規劃里程碑</span></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Right：表單卡片（參考 Vercel Demo 的表單結構） -->
            <aside class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-[0_20px_60px_rgba(0,0,0,0.45)] backdrop-blur-xl">
                <div class="flex items-center gap-2 text-white/90">
                    <i data-lucide="send" class="h-4 w-4 text-indigo-300"></i>
                    <div class="text-sm font-extrabold tracking-widest text-white/80">填寫資訊</div>
                </div>
                <div class="mt-2 text-2xl font-extrabold tracking-tight text-white">提交諮詢需求</div>
                <p class="mt-2 text-sm leading-relaxed text-white/65">
                    送出後會開啟 Email 草稿，讓你先確認內容再寄出（避免填完就直接送出造成資訊不完整）。
                </p>

                <form id="consultationForm" class="mt-6 space-y-4">
                    <div class="space-y-2">
                        <label for="companyEmail" class="text-sm font-semibold text-white/85">公司電子郵件 *</label>
                        <input id="companyEmail" name="companyEmail" type="email" required autocomplete="email"
                               placeholder="name@company.com"
                               class="w-full rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-white/25" />
                    </div>

                    <div class="space-y-2">
                        <label for="country" class="text-sm font-semibold text-white/85">國家／地區 *</label>
                        <select id="country" name="country" required
                                class="w-full rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-white/25">
                            <option value="" selected disabled>請選擇</option>
                            @foreach (var opt in countryOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label for="interest" class="text-sm font-semibold text-white/85">主要需求面向 *</label>
                        <select id="interest" name="interest" required
                                class="w-full rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-white/25">
                            <option value="" selected disabled>請選擇</option>
                            @foreach (var opt in interestOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label for="help" class="text-sm font-semibold text-white/85">需要我們怎麼協助你？ *</label>
                        <textarea id="help" name="help" required rows="5"
                                  placeholder="請簡述：目標、現況卡點、希望交付的成果、時程/預算區間（有就寫）"
                                  class="w-full resize-y rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-white/25"></textarea>
                    </div>

                    <div class="space-y-2">
                        <label for="contactName" class="text-sm font-semibold text-white/85">聯絡人</label>
                        <input id="contactName" name="contactName" type="text" autocomplete="name"
                               placeholder="姓名（選填）"
                               class="w-full rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-white/25" />
                    </div>

                    <div class="space-y-2">
                        <label for="contactPhone" class="text-sm font-semibold text-white/85">聯絡電話</label>
                        <input id="contactPhone" name="contactPhone" type="tel" autocomplete="tel"
                               placeholder="電話（選填）"
                               class="w-full rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-white/25" />
                    </div>

                    <button type="submit"
                            class="mt-2 inline-flex w-full items-center justify-center gap-2 rounded-full bg-slate-100 px-6 py-3 text-sm font-extrabold text-slate-900 hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-white/30">
                        以 Email 寄出諮詢
                        <i data-lucide="arrow-right" class="h-4 w-4"></i>
                    </button>

                    <div class="text-xs leading-relaxed text-white/55">
                        或直接寄信至：<a class="font-semibold text-white/70 hover:text-white" href="mailto:hiaconde@gmail.com">hiaconde@gmail.com</a>
                    </div>
                </form>
            </aside>
        </div>
    </main>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var form = document.getElementById('consultationForm');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                var get = function (name) {
                    var el = form.elements[name];
                    return el && el.value ? String(el.value).trim() : '';
                };

                var lines = [
                    '【公司電子郵件】' + get('companyEmail'),
                    '【國家／地區】' + get('country'),
                    '【主要需求面向】' + get('interest'),
                    '【需求描述】',
                    get('help'),
                    '',
                    '【聯絡人】' + get('contactName'),
                    '【聯絡電話】' + get('contactPhone')
                ];

                var subject = 'Horizon Nova 諮詢需求 - ' + get('companyEmail');
                var body = lines.join('\\n');
                var mailto = 'mailto:hiaconde@gmail.com?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
                window.location.href = mailto;
            });
        });
    </script>
}

