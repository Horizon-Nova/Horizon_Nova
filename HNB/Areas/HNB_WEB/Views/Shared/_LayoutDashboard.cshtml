@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
<!DOCTYPE HTML>
<html>
<head>
    <meta charset="utf-8">
    <meta name="renderer" content="webkit|ie-comp|ie-stand">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1.0,maximum-scale=1.0,user-scalable=no" />
    <meta http-equiv="Cache-Control" content="no-siteapp" />

    <meta name="keywords" content="Horizon Nova後台管理系統">
    <meta name="description" content="Horizon Nova後台管理系統">

    <link rel="bookmark" href='@Url.Content("~/favicon.ico")' />
    <link rel="shortcut icon" href="@Url.Content("~/favicon.ico")" type="image/x-icon" />

    <!-- CSS -->
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap/3.3.7/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/fontawesome/4.7.0/css/fontawesome.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/HNB_WEB/css/style.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/HNB_WEB/css/yisha.min.css")" />

    <!-- JS -->
    <script src="@Url.Content("~/lib/jquery/2.1.4/jquery.min.js")"></script>
    <script src="@Url.Content("~/lib/bootstrap/3.3.7/js/bootstrap.min.js")"></script>
    <script src="@Url.Content("~/lib/layer/3.1.1/layer.min.js")"></script>
    <script src="@Url.Content("~/lib/jquery.metisMenu/1.1.3/jquery.metisMenu.js")"></script>
    <script src="@Url.Content("~/lib/jquery.slimscroll/1.3.8/jquery.slimscroll.min.js")"></script>
    <script src="@Url.Content("~/HNB_WEB/js/yisha.min.js")"></script>
    <script src="@Url.Content("~/HNB_WEB/js/yisha-index.min.js")"></script>

    @RenderSection("header", false)

    <title>Horizon Nova後台管理系統</title>
    <style type="text/css">
        .nav > li:hover .dropdown-menu {
            display: block;
        }
    </style>
    <script type="text/javascript">
        var ctx = '@Url.Content("~/")';
    </script>
</head>
<body class="fixed-sidebar full-height-layout gray-bg login">
    @RenderBody()
    @RenderSection("footer", false)

    <script src="@Url.Content("~/HNB_WEB/js/yisha-init.min.js")"></script>

    @RenderSection("js_section", required: false)

</body>
</html>