@{
    var ctrl = (string?)ViewContext.RouteData.Values["controller"] ?? "";
    var act = (string?)ViewContext.RouteData.Values["action"] ?? "";
    bool IsActive(string c, string a) =>
        string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(act, a, StringComparison.OrdinalIgnoreCase);
    var userName = (User?.Identity?.Name ?? "Admin");
    var email = ViewBag.Email as string ?? "admin@example.com";
    var roleName = ViewBag.Role as string ?? "Administrator";
    var initial = string.IsNullOrEmpty(userName) ? "A" : userName.Substring(0, 1).ToUpper();
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>


    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <link rel="stylesheet" href="~/HNB_WEB/css/LayoutBMS.css" asp-append-version="true" />
    <script src="~/HNB_WEB/js/LayoutBMS.js" asp-append-version="true"></script>
</head>
<body>

    <div class="container-fluid">
        <div class="row g-0">
            <!-- Sidebar -->
            <aside id="sidebar" class="col-auto bms-sidebar">
                <div class="border-bottom d-flex align-items-center justify-content-between px-2" style="height:64px;">
                    <div class="fw-semibold fs-5 label">管理系統</div>
                    <button id="toggleBtn" class="btn btn-light bms-toggle" type="button" aria-label="切換側欄">
                        <i data-lucide="chevron-left"></i>
                    </button>

                </div>

                <nav class="nav nav-pills flex-column gap-1 p-2"
                     style="--bs-nav-pills-link-active-bg: var(--bs-primary-bg-subtle);
                --bs-nav-pills-link-active-color: var(--bs-primary);">
                    <a class="nav-link d-flex align-items-center rounded-3 px-3 py-2 @(IsActive("Backoffice", "Dashboard") ? "active fw-semibold" : "link-body-emphasis")"
                       href="@Url.Action("Dashboard", "Backoffice", new { area = "HNB_WEB" })">
                        <i data-lucide="layout-dashboard" class="me-2 icon" style="width:18px;height:18px;"></i>
                        <span class="label">儀表板</span>
                    </a>
                    <a class="nav-link d-flex align-items-center rounded-3 px-3 py-2 @(IsActive("Backoffice", "ApiSecurity") ? "active fw-semibold" : "link-body-emphasis")"
                       href="@Url.Action("ApiSecurity", "Backoffice", new { area = "HNB_WEB" })">
                        <i data-lucide="shield" class="me-2 icon" style="width:18px;height:18px;"></i>
                        <span class="label">API 安全控管</span>
                    </a>
                    <a class="nav-link d-flex align-items-center rounded-3 px-3 py-2 @(IsActive("Backoffice", "UserManagement") ? "active fw-semibold" : "link-body-emphasis")"
                       href="@Url.Action("UserManagement", "Backoffice", new { area = "HNB_WEB" })">
                        <i data-lucide="users" class="me-2 icon" style="width:18px;height:18px;"></i>
                        <span class="label">權限管理</span>
                    </a>
                    <a class="nav-link d-flex align-items-center rounded-3 px-3 py-2 @(IsActive("Backoffice", "KeyManagement") ? "active fw-semibold" : "link-body-emphasis")"
                       href="@Url.Action("KeyManagement", "Backoffice", new { area = "HNB_WEB" })">
                        <i data-lucide="key" class="me-2 icon" style="width:18px;height:18px;"></i>
                        <span class="label">KEY 保管</span>
                    </a>
                    <a class="nav-link d-flex align-items-center rounded-3 px-3 py-2 @(IsActive("Backoffice", "Settings") ? "active fw-semibold" : "link-body-emphasis")"
                       href="@Url.Action("Settings", "Backoffice", new { area = "HNB_WEB" })">
                        <i data-lucide="settings" class="me-2 icon" style="width:18px;height:18px;"></i>
                        <span class="label">系統設定</span>
                    </a>
                </nav>
            </aside>

            <!-- Main -->
            <div class="col d-flex flex-column">
                <!-- Header -->
                <header class="bms-topbar border-bottom">
                    <div class="container-fluid d-flex align-items-center justify-content-between px-3" style="height:64px;">
                        <div class="fw-semibold fs-5 label">後台管理系統</div>

                        <div class="d-flex align-items-center gap-2">
                            <div class="dropdown">
                                <button class="btn btn-light position-relative rounded-circle p-0 d-flex align-items-center justify-content-center bms-avatar-btn"
                                        type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                        aria-label="使用者選單">
                                    <span class="bms-avatar fw-semibold">@initial</span>
                                </button>

                                <div class="dropdown-menu dropdown-menu-end shadow py-2 bms-user-menu">
                                    <div class="px-3">
                                        <div class="small">@userName</div>
                                        <div class="text-secondary small">@email</div>
                                        <div class="text-secondary small">角色：@roleName</div>
                                    </div>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item d-flex align-items-center gap-2" href="@Url.Action("Profile", "Account")">
                                        <i data-lucide="user" class="lucide-16"></i> 個人資料
                                    </a>
                                    <div class="dropdown-divider"></div>
                                    <button class="dropdown-item d-flex align-items-center gap-2" type="button" onclick="bmsLogout()">
                                        <i data-lucide="log-out" class="lucide-16"></i> 登出
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                <!-- Main content -->
                <main class="flex-fill">
                    @RenderBody()
                </main>
            </div>

        </div>
    </div>


    @RenderSection("Scripts", required: false)
</body>
</html>
