<!DOCTYPE html>
<html lang="zh-Hant" class="scroll-smooth scroll-pt-24">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    @{
        var pageTitle = ViewData["Title"] as string;
        var pageDescription = ViewData["Description"] as string;
    }

    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="@Url.Content("~/HNB_WEB/image/horizon-nova.svg")">
    <link rel="shortcut icon" type="image/svg+xml" href="@Url.Content("~/HNB_WEB/image/horizon-nova.svg")">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide / 其他庫 -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@shoelace-style/shoelace@2.13.0/cdn/themes/light.css">
    <script type="module" src="https://cdn.jsdelivr.net/npm/@@shoelace-style/shoelace@2.13.0/cdn/shoelace.js"></script>
    <link rel="stylesheet" href="~/HNB_WEB/css/Layout.css" asp-append-version="true" />
    <script src="~/HNB_WEB/js/Layout.js" asp-append-version="true"></script>

    @RenderSection("Head", required: false)
</head>
<body class="min-h-screen bg-slate-900">
    @RenderBody()

    <script>
        document.addEventListener('DOMContentLoaded', () => {
          if (window.lucide && window.lucide.createIcons) {
            window.lucide.createIcons();
          }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>

