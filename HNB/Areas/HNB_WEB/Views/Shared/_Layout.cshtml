<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <link rel="stylesheet" href="~/HNB_WEB/css/Layout.css" asp-append-version="true" />
    <script src="~/HNB_WEB/js/Layout.js" asp-append-version="true"></script>
</head>
<body>
    <!-- Header -->
    <header class="border-bottom bg-white sticky-top z-3">
        <div class="px-5 py-3 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <!-- 返回首頁 -->
                <a href="/" class="btn btn-link btn-sm d-inline-flex align-items-center text-decoration-none">
                    <i data-lucide="arrow-left" class="me-2"></i>
                    <span>返回首頁</span>
                </a>

                <!-- 垂直分隔線 -->
                <div class="vr mx-3"></div>

                <!-- 品牌區塊 -->
                <div class="d-flex align-items-center gap-2">
                    <div class="logo-nova d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-2"
                         style="width:32px;height:32px;">
                        <img src="~/image/Horizon Nova Logo1.png" alt="HN" />
                    </div>
                    <span class="fw-bold fs-5 text-gradient-nova">Horizon-Nova</span>
                </div>
            </div>
        </div>
    </header>


    @RenderBody()

    @RenderSection("Scripts", required: false)
</body>
</html>
