<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/HNB_WEB/image/Horizon Nova Icon.png">
    <link rel="shortcut icon" type="image/png" href="~/HNB_WEB/image/Horizon Nova Icon.png">


    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide / 其他庫 -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>


    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@shoelace-style/shoelace@2.13.0/cdn/themes/light.css">
    <script type="module" src="https://cdn.jsdelivr.net/npm/@@shoelace-style/shoelace@2.13.0/cdn/shoelace.js"></script>
    <script src="~/HNB_WEB/js/Layout.js" asp-append-version="true"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50 text-gray-900">
    @RenderBody()

    <script>
        document.addEventListener('DOMContentLoaded', () => {
          if (window.lucide && window.lucide.createIcons) {
            window.lucide.createIcons();
          }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
