@using Models.HnbWeb
@{
    ViewData["Title"] = "作品集｜精選案例與技術實作";
    ViewData["Description"] = "Horizon Nova Technology（Horizon Nova）作品集：涵蓋網站開發、企業系統、行動 APP、AI/資料智能與部署維運等軟體開發外包案例，展示需求、解法與交付成果。";
    ViewData["Keywords"] = "作品集,案例,軟體開發外包,網站開發,系統整合,行動 APP,AI 應用,部署維運,Horizon Nova Technology";
    ViewData["Canonical"] = "/HNB_WEB/Portfolio";
    Layout = "_Layout";
}

<div class="min-h-screen bg-black text-white">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0">
        <div class="absolute inset-0 opacity-[0.08]"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px); background-size: 22px 22px; background-position: center;">
        </div>
    </div>

    @await Html.PartialAsync("Partials/_Header")

    <main class="relative z-10 mx-auto w-full max-w-7xl px-4 pt-32 pb-20 sm:px-6 lg:px-8">
        @await Html.PartialAsync("Partials/_Title")
        @await Html.PartialAsync("Partials/_Stats")
        @await Html.PartialAsync("Partials/_Projects")
        @await Html.PartialAsync("Partials/_Team")
        @await Html.PartialAsync("Partials/_Cta")
    </main>
</div>
