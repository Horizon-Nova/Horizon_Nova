@using Models.HnbWeb
@{
    var projects = ViewBag.PortfolioDataMap as List<project> ?? new List<project>();

    bool MatchAny(string? value, params string[] keys)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        for (var i = 0; i < keys.Length; i++)
        {
            if (value.Contains(keys[i], StringComparison.OrdinalIgnoreCase)) return true;
        }
        return false;
    }

    // 依你描述：目前「完整主體」主要就軟體、Web 兩個
    var mainSoftware = projects.FirstOrDefault(p =>
        MatchAny(p.category, "軟體", "software") || MatchAny(p.name, "軟體", "software"));

    var mainWeb = projects.FirstOrDefault(p =>
        (MatchAny(p.category, "web", "網站", "網頁", "企業系統") || MatchAny(p.name, "web", "網站", "網頁", "企業系統"))
        && (mainSoftware == null || p.id != mainSoftware.id));

    var featured = new List<project>();
    if (mainSoftware != null) featured.Add(mainSoftware);
    if (mainWeb != null) featured.Add(mainWeb);
    if (featured.Count < 2)
    {
        featured.AddRange(projects.Where(p => featured.All(x => x.id != p.id)).Take(2 - featured.Count));
    }

    var samples = projects.Where(p => featured.All(x => x.id != p.id)).ToList();
}

                </section>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-[0_18px_60px_rgba(2,6,23,0.35)]">
        <div class="text-sm font-extrabold tracking-widest text-white/70">說明</div>
        <div class="mt-3 text-white/75 leading-relaxed">
            目前完整可展示的主體以「軟體」與「Web」為主，其餘項目多為測試樣品/PoC。以下分為兩區呈現：主體成果（可作為交付參考）與樣品庫（概念驗證/技術樣板）。\n        </div>
    </div>

    @if (!projects.Any())
    {
        <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-12 text-center text-white/60">
            目前尚無任何專案資料。
        </div>
    }
    else
    {
        <!-- 主體成果 -->
        <section class="mt-10">
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/80">主體成果</span>
                <h2 class="text-2xl font-extrabold tracking-tight text-white">以完整交付為主的兩個主體</h2>
            </div>
            <p class="mt-3 text-white/70">點擊後直接進入專案詳情，查看挑戰、解法、交付與成果。</p>

            <div class="mt-6 grid gap-6 lg:grid-cols-2">
                @foreach (var p in featured)
                {
                    var accent = string.IsNullOrWhiteSpace(p.accent_color) ? "#2563eb" : p.accent_color;
                    var shot = p.screenshots?.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
                    <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-[0_18px_60px_rgba(2,6,23,0.35)]">
                        <div class="overflow-hidden rounded-2xl border border-white/10 bg-black/30">
                            <div class="aspect-video w-full bg-white/5">
                                @if (!string.IsNullOrWhiteSpace(shot))
                                {
                                    <img src="@shot" alt="專案截圖" class="h-full w-full object-cover" />
                                }
                                else
                                {
                                    <div class="flex h-full w-full items-center justify-center text-sm text-white/55">尚無截圖</div>
                                }
                            </div>
                        </div>

                        <div class="mt-5 flex items-start gap-3">
                            <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-white/5 ring-1 ring-white/10">
                                <i data-lucide="@(string.IsNullOrWhiteSpace(p.icon) ? "file-text" : p.icon)" class="h-6 w-6" style="color:@accent"></i>
                            </span>
                            <div class="min-w-0">
                                <div class="flex flex-wrap gap-2">
                                    <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/70">@p.category</span>
                                    @if (!string.IsNullOrWhiteSpace(p.duration))
                                    {
                                        <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/70">時程：@p.duration</span>
                                    }
                                    @if (p.team_size.HasValue)
                                    {
                                        <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/70">團隊：@p.team_size 人</span>
                                    }
                                </div>
                                <h3 class="mt-3 text-2xl font-extrabold tracking-tight text-white">@p.name</h3>
                                @if (!string.IsNullOrWhiteSpace(p.outcome_tagline))
                                {
                                    <p class="mt-3 text-lg leading-relaxed text-white/80">@p.outcome_tagline</p>
                                }
                                else if (!string.IsNullOrWhiteSpace(p.summary))
                                {
                                    <p class="mt-3 text-base leading-relaxed text-white/70">@p.summary</p>
                                }
                            </div>
                        </div>

                        @if (p.outcome_kpis?.Any(x => !string.IsNullOrWhiteSpace(x)) == true)
                        {
                            <div class="mt-4 flex flex-wrap gap-2">
                                @foreach (var kpi in p.outcome_kpis.Where(x => !string.IsNullOrWhiteSpace(x)).Take(4))
                                {
                                    <span class="inline-flex items-center rounded-full bg-white/5 px-3 py-1 text-xs font-semibold text-white/80 ring-1 ring-white/10">@kpi</span>
                                }
                            </div>
                        }

                        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                            <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                               class="inline-flex flex-1 items-center justify-center gap-2 rounded-full bg-slate-100 px-6 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-200">
                                閱讀案例
                                <i data-lucide="arrow-right" class="h-4 w-4"></i>
                            </a>
                            <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                               class="inline-flex items-center justify-center gap-2 rounded-full border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 hover:bg-white/10">
                                以此規格諮詢
                            </a>
                        </div>
                    </article>
                }
            </div>
        </section>

        <!-- 樣品庫 -->
        <section class="mt-12">
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/70">樣品 / PoC</span>
                <h2 class="text-xl font-extrabold tracking-tight text-white">測試樣品與技術樣板（非成交成果）</h2>
            </div>
            <p class="mt-3 text-white/65">用來展示技術方向與可行性，避免與主體成果混淆。</p>

            @if (!samples.Any())
            {
                <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-10 text-center text-white/60">
                    目前沒有其他樣品。
                </div>
            }
            else
            {
                <div class="mt-6 grid gap-4 md:grid-cols-2">
                    @foreach (var p in samples)
                    {
                        <article class="rounded-2xl border border-white/10 bg-white/5 p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <div class="text-xs font-semibold tracking-widest text-white/60">@p.category</div>
                                    <div class="mt-2 text-lg font-extrabold tracking-tight text-white">@p.name</div>
                                    @if (!string.IsNullOrWhiteSpace(p.summary))
                                    {
                                        <div class="mt-2 text-sm leading-relaxed text-white/65">@p.summary</div>
                                    }
                                </div>
                                <span class="shrink-0 inline-flex items-center rounded-full border border-white/10 bg-black/20 px-3 py-1 text-xs font-semibold text-white/70">
                                    樣品
                                </span>
                            </div>
                            <div class="mt-4">
                                <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                                   class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2.5 text-sm font-semibold text-white/85 hover:bg-white/10 hover:text-white">
                                    查看詳情
                                    <i data-lucide="arrow-right" class="h-4 w-4"></i>
                                </a>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</section>
