@{
    var slug = (ViewData["Slug"] as string) ?? string.Empty;

    ViewData["Title"] = "產品介紹｜" + (string.IsNullOrWhiteSpace(slug) ? "未指定" : slug);
    ViewData["Description"] = "產品介紹頁（版面原型）：以產品敘事呈現問題、解法、模組與交付內容，後續再接真實資料。";
    ViewData["Keywords"] = "產品介紹,解決方案,系統模組,交付內容";
    ViewData["Canonical"] = string.IsNullOrWhiteSpace(slug) ? "/product" : $"/product/{slug}";
    Layout = "_Layout";

    var products = new[]
    {
        new
        {
            Slug = "ops-observability",
            Eyebrow = "Ops / 可觀測性",
            Name = "Observability Suite",
            Summary = "把監控、告警、事件留存與追溯串成一條線，讓維運變成可被驗證的流程。",
            Status = "Beta",
            Tags = new[] { "告警", "儀表板", "事件追溯", "可觀測性" },
            Modules = new[] { "指標/事件收集", "告警規則與通知", "事件留存與追溯", "儀表板模板" },
            Deliverables = new[] { "可部署服務與權限控管", "儀表板與告警規則範本", "事件資料結構與留存策略", "維運交接文件（版面原型）" }
        },
        new
        {
            Slug = "ai-data-intelligence",
            Eyebrow = "AI / 資料智能",
            Name = "AI Data Toolkit",
            Summary = "把 OCR、向量搜尋與資料管線整合成可維運功能，重點在可部署、可追蹤、可迭代。",
            Status = "規劃中",
            Tags = new[] { "OCR", "向量搜尋", "資料管線", "模型整合" },
            Modules = new[] { "資料擷取與清洗", "向量化與相似度查詢", "流程自動化回填", "監控與版本策略" },
            Deliverables = new[] { "API/後台（可部署）", "資料管線設計與交付", "監控告警與事件留存", "維運與迭代建議（版面原型）" }
        }
    };

    var product = products.FirstOrDefault(p => p.Slug.Equals(slug, StringComparison.OrdinalIgnoreCase));
}

<div class="min-h-screen bg-black text-white">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0">
        <div class="absolute inset-0 opacity-[0.08]"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px); background-size: 22px 22px; background-position: center;">
        </div>
    </div>

    <main class="relative z-10 mx-auto w-full max-w-7xl px-4 pt-28 pb-20 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center gap-3 text-sm text-white/60">
            <a href="@Url.Content("~/product")" class="rounded-full px-3 py-1 hover:bg-white/10 hover:text-white">產品</a>
            <span>/</span>
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-white/75">@slug</span>
        </div>

        @if (product == null)
        {
            <section class="mt-10 rounded-3xl border border-white/10 bg-white/5 p-10">
                <h1 class="text-3xl font-extrabold tracking-tight">找不到此產品</h1>
                <p class="mt-4 text-white/70">此頁為版面原型，目前只建立部分產品 slug。你可以先回到產品列表頁查看。</p>
                <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                    <a href="@Url.Content("~/product")"
                       class="inline-flex items-center justify-center gap-2 rounded-full bg-slate-100 px-7 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-200">
                        回到產品列表
                        <i data-lucide="arrow-right" class="h-4 w-4"></i>
                    </a>
                    <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                       class="inline-flex items-center justify-center gap-2 rounded-full border border-white/10 bg-white/5 px-7 py-3 text-sm font-semibold text-white/90 hover:bg-white/10">
                        直接諮詢需求
                    </a>
                </div>
            </section>
        }
        else
        {
            <header class="mt-10 max-w-4xl">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold text-white/80">@product.Eyebrow</span>
                    <span class="inline-flex items-center rounded-full border border-white/10 bg-black/20 px-4 py-2 text-xs font-semibold text-white/75">@product.Status</span>
                </div>
                <h1 class="mt-6 text-4xl font-extrabold tracking-tight sm:text-5xl">@product.Name</h1>
                <p class="mt-5 text-base leading-relaxed text-white/70">@product.Summary</p>
                <div class="mt-7 flex flex-wrap gap-2">
                    @foreach (var tag in product.Tags.Take(8))
                    {
                        <span class="inline-flex items-center rounded-full bg-white/5 px-3 py-1 text-xs font-semibold text-white/80 ring-1 ring-white/10">@tag</span>
                    }
                </div>
                <div class="mt-10 flex flex-col gap-3 sm:flex-row">
                    <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                       class="inline-flex items-center justify-center gap-2 rounded-full bg-slate-100 px-7 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-200">
                        預約示範 / 需求討論
                        <i data-lucide="arrow-right" class="h-4 w-4"></i>
                    </a>
                    <a href="#deliverables"
                       class="inline-flex items-center justify-center gap-2 rounded-full border border-white/10 bg-white/5 px-7 py-3 text-sm font-semibold text-white/90 hover:bg-white/10">
                        看交付內容
                    </a>
                </div>
            </header>

            <section class="mt-12 grid gap-6 lg:grid-cols-3">
                <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
                    <div class="text-sm font-extrabold tracking-widest text-white/70">你可能遇到的問題</div>
                    <ul class="mt-4 grid gap-3 text-sm leading-relaxed text-white/70">
                        <li>告警很多但無法追溯，事件只剩截圖與口述。</li>
                        <li>資料散在各工具，切換成本高且責任不清。</li>
                        <li>交付時沒有可交接規格，維運只靠人。</li>
                    </ul>
                </article>
                <article class="rounded-3xl border border-white/10 bg-white/5 p-6 lg:col-span-2">
                    <div class="text-sm font-extrabold tracking-widest text-white/70">我們的解法（版面原型）</div>
                    <div class="mt-4 text-white/75 leading-relaxed">
                        以「可驗收的流程」切分：收集 → 規則 → 通知 → 留存 → 追溯。每一步都能被稽核與交接，並保留擴充點讓你後續接進既有系統。
                    </div>
                    <div class="mt-6 grid gap-4 sm:grid-cols-2">
                        <div class="rounded-2xl border border-white/10 bg-black/20 p-5">
                            <div class="text-sm font-bold text-white">可觀測性資料模型</div>
                            <div class="mt-2 text-sm text-white/65">先把事件/指標的結構定義清楚，後續工具更換不會推倒重來。</div>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-black/20 p-5">
                            <div class="text-sm font-bold text-white">告警到追溯的閉環</div>
                            <div class="mt-2 text-sm text-white/65">告警不是通知而已，重點是「能回頭查為什麼」。</div>
                        </div>
                    </div>
                </article>
            </section>

            <section class="mt-12">
                <div class="flex items-center justify-between gap-6">
                    <div>
                        <div class="text-sm font-extrabold tracking-widest text-white/70">功能模組</div>
                        <h2 class="mt-3 text-2xl font-extrabold tracking-tight">用模組化承接未來擴充</h2>
                    </div>
                </div>
                <div class="mt-6 grid gap-4 md:grid-cols-2">
                    @foreach (var m in product.Modules)
                    {
                        <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                            <div class="flex items-start gap-3">
                                <i data-lucide="layers" class="mt-0.5 h-5 w-5 text-white/60"></i>
                                <div class="min-w-0">
                                    <div class="text-sm font-bold text-white">@m</div>
                                    <div class="mt-1 text-sm text-white/65">此處先以版面原型呈現，後續接真實資料再補「輸入/輸出/權限/限制」。</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section id="deliverables" class="mt-12">
                <div class="text-sm font-extrabold tracking-widest text-white/70">交付內容</div>
                <h2 class="mt-3 text-2xl font-extrabold tracking-tight">可交接、可維運、可驗收</h2>
                <div class="mt-6 rounded-3xl border border-white/10 bg-white/5 p-6">
                    <ul class="grid gap-3 text-sm leading-relaxed text-white/75 sm:grid-cols-2">
                        @foreach (var d in product.Deliverables)
                        {
                            <li class="flex items-start gap-2">
                                <i data-lucide="check" class="mt-0.5 h-4 w-4 text-white/60"></i>
                                <span class="min-w-0">@d</span>
                            </li>
                        }
                    </ul>
                </div>
            </section>

            <section class="mt-12">
                <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <div class="text-sm font-extrabold tracking-widest text-white/70">下一步</div>
                            <div class="mt-3 text-xl font-extrabold tracking-tight">把你的情境套進這個產品版型</div>
                            <div class="mt-2 text-sm text-white/65">這頁先完成敘事結構，後續會把欄位與資料來源接回系統。</div>
                        </div>
                        <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                           class="inline-flex items-center justify-center gap-2 rounded-full bg-slate-100 px-7 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-200">
                            以此產品版型諮詢
                            <i data-lucide="arrow-right" class="h-4 w-4"></i>
                        </a>
                    </div>
                </div>
            </section>
        }
    </main>
</div>

