@model Models.HnbWeb.project
@{
    ViewData["Title"] = $"{Model.name}｜專案詳情";
    ViewData["Description"] = string.IsNullOrWhiteSpace(Model.summary)
        ? "Horizon Nova Technology（Horizon Nova）專案詳情頁：包含專案概述、功能與交付內容。"
        : $"{Model.summary}（Horizon Nova Technology 專案詳情）";
    ViewData["Keywords"] = "專案詳情,作品集,案例,軟體開發外包,網站開發,系統整合,AI 應用,Horizon Nova Technology";
    Layout = "_LayoutProjectDetail";
    var accent = string.IsNullOrWhiteSpace(Model.accent_color) ? "#2563eb" : Model.accent_color;
}
<!-- 建議：在最外層用 CSS 變數控制主色（--color） -->
<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50" style="--color: #2563eb;">
    <!-- Header -->
    <header class="border-b bg-white/80 backdrop-blur-sm sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href="@Url.Action("Index", "Portfolio", new { area = "HNB_WEB" })"
                   class="inline-flex items-center gap-2 text-gray-700 hover:bg-gray-100 px-3 py-2 rounded-md transition">
                    <i data-lucide="arrow-left" class="h-4 w-4"></i>
                    <span>返回作品展示</span>
                </a>

                <div class="h-8 border-l border-gray-300"></div>
                <div class="flex items-center space-x-2">
                    <div class="h-10 w-10 rounded-lg overflow-hidden bg-white shadow">
                        <img src="~/HNB_WEB/image/Horizon Nova Icon.png" alt="HN" class="h-10 w-10 object-cover" />
                    </div>
                    <span class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                        Horizon-Nova
                    </span>
                </div>
            </div>
        </div>
    </header>

    <div class="container mx-auto px-4 py-12">
        <div class="max-w-6xl mx-auto">
            <!-- Project Header -->
            <div class="mb-8">
                <div class="flex items-center space-x-4 mb-4">
                    <div class="p-3 bg-white rounded-xl shadow-lg">
                        <i data-lucide="@Model.icon" class="h-8 w-8" style="color:@accent"></i>
                    </div>
                    <div>
                        <div class="flex items-center space-x-3 mb-2">
                            <h1 class="text-4xl font-bold text-gray-800">
                                @Model.name
                            </h1>
                            <!-- 類別徽章 -->
                            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold"
                                  style="background-color:color-mix(in srgb,@accent 15%,transparent);color:@accent;">
                                @Model.category
                            </span>
                        </div>
                        <p class="text-lg text-gray-600">
                            @Model.summary
                        </p>
                    </div>
                </div>
            </div>


            <!-- Project Images -->
            @if (Model.screenshots != null && Model.screenshots.Any())
            {
                <div class="mb-12">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        @foreach (var shot in Model.screenshots.Take(3))
                        {
                            if (!string.IsNullOrWhiteSpace(shot))
                            {
                                <div class="aspect-video bg-gray-200 rounded-lg overflow-hidden">
                                    <img src="@shot" alt="專案截圖" class="w-full h-full object-cover" />
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            <!-- Tabs -->
            <div data-tabs-root class="w-full">
                <div class="grid grid-cols-4 gap-2 mb-8 text-sm">
                    <button class="tab-btn px-3 py-2 rounded bg-white shadow font-medium" data-tab="overview">專案概述</button>
                    <button class="tab-btn px-3 py-2 rounded hover:bg-white/70" data-tab="features">功能特色</button>
                    <button class="tab-btn px-3 py-2 rounded hover:bg-white/70" data-tab="technical">技術實作</button>
                    <button class="tab-btn px-3 py-2 rounded hover:bg-white/70" data-tab="results">成果展示</button>
                </div>

                <!-- Overview -->
                <section class="tab-pane space-y-6" data-pane="overview">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="lg:col-span-2">
                            <div class="bg-white rounded-xl shadow">
                                <div class="p-5">
                                    <h3 class="text-2xl font-semibold">專案介紹</h3>
                                </div>
                                <div class="px-5 pb-5">
                                    <p class="text-gray-700 leading-relaxed mb-6">
                                        @Model.intro
                                    </p>
                                    <h4 class="font-semibold mb-3">主要挑戰</h4>
                                    <ul class="space-y-2 mb-6">
                                        @foreach (var challenge in (Model.challenges ?? new List<string>()))
                                        {
                                            if (!string.IsNullOrWhiteSpace(challenge))
                                            {
                                                <li class="flex items-start space-x-2">
                                                    <i data-lucide="target" class="h-4 w-4 text-red-500 mt-1 flex-shrink-0"></i>
                                                    <span class="text-gray-700">@challenge</span>
                                                </li>
                                            }
                                        }
                                    </ul>

                                    <h4 class="font-semibold mb-3">解決方案</h4>
                                    <ul class="space-y-2">
                                        @foreach (var solution in (Model.solution ?? new List<string>()))
                                        {
                                            if (!string.IsNullOrWhiteSpace(solution))
                                            {
                                                <li class="flex items-start space-x-2">
                                                    <i data-lucide="zap" class="h-4 w-4 text-green-500 mt-1 flex-shrink-0"></i>
                                                    <span class="text-gray-700">@solution</span>
                                                </li>
                                            }
                                        }
                                    </ul>

                                </div>
                            </div>
                        </div>

                        <div class="space-y-6">
                            <!-- Project Info -->
                            <div class="bg-white rounded-xl shadow">
                                <div class="p-5 border-b">
                                    <h3 class="text-lg font-semibold">專案資訊</h3>
                                </div>
                                <div class="p-5 space-y-4">
                                    @if (!string.IsNullOrWhiteSpace(Model.duration))
                                    {
                                        <div class="flex items-center space-x-3">
                                            <i data-lucide="calendar" class="h-5 w-5" style="color: var(--color)"></i>
                                            <div>
                                                <p class="font-medium">開發時程</p>
                                                <p class="text-sm text-gray-600">@Model.duration</p>
                                            </div>
                                        </div>
                                    }
                                    @if (Model.team_size.HasValue)
                                    {
                                        <div class="flex items-center space-x-3">
                                            <i data-lucide="users" class="h-5 w-5 text-green-600"></i>
                                            <div>
                                                <p class="font-medium">團隊規模</p>
                                                <p class="text-sm text-gray-600">@Model.team_size 人</p>
                                            </div>
                                        </div>
                                    }
                                    @if (Model.is_client_confidential || !string.IsNullOrWhiteSpace(Model.client_name))
                                    {
                                        var clientText = Model.is_client_confidential ? "客戶保密" : Model.client_name;
                                        <div class="flex items-center space-x-3">
                                            <i data-lucide="database" class="h-5 w-5 text-purple-600"></i>
                                            <div>
                                                <p class="font-medium">客戶</p>
                                                <p class="text-sm text-gray-600">@clientText</p>
                                            </div>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(Model.status))
                                    {
                                        <div class="flex items-center space-x-3">
                                            <i data-lucide="check-circle" class="h-5 w-5 text-green-600"></i>
                                            <div>
                                                <p class="font-medium">專案狀態</p>
                                                <p class="text-sm text-gray-600">@Model.status</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Technologies -->
                            <div class="bg-white rounded-xl shadow">
                                <div class="p-5 border-b">
                                    <h3 class="text-lg font-semibold">使用技術</h3>
                                </div>
                                <div class="p-5">
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var tech in (Model.tech_stack ?? new List<string>()))
                                        {
                                            if (!string.IsNullOrWhiteSpace(tech))
                                            {
                                                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent hover:bg-secondary/80 bg-gray-100 text-gray-700">@tech</span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Features -->
                <section class="tab-pane hidden space-y-6" data-pane="features">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        @if (Model.features != null && Model.features.Any())
                        {
                            @for (var index = 0; index < (Model.features?.Count ?? 0); index++)
                            {
                                var feature = Model.features[index];
                                if (string.IsNullOrWhiteSpace(feature))
                                {
                                    continue;
                                }

                                <div class="bg-white rounded-xl shadow hover:shadow-lg transition-all duration-300">
                                    <div class="p-5 border-b">
                                        <h3 class="text-lg font-semibold flex items-center gap-2">
                                            <i data-lucide="check-circle" class="h-5 w-5 text-green-600"></i>
                                            <span>@feature</span>
                                        </h3>
                                    </div>
                                    <div class="p-5">
                                        <p class="text-gray-700">
                                            @((Model.feature_intro != null && index < Model.feature_intro.Count && !string.IsNullOrWhiteSpace(Model.feature_intro[index])) ? Model.feature_intro[index] : "尚未開放功能詳細資訊")
                                        </p>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </section>

                <!-- Technical -->
                <section class="tab-pane hidden space-y-6" data-pane="technical">
                    <div class="bg-white rounded-xl shadow">
                        <div class="p-5">
                            <h3 class="text-lg font-semibold">技術架構</h3>
                            <p class="text-sm text-gray-600">專案的技術實作細節和架構設計</p>
                        </div>
                        <div class="p-5">
                            @if (!string.IsNullOrWhiteSpace(Model.architecture_image_url))
                            {
                                <div class="aspect-video bg-gray-100 rounded-lg flex items-center justify-center mb-6 overflow-hidden">
                                    <img src="@Model.architecture_image_url" alt="architecture" class="w-full h-full object-contain" />

                                </div>
                            }

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <h4 class="font-semibold mb-3">核心技術</h4>
                                    <ul class="space-y-2">
                                        @foreach (var core in Model.tech_stack?.Take(3) ?? Enumerable.Empty<string>())
                                        {
                                            if (!string.IsNullOrWhiteSpace(core))
                                            {
                                                <li class="flex items-center space-x-2">
                                                    <i data-lucide="code" class="h-4 w-4 text-blue-500"></i>
                                                    <span>@core</span>
                                                </li>
                                            }
                                        }
                                    </ul>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-3">開發工具</h4>
                                    <ul class="space-y-2">
                                        @foreach (var tool in Model.tech_stack ?? new List<string>())
                                        {
                                            if (!string.IsNullOrWhiteSpace(tool))
                                            {
                                                <li class="flex items-center space-x-2">
                                                    <i data-lucide="server" class="h-4 w-4 text-green-600"></i>
                                                    <span>@tool</span>
                                                </li>
                                            }
                                        }

                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>


                <!-- Results -->
                <section class="tab-pane hidden space-y-6" data-pane="results">
                    <div class="bg-white rounded-xl shadow">
                        <div class="p-5 border-b">
                            <h3 class="text-lg font-semibold">專案成果</h3>
                            <p class="text-sm text-gray-600">量化的專案成效與改善指標</p>
                        </div>
                        <div class="p-5">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <ul class="space-y-3">
                                    @{
                                        var outcomes = (Model.outcome_kpis ?? new List<string>())
                                            .Where(x => !string.IsNullOrWhiteSpace(x))
                                            .ToList();
                                    }
                                    @if (!string.IsNullOrWhiteSpace(Model.outcome_tagline))
                                    {
                                        <li class="flex items-center space-x-3">
                                            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                                                <i data-lucide="sparkles" class="h-4 w-4 text-blue-600"></i>
                                            </div>
                                            <span class="font-medium text-gray-800">@Model.outcome_tagline</span>
                                        </li>
                                    }
                                    @foreach (var outcome in outcomes)
                                    {
                                        <li class="flex items-center space-x-3">
                                            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                                                <i data-lucide="check-circle" class="h-4 w-4 text-green-600"></i>
                                            </div>
                                            <span class="font-medium text-gray-800">@outcome</span>
                                        </li>
                                    }
                                </ul>
                                <div class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-lg p-6">
                                    <h4 class="font-semibold mb-4">客戶回饋</h4>
                                    <p class="text-gray-700 italic">
                                        @(!string.IsNullOrWhiteSpace(Model.feedback)
                                            ? Model.feedback
                                            : "此專案帶來顯著效益與改善。")
                                    </p>
                                    @if (Model.is_client_confidential || !string.IsNullOrWhiteSpace(Model.client_name))
                                    {
                                        <p class="text-gray-600 text-sm mt-2">- @(Model.is_client_confidential ? "客戶保密" : Model.client_name)</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <!-- CTA -->
            <div class="mt-12 text-center">
                <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-2xl shadow">
                    <div class="py-8 px-6">
                        <h3 class="text-2xl font-bold mb-4">對此專案有興趣？</h3>
                        <p class="mb-6">讓我們為您打造類似的解決方案</p>
                        <a href="javascript:void(0)"
                           class="inline-flex items-center gap-2 bg-white text-blue-600 hover:bg-gray-100 px-5 py-3 rounded-lg font-semibold">
                            立即諮詢
                            <i data-lucide="arrow-right" class="h-5 w-5"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 輕量 Tabs 切換
        document.addEventListener('DOMContentLoaded', () => {
          const root = document.querySelector('[data-tabs-root]');
          if (!root) return;

          const btns = root.querySelectorAll('.tab-btn');
          const panes = root.querySelectorAll('.tab-pane');

          const show = (tab) => {
            panes.forEach(p => p.classList.toggle('hidden', p.getAttribute('data-pane') !== tab));
            btns.forEach(b => {
              const active = b.getAttribute('data-tab') === tab;
              b.classList.toggle('bg-white', active);
              b.classList.toggle('shadow', active);
            });
          };

          show('overview');
          btns.forEach(b => b.addEventListener('click', () => show(b.getAttribute('data-tab'))));

          // 重新渲染 lucide（若已全域處理可移除）
        });
    </script>
}

