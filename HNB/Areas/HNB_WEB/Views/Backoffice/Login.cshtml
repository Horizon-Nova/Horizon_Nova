@{
    ViewData["Title"] = "後台管理系統 - 登入";
    Layout = "~/Areas/HNB_WEB/Views/Shared/_LayoutBMS.cshtml";
}
<div class="d-flex align-items-center" style="min-height:100vh;
     background:linear-gradient(135deg,#eef4ff,#e6f0ff);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5">
                <div class="card shadow-sm border-0" style="border-radius:1rem;">
                    <div class="card-body p-3 p-md-3">
                        <h1 class="h4 fw-bold text-center mb-2">後台管理系統</h1>
                        <p class="text-secondary text-center mb-4">請輸入您的帳號密碼登入系統</p>

                        <form method="post" action="@Url.Action("Dashboard", "Backoffice", new { area = "HNB_WEB" })" novalidate>
                            <div class="mb-3">
                                <label for="username" class="form-label">用戶名</label>
                                <input id="username" name="username" type="text" required
                                       class="form-control border-0" style="background:linear-gradient(135deg,#eef4ff,#e6f0ff);"
                                       placeholder="admin">
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">密碼</label>
                                <input id="password" name="password" type="password" required
                                       class="form-control border-0" style="background:linear-gradient(135deg,#eef4ff,#e6f0ff);"
                                       placeholder="•••••">
                            </div>

                            <button type="submit" class="btn w-100 py-2 text-white bg-black">
                                登入
                            </button>
                        </form>

                        <div class="text-center mt-3 small text-secondary">
                            測試帳號：<span class="text-muted">admin / admin</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
