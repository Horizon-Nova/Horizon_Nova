@{
    ViewData["Title"] = "系統設定 - 後台管理系統";
    Layout = "~/Areas/HNB_WEB/Views/Shared/_LayoutBMS.cshtml";

    var tabs = new[] {
        new { Id = "directory",    Title = "目錄管理",   ViewName = "_Directory" },
        new { Id = "system",       Title = "系統設定",   ViewName = "_Directory" },
        new { Id = "security",     Title = "安全設定",   ViewName = "_Directory" },
        new { Id = "notification", Title = "通知設定",   ViewName = "_Directory" },
        new { Id = "database",     Title = "資料庫",     ViewName = "_Directory" },
        new { Id = "schedule",     Title = "排程任務",   ViewName = "_Directory" },
        new { Id = "server",       Title = "伺服器資訊", ViewName = "_Directory" }
    };

    var activeIndex = 0;
}

<div class="container-fluid py-4">

    <div class="mb-4">
        <div class="d-flex align-items-center mb-1">
            <i data-lucide="settings" class="me-2" style="width:32px;height:32px;"></i>
            <h1 class="fw-bold fs-3 mb-0">系統設定</h1>
        </div>
        <p class="text-secondary mb-0">完整的系統配置和管理功能</p>
    </div>

    <!-- Tabs -->
    <div class="bms-tabsbar mb-3">
        <ul class="nav nav-pills nav-fill bms-tabs gap-2 p-1" id="settingsTabs" role="tablist">
            @for (int i = 0; i < tabs.Length; i++)
            {
                var t = tabs[i];
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(i == 1 ? "active" : "")"
                            id="tab-@t.Id"
                            data-bs-toggle="tab"
                            data-bs-target="#pane-@t.Id"
                            type="button"
                            role="tab">
                        @t.Title
                    </button>
                </li>
            }
        </ul>
    </div>

    <div class="tab-content" id="settingsTabsContent">
        @for (int i = 0; i < tabs.Length; i++)
        {
            var t = tabs[i];
            <div class="tab-pane fade @(i == activeIndex ? "show active" : "")"
                 id="pane-@t.Id" role="tabpanel" aria-labelledby="tab-@t.Id">
                @Html.Partial(t.ViewName)
            </div>
        }
    </div>



</div>
