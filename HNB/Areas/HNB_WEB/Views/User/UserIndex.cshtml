@{
    Layout = "~/Areas/HNB_WEB/Views/Shared/_LayoutTeamZone.cshtml";
}
<link rel="stylesheet" href="~/css/UserIndex.css" />
<script src="~/js/UserIndex.js"></script>

<div class="row gx-0" id="mainLayoutRow">
    <!-- 組織機構側欄 -->
    <div class="col-lg-2" id="sidebarPanel">
        <div class="border rounded-0">
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom bg-light">
                <h5 class="mb-0">組織機構</h5>
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-no-border" title="管理部門"><i class="fa fa-edit"></i></button>
                    <button class="btn btn-no-border d-none" id="btnExpand" title="展開全部"><i class="fa fa-chevron-up"></i></button>
                    <button class="btn btn-no-border" id="btnCollapseTree" title="摺疊全部"><i class="fa fa-chevron-down"></i></button>
                    <button class="btn btn-no-border" id="btnRefresh" title="刷新"><i class="fa fa-refresh"></i></button>
                </div>
            </div>
            <div class="px-3 py-2" id="sidebarContent">
                <div id="departmentTree" class="ztree">（此處為部門樹）</div>
            </div>
        </div>
    </div>

    <!-- 摺疊按鈕 -->
    <div class="col-auto d-flex align-items-center top-5 d-none d-lg-flex bg-light" style="height: 100vh; ">
        <button class="btn btn-no-border" id="btnToggleSidebar" title="摺疊側欄">
            <i class="fa fa-chevron-left"></i>
        </button>
    </div>
</div>
