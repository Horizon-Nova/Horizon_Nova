@{
    Layout = null;
}
<!-- 自訂樣式 -->
<link rel="stylesheet" href="~/DialVision/css/AppWeb.css" />
<script src="~/DialVision/js/AppWeb.js"></script>
<!-- Bootstrap & Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/components/flutter_bridge.js"></script>


<div class="container-fluid min-vh-100 d-flex flex-column px-2 pt-3 bg-secondary overflow-hidden">

    <!-- 輪播 Banner -->
    <div id="promoCarousel" class="carousel slide mt-3 mb-3  shadow-sm" data-bs-ride="carousel" style="height: 40vh;">
        <div class="carousel-inner h-100 rounded-3  ">
            <div class="carousel-item active h-100">
                <img src="~/DialVision/image/promo1.webp" class="d-block w-100 h-100 object-fit-cover" alt="promo1" />
            </div>
            <div class="carousel-item h-100">
                <img src="~/DialVision/image/promo2.webp" class="d-block w-100 h-100 object-fit-cover" alt="promo2" />
            </div>
            <div class="carousel-item h-100">
                <img src="~/DialVision/image/promo3.webp" class="d-block w-100 h-100 object-fit-cover" alt="promo3" />
            </div>
            <div class="carousel-item h-100">
                <img src="~/DialVision/image/promo4.webp" class="d-block w-100 h-100 object-fit-cover" alt="promo4" />
            </div>
        </div>

        <!-- 選配：上一張、下一張按鈕 -->
        <button class="carousel-control-prev" type="button" data-bs-target="#promoCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#promoCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <!-- 功能導覽卡片滑動區 -->
    <div class="flex-grow-1">
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">

            <div class="col">
                <a href="javascript:void(0);" class="function-card text-decoration-none" data-function="camera">
                    <div class="card text-center shadow-sm h-100">
                        <div class="card-body d-flex flex-column justify-content-center">
                            <i class="fa fa-camera fa-2x text-primary mb-2"></i>
                            <div class="card-title small">開始拍照</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="javascript:void(0);" class="function-card text-decoration-none" data-function="history">
                    <div class="card text-center shadow-sm h-100">
                        <div class="card-body d-flex flex-column justify-content-center">
                            <i class="fa fa-history fa-2x text-success mb-2"></i>
                            <div class="card-title small">歷史紀錄</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="javascript:void(0);" class="function-card text-decoration-none" data-function="eos">
                    <div class="card text-center shadow-sm h-100">
                        <div class="card-body d-flex flex-column justify-content-center">
                            <i class="fa fa-robot fa-2x text-info mb-2"></i>
                            <div class="card-title small">Eos 助理</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="javascript:void(0);" class="function-card text-decoration-none" data-function="settings">
                    <div class="card text-center shadow-sm h-100">
                        <div class="card-body d-flex flex-column justify-content-center">
                            <i class="fa fa-cog fa-2x text-secondary mb-2"></i>
                            <div class="card-title small">裝置設定</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="javascript:void(0);" class="function-card text-decoration-none" data-function="alert">
                    <div class="card text-center shadow-sm h-100">
                        <div class="card-body d-flex flex-column justify-content-center">
                            <i class="fa fa-bell fa-2x text-warning mb-2"></i>
                            <div class="card-title small">異常通報</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <div class="card text-center shadow-sm opacity-50 h-100">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <i class="fa fa-comment-dots fa-2x text-muted mb-2"></i>
                        <div class="card-title small">問題回饋<br />(開發中)</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

