<script>
    document.addEventListener('DOMContentLoaded', function () {
        //#region 變數初始化
        const carouselContainer = document.querySelector('#imageCarousel');
        // 僅選取指示器，不含控制鍵
        const indicators = carouselContainer.querySelectorAll('[data-bs-slide-to]');
        const carouselItems = document.querySelectorAll('.carousel-wrapper .carousel-item');
        let currentSlide = 0;
        const totalSlides = carouselItems.length;
        let autoPlayInterval;
        //#endregion

        //#region UI 更新
        function updateIndicators(activeIndex) {
            indicators.forEach((indicator, index) => {
                const isActive = index === activeIndex;
                indicator.classList.toggle('bg-blue-600', isActive);
                indicator.classList.toggle('bg-gray-300', !isActive);
                indicator.setAttribute('aria-current', isActive ? 'true' : 'false'); // 三元
            });
        }

        function updateCarouselItems(activeIndex) {
            const carouselWrapper = document.querySelector('.carousel-wrapper');
            const translateX = -activeIndex * 100;
            carouselWrapper.style.transform = `translateX(${translateX}%)`;
        }
        //#endregion

        //#region 導航控制
        function goToSlide(slideIndex) {
            slideIndex = slideIndex % totalSlides;
            slideIndex = slideIndex < 0 ? slideIndex + totalSlides : slideIndex; // 三元
            currentSlide = slideIndex;
            updateIndicators(currentSlide);
            updateCarouselItems(currentSlide);
        }

        const nextSlide = () => goToSlide(currentSlide + 1);
        const prevSlide = () => goToSlide(currentSlide - 1);
        //#endregion

        //#region 事件綁定
        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => goToSlide(index));
        });

        // 僅控制鍵綁定上一張/下一張（避免誤算入指示器）
        const prevBtn = carouselContainer.querySelector('.carousel-control-prev');
        const nextBtn = carouselContainer.querySelector('.carousel-control-next');
        prevBtn?.addEventListener('click', prevSlide);
        nextBtn?.addEventListener('click', nextSlide);

        function startAutoPlay() { autoPlayInterval = setInterval(nextSlide, 5000); }
        function stopAutoPlay() { autoPlayInterval ? clearInterval(autoPlayInterval) : null; } // 三元
        carouselContainer.addEventListener('mouseenter', stopAutoPlay);
        carouselContainer.addEventListener('mouseleave', startAutoPlay);
        //#endregion

        //#region 初始化
        updateIndicators(0);
        updateCarouselItems(0);
        startAutoPlay();
        //#endregion
    });
</script>

