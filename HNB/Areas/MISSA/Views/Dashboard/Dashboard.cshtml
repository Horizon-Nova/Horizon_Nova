<script>
    document.addEventListener('DOMContentLoaded', function () {
        //#region 變數初始化
        const carouselContainer = document.querySelector('#imageCarousel');
        // 僅選取指示器，不含控制鍵
        const indicators = carouselContainer.querySelectorAll('[data-bs-slide-to]');
        const carouselItems = document.querySelectorAll('.carousel-wrapper .carousel-item');
        let currentSlide = 0;
        const totalSlides = carouselItems.length;
        let autoPlayInterval;
        //#endregion

        //#region UI 更新
        function updateIndicators(activeIndex) {
            indicators.forEach((indicator, index) => {
                const isActive = index === activeIndex;
                indicator.classList.toggle('bg-blue-600', isActive);
                indicator.classList.toggle('bg-gray-300', !isActive);
                indicator.setAttribute('aria-current', isActive ? 'true' : 'false'); // 三元
            });
        }

        function updateCarouselItems(activeIndex) {
            const carouselWrapper = document.querySelector('.carousel-wrapper');
            const translateX = -activeIndex * 100;
            carouselWrapper.style.transform = `translateX(${translateX}%)`;
        }
        //#endregion

        //#region 導航控制
        function goToSlide(slideIndex) {
            slideIndex = slideIndex % totalSlides;
            slideIndex = slideIndex < 0 ? slideIndex + totalSlides : slideIndex; // 三元
            currentSlide = slideIndex;
            updateIndicators(currentSlide);
            updateCarouselItems(currentSlide);
        }

        const nextSlide = () => goToSlide(currentSlide + 1);
        const prevSlide = () => goToSlide(currentSlide - 1);
        //#endregion

        //#region 事件綁定
        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => goToSlide(index));
        });

        // 僅控制鍵綁定上一張/下一張（避免誤算入指示器）
        const prevBtn = carouselContainer.querySelector('.carousel-control-prev');
        const nextBtn = carouselContainer.querySelector('.carousel-control-next');
        prevBtn?.addEventListener('click', prevSlide);
        nextBtn?.addEventListener('click', nextSlide);

        function startAutoPlay() { autoPlayInterval = setInterval(nextSlide, 5000); }
        function stopAutoPlay() { autoPlayInterval ? clearInterval(autoPlayInterval) : null; } // 三元
        carouselContainer.addEventListener('mouseenter', stopAutoPlay);
        carouselContainer.addEventListener('mouseleave', startAutoPlay);
        //#endregion

        //#region 初始化
        updateIndicators(0);
        updateCarouselItems(0);
        startAutoPlay();
        //#endregion
    });

    // 活動輪播控制
    document.addEventListener('DOMContentLoaded', function () {
        //#region 變數初始化
        const activityContainer = document.querySelector('#activityCarousel');
        const activityIndicators = activityContainer.querySelectorAll('[data-activity-slide-to]');
        const activityItems = document.querySelectorAll('.activity-wrapper .activity-item');
        const activityPrevBtn = document.getElementById('activityPrevBtn');
        const activityNextBtn = document.getElementById('activityNextBtn');
        let currentActivity = 0;
        const totalActivities = activityItems.length;
        //#endregion

        //#region UI 更新
        function updateActivityIndicators(activeIndex) {
            activityIndicators.forEach((indicator, index) => {
                const isActive = index === activeIndex;
                indicator.classList.toggle('bg-blue-600', isActive);
                indicator.classList.toggle('bg-gray-300', !isActive);
                indicator.setAttribute('aria-current', isActive ? 'true' : 'false');
            });
        }

        function updateActivityItems(activeIndex) {
            const activityWrapper = document.querySelector('.activity-wrapper');
            const translateX = -activeIndex * 100;
            activityWrapper.style.transform = `translateX(${translateX}%)`;
        }
        //#endregion

        //#region 導航控制
        function goToActivity(activityIndex) {
            activityIndex = activityIndex % totalActivities;
            activityIndex = activityIndex < 0 ? activityIndex + totalActivities : activityIndex;
            currentActivity = activityIndex;
            updateActivityIndicators(currentActivity);
            updateActivityItems(currentActivity);
        }

        const nextActivity = () => goToActivity(currentActivity + 1);
        const prevActivity = () => goToActivity(currentActivity - 1);
        //#endregion

        //#region 事件綁定
        activityIndicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => goToActivity(index));
        });

        activityPrevBtn?.addEventListener('click', prevActivity);
        activityNextBtn?.addEventListener('click', nextActivity);
        //#endregion

        //#region 初始化
        updateActivityIndicators(0);
        updateActivityItems(0);
        //#endregion
    });

    // 歷年活動年份切換
    document.addEventListener('DOMContentLoaded', function () {
        const yearButtons = document.querySelectorAll('.year-btn');
        const yearContents = document.querySelectorAll('.year-content');

        yearButtons.forEach(button => {
            button.addEventListener('click', function() {
                const targetYear = this.getAttribute('data-year');
                
                // 更新按鈕狀態
                yearButtons.forEach(btn => {
                    btn.classList.remove('active', 'bg-blue-600', 'text-white');
                    btn.classList.add('bg-gray-100', 'text-gray-600');
                });
                this.classList.add('active', 'bg-blue-600', 'text-white');
                this.classList.remove('bg-gray-100', 'text-gray-600');
                
                // 顯示對應年份內容
                yearContents.forEach(content => {
                    if (content.getAttribute('data-year') === targetYear) {
                        content.classList.remove('hidden');
                    } else {
                        content.classList.add('hidden');
                    }
                });
            });
        });
    });
</script>

