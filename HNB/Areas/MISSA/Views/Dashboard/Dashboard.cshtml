@{
    ViewBag.Title = "資管系學會首頁";
    Layout = "~/Areas/MISSA/Views/Shared/_Layout.cshtml";
}


<div class="space-y-8">
    <!-- 標題 -->


    <!-- 圖片輪播 -->
    <div class="relative bg-white rounded-lg shadow-sm overflow-hidden border border-gray-200">
        <div id="imageCarousel" class="relative">
            <!-- Indicators -->
            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2 z-10">
                <button type="button" data-bs-target="#imageCarousel" data-bs-slide-to="0"
                    class="w-3 h-3 rounded-full bg-blue-600 transition-all duration-300 shadow-sm hover:scale-110" 
                    aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#imageCarousel" data-bs-slide-to="1"
                    class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-300 hover:bg-blue-500 hover:scale-110" 
                    aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#imageCarousel" data-bs-slide-to="2"
                    class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-300 hover:bg-blue-500 hover:scale-110" 
                    aria-label="Slide 3"></button>
                <button type="button" data-bs-target="#imageCarousel" data-bs-slide-to="3"
                    class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-300 hover:bg-blue-500 hover:scale-110" 
                    aria-label="Slide 4"></button>
            </div>

            <!-- Carousel Items -->
            <div class="carousel-inner relative overflow-hidden">
                <div class="carousel-wrapper flex transition-transform duration-500 ease-in-out">
                    <div class="carousel-item w-full flex-shrink-0">
                        <img src="~/missa/image/Carousel/carousel-1.jpg" class="w-full h-96 object-cover" alt="Carousel Image 1">
                    </div>
                    <div class="carousel-item w-full flex-shrink-0">
                        <img src="~/missa/image/Carousel/carousel-2.jpg" class="w-full h-96 object-cover" alt="Carousel Image 2">
                    </div>
                    <div class="carousel-item w-full flex-shrink-0">
                        <img src="~/missa/image/Carousel/carousel-3.jpg" class="w-full h-96 object-cover" alt="Carousel Image 3">
                    </div>
                    <div class="carousel-item w-full flex-shrink-0">
                        <img src="~/missa/image/Carousel/carousel-4.jpg" class="w-full h-96 object-cover" alt="Carousel Image 4">
                    </div>
                        </div>
            </div>

            <!-- Controls -->
            <button class="carousel-control-prev absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/20 hover:bg-black/40 text-white rounded-full w-10 h-10 flex items-center justify-center transition-all" 
                    type="button" data-bs-target="#imageCarousel" data-bs-slide="prev">
                <i data-lucide="chevron-left" class="h-5 w-5"></i>
            </button>

            <button class="carousel-control-next absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/20 hover:bg-black/40 text-white rounded-full w-10 h-10 flex items-center justify-center transition-all" 
                    type="button" data-bs-target="#imageCarousel" data-bs-slide="next">
                <i data-lucide="chevron-right" class="h-5 w-5"></i>
            </button>
        </div>
    </div>

    <!-- 分割線 -->
    <div class="border-t border-slate-200"></div>

    <!-- 活動詳情 -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
        <h2 class="text-2xl font-semibold text-gray-800 mb-6 flex items-center border-l-4 border-blue-600 pl-3">
            <i data-lucide="calendar-heart" class="h-6 w-6 mr-2 text-blue-600"></i>
            精彩活動回顧
        </h2>
        
        <!-- 活動輪播 -->
        <div class="relative">
            <!-- 活動容器 -->
            <div class="overflow-hidden rounded-lg">
                <div id="activityCarousel" class="relative">
                    <!-- 活動項目容器 -->
                    <div class="activity-wrapper flex transition-transform duration-500 ease-in-out">
                        <!-- 活動1: 同樂會 -->
                        <div class="activity-item w-full flex-shrink-0">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                <!-- 活動圖片 -->
                                <div class="relative">
                                    <img src="~/missa/image/Carousel/carousel-4.jpg" 
                                         class="w-full h-80 object-cover rounded-lg shadow-md" 
                                         alt="系學會同樂會活動">
                                    <div class="absolute top-4 left-4 bg-blue-600 text-white px-3 py-1 rounded-full text-sm font-medium">
                                        同樂會活動
                                    </div>
                                </div>
                                
                                <!-- 活動內容 -->
                                <div class="space-y-6">
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800 mb-3">資管系學會同樂會</h3>
                                        <p class="text-gray-600 leading-relaxed mb-4">
                                            一場充滿歡笑與溫馨的系學會同樂會，同學們齊聚一堂，透過輕鬆有趣的遊戲和活動，增進彼此的情誼，創造美好的大學回憶。
                                        </p>
                                    </div>
                                    
                                    <!-- 活動資訊 -->
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg">
                                            <i data-lucide="calendar" class="h-5 w-5 text-blue-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">活動日期</div>
                                                <div class="text-xs text-gray-600">2024年9月15日</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg">
                                            <i data-lucide="map-pin" class="h-5 w-5 text-green-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">活動地點</div>
                                                <div class="text-xs text-gray-600">資管系館大廳</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 p-3 bg-purple-50 rounded-lg">
                                            <i data-lucide="users" class="h-5 w-5 text-purple-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">參與人數</div>
                                                <div class="text-xs text-gray-600">約80位同學</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 p-3 bg-orange-50 rounded-lg">
                                            <i data-lucide="clock" class="h-5 w-5 text-orange-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">活動時長</div>
                                                <div class="text-xs text-gray-600">2小時</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- 活動亮點 -->
                                    <div>
                                        <h4 class="text-lg font-semibold text-gray-800 mb-3">活動亮點</h4>
                                        <div class="space-y-2">
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-blue-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">有趣的破冰遊戲，讓新生快速融入</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-green-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">精彩的才藝表演，展現同學多才多藝</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-purple-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">豐盛的點心與飲料，溫馨的聚會氛圍</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-orange-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">系學會幹部介紹，讓同學了解服務團隊</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- 行動按鈕 -->
                                    <div class="flex gap-3 pt-4">
                                        <button class="flex-1 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors flex items-center justify-center gap-2">
                                            <i data-lucide="image" class="h-4 w-4"></i>
                                            查看更多照片
                                        </button>
                                        <button class="flex-1 bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center gap-2">
                                            <i data-lucide="share-2" class="h-4 w-4"></i>
                                            分享活動
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- 活動2: 系周會 -->
                        <div class="activity-item w-full flex-shrink-0">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                <!-- 活動圖片 -->
                                <div class="relative">
                                    <img src="~/missa/image/Carousel/carousel-3.jpg" 
                                         class="w-full h-80 object-cover rounded-lg shadow-md" 
                                         alt="系周會活動">
                                    <div class="absolute top-4 left-4 bg-green-600 text-white px-3 py-1 rounded-full text-sm font-medium">
                                        系周會活動
                                    </div>
                                </div>
                                
                                <!-- 活動內容 -->
                                <div class="space-y-6">
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-800 mb-3">資管系周會</h3>
                                        <p class="text-gray-600 leading-relaxed mb-4">
                                            每週定期舉行的系周會，是同學們了解系上最新動態、參與討論重要議題的重要平台，也是凝聚系上向心力的重要活動。
                                        </p>
                                    </div>
                                    
                                    <!-- 活動資訊 -->
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg">
                                            <i data-lucide="calendar" class="h-5 w-5 text-blue-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">活動日期</div>
                                                <div class="text-xs text-gray-600">每週三下午</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg">
                                            <i data-lucide="map-pin" class="h-5 w-5 text-green-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">活動地點</div>
                                                <div class="text-xs text-gray-600">資管系會議室</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 p-3 bg-purple-50 rounded-lg">
                                            <i data-lucide="users" class="h-5 w-5 text-purple-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">參與人數</div>
                                                <div class="text-xs text-gray-600">全系師生</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 p-3 bg-orange-50 rounded-lg">
                                            <i data-lucide="clock" class="h-5 w-5 text-orange-600"></i>
                                            <div>
                                                <div class="text-sm font-medium text-gray-800">活動時長</div>
                                                <div class="text-xs text-gray-600">1小時</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- 活動亮點 -->
                                    <div>
                                        <h4 class="text-lg font-semibold text-gray-800 mb-3">活動亮點</h4>
                                        <div class="space-y-2">
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-blue-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">系上最新政策與重要公告</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-green-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">學生代表意見反映與討論</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-purple-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">學術活動與競賽資訊分享</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 bg-orange-600 rounded-full"></div>
                                                <span class="text-sm text-gray-600">師生互動交流與經驗分享</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- 行動按鈕 -->
                                    <div class="flex gap-3 pt-4">
                                        <button class="flex-1 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors flex items-center justify-center gap-2">
                                            <i data-lucide="file-text" class="h-4 w-4"></i>
                                            查看會議記錄
                                        </button>
                                        <button class="flex-1 bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center gap-2">
                                            <i data-lucide="share-2" class="h-4 w-4"></i>
                                            分享活動
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 控制按鈕 -->
            <button id="activityPrevBtn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/20 hover:bg-black/40 text-white rounded-full w-10 h-10 flex items-center justify-center transition-all z-10">
                <i data-lucide="chevron-left" class="h-5 w-5"></i>
            </button>
            
            <button id="activityNextBtn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/20 hover:bg-black/40 text-white rounded-full w-10 h-10 flex items-center justify-center transition-all z-10">
                <i data-lucide="chevron-right" class="h-5 w-5"></i>
            </button>
            
            <!-- 指示器 -->
            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2 z-10">
                <button type="button" data-activity-target="#activityCarousel" data-activity-slide-to="0"
                    class="w-3 h-3 rounded-full bg-blue-600 transition-all duration-300 shadow-sm hover:scale-110" 
                    aria-current="true" aria-label="Activity 1"></button>
                <button type="button" data-activity-target="#activityCarousel" data-activity-slide-to="1"
                    class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-300 hover:bg-blue-500 hover:scale-110" 
                    aria-label="Activity 2"></button>
            </div>
        </div>
    </div>

    <!-- 分割線 -->
    <div class="border-t border-slate-200"></div>

    <!-- 歷年活動 -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
        <h2 class="text-2xl font-semibold text-gray-800 mb-6 flex items-center border-l-4 border-blue-600 pl-3">
            <i data-lucide="history" class="h-6 w-6 mr-2 text-blue-600"></i>
            歷年活動回顧
        </h2>
        
        <!-- 年份選擇器 -->
        <div class="flex flex-wrap gap-2 mb-6">
            <button class="year-btn active px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium transition-all hover:bg-blue-700" data-year="2024">
                2024年
            </button>
            <button class="year-btn px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-medium transition-all hover:bg-gray-200" data-year="2023">
                2023年
            </button>
            <button class="year-btn px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-medium transition-all hover:bg-gray-200" data-year="2022">
                2022年
            </button>
            <button class="year-btn px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-medium transition-all hover:bg-gray-200" data-year="2021">
                2021年
            </button>
        </div>
        
        <!-- 活動時間軸 -->
        <div class="space-y-6">
            <!-- 2024年活動 -->
            <div class="year-content" data-year="2024">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- 活動卡片1 -->
                    <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-4 border border-blue-200 hover:shadow-md transition-all cursor-pointer">
                        <div class="relative mb-3">
                            <img src="~/missa/image/Carousel/carousel-1.jpg" 
                                 class="w-full h-40 object-cover rounded-lg" 
                                 alt="迎新活動">
                            <div class="absolute top-2 left-2 bg-blue-600 text-white px-2 py-1 rounded text-xs font-medium">
                                迎新活動
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h3 class="font-semibold text-gray-800">新生迎新活動</h3>
                            <p class="text-sm text-gray-600">歡迎新生加入資管系大家庭</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <i data-lucide="calendar" class="h-3 w-3"></i>
                                <span>2024.09.15</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 活動卡片2 -->
                    <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-lg p-4 border border-green-200 hover:shadow-md transition-all cursor-pointer">
                        <div class="relative mb-3">
                            <img src="~/missa/image/Carousel/carousel-2.jpg" 
                                 class="w-full h-40 object-cover rounded-lg" 
                                 alt="學術競賽">
                            <div class="absolute top-2 left-2 bg-green-600 text-white px-2 py-1 rounded text-xs font-medium">
                                學術競賽
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h3 class="font-semibold text-gray-800">程式設計競賽</h3>
                            <p class="text-sm text-gray-600">系上程式設計能力競賽</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <i data-lucide="calendar" class="h-3 w-3"></i>
                                <span>2024.10.20</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 活動卡片3 -->
                    <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg p-4 border border-purple-200 hover:shadow-md transition-all cursor-pointer">
                        <div class="relative mb-3">
                            <img src="~/missa/image/Carousel/carousel-3.jpg" 
                                 class="w-full h-40 object-cover rounded-lg" 
                                 alt="系周會">
                            <div class="absolute top-2 left-2 bg-purple-600 text-white px-2 py-1 rounded text-xs font-medium">
                                系周會
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h3 class="font-semibold text-gray-800">定期系周會</h3>
                            <p class="text-sm text-gray-600">每週系上重要事項討論</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <i data-lucide="calendar" class="h-3 w-3"></i>
                                <span>每週三</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 2023年活動 -->
            <div class="year-content hidden" data-year="2023">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- 活動卡片1 -->
                    <div class="bg-gradient-to-br from-orange-50 to-orange-100 rounded-lg p-4 border border-orange-200 hover:shadow-md transition-all cursor-pointer">
                        <div class="relative mb-3">
                            <img src="~/missa/image/Carousel/carousel-4.jpg" 
                                 class="w-full h-40 object-cover rounded-lg" 
                                 alt="同樂會">
                            <div class="absolute top-2 left-2 bg-orange-600 text-white px-2 py-1 rounded text-xs font-medium">
                                同樂會
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h3 class="font-semibold text-gray-800">系學會同樂會</h3>
                            <p class="text-sm text-gray-600">年度系學會同樂聚會活動</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <i data-lucide="calendar" class="h-3 w-3"></i>
                                <span>2023.12.15</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 活動卡片2 -->
                    <div class="bg-gradient-to-br from-teal-50 to-teal-100 rounded-lg p-4 border border-teal-200 hover:shadow-md transition-all cursor-pointer">
                        <div class="relative mb-3">
                            <img src="~/missa/image/Carousel/carousel-1.jpg" 
                                 class="w-full h-40 object-cover rounded-lg" 
                                 alt="畢業典禮">
                            <div class="absolute top-2 left-2 bg-teal-600 text-white px-2 py-1 rounded text-xs font-medium">
                                畢業典禮
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h3 class="font-semibold text-gray-800">畢業典禮</h3>
                            <p class="text-sm text-gray-600">歡送畢業生的重要時刻</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <i data-lucide="calendar" class="h-3 w-3"></i>
                                <span>2023.06.15</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 活動卡片3 -->
                    <div class="bg-gradient-to-br from-red-50 to-red-100 rounded-lg p-4 border border-red-200 hover:shadow-md transition-all cursor-pointer">
                        <div class="relative mb-3">
                            <img src="~/missa/image/Carousel/carousel-2.jpg" 
                                 class="w-full h-40 object-cover rounded-lg" 
                                 alt="運動會">
                            <div class="absolute top-2 left-2 bg-red-600 text-white px-2 py-1 rounded text-xs font-medium">
                                運動會
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h3 class="font-semibold text-gray-800">系運會</h3>
                            <p class="text-sm text-gray-600">系上運動競賽活動</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <i data-lucide="calendar" class="h-3 w-3"></i>
                                <span>2023.04.20</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 2022年活動 -->
            <div class="year-content hidden" data-year="2022">
                <div class="text-center py-12 text-gray-500">
                    <i data-lucide="archive" class="h-16 w-16 mx-auto mb-4 text-gray-300"></i>
                    <p class="text-lg font-medium">2022年活動記錄</p>
                    <p class="text-sm">活動資料整理中，敬請期待</p>
                </div>
            </div>
            
            <!-- 2021年活動 -->
            <div class="year-content hidden" data-year="2021">
