@{
    Layout = null;
    var selectedTime = ViewBag.SelectedTime as string ?? "00:00";
}

@for (int h = 0; h < 24; h++)
{
    for (int m = 0; m < 60; m += 30)
    {
        var timeStr = $"{h:00}:{m:00}";
        var selected = selectedTime == timeStr ? "selected" : "";
        <div class="wheel-item @selected" data-time="@timeStr" onclick="selectTime('@timeStr')">@timeStr</div>
    }
}

