@{
	Layout = null;
}

<link rel="stylesheet" href="~/NovaAPP/DialVision/css/camera-screen.css" />

<div class="camera-header">
	<h1 class="camera-title">拍攝錶盤</h1>
	<p class="camera-subtitle">對準錶盤並拍攝，之後可進行設定。</p>
</div>

<div class="camera-stage">
	<video id="cameraVideo" playsinline autoplay muted></video>
	<canvas id="cameraCanvas"></canvas>
	<div class="camera-frame"></div>
</div>

<div class="camera-actions">
 	<button type="button" class="btn-action" onclick="capturePhoto()" aria-label="拍照">
 		<i data-lucide="camera" style="width:18px;height:18px;"></i>
 	</button>
 	<button type="button" class="btn-action" onclick="retakePhoto()" aria-label="重拍">
 		<i data-lucide="rotate-ccw" style="width:18px;height:18px;"></i>
 	</button>
</div>
<div class="dashboard-bottom-nav">
	<button type="button" class="dashboard-nav-btn active" onclick="switchScreen && switchScreen('dashboard')">
		<i data-lucide="layout-dashboard" style="width: 18px; height: 18px;"></i>
	</button>
	<button type="button" class="dashboard-nav-btn" id="btnClose" onclick="switchScreen && switchScreen('register')">
		<i data-lucide="x" style="width: 18px; height: 18px;" class="close-icon"></i>
	</button>
	<button type="button" class="dashboard-nav-btn" onclick="switchScreen && switchScreen('settings')">
		<i data-lucide="settings" style="width: 18px; height: 18px;"></i>
	</button>
</div>
<script src="~/NovaAPP/DialVision/js/camera-screen.js"></script>


