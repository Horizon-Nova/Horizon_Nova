@{
    Layout = null;
}

<link rel="stylesheet" href="~/NovaAPP/DialVision/css/dashboard-screen.css" />

<div class="dashboard-header">
    <h1 class="dashboard-greeting">早安，策略指揮官</h1>
    <p class="dashboard-subtitle">能源網格保持穩定，以下為今日任務與即時指標摘要。</p>
</div>

<div class="dashboard-list">
    <div class="dashboard-list-item" data-meter-id="1" onclick="switchScreen && switchScreen('camera')">
        <div class="dashboard-list-content">
            <h3 class="dashboard-list-title">中國科技大學-光605實驗室-牆壁電表</h3>
            <p class="dashboard-list-meta">每月 | 2025-11-13 | 1天(30h)</p>
        </div>
        <div class="dashboard-list-arrow">>></div>
    </div>
    
    <div class="dashboard-list-item" data-meter-id="2" onclick="switchScreen && switchScreen('camera')">
        <div class="dashboard-list-content">
            <h3 class="dashboard-list-title">中國科技大學-光605實驗室-牆壁電表</h3>
            <p class="dashboard-list-meta">每月 | 2025-11-13 | 1天(30h)</p>
        </div>
        <div class="dashboard-list-arrow">>></div>
    </div>
    
    <div class="dashboard-list-item" data-meter-id="3" onclick="switchScreen && switchScreen('camera')">
        <div class="dashboard-list-content">
            <h3 class="dashboard-list-title">中國科技大學-光605實驗室-牆壁電表</h3>
            <p class="dashboard-list-meta">每月 | 2025-11-13 | 1天(30h)</p>
        </div>
        <div class="dashboard-list-arrow">>></div>
    </div>
</div>

<div class="dashboard-bottom-nav">
    <button type="button" class="dashboard-nav-btn active" onclick="switchScreen && switchScreen('dashboard')">
        <i data-lucide="layout-dashboard" style="width: 18px; height: 18px;"></i>
    </button>
    <button type="button" class="dashboard-nav-btn" id="btnClose" onclick="switchScreen && switchScreen('register')">
        <i data-lucide="x" style="width: 18px; height: 18px;" class="close-icon"></i>
    </button>
    <button type="button" class="dashboard-nav-btn" onclick="switchScreen && switchScreen('settings')">
        <i data-lucide="settings" style="width: 18px; height: 18px;"></i>
    </button>
</div>

<script src="~/NovaAPP/DialVision/js/dashboard-screen.js"></script>
