@{
	Layout = null;
}

<link rel="stylesheet" href="~/NovaAPP/DialVision/css/settings-screen.css" />

<div class="settings-header">
	<h1 class="settings-title">使用者資訊</h1>
	<p class="settings-subtitle">帳戶概要與訂閱狀態</p>
</div>

<div class="settings-section">
	<div class="settings-item">
		<div class="settings-item-icon">
			<i data-lucide="clipboard-list" style="width:18px;height:18px;"></i>
		</div>
		<div class="settings-item-content">
			<div class="settings-item-label">已註冊錶盤</div>
			<div class="settings-item-value" id="settingsRegisteredCount">3</div>
		</div>
	</div>
</div>

<div class="settings-section">
	<div class="settings-item">
		<div class="settings-item-icon">
			<i data-lucide="user" style="width:18px;height:18px;"></i>
		</div>
		<div class="settings-item-content">
			<div class="settings-item-label">使用者名稱</div>
			<div class="settings-item-value" id="settingsUserName">NovaCommander</div>
		</div>
	</div>
</div>

<div class="settings-section">
	<div class="settings-item">
		<div class="settings-item-icon">
			<i data-lucide="layers" style="width:18px;height:18px;"></i>
		</div>
		<div class="settings-item-content">
			<div class="settings-item-label">等級</div>
			<div class="settings-item-value" id="settingsUserLevel">Pro</div>
		</div>
	</div>
</div>

<div class="settings-section">
	<div class="settings-item">
		<div class="settings-item-icon">
			<i data-lucide="badge-check" style="width:18px;height:18px;"></i>
		</div>
		<div class="settings-item-content">
			<div class="settings-item-label">訂閱狀態</div>
			<div class="settings-item-value" id="settingsSubscription">啟用</div>
		</div>
	</div>
</div>

<div class="dashboard-bottom-nav">
	<button type="button" class="dashboard-nav-btn active" onclick="switchScreen && switchScreen('dashboard')">
		<i data-lucide="layout-dashboard" style="width: 18px; height: 18px;"></i>
	</button>
	<button type="button" class="dashboard-nav-btn" id="btnClose" onclick="switchScreen && switchScreen('register')">
		<i data-lucide="x" style="width: 18px; height: 18px;" class="close-icon"></i>
	</button>
	<button type="button" class="dashboard-nav-btn" onclick="switchScreen && switchScreen('settings')">
		<i data-lucide="settings" style="width: 18px; height: 18px;"></i>
	</button>
</div>

<script src="~/NovaAPP/DialVision/js/settings-screen.js"></script>


