@{
    Layout = null;
}

<link rel="stylesheet" href="~/NovaAPP/DialVision/css/login-screen.css" />

<div class="login-brand">
    <div class="login-logo">
        <div class="logo-box">NM</div>
        <h2 class="brand-title">NovaMatrixX</h2>
    </div>
    <h1 class="login-heading">登入智慧矩陣</h1>
    <p class="login-subtitle">請輸入帳號與密碼繼續。</p>
</div>

<form class="login-form">
    <div class="form-group">
        <label class="form-label">帳號 / Email</label>
        <div style="position: relative;">
            <i data-lucide="user" class="input-icon"></i>
            <input type="text" class="form-input" placeholder="your.name@example.com" />
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">密碼</label>
        <div style="position: relative;">
            <i data-lucide="lock" class="input-icon"></i>
            <input type="password" class="form-input" placeholder="請輸入密碼" />
            <button type="button" class="password-toggle">
                <i data-lucide="eye-off" style="width: 14px; height: 14px;"></i>
            </button>
        </div>
    </div>

    <div class="remember-row">
        <div class="remember-checkbox">
            <input type="checkbox" id="remember" checked />
            <label for="remember">記住我</label>
        </div>
        <button type="button" class="forgot-link">忘記密碼？</button>
    </div>

    <button type="button" class="btn-login" id="btnLogin">
        <span>登入 NovaMatrixX</span>
        <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
    </button>

    <button type="button" class="btn-help">需要協助？聯絡系統管理員</button>
</form>

<script src="~/NovaAPP/DialVision/js/login-screen.js"></script>
