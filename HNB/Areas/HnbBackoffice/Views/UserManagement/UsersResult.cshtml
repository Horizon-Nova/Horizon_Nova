@model IEnumerable<Models.HnbHnbBackoffice.person_relation_v>
<table id="tablediv" class="min-w-full text-sm [&_th]:whitespace-nowrap [&_td]:whitespace-nowrap">
    <thead class="bg-slate-50 sticky top-0">
        <tr class="text-left text-slate-600">
            <th class="px-4 py-3 font-medium">本人 ID</th>
            <th class="px-4 py-3 font-medium">本人姓名</th>
            <th class="px-4 py-3 font-medium">本人部門</th>
            <th class="px-4 py-3 font-medium">關聯人 ID</th>
            <th class="px-4 py-3 font-medium">關聯人姓名</th>
            <th class="px-4 py-3 font-medium">關聯人部門</th>
            <th class="px-4 py-3 font-medium">距離</th>
            <th class="px-4 py-3 font-medium">關係</th>
            <th class="px-4 py-3 font-medium">操作</th>
        </tr>
    </thead>
    <tbody id="users-tbody" class="divide-y">
        @foreach (var item in Model)
        {
            <tr>
                <td class="px-4 py-2">@(item.person_id.HasValue? item.person_id : null)</td>
                <td class="px-4 py-2">@(item.person_name != null ? item.person_name : "-")</td>
                <td class="px-4 py-2">@(item.person_dept_id != null ? item.person_dept_id : "-")</td>
                <td class="px-4 py-2">@(item.related_person_id.HasValue? item.related_person_id : null)</td>
                <td class="px-4 py-2">@(item.related_person_name != null ? item.related_person_name : "-")</td>
                <td class="px-4 py-2">@(item.related_dept_id != null ? item.related_dept_id : "-")</td>
                <td class="px-4 py-2">@(item.distance.HasValue? item.distance : null)</td>
                <td class="px-4 py-2">@(item.relation != null ? item.relation : "-")</td>
                <td class="px-4 py-2">
                    <div class="grid grid-cols-2 gap-2">
                        <button type="button"
                                class="btn btn-link p-0 text-primary"
                                data-bs-toggle="modal"
                                data-bs-target="#EditModal"
                                data-person-id="@item.person_id">
                            <i data-lucide="edit-3" class="h-4 w-4"></i>
                        </button>

                        <!-- 刪除按鈕 -->
                        <button type="button"
                                class="btn btn-link p-0 text-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#DeleteModal"
                                data-person-id="@item.person_id"
                                data-person-name="@item.person_name">
                            <i data-lucide="trash-2" class="h-4 w-4"></i>
                        </button>
                    </div>
                </td>
            </tr>

        }
    </tbody>
</table>

<!-- 編輯彈窗（Bootstrap） -->
<div class="modal fade" id="EditModal" tabindex="-1" aria-labelledby="EditModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="EditModalLabel">編輯用戶</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div>目前僅示範彈窗，PersonId：<span id="edit-person-id" class="font-monospace"></span></div>
                <div class="mt-3">
                    <label class="form-label">備註</label>
                    <input id="edit-note" class="form-control" placeholder="先模擬，不送資料">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-dark" id="btnEditSave">儲存</button>
            </div>
        </div>
    </div>
</div>

<!-- 刪除彈窗（Bootstrap） -->
<div class="modal fade" id="DeleteModal" tabindex="-1" aria-labelledby="DeleteModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="DeleteModalLabel">刪除確認</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="text-secondary">
                    若要刪除，請在下方輸入框輸入：<b>確認</b><br>
                    目標：<span id="delete-target" class="font-monospace"></span>
                </p>
                <input id="deleteConfirmInput" class="form-control" placeholder="輸入 確認 才能刪除">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger" id="btnDeleteConfirm">確認刪除</button>
            </div>
        </div>
    </div>
</div>
