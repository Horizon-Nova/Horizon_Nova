<div class="row g-4">

    <!-- 左側：基本資料 -->
    <div class="col-md-9">
        <div class="card h-100">
            <div class="card-header py-2">
                <div class="fw-semibold">基本資料</div>
                <small class="text-muted">新版 user_profiles 欄位（精簡常用 + 友善對齊）</small>
            </div>

            <div class="card-body">

                <!-- 區塊：身分 -->
                <div class="form-section-title">身分</div>
                <div class="form-section-sub">人員主鍵與部門對應</div>
                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">人員ID<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <input type="text" name="id" class="form-control" placeholder="例如：10A0010110001" required>
                    </div>

                    <label class="col-lg-2 col-form-label">別名 (alias)<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <input type="text" name="alias" class="form-control" placeholder="例如：cv-emp01" required>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">部門ID</label>
                    <div class="col-lg-4">
                        <input type="text" name="deptid" id="deptid" class="form-control" placeholder="例如：10A0010110">
                        <small class="form-text text-muted">輸入後會自動推得區域/中心</small>
                    </div>

                    <label class="col-lg-2 col-form-label">區域/中心</label>
                    <div class="col-lg-2">
                        <input type="text" name="area_cde" id="area_cde" class="form-control" placeholder="A0 / B0">
                    </div>
                    <div class="col-lg-2">
                        <input type="text" name="center" id="center" class="form-control" placeholder="Center-A0">
                    </div>
                </div>

                <div class="form-section-divider"></div>

                <!-- 區塊：姓名與聯絡 -->
                <div class="form-section-title">姓名與聯絡</div>
                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">中文姓名</label>
                    <div class="col-lg-4">
                        <input type="text" name="name2" class="form-control" placeholder="例如：雲服務課 員工01">
                    </div>

                    <label class="col-lg-2 col-form-label">英文姓名</label>
                    <div class="col-lg-4">
                        <input type="text" name="name" class="form-control" placeholder="例如：CloudK.E01">
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">Email</label>
                    <div class="col-lg-4">
                        <input type="email" name="email" class="form-control" placeholder="name@HorizonNova.com">
                        <small class="form-text text-muted">account 會由 email 自動產生</small>
                    </div>

                    <label class="col-lg-2 col-form-label">公司電話</label>
                    <div class="col-lg-2">
                        <input type="text" name="comp_phone" class="form-control" placeholder="(02)55625788">
                    </div>
                    <div class="col-lg-2">
                        <input type="text" name="extension" class="form-control" placeholder="分機 3526">
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">手機</label>
                    <div class="col-lg-4">
                        <input type="text" name="mobile" class="form-control" placeholder="例如：0912xxxxxx">
                    </div>

                    <label class="col-lg-2 col-form-label">聯絡電話</label>
                    <div class="col-lg-4">
                        <input type="text" name="phone" class="form-control">
                    </div>
                </div>

                <div class="form-section-divider"></div>

                <!-- 區塊：人資屬性 -->
                <div class="form-section-title">人資屬性</div>
                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">PID<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <input type="text" name="pid" class="form-control" placeholder="A123456789" required>
                    </div>

                    <label class="col-lg-2 col-form-label">性別<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <select name="sex" class="form-control" required>
                            <option value="">（未設定）</option>
                            <option value="M">男</option>
                            <option value="F">女</option>
                        </select>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">生日<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <input type="date" name="birthday" class="form-control" required>
                    </div>

                    <label class="col-lg-2 col-form-label">血型</label>
                    <div class="col-lg-4">
                        <select name="blood_type" class="form-control">
                            <option value="">（未設定）</option>
                            <option>A</option>
                            <option>B</option>
                            <option>O</option>
                            <option>AB</option>
                            <option>其他</option>
                        </select>
                    </div>
                </div>

                <div class="form-section-divider"></div>

                <!-- 區塊：職務與任用 -->
                <div class="form-section-title">職務與任用</div>
                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">職稱代碼<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <select name="titleid" id="titleid" class="form-control" required>
                            <option value="">（未設定）</option>
                            <option value="DIR">DIR（中心總監）</option>
                            <option value="CHIEF">CHIEF（處長）</option>
                            <option value="MGR">MGR（部長）</option>
                            <option value="LEAD">LEAD（課長）</option>
                            <option value="ENG">ENG（工程師）</option>
                        </select>
                    </div>

                    <label class="col-lg-2 col-form-label">職稱名稱</label>
                    <div class="col-lg-4">
                        <input type="text" name="titlename" id="titlename" class="form-control" placeholder="例如：工程師">
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">等級<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <input type="number" name="level" class="form-control" value="0" min="0" required>
                    </div>

                    <label class="col-lg-2 col-form-label">職務代碼<span class="text-danger">*</span></label>
                    <div class="col-lg-4">
                        <input type="number" name="positioncode" class="form-control" value="0" min="0" required>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">任職狀態碼</label>
                    <div class="col-lg-4">
                        <select name="status" class="form-control">
                            <option value="0" selected>0（在職/預設）</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                        </select>
                    </div>

                    <label class="col-lg-2 col-form-label">工作狀態</label>
                    <div class="col-lg-4">
                        <input type="text" name="job_status" class="form-control" value="1" placeholder="例如：1">
                        <small class="form-text text-muted">與你現行系統相容</small>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">到職日</label>
                    <div class="col-lg-4">
                        <input type="date" name="regest_date" class="form-control">
                    </div>

                    <label class="col-lg-2 col-form-label">成本中心</label>
                    <div class="col-lg-4">
                        <input type="text" name="costcenter" class="form-control" placeholder="例如：12A0000500">
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">旗標</label>
                    <div class="col-lg-10">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="away" id="chkAway" value="true">
                            <label class="form-check-label" for="chkAway">外出</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="pluralism" id="chkPluralism" value="true">
                            <label class="form-check-label" for="chkPluralism">兼職</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="manager" id="chkManager" value="true">
                            <label class="form-check-label" for="chkManager">主管</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="isdeptmanager" id="chkIsDeptManager" value="true">
                            <label class="form-check-label" for="chkIsDeptManager">部門主管</label>
                        </div>
                    </div>
                </div>

                <div class="form-section-divider"></div>

                <!-- 區塊：建立資訊 -->
                <div class="form-section-title">建立資訊</div>
                <div class="form-group row">
                    <label class="col-lg-2 col-form-label">建立者</label>
                    <div class="col-lg-4">
                        <input type="text" name="cr_user" class="form-control" value="eipadmin">
                    </div>

                    <label class="col-lg-2 col-form-label">建立時間</label>
                    <div class="col-lg-4">
                        <input type="datetime-local" name="cr_date" class="form-control">
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- 右側：頭像 -->
    <div class="col-md-3">
        <div class="card">
            <div class="card-header py-2">
                <div class="fw-semibold">頭像</div>
                <small class="text-muted">支援 JPG / PNG / WEBP</small>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <div class="position-relative rounded-circle border bg-light d-flex align-items-center justify-content-center mb-3"
                     style="width:96px;height:96px; overflow:hidden;">
                    <img id="avatarPreview" class="d-none w-100" style="object-fit:cover;" alt="avatar preview">
                    <div id="avatarPlaceholder" class="text-secondary">👤</div>
                </div>
                <div class="d-flex gap-2">
                    <label class="btn btn-outline-secondary btn-sm mb-0">
                        上傳
                        <input id="avatar" name="avatar" type="file" accept="image/*" class="d-none" onchange="previewAvatar(this)">
                    </label>
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearAvatar()">清除</button>
                </div>
            </div>
        </div>
    </div>

</div>
<style>
    /* 微調表單對齊與間距 */
    .form-section-title {
        font-weight: 600;
        font-size: .95rem;
        color: #555;
        margin-bottom: .25rem;
    }

    .form-section-sub {
        font-size: .8rem;
        color: #888;
        margin-bottom: .75rem;
    }

    .form-section-divider {
        border-top: 1px dashed #e3e3e3;
        margin: .75rem 0 1rem 0;
    }

</style>
<script>
        function previewAvatar(input){
      var f = input.files && input.files[0];
      var $pv = $('#avatarPreview');
      var $ph = $('#avatarPlaceholder');
      if(!f){
        $pv.addClass('d-none').attr('src','');
        $ph.removeClass('d-none');
        return;
      }
      if(!/^image\/(jpeg|png|webp|jpg)$/i.test(f.type)){ alert('檔案需為 JPG/PNG/WEBP'); input.value=''; return; }
      var rd = new FileReader();
      rd.onload = function(e){
        $pv.attr('src', e.target.result).removeClass('d-none');
        $ph.addClass('d-none');
      };
      rd.readAsDataURL(f);
    }

    function clearAvatar(){
      var $in = $('#avatar');
      $in.val('');
      $('#avatarPreview').addClass('d-none').attr('src','');
      $('#avatarPlaceholder').removeClass('d-none');
    }
</script>