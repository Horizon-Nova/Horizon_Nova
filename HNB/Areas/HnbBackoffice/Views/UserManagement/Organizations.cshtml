<div class="bg-white border rounded-xl space-y-2">
    <!-- Header -->
    <header class="px-6 mt-3">
        <h2 class="text-xl font-semibold flex items-center gap-2">
            <i data-lucide="building" class="h-5 w-5"></i>
            組織架構
        </h2>
        <p class="text-slate-500">管理組織清單與上下層關係</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 border-t">
        <!-- 左側查詢面板 -->
        <aside class="md:col-span-3 border-r p-4 space-y-4">
            <div class="space-y-2">
                <label class="block text-sm font-medium">關鍵字</label>
                <div class="relative">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400"></i>
                    <input id="orgs-q" class="w-full rounded-md border px-9 py-2" placeholder="組織名稱、描述">
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">層級</label>
                <select id="orgs-level" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="top">頂級組織</option>
                    <option value="child">次級組織</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">上級組織</label>
                <select id="orgs-parent" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="1">技術部</option>
                    <option value="2">行銷部</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">建立日期</label>
                <div class="grid grid-cols-2 gap-2">
                    <input id="orgs-date-from" type="date" class="w-full rounded-md border px-3 py-2">
                    <input id="orgs-date-to" type="date" class="w-full rounded-md border px-3 py-2">
                </div>
            </div>

            <div class="flex gap-2 pt-2">
                <button id="orgs-apply" class="flex-1 px-3 py-2 rounded-md bg-slate-900 text-white">
                    <i data-lucide="filter" class="h-4 w-4 inline-block mr-1"></i> 套用
                </button>
                <button id="orgs-reset" class="px-3 py-2 rounded-md border">重設</button>
            </div>
        </aside>

        <!-- 右側結果表格 -->
        <section class="md:col-span-9 p-4">
            <header class="flex items-center justify-between mb-3">
                <div id="orgs-active-chips" class="text-sm text-slate-500"></div>
                <div class="text-sm text-slate-500">共 N 個組織 · 顯示 1–10</div>
            </header>

            <div class="overflow-x-auto rounded-xl border">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 sticky top-0 z-[1]">
                        <tr class="text-left text-slate-600">
                            <th class="px-4 py-3 font-medium">組織名稱</th>
                            <th class="px-4 py-3 font-medium">描述</th>
                            <th class="px-4 py-3 font-medium">上級組織</th>
                            <th class="px-4 py-3 font-medium">建立時間</th>
                            <th class="px-4 py-3 font-medium">操作</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <tr>
                            <td class="px-4 py-3 font-medium">技術部</td>
                            <td class="px-4 py-3">負責系統開發與維護</td>
                            <td class="px-4 py-3">頂級組織</td>
                            <td class="px-4 py-3">2024/01/01</td>
                            <td class="px-4 py-3">
                                <button class="inline-flex items-center gap-1 rounded-md border px-2 py-1 hover:bg-slate-50">
                                    <i data-lucide="edit" class="w-4 h-4"></i> 編輯
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
