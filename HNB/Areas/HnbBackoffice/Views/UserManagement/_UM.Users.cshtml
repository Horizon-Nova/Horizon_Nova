<div class="bg-white border rounded-xl space-y-2">

    <header class="flex items-center justify-between px-6 mt-3">
        <div>
            <h2 class="text-xl font-semibold flex items-center gap-2">
                <i data-lucide="square-user" class="h-5 w-5"></i>
                用戶管理
            </h2>
            <p class="text-slate-500">管理帳號與權限（白名單 / 組織）</p>
        </div>

        <button type="button"
                onclick="openModal()"
                class="inline-flex items-center gap-2 px-3 py-2 rounded-md bg-slate-900 text-white hover:bg-slate-800">
            <i data-lucide="plus" class="h-4 w-4"></i>
            新增
        </button>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 border-t">
        <aside class="md:col-span-3 border-r p-4 space-y-4">
            <div class="space-y-2">
                <label class="block text-sm font-medium">關鍵字</label>
                <div class="relative">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400"></i>
                    <input id="q" class="w-full rounded-md border px-9 py-2" placeholder="用戶名、Email">
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">權限類型</label>
                <select id="perm" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="whitelist">白名單</option>
                    <option value="organization">組織</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">狀態</label>
                <select id="status" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="active">啟用</option>
                    <option value="inactive">停用</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">所屬組織</label>
                <select id="org" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="tech">技術部</option>
                    <option value="mkt">行銷部</option>
                </select>
            </div>

            <div class="flex gap-2 pt-2">
                <button id="btn-apply" class="flex-1 px-3 py-2 rounded-md bg-slate-900 text-white">
                    <i data-lucide="filter" class="h-4 w-4 inline-block mr-1"></i> 套用
                </button>
                <button id="btn-reset" class="px-3 py-2 rounded-md border">重設</button>
            </div>
        </aside>

        <!-- 右側結果表格 -->
        <section class="md:col-span-9 p-4">
            <header class="flex items-center justify-between mb-3">
                <div class="text-sm text-slate-500" id="active-chips">
                </div>
                <div class="text-sm text-slate-500">共 N 位用戶 · 顯示 1–10</div>
            </header>

            <div class="overflow-x-auto rounded-xl border">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 sticky top-0 ">
                        <tr class="text-left text-slate-600">
                            <th class="px-4 py-3 font-medium">用戶名</th>
                            <th class="px-4 py-3 font-medium">電子郵件</th>
                            <th class="px-4 py-3 font-medium">權限類型</th>
                            <th class="px-4 py-3 font-medium">角色 / 組織</th>
                            <th class="px-4 py-3 font-medium">狀態</th>
                            <th class="px-4 py-3 font-medium">最後登入</th>
                            <th class="px-4 py-3 font-medium">操作</th>
                        </tr>
                    </thead>
                    <tbody id="users-tbody" class="divide-y">
                        <tr><td class="px-4 py-6 text-slate-400" colspan="7">請使用左側條件篩選或直接套用</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

<script>
    function openModal() {
      $.ajax({
        type: 'GET',
        url: '@Url.Action("UserManagementTab", "UserManagement", new { area = "HnbBackoffice", t = "usersdialog" })',
        data: { _: Date.now() },
        cache: false,
        timeout: 30000,
        beforeSend: function (xhr, settings) {
          $('#CreateUserDialog').html(
            '<div class="p-3">'+
            '  <div class="placeholder-wave mb-2"><span class="placeholder col-3"></span></div>'+
            '  <div class="placeholder-wave mb-2"><span class="placeholder col-12"></span></div>'+
            '  <div class="placeholder-wave mb-2"><span class="placeholder col-8"></span></div>'+
            '</div>'
          );
          // 先把錯誤清掉
          $('#formErr').addClass('d-none').text('');
        },
        success: function (response, status, xhr) {
          $('#CreateUserDialog').html(response);
          if (window.lucide && window.lucide.createIcons) { lucide.createIcons(); }

          var el = document.getElementById('createUserModal');
          var modal = bootstrap.Modal.getOrCreateInstance(el, { backdrop: 'static', keyboard: true });
          modal.show();
        },
        error: function (xhr, status, err) {
          alert('載入失敗，請稍後再試（' + (xhr.status || '未知') + '）');
        },
        complete: function (xhr, status) { }
      });
    }

    // 關閉 Modal
    function closeModal() {
      var el = document.getElementById('createUserModal');
      var modal = bootstrap.Modal.getInstance(el);
      if (modal) modal.hide();
    }

    // 關閉後清理內容（可避免殘留舊資料）
    (function bindModalCleanup(){
      var el = document.getElementById('createUserModal');
      el.addEventListener('hidden.bs.modal', function () {
        $('#CreateUserDialog').empty();
        $('#formErr').addClass('d-none').text('');
      });
    })();

    function submitCreateUser(){
      var $form = $('#formCreateUser');
      var fd = new FormData($form[0]);

      var $saveBtn = $form.find('button[type="button"][onclick="submitCreateUser()"]');

      $.ajax({
        type: 'POST',
        url: $form.attr('action'),
        data: fd,
        processData: false,
        contentType: false,
        cache: false,
        timeout: 60000,
        headers: { 'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val() || '' },
        beforeSend: function(xhr, settings){
          $saveBtn.prop('disabled', true).addClass('opacity-60 cursor-not-allowed');
          $('#formErr').addClass('hidden').text('');
        },
        success: function(res, status, xhr){
          if(res && res.ok){
            closeModal();
            alert('儲存成功');
          }else{
            $('#formErr').text((res && res.message) || '儲存失敗').removeClass('hidden');
          }
        },
        error: function(xhr, status, err){
          $('#formErr').text('伺服器錯誤：' + (xhr.status || '未知')).removeClass('hidden');
        },
        complete: function(xhr, status){
          $saveBtn.prop('disabled', false).removeClass('opacity-60 cursor-not-allowed');
        }
      });
    }

</script>


