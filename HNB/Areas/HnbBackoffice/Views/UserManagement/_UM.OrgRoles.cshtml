<div class="bg-white border rounded-xl space-y-2">
    <!-- Header -->
    <header class="px-6 mt-3">
        <h2 class="text-xl font-semibold flex items-center gap-2">
            <i data-lucide="id-card" class="h-5 w-5"></i>
            組織角色
        </h2>
        <p class="text-slate-500">管理組織角色、系統權限與 UI 權限</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 border-t">
        <!-- 左側查詢面板 -->
        <aside class="md:col-span-3 border-r p-4 space-y-4">
            <div class="space-y-2">
                <label class="block text-sm font-medium">關鍵字</label>
                <div class="relative">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400"></i>
                    <input id="orgroles-q" class="w-full rounded-md border px-9 py-2" placeholder="角色名稱、描述">
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">所屬組織</label>
                <select id="orgroles-org" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="1">技術部</option>
                    <option value="2">行銷部</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">系統權限數</label>
                <select id="orgroles-sysperm" class="w-full rounded-md border px-3 py-2">
                    <option value="">不限</option>
                    <option value="0">0</option>
                    <option value="1-3">1–3</option>
                    <option value="4+">4 以上</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium">UI 權限類型</label>
                <select id="orgroles-uitype" class="w-full rounded-md border px-3 py-2">
                    <option value="">全部</option>
                    <option value="button">button</option>
                    <option value="field">field</option>
                    <option value="keyword">keyword</option>
                </select>
            </div>

            <div class="flex gap-2 pt-2">
                <button id="orgroles-apply" class="flex-1 px-3 py-2 rounded-md bg-slate-900 text-white">
                    <i data-lucide="filter" class="h-4 w-4 inline-block mr-1"></i> 套用
                </button>
                <button id="orgroles-reset" class="px-3 py-2 rounded-md border">重設</button>
            </div>
        </aside>

        <!-- 右側結果表格 -->
        <section class="md:col-span-9 p-4">
            <header class="flex items-center justify-between mb-3">
                <div id="orgroles-active-chips" class="text-sm text-slate-500"></div>
                <div class="text-sm text-slate-500">共 N 個角色 · 顯示 1–10</div>
            </header>

            <div class="overflow-x-auto rounded-xl border">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 sticky top-0 z-[1]">
                        <tr class="text-left text-slate-600">
                            <th class="px-4 py-3 font-medium">角色名稱</th>
                            <th class="px-4 py-3 font-medium">所屬組織</th>
                            <th class="px-4 py-3 font-medium">系統權限</th>
                            <th class="px-4 py-3 font-medium">UI 權限</th>
                            <th class="px-4 py-3 font-medium">操作</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <tr>
                            <td class="px-4 py-3">
                                <div class="font-medium">Department Manager</div>
                                <div class="text-slate-500 text-xs">部門經理</div>
                            </td>
                            <td class="px-4 py-3">
                                <span class="inline-flex rounded-full border px-2 py-0.5">技術部</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="inline-flex rounded-full border px-2 py-0.5">2 項系統權限</span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    <span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-xs">編輯按鈕</span>
                                    <span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-xs">薪資欄位</span>
                                    <span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-xs">+更多</span>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <button class="inline-flex items-center gap-1 rounded-md border px-2 py-1 hover:bg-slate-50">
                                    <i data-lucide="edit" class="w-4 h-4"></i> 編輯
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
