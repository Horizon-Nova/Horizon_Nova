<!-- 資料表編輯 Modal（共用） -->
<div id="tableEditModal" class="modal fade" tabindex="-1" aria-hidden="true"
     data-load-url='@Url.Action("LoadTableDetails", "Database", new { area = "Backoffice" })'
     data-save-url='@Url.Action("UpdateTableStructure", "Database", new { area = "Backoffice" })'>
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">編輯資料表：<span id="tableEditTitle"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body p-4">
                <div id="tableEditContent">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">載入中...</span>
                        </div>
                        <p class="mt-2 text-muted">載入資料表結構中...</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 w-100">
                <div class="grid grid-cols-2 gap-2 w-100">
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">取消</button>
                    <button type="button" id="btnTableEditSave" class="btn btn-primary w-100" onclick="return saveTableStructure();">儲存</button>
                </div>
            </div>
        </div>
    </div>
</div>
