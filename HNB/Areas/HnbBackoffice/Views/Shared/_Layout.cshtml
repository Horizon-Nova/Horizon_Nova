@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "後台管理系統";
    var userName = ViewBag.UserName as string ?? "Admin";
    var userEmail = ViewBag.UserEmail as string ?? "admin@example.com";
    var userRole = ViewBag.UserRole as string ?? "Admin";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    <link rel="icon" type="image/png" href="https://horizon-nova.up.railway.app/image/Horizon%20Nova%20Logo1.png" />
    <link rel="shortcut icon" type="image/png" href="https://horizon-nova.up.railway.app/image/Horizon%20Nova%20Logo1.png" />

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Bootstrap 5 必要檔案 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables (必須在jQuery之後載入) -->
    <link href="https://cdn.datatables.net/2.1.8/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/2.1.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.bootstrap5.min.js"></script>

    <!-- Lucide / 其他庫 -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <!-- 其他 -->
    <script src="https://cdn.balkan.app/orgchart.js"></script>
    <link rel="stylesheet" href="~/HnbBackoffice/css/LayoutBackoffice.css" />
    <link rel="stylesheet" href="~/HnbBackoffice/css/DatabaseManagement.css" />
    <script src="~/HnbBackoffice/js/LayoutBackoffice.js"></script>
    <script src="~/HnbBackoffice/js/DatabaseManagement.js"></script>

</head>

<!-- 預覽 Modal -->
<div id="pvModal"
     class="modal fade"
     tabindex="-1" aria-hidden="true"
     data-preview-url='@Url.Action("Preview", "Backoffice", new { area = "Backoffice" })'>
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">預覽：<span id="pvTitle"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body p-0"><div id="pvContainer" class="p-3"></div></div>
            <div class="modal-footer border-0">
                <a id="pvOpenNew" class="btn btn-outline-secondary" target="_blank" rel="noopener">在新視窗開啟</a>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

<!-- 編輯 Modal（共用） -->
<div id="edModal" class="modal fade" tabindex="-1" aria-hidden="true"
     data-read-url='@Url.Action("ReadText", "Backoffice", new { area = "Backoffice" })'
     data-save-url='@Url.Action("SaveText", "Backoffice", new { area = "Backoffice" })'>
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">編輯：<span id="edTitle"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body p-0">
                <textarea id="edInput" class="form-control" style="height:65vh; border:0; border-radius:0;"></textarea>
                <input id="edHiddenName" type="hidden"><input id="edHiddenPath" type="hidden">
            </div>
            <div class="modal-footer border-0 px-4 pb-4 w-100">
                <div class="grid grid-cols-2 gap-2 w-100">
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">取消</button>
                    <button type="button" id="btnEdSave" class="btn btn-primary w-100" onclick="return fmEditSave();">儲存</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 資料表編輯 Modal -->
@await Html.PartialAsync("_TableEditModal")

<body class="h-screen w-screen bg-gradient-to-br from-slate-50 to-blue-50 text-slate-900">

    <div class="h-screen flex">
        <!-- Sidebar -->
        <aside id="sidebar"
               class="relative bg-white border-r border-slate-200 transition-all duration-300 w-64 data-[collapsed=true]:w-16">
            <div class="flex h-16 items-center justify-between px-4 border-b border-slate-200">
                <h2 class="text-lg font-semibold truncate hidden data-[collapsed=false]:block"
                    data-collapsed-target>
                    管理系統
                </h2>
                <button id="btnToggleSidebar"
                        type="button"
                        class="h-8 w-8 inline-flex items-center justify-center rounded-md hover:bg-slate-100"
                        title="收合/展開">
                    <i id="iconChevron" data-lucide="chevron-left" class="h-4 w-4"></i>
                </button>
            </div>

            <nav class="px-3 py-4 overflow-y-auto h-[calc(100vh-4rem)] space-y-2">
                <a href="@Url.Action("Dashboard", "Backoffice", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="layout-dashboard" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>Dashboard</span>
                </a>
                <a href="@Url.Action("", "", new { area="HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="shield" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>API 安全控管</span>
                </a>
                <a href="@Url.Action("UserManagement", "UserManagement", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="users" class="h-4 w-4 shrink-0"></i>
                    <span0 class="truncate" data-collapsed-target>權限管理</span0>
                </a>
                <a href="@Url.Action("", "", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="key" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>KEY 保管</span>
                </a>
                <a href="@Url.Action("", "", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="brain" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>AI模型管理</span>
                </a>
                <a href="@Url.Action("Settings", "Settings", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="settings" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>系統設定</span>
                </a>
                <a href="@Url.Action("FileManager", "Backoffice", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="folder-tree" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>檔案總管</span>
                </a>
                <a href="@Url.Action("DatabaseManagement", "Database", new { area = "HnbBackoffice" })"
                   class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                    <i data-lucide="database" class="h-4 w-4 shrink-0"></i>
                    <span class="truncate" data-collapsed-target>資料庫管理</span>
                </a>
            </nav>
        </aside>

        <!-- Main -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-16 border-b bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/60">
                <div class="flex h-16 items-center justify-between px-6">
                    <h1 class="text-xl font-semibold truncate">後台管理系統</h1>
                    <div class="relative">
                        <button id="btnUserMenu"
                                type="button"
                                class="relative h-8 w-8 rounded-full ring-1 ring-slate-200 bg-white flex items-center justify-center hover:bg-slate-50"
                                aria-haspopup="menu"
                                aria-expanded="false">
                            <span class="text-sm font-medium">
                                @userName.Substring(0, 1).ToUpper()
                            </span>
                        </button>
                        <!-- Dropdown -->
                        <div id="userMenu"
                             class="hidden absolute right-0 mt-2 w-56 rounded-md border border-slate-200 bg-white shadow-md p-2 z-50"
                             role="menu" aria-labelledby="btnUserMenu">
                            <div class="px-3 py-2">
                                <p class="text-sm font-medium leading-none">@userName</p>
                                <p class="text-xs leading-none text-slate-500">@userEmail</p>
                                <p class="text-xs leading-none text-slate-500 mt-1">角色: @userRole</p>
                            </div>
                            <div class="my-2 h-px bg-slate-200"></div>
                            <a class="flex items-center gap-2 px-3 py-2 rounded-md hover:bg-slate-100" href="#">
                                <i data-lucide="user" class="h-4 w-4"></i> 個人資料
                            </a>
                            <div class="my-2 h-px bg-slate-200"></div>
                            <form method="post" action="@Url.Action("Logout", "Authorize", new { area = "Backoffice" })">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="w-full text-left flex items-center gap-2 px-3 py-2 rounded-md hover:bg-slate-100">
                                    <i data-lucide="log-out" class="h-4 w-4"></i> 登出
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <main class="flex-1 overflow-auto p-6">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- 模態視窗容器 -->
    <div id="modalContainer"></div>

    @RenderSection("Scripts", required: false)
</body>

</html>