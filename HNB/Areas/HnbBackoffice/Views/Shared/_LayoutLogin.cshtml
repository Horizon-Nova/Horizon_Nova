@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "後台管理系統";
    var userName = ViewBag.UserName as string ?? "Admin";
    var userEmail = ViewBag.UserEmail as string ?? "admin@example.com";
    var userRole = ViewBag.UserRole as string ?? "Admin";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <style>
        html, body {
            font-size: .875rem;
            line-height: 1.25rem;
        }

        .hidden-important {
            display: none !important;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) window.lucide.createIcons();
        });
    </script>
</head>
<body class="h-full bg-white">
    <!-- 背景裝飾 -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-16 -left-16 w-56 h-56 rounded-full bg-indigo-200/40 blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-20 -right-20 w-72 h-72 rounded-full bg-purple-200/40 blur-3xl animate-pulse"></div>
    </div>

    @RenderBody()

    @RenderSection("Scripts", required: false)
</body>
</html>