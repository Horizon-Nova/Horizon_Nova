<form id="addTableForm">
    <div class="space-y-6">
        <!-- 資料表基本資訊 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label for="tableName" class="block text-sm font-medium text-slate-700 mb-2">資料表名稱</label>
                <input type="text" id="tableName" name="tableName" 
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                       placeholder="例如: users" required />
            </div>
            <div>
                <label for="tableDescription" class="block text-sm font-medium text-slate-700 mb-2">資料表說明</label>
                <input type="text" id="tableDescription" name="tableDescription" 
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                       placeholder="例如: 使用者資料表" />
            </div>
        </div>
        
        <!-- 欄位定義表格 -->
        <div>
            <div class="flex items-center justify-between mb-4">
                <label class="block text-sm font-medium text-slate-700">資料表欄位</label>
                <button type="button" onclick="addTableRow()" 
                        class="flex items-center px-3 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                    <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                    新增欄位
                </button>
            </div>
            
            <div class="border border-slate-200 rounded-lg overflow-hidden">
                <table class="w-full">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">欄位名稱</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">資料型態</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">長度</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">預設值</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">約束條件</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">操作</th>
                        </tr>
                    </thead>
                    <tbody id="tableFieldsBody" class="bg-white divide-y divide-slate-200">
                        <!-- 預設欄位 -->
                        <tr>
                            <td class="px-4 py-3">
                                <input type="text" name="fieldName" value="id" 
                                       class="w-full px-2 py-1 border border-slate-300 rounded text-sm" readonly />
                            </td>
                            <td class="px-4 py-3">
                                <select name="fieldType" class="w-full px-2 py-1 border border-slate-300 rounded text-sm">
                                    <option value="bigint">bigint</option>
                                    <option value="uuid">uuid</option>
                                </select>
                            </td>
                            <td class="px-4 py-3">
                                <input type="text" name="fieldLength" placeholder="自動" 
                                       class="w-full px-2 py-1 border border-slate-300 rounded text-sm" readonly />
                            </td>
                            <td class="px-4 py-3">
                                <input type="text" name="fieldDefault" placeholder="自動" 
                                       class="w-full px-2 py-1 border border-slate-300 rounded text-sm" readonly />
                            </td>
                            <td class="px-4 py-3">
                                <select name="fieldConstraint" class="w-full px-2 py-1 border border-slate-300 rounded text-sm">
                                    <option value="">無</option>
                                    <option value="Not Null" selected>必填</option>
                                    <option value="Primary Key">Primary Key</option>
                                </select>
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-xs text-slate-500">預設欄位</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</form>