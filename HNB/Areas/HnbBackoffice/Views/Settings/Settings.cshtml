@{  
    ViewData["Title"] = "系統設定 - 後台管理系統";  
    Layout = "~/Areas/HnbBackoffice/Views/Shared/_Layout.cshtml";  
}  

<section class="space-y-6">  
    <header class="flex items-center justify-between">  
        <div>  
            <h1 class="text-3xl font-bold flex items-center gap-3">  
                <i data-lucide="settings" class="h-8 w-8"></i> 系統設定  
            </h1>  
            <p class="text-slate-500">完整的系統配置和管理功能</p>  
        </div>  
    </header>  

    <div>  
        <div class="grid grid-cols-6 gap-2 border rounded-lg p-1 bg-white">
            <button type="button" class="hn-tab px-3 py-2 rounded-md" onclick="loadTab('system')">系統設定</button>
            <button type="button" class="hn-tab px-3 py-2 rounded-md" onclick="loadTab('security')">安全設定</button>
            <button type="button" class="hn-tab px-3 py-2 rounded-md" onclick="loadTab('notification')">通知設定</button>
            <button type="button" class="hn-tab px-3 py-2 rounded-md" onclick="loadTab('database')">資料庫</button>
            <button type="button" class="hn-tab px-3 py-2 rounded-md" onclick="loadTab('schedule')">排程任務</button>
            <button type="button" class="hn-tab px-3 py-2 rounded-md" onclick="loadTab('server')">伺服器資訊</button>
        </div>

    </div>  

    <div id="tabContent" class="space-y-4 min-h-[200px]">
        <span class="animate-pulse text-slate-400">載入中…</span>
    </div>
</section>  

@section Scripts {
    <script>
        function loadTab(tab) {
          $.ajax({
            type: 'GET',
            url: '@Url.Action("SettingsTab", "Settings", new { area = "HnbBackoffice" })',
            data: { t: tab },
            success: function (res) {
              $('#tabContent').html(res);
            },
            error: function () {
              alert('失敗，請稍後再試。');
            }
          });
        }
        $(function () { loadTab('system'); });

    </script>
}
