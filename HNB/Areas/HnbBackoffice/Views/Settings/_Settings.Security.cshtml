@{
    var sessionTimeout = 3600;
    var maxLoginAttempts = 5;
    var enableTwoFactor = true;
    var ipWhitelist = new[] { "127.0.0.1", "192.168.1.0/24" };
}

<div class="bg-white border rounded-xl p-6 space-y-6">
    <header>
        <h2 class="text-xl font-semibold flex items-center gap-2">
            <i data-lucide="shield" class="h-5 w-5"></i>
            安全設定
        </h2>
        <p class="text-slate-500">系統安全配置和訊息安全設定</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
            <label class="block text-sm font-medium">會話逾時 (秒)</label>
            <input type="number" class="w-full rounded-md border px-3 py-2" value="@sessionTimeout" />

            <label class="block text-sm font-medium">最大登入嘗試次數</label>
            <input type="number" class="w-full rounded-md border px-3 py-2" value="@maxLoginAttempts" />

            <div class="flex items-center justify-between">
                <div>
                    <label class="block text-sm font-medium">雙因子驗證</label>
                    <p class="text-xs text-slate-500">提升帳戶安全性</p>
                </div>
                <input type="checkbox" class="h-5 w-5" @(enableTwoFactor ? "checked" : "") />
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium mb-2">IP 白名單（每行一個）</label>
            <textarea rows="8" class="w-full rounded-md border px-3 py-2">@string.Join("\n", ipWhitelist)</textarea>
        </div>
    </div>
</div>
