@{
    var tasks = new[] {
        new { id=1, name="資料庫備份", schedule="0 2 * * *", enabled=true,  lastRun="2024-01-20 02:00:00", nextRun="2024-01-21 02:00:00", status="success" },
        new { id=2, name="日誌清理",   schedule="0 3 * * 0", enabled=true,  lastRun="2024-01-14 03:00:00", nextRun="2024-01-21 03:00:00", status="success" },
        new { id=3, name="系統健檢",   schedule="*/15 * * * *", enabled=false, lastRun="",               nextRun="2024-01-20 11:00:00", status="pending" }
    };
    Func<string,string> badge = s => s switch {
        "success" => "<span class=\"text-green-700 bg-green-100 rounded px-2 py-1 text-xs inline-flex items-center gap-1\"><i data-lucide=\"check-circle\" class=\"h-3 w-3\"></i>成功</span>",
        "error"   => "<span class=\"text-red-700 bg-red-100 rounded px-2 py-1 text-xs inline-flex items-center gap-1\"><i data-lucide=\"alert-triangle\" class=\"h-3 w-3\"></i>錯誤</span>",
        "running" => "<span class=\"text-slate-700 bg-slate-100 rounded px-2 py-1 text-xs inline-flex items-center gap-1\"><i data-lucide=\"activity\" class=\"h-3 w-3\"></i>執行中</span>",
        "pending" => "<span class=\"text-slate-700 border rounded px-2 py-1 text-xs inline-flex items-center gap-1\"><i data-lucide=\"clock\" class=\"h-3 w-3\"></i>待執行</span>",
        _ => $"<span class=\"text-slate-700 bg-slate-100 rounded px-2 py-1 text-xs\">{s}</span>"
    };
}

<div class="bg-white border rounded-xl p-6 space-y-6">
    <header class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold flex items-center gap-2">
                <i data-lucide="clock" class="h-5 w-5"></i>
                排程任務
            </h2>
            <p class="text-slate-500">系統定時任務和自動化作業管理</p>
        </div>
        <div class="flex gap-2">
            <button class="px-3 py-2 rounded-md bg-slate-900 text-white">
                <i data-lucide="plus" class="h-4 w-4 inline-block mr-1"></i> 新增任務
            </button>
            <button class="px-3 py-2 rounded-md border">
                <i data-lucide="refresh-cw" class="h-4 w-4 inline-block mr-1"></i> 刷新狀態
            </button>
        </div>
    </header>

    <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
            <thead class="text-left bg-slate-50">
                <tr>
                    <th class="px-4 py-3 font-semibold">任務名稱</th>
                    <th class="px-4 py-3 font-semibold">排程</th>
                    <th class="px-4 py-3 font-semibold">狀態</th>
                    <th class="px-4 py-3 font-semibold">最後執行</th>
                    <th class="px-4 py-3 font-semibold">下次執行</th>
                    <th class="px-4 py-3 font-semibold">操作</th>
                </tr>
            </thead>
            <tbody class="divide-y">
                @foreach (var t in tasks)
                {
                    <tr>
                        <td class="px-4 py-3 font-medium">@t.name</td>
                        <td class="px-4 py-3 font-mono">@t.schedule</td>
                        <td class="px-4 py-3">@Html.Raw(badge(t.status))</td>
                        <td class="px-4 py-3">@(!string.IsNullOrEmpty(t.lastRun) ? t.lastRun : "從未執行")</td>
                        <td class="px-4 py-3">@t.nextRun</td>
                        <td class="px-4 py-3">
                            <div class="flex gap-2">
                                <button class="px-2 py-1 rounded-md border" title="啟用/暫停">
                                    @if (t.enabled) { <i data-lucide="pause" class="h-4 w-4"></i> } else { <i data-lucide="play" class="h-4 w-4"></i> }
                                </button>
                                <button class="px-2 py-1 rounded-md border" title="編輯"><i data-lucide="edit" class="h-4 w-4"></i></button>
                                <button class="px-2 py-1 rounded-md border" title="刪除"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
