@model Models.HnbHnbBackoffice.vw_system_config_database

@{
    var freq = Model.backup_frequency?.Trim();
}

<div class="bg-white border rounded-xl p-6 space-y-6">
    <header>
        <h2 class="text-xl font-semibold flex items-center gap-2">
            <i data-lucide="database" class="h-5 w-5"></i>
            資料庫設定
        </h2>
        <p class="text-slate-500">資料庫連線設定和備份管理</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
            <label class="block text-sm font-medium">主機位址</label>
            <input class="w-full rounded-md border px-3 py-2"
                   value="@Model.db_host" />

            <label class="block text-sm font-medium">連接埠</label>
            <input type="number" class="w-full rounded-md border px-3 py-2"
                   value="@Model.db_port" />

            <label class="block text-sm font-medium">資料庫名稱</label>
            <input class="w-full rounded-md border px-3 py-2"
                   value="@Model.db_name" />
        </div>

        <div class="space-y-4 p-4 border rounded-lg">
            <div class="text-base font-semibold">備份設定</div>

            <div class="flex items-center justify-between">
                <span>啟用自動備份</span>
                <input type="checkbox" class="h-5 w-5"
                       @(Model.auto_backup_enabled == true ? "checked" : "") />
            </div>

            <div class="grid gap-2">
                <label class="block text-sm font-medium">備份頻率</label>
                <select class="w-full rounded-md border px-3 py-2">
                    <option value="hourly" @(freq == "hourly" ? "selected" : "")>每小時</option>
                    <option value="daily" @(freq == "daily" ? "selected" : "")>每日</option>
                    <option value="weekly" @(freq == "weekly" ? "selected" : "")>每週</option>
                </select>
            </div>
        </div>
    </div>

    <div class="flex justify-end gap-2">
        <button class="px-4 py-2 rounded-md border">測試連線</button>
        <button class="px-4 py-2 rounded-md bg-slate-900 text-white">
            <i data-lucide="save" class="h-4 w-4 inline-block mr-1"></i> 保存設定
        </button>
    </div>
</div>
