@{
    ViewData["Title"] = "系統設定 - 後台管理系統";
    Layout = "~/Areas/HnbBackoffice/Views/Shared/_LayoutLogin.cshtml";
    var returnUrl = Context?.Request?.Query["returnUrl"].ToString() ?? "/HnbBackoffice/Backoffice/Dashboard";
}
<main class="min-h-screen flex items-center justify-center px-4 py-8 sm:px-6 lg:px-8">
    <div class="w-full max-w-sm sm:max-w-md lg:max-w-lg">
        <div class="relative rounded-2xl bg-white shadow-xl ring-1 ring-slate-200 p-5 sm:p-7 lg:p-10">
            <header class="mb-6 sm:mb-8 text-center space-y-2">
                <i data-lucide="log-in" class="w-9 h-9 sm:w-10 sm:h-10 text-indigo-600 mx-auto animate-bounce"></i>
                <h1 class="text-xl sm:text-2xl font-bold text-slate-800">歡迎登入</h1>
                <p class="text-xs sm:text-sm text-slate-500">請輸入帳號與密碼，或使用下方圖示快速登入</p>
            </header>

            @if (ViewBag.ErrorMessage is string err && !string.IsNullOrWhiteSpace(err))
            {
                <div class="mb-4 rounded-lg bg-red-50 text-red-700 px-3 py-2 text-sm">@err</div>
            }

            <form id="FormData"
                  action="@Url.Action("LoginFuntion", "Authorize", new { area = "HnbBackoffice" })"
                  method="post"
                  class="space-y-4 sm:space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" id="returnUrl" name="returnUrl" value="@returnUrl" />

                <div>
                    <label for="Username" class="block text-sm font-medium text-slate-700">帳號</label>
                    <div class="relative mt-1">
                        <i data-lucide="user" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input id="Username" name="username" type="text" autocomplete="username"
                               class="w-full rounded-xl border border-slate-300 pl-10 pr-3 py-2 sm:py-2.5 text-slate-900 placeholder-slate-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition"
                               placeholder="your.name@example.com" />
                    </div>
                </div>

                <div>
                    <div class="flex items-center justify-between">
                        <label for="Password" class="block text-sm font-medium text-slate-700">密碼</label>
                        <a href="#" class="text-xs sm:text-sm text-indigo-600 hover:underline">忘記密碼？</a>
                    </div>
                    <div class="relative mt-1">
                        <i data-lucide="lock" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input id="Password" name="password" type="password" autocomplete="current-password"
                               class="w-full rounded-xl border border-slate-300 pl-10 pr-10 py-2 sm:py-2.5 text-slate-900 placeholder-slate-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition"
                               placeholder="••••••••" />
                        <button type="button" id="togglePwdBtn"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition"
                                aria-label="顯示/隱藏密碼" title="顯示/隱藏密碼">
                            <i id="eyeIcon" data-lucide="eye" class="w-5 h-5"></i>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <label for="rememberMe" class="inline-flex items-center gap-2 text-sm text-slate-600 select-none">
                        <input id="rememberMe" name="rememberMe" type="checkbox"
                               class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                        記住我
                    </label>
                </div>

                <button id="btnSubmit" type="button" onclick="SubmitForm()"
                        class="w-full flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-4 py-2.5 text-white font-medium shadow-md hover:scale-[1.02] hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-white transition-transform duration-200">
                    <i data-lucide="log-in" class="w-5 h-5"></i>
                    <span class="text-sm sm:text-base">登入</span>
                    <svg id="btnSpinner" class="animate-spin h-5 w-5 ml-1 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                    </svg>
                </button>

                <!-- 低調的登出：文字連結樣式，置中放在登入下方 -->
                <div class="text-center">
                    <button type="button"
                            onclick="LogoutFormSubmit()"
                            class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 hover:underline transition"
                            aria-label="登出">
                        <i data-lucide="log-out" class="w-4 h-4"></i>
                        <span>登出</span>
                    </button>
                </div>
            </form>

            <div class="my-5 sm:my-6 flex items-center">
                <div class="h-px flex-1 bg-slate-200"></div>
                <span class="px-3 text-[11px] sm:text-xs text-slate-400">或以社群快速登入</span>
                <div class="h-px flex-1 bg-slate-200"></div>
            </div>

            <!-- GitHub -->
            <div class="flex items-center justify-center">
                <button type="button" onclick="GithubLogin()"
                        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-300 bg-white shadow-sm hover:bg-slate-50 hover:scale-105 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-white transition"
                        aria-label="以 GitHub 登入" title="以 GitHub 登入">
                    <i data-lucide="github" class="w-5 h-5 text-slate-800"></i>
                </button>
            </div>

            <!-- 隱藏的登出表單（供 JS 提交，含防偽） -->
            <form id="LogoutForm"
                  action="@Url.Action("Logout", "Authorize", new { area = "HnbBackoffice" })"
                  method="post" class="hidden">
                @Html.AntiForgeryToken()
            </form>
        </div>

        <p class="mt-6 text-center text-xs text-slate-500">&copy; @DateTime.Now.Year Horizon-Nova</p>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide && lucide.createIcons) lucide.createIcons();
            document.getElementById('togglePwdBtn')?.addEventListener('click', function () {
                var input = document.getElementById('Password');
                var eye = document.getElementById('eyeIcon');
                if (!input) return;
                if (input.type === 'password') { input.type = 'text'; eye.setAttribute('data-lucide', 'eye-off'); }
                else { input.type = 'password'; eye.setAttribute('data-lucide', 'eye'); }
                if (window.lucide && lucide.createIcons) lucide.createIcons();
            });
        });

        function SubmitForm() {
            var btn = document.getElementById('btnSubmit');
            var spn = document.getElementById('btnSpinner');
            btn.disabled = true; btn.classList.add('opacity-70','cursor-not-allowed');
            spn.classList.remove('hidden');
            document.getElementById('FormData').submit();
        }

        function GithubLogin(){
          var ret = document.getElementById('returnUrl')?.value || '/';

          var base = '@Url.Action("RedirectGitHub", "GitHubAccess", new { area = "HnbBackoffice" })';
          var url  = base + '?returnUrl=' + encodeURIComponent(ret) + '&popup=1';

          var w = 720, h = 720;
          var y = Math.max(0, (screen.height - h) / 2);
          var x = Math.max(0, (screen.width  - w) / 2);
          var pop = window.open(url, 'gh_oauth',
            'width='+w+',height='+h+',left='+x+',top='+y+',resizable=yes,scrollbars=yes');

          if(!pop){ window.location.href = url; return; }

          var handler = function(e){
            if(e.origin !== location.origin) return;
            if(!e.data || e.data.type !== 'GH_AUTH_DONE') return;
            window.removeEventListener('message', handler);
            var to = e.data.redirectTo || ret;
            window.location.href = to;
          };
          window.addEventListener('message', handler);

          setTimeout(function(){
            try{ if(!pop || pop.closed) window.location.href = url; }catch(_){}
          }, 60000);
        }

        function LogoutFormSubmit() {
            document.getElementById('LogoutForm').submit();
        }

    </script>
}
