@using HNB.Areas.HnbBackoffice.Dtos
@model IEnumerable<FileTreeNodeDto>
@{
    var listUrl = Url.Action("FileManager", "Backoffice", new { area = "HnbBackoffice" });
    var selected = (ViewBag.SelectedPath as string) ?? "/";
}
@foreach (var n in Model)
{
    var pad = (n.Depth * 12) + "px";
    var active = string.Equals(n.VirtualPath, selected, StringComparison.OrdinalIgnoreCase)
        ? "bg-slate-100 ring-1 ring-slate-200"
        : "";
    <li>
        <a class="flex items-center gap-2 px-2 py-1 rounded hover:bg-slate-100 @active"
           style="--pad:@pad"
           href="@listUrl?path=@(Uri.EscapeDataString(n.VirtualPath))">
            <i data-lucide="folder" class="w-4 h-4 text-amber-500"></i>
            <span>@n.Name</span>
        </a>
    </li>
}
