@{
    ViewData["Title"] = "檔案總管 - 後台管理系統";
    Layout = "~/Areas/HnbBackoffice/Views/Shared/_Layout.cshtml";
}

<section class="space-y-6">
    <header>
        <h1 class="text-2xl font-bold flex items-center gap-2">
            <i data-lucide="folder-tree" class="w-6 h-6"></i> 檔案總管
        </h1>
        <p class="text-slate-500">管理後端檔案與資料夾</p>
    </header>
    <form id="fmTokens">@Html.AntiForgeryToken()</form>

    <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 bg-white border rounded-xl p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                <!-- 左側資料夾樹 -->
                <aside class="col-span-12 md:col-span-3 md:sticky md:top-2 bg-white border rounded-lg p-4 space-y-3 order-1">
                    <div class="flex items-center justify-between">
                        <h3 class="text-sm font-semibold flex items-center gap-1">
                            <i data-lucide="folders" class="w-4 h-4"></i> 資料夾
                        </h3>
                        <div class="flex gap-1">
                            <button id="btnAddFolder" class="p-1.5 rounded hover:bg-slate-100"
                                    title="新增資料夾" onclick="return fmAddFolder();">
                                <i data-lucide="folder-plus" class="w-4 h-4"></i>
                            </button>
                            <button id="btnAddFile" class="p-1.5 rounded hover:bg-slate-100"
                                    title="新增檔案" onclick="return fmAddFile();">
                                <i data-lucide="file-plus" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                    <ul id="tree" class="space-y-1 text-sm"></ul>

                </aside>

                <!-- 右側檔案清單（以下為寫死示範） -->
                <main class="col-span-12 md:col-span-9 bg-white border rounded-lg p-4 space-y-6 order-2">

                    <!-- 拖曳上傳 -->
                    <form id="uploadForm" class="space-y-2" onsubmit="return false;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="path" id="uploadPath" value="/" />

                        <!-- 拖曳/點擊區 -->
                        <div id="dropzone" class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:bg-slate-50 cursor-pointer transition">
                            <i data-lucide="upload-cloud" class="w-10 h-10 mx-auto text-slate-400"></i>
                            <p class="mt-2 text-sm text-slate-600">
                                拖曳檔案到這裡，或
                                <label for="fileInput" class="text-blue-600 cursor-pointer hover:underline">點擊上傳</label>
                            </p>
                            <input id="fileInput" name="files" type="file" class="hidden" multiple />
                        </div>

                        <!-- 進度列-->
                        <div id="uploadPanel" class="hidden mt-3 rounded border p-3 text-sm">
                            <div class="flex items-center justify-between mb-2">
                                <div>上傳進度：<span id="upPct">0%</span>（<span id="upBytes">0 / 0</span>）</div>
                                <div>預估剩餘：<span id="upEta">—</span></div>
                            </div>
                            <div class="w-full h-2 bg-slate-200 rounded overflow-hidden">
                                <div id="upBar" class="h-2 bg-blue-500" style="width:0%"></div>
                            </div>
                            <div class="mt-2">
                                <button id="btnCancelUpload" type="button" class="px-3 py-1 rounded border">中斷上傳</button>
                            </div>
                        </div>

                        <!-- 重新整理 -->
                        <div class="flex items-center gap-3">
                            <button id="btnRefresh" class="text-sm text-gray-600 hover:text-gray-800" type="button" onclick="location.reload()">
                                重新整理
                            </button>
                        </div>
                    </form>


                    <div id="fileListPanel"></div>

                    <!-- 預覽 / 編輯面板（保留結構；未啟用） -->
                    <div id="previewPanel" class="hidden fixed inset-0 bg-black/40 z-50">
                        <div class="absolute inset-0 flex items-center justify-center p-4">
                            <div class="bg-white light:bg-slate-900 w-full max-w-5xl rounded-xl shadow-xl overflow-hidden">
                                <div class="flex items-center justify-between px-4 py-3 border-b">
                                    <div class="font-semibold" id="pvTitle">預覽</div>
                                    <div class="flex items-center gap-2">
                                        <button class="px-2 py-1 text-sm rounded bg-slate-100 hover:bg-slate-200" onclick="document.getElementById('previewPanel').classList.add('hidden')">關閉</button>
                                    </div>
                                </div>
                                <div id="pvBody" class="p-4 max-h-[70vh] overflow-auto text-sm"></div>
                                <div id="pvEditBar" class="hidden border-t px-4 py-3 flex justify-end gap-2">
                                    <select id="pvEncoding" class="border rounded px-2 py-1 text-sm">
                                        <option value="utf-8">UTF-8</option>
                                        <option value="utf-8-bom">UTF-8 (BOM)</option>
                                    </select>
                                    <button class="px-3 py-1.5 text-sm rounded bg-blue-600 text-white hover:bg-blue-700">儲存</button>
                                    <button class="px-3 py-1.5 text-sm rounded bg-slate-100 hover:bg-slate-200" onclick="document.getElementById('previewPanel').classList.add('hidden')">取消</button>
                                </div>
                            </div>
                        </div>
                    </div>

                </main>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>

        function curPath(){ return new URLSearchParams(location.search).get('path') || '/'; }
        function fmToken() {
            const el = document.querySelector('#fmTokens input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }
        function fmtBytes(n){ if(!n) return '0 B'; const u=['B','KB','MB','GB']; let i=0; while(n>=1024&&i<u.length-1){n/=1024;i++;} return (n<10? n.toFixed(2):Math.round(n))+' '+u[i]; }
        function warnBeforeUnload(enable){
          window.onbeforeunload = enable ? function(){ return '檔案正在上傳，離開將中止。'; } : null;
        }

        function loadTree(){
          const url = '@Url.Action("TreePartial", "Backoffice", new { area = "HnbBackoffice" })' + '?path=' + encodeURIComponent(curPath());
          $('#tree').load(url, ()=> window.lucide?.createIcons?.());
        }

        function loadList(){
          const url = '@Url.Action("ListPartial", "Backoffice", new { area = "HnbBackoffice" })'
                    + '?path=' + encodeURIComponent(curPath());
          $('#fileListPanel').load(url, () => window.lucide?.createIcons?.());
        }

        function fmAddFolder() {
            var name = prompt('請輸入資料夾名稱：');
            if (!name) return false;
            name = name.trim();
            if (!name || /[\\/:*?"<>|]/.test(name)) { alert('名稱含非法字元或為空'); return false; }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("CreateFolder", "Backoffice", new { area = "HnbBackoffice" })',
                data: { path: curPath(), name: name },
                headers: { 'RequestVerificationToken': fmToken() },
                success: function(res){
                    if (res && res.ok) { loadList(curPath()); loadTree(curPath()); }
                    else { alert(res?.message || '建立失敗'); }
                },
                error: function(xhr){ alert('建立失敗：' + xhr.status); },
            });
            return false;
        }

        function fmAddFile() {
            var name = prompt('請輸入檔名（含副檔名）：');
            if (!name) return false;
            name = name.trim();
            if (!name || /[\\/:*?"<>|]/.test(name)) { alert('名稱含非法字元或為空'); return false; }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("CreateFile", "Backoffice", new { area = "HnbBackoffice" })',
                data: { path: curPath(), name: name },
                headers: { 'RequestVerificationToken': fmToken() },
                success: function(res){
                    if (res && res.ok) { loadList(curPath()); }
                    else { alert(res?.message || '建立失敗'); }
                },
                error: function(xhr){ alert('建立失敗：' + xhr.status); },
            });
            return false;
        }

        function updateUiProgress(pct, sent, total, startTs){
          const elapsed = (Date.now() - startTs)/1000;
          const speed = sent / Math.max(elapsed,1);
          const remain = Math.max(total - sent, 0);
          const eta = speed > 0 ? Math.ceil(remain / speed) : 0;
          $('#upPct').text(pct.toFixed(1) + '%');
          $('#upBytes').text(`${fmtBytes(sent)} / ${fmtBytes(total)}`);
          $('#upBar').css('width', pct.toFixed(1) + '%');
          $('#upEta').text(eta ? (eta + ' 秒') : '計算中');
        }

        async function gatherFilesFromDrop(dt){
          const items = dt.items ? Array.from(dt.items) : [];
          if (!items.length) return Array.from(dt.files || []);
          const entries = items.map(it => it.webkitGetAsEntry && it.webkitGetAsEntry()).filter(Boolean);
          const out = [];
          async function walk(entry, prefix=''){
            if (entry.isFile){
              await new Promise(res => entry.file(f => { f._rel = prefix + f.name; out.push(f); res(); }));
            } else if (entry.isDirectory){
              const reader = entry.createReader();
              await new Promise((res,rej)=>{
                const read = () => reader.readEntries(async rs=>{
                  if(!rs.length){ res(); return; }
                  for(const r of rs) await walk(r, prefix + entry.name + '/');
                  read();
                }, rej);
                read();
              });
            }
          }
          for (const e of entries) await walk(e, '');
          return out.length ? out : Array.from(dt.files || []);
        }

        function startUpload(files){
          if (!files.length) return;

          const totalSize = files.reduce((s,f)=> s + (f.size||0), 0);
          const startTs = Date.now();
          uploading = true; warnBeforeUnload(true);
          $('#uploadPanel').removeClass('hidden');
          updateUiProgress(0, 0, totalSize, startTs);

          const fd = new FormData();
          fd.append('__RequestVerificationToken', fmToken());
          fd.append('path', curPath());
          for (const f of files){
            fd.append('files', f, f.name);
            fd.append('keys', (f.webkitRelativePath || f._rel || f.name));
          }

          currentXhr = $.ajax({
            type: 'POST',
            url: '@Url.Action("Upload", "Backoffice", new { area = "HnbBackoffice" })',
            data: fd, processData: false, contentType: false, timeout: 0,
            xhr: function () {
              const xhr = $.ajaxSettings.xhr();
              if (xhr.upload) {
                xhr.upload.onprogress = function (e) {
                  if (e.lengthComputable) {
                    const sent = e.loaded;
                    const pct = totalSize ? (sent * 100 / (totalSize)) : 0;
                    updateUiProgress(pct, sent, totalSize, startTs);
                  }
                };
              }
              return xhr;
            },
            beforeSend: function(){
            },
            success: function(res){
              if (!res?.ok) alert(res?.message || '上傳失敗');
            },
            error: function(xhr, status){
              if (status !== 'abort') alert('上傳中斷或失敗：' + xhr.status);
            },
            complete: function(){
              uploading = false; warnBeforeUnload(false);
              currentXhr = null;
              $('#uploadPanel').addClass('hidden');
              loadList(); loadTree(curPath());
            }
          });
        }

        function cancelUpload(){
          if (currentXhr) currentXhr.abort();
        }

        $(function(){
            $('#fileInput').on('change', (e)=> startUpload(Array.from(e.target.files||[])));
            $('#dropzone').on('dragover', (e)=> { e.preventDefault(); e.originalEvent.dataTransfer.dropEffect='copy'; });
            $('#dropzone').on('drop', async (e)=> {
              e.preventDefault();
              const files = await gatherFilesFromDrop(e.originalEvent.dataTransfer);
              startUpload(files);
            });
            $('#btnCancelUpload').on('click', ()=> cancelUpload());
            loadTree(); loadList();
        });

    </script>
}
