                    </div>
                </div>
                <div class="secondary-metrics">
                    <div class="secondary-metric">
                        <div class="secondary-label">系統用量</div>
                        <div class="secondary-value" id="system-dalle3">-</div>
                    </div>
                    <div class="secondary-metric">
