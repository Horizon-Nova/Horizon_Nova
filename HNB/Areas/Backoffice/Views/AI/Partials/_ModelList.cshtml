                    <button type="button" class="btn btn-link btn-sm p-0" id="viewRecords-qdrant">查看全部 →</button>
                </div>
                <div class="records-list" id="recentRecords-qdrant">
                    <div class="text-muted small text-center py-3">暫無使用紀錄</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function selectModel(modelId) {
    // 更新導航項目的 active 狀態
    document.querySelectorAll('.model-nav-item').forEach(item => {
        item.classList.remove('active');
    });
    document.querySelector(`[data-model="${modelId}"]`).classList.add('active');
    
    // 顯示對應的詳細面板
    document.querySelectorAll('.model-detail-content').forEach(panel => {
        panel.style.display = 'none';
    });
    document.getElementById(`detail-${modelId}`).style.display = 'flex';
    
    // 重新初始化圖標
    if (window.lucide) {
        window.lucide.createIcons();
    }
}

// 側邊欄搜尋
document.getElementById('sidebarSearch')?.addEventListener('input', function(e) {
    const term = e.target.value.toLowerCase().trim();
    document.querySelectorAll('.model-nav-item').forEach(item => {
        const name = item.querySelector('.nav-name')?.textContent.toLowerCase() || '';
        const desc = item.querySelector('.nav-desc')?.textContent.toLowerCase() || '';
        item.style.display = (!term || name.includes(term) || desc.includes(term)) ? '' : 'none';
    });
});

// 初始化顯示第一個模型
if (document.querySelector('.model-nav-item[data-model="groundingdino"]')) {
    selectModel('groundingdino');
}
</script>
