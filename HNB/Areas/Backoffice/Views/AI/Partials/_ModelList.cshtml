            </div>
            <div class="info-area">
                <div class="info-section">
                    <div class="section-title">
                        <h6><i data-lucide="file-text" style="width: 16px; height: 16px;"></i>API 資訊</h6>
                    </div>
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-item-label">API 狀態</span>
                            <span class="info-item-value">-</span>
                        </div>
                        <div class="info-item">
                            <span class="info-item-label">API 版本</span>
                            <span class="info-item-value">-</span>
                        </div>
                        <div class="info-item" style="grid-column: 1 / -1;">
                            <span class="info-item-label">端點</span>
                            <span class="info-item-value text-truncate" style="max-width: 100%;">-</span>
                        </div>
                    </div>
                </div>
                <div class="info-section">
                    <div class="section-title">
                        <h6><i data-lucide="clock" style="width: 16px; height: 16px;"></i>時間資訊</h6>
                    </div>
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-item-label">上線時間</span>
                            <span class="info-item-value" id="onlineTime-dalle3">-</span>
                        </div>
                        <div class="info-item">
                            <span class="info-item-label">使用時間</span>
                            <span class="info-item-value" id="usageTime-dalle3">-</span>
                        </div>
                        <div class="info-item">
                            <span class="info-item-label">最後使用</span>
                            <span class="info-item-value" id="lastUsed-dalle3">-</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="records-area">
                <div class="section-title">
                    <h6><i data-lucide="list" style="width: 16px; height: 16px;"></i>使用紀錄</h6>
