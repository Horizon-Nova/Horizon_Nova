@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "後台管理系統";
    
    // 直接從 User Identity 取得使用者資訊
    var currentUserName = User.Identity?.Name ?? "未知用戶";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "未設定";
    var fullName = User.FindFirst("FullName")?.Value ?? currentUserName;
    var userType = User.FindFirst("UserType")?.Value ?? "一般用戶";
    var userRole = User.FindFirst("Role")?.Value ?? userType;
    var displayName = !string.IsNullOrEmpty(fullName) ? fullName : currentUserName;
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/HNB_WEB/image/Horizon Nova Icon.png">
    <link rel="shortcut icon" type="image/png" href="~/HNB_WEB/image/Horizon Nova Icon.png">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    
    <!-- DataTable -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.tailwindcss.min.css">
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.tailwindcss.min.js"></script>

    <!-- 自訂樣式 -->
    <link rel="stylesheet" href="~/Backoffice/css/Layout.css" />
    <link rel="stylesheet" href="~/Backoffice/css/DatabaseManagement.css" />
    <link rel="stylesheet" href="~/lib/github-calendar/GitHubCalendar.css" />
    <link rel="stylesheet" href="~/Backoffice/css/Wardrobe.css" />
    <script src="~/Backoffice/js/Layout.js"></script>
    <script src="~/Backoffice/js/DatabaseManagement.js"></script>
    <script src="~/lib/github-calendar/GitHubCalendar.js"></script>
    <script src="~/Backoffice/js/Wardrobe.js"></script>

</head>
<body class="h-screen w-screen bg-gradient-to-br from-slate-50 to-blue-50 text-slate-900">

    <div class="h-screen flex">
        <!-- Sidebar -->
        <aside id="sidebar"
               class="relative bg-white border-r border-slate-200 transition-all duration-300 w-64 data-[collapsed=true]:w-16">
            <div class="flex h-16 items-center justify-between px-4 border-b border-slate-200">
                <h2 class="text-lg font-semibold truncate hidden data-[collapsed=false]:block"
                    data-collapsed-target>
                    管理系統
                </h2>
                <button id="btnToggleSidebar"
                        type="button"
                        class="h-8 w-8 inline-flex items-center justify-center rounded-md hover:bg-slate-100"
                        title="收合/展開">
                    <i id="iconChevron" data-lucide="chevron-left" class="h-4 w-4"></i>
                </button>
            </div>

            <nav class="px-3 py-4 overflow-y-auto h-[calc(100vh-4rem)] space-y-2">
                @{
                    var sidebarNavigation = ViewBag.SidebarNavigation as List<Models.HnbHnbBackoffice.vw_sidebar_navigation> ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
                    var rootItems = sidebarNavigation.Where(n => string.IsNullOrEmpty(n.parent_code)).OrderBy(n => n.sort_order).ToList();
                }
                
                @if (sidebarNavigation.Any())
                {
                    @foreach (var item in rootItems)
                    {
                        @await Html.PartialAsync("_NavigationItem", item, new ViewDataDictionary(ViewData) { { "AllNavigations", sidebarNavigation } })
                    }
                }
                else
                {
                    <a href="@Url.Action("Index", "Dashboard", new { area = "Backoffice" })"
                       class="w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100">
                        <i data-lucide="home" class="h-4 w-4 shrink-0"></i>
                        <span class="truncate" data-collapsed-target>儀表板</span>
                    </a>
                    
                    @if (ViewBag.SidebarError != null)
                    {
                        <div class="px-3 py-2 text-xs text-red-600">
                            @ViewBag.SidebarError
                        </div>
                    }
                }
            
            </nav>
        </aside>

        <!-- Main -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-16 border-b bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/60">
                <div class="flex h-16 items-center justify-between px-6">
                    <h1 class="text-xl font-semibold truncate">後台管理系統</h1>
                    <div class="relative">
                        <button id="btnUserMenu"
                                type="button"
                                class="relative h-8 w-8 rounded-full ring-1 ring-slate-200 bg-white flex items-center justify-center hover:bg-slate-50"
                                aria-haspopup="menu"
                                aria-expanded="false">
                            <span class="text-sm font-medium">
                                @displayName.Substring(0, 1).ToUpper()
                            </span>
                        </button>
                        <!-- Dropdown -->
                        <div id="userMenu"
                             class="hidden absolute right-0 mt-2 w-56 rounded-md border border-slate-200 bg-white shadow-md p-2 z-50"
                             role="menu" aria-labelledby="btnUserMenu">
                            <div class="px-3 py-2">
                                <p class="text-sm font-medium leading-none">@displayName</p>
                                <p class="text-xs leading-none text-slate-500">@userEmail</p>
                                <p class="text-xs leading-none text-slate-500 mt-1">角色: @userRole</p>
                            </div>
                            <div class="my-2 h-px bg-slate-200"></div>
                            <a class="flex items-center gap-2 px-3 py-2 rounded-md hover:bg-slate-100" href="@Url.Action("Profile", "Backoffice", new { area = "Backoffice" })">
                                <i data-lucide="user" class="h-4 w-4"></i> 個人資料
                            </a>
                            <div class="my-2 h-px bg-slate-200"></div>
                            <form method="post" action="@Url.Action("Logout", "Authorize", new { area = "Backoffice" })">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="w-full text-left flex items-center gap-2 px-3 py-2 rounded-md hover:bg-slate-100">
                                    <i data-lucide="log-out" class="h-4 w-4"></i> 登出
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <main class="flex-1 overflow-auto p-6">
                <!-- Page Header -->
                @if (ViewData["PageTitle"] != null || ViewData["PageDescription"] != null || ViewData["PageIcon"] != null)
                {
                    <header class="flex items-center justify-between mb-6">
                        <div>
                            <h1 class="text-3xl font-bold flex items-center gap-3">
                                @if (ViewData["PageIcon"] != null)
                                {
                                    <i data-lucide="@ViewData["PageIcon"]" class="h-8 w-8"></i>
                                }
                                @(ViewData["PageTitle"] ?? ViewData["Title"])
                            </h1>
                            @if (ViewData["PageDescription"] != null)
                            {
                                <p class="text-slate-500">@ViewData["PageDescription"]</p>
                            }
                        </div>
                    </header>
                }
                
                @RenderBody()
            </main>
        </div>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>