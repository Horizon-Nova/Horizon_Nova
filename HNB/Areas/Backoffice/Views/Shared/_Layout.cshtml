@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "後台管理系統";
    var currentUserName = User.Identity?.Name ?? "未知用戶";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "未設定";
    var fullName = User.FindFirst("FullName")?.Value ?? currentUserName;
    var userType = User.FindFirst("UserType")?.Value ?? "一般用戶";
    var userRole = User.FindFirst("Role")?.Value ?? "一般用戶";
    var organizationName = User.FindFirst("OrganizationName")?.Value ?? "未分配組織";
    var organizationId = User.FindFirst("OrganizationId")?.Value;
    var displayName = !string.IsNullOrEmpty(fullName) ? fullName : currentUserName;
    var avatarInitial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Substring(0, 1).ToUpper();
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/HNB_WEB/image/Horizon Nova Icon.png">
    <link rel="shortcut icon" type="image/png" href="~/HNB_WEB/image/Horizon Nova Icon.png">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Dropzone.js -->
    <link rel="stylesheet" href="https://unpkg.com/dropzone@5/dist/min/dropzone.min.css" type="text/css" />
    <script src="https://unpkg.com/dropzone@5/dist/min/dropzone.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- DataTable Bootstrap -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    <!-- HNB DataTable 模組 -->
    <link rel="stylesheet" href="~/lib/datatable/hnb-datatable.css">
    <script src="~/lib/datatable/hnb-datatable.js"></script>
   
    <!-- 自訂樣式 -->
    <link rel="stylesheet" href="~/Backoffice/css/Layout.css" />
    <link rel="stylesheet" href="~/Backoffice/css/DatabaseManagement.css" />
    <link rel="stylesheet" href="~/Backoffice/css/Wardrobe.css" />
    
    <script src="~/Backoffice/js/Modal.js"></script>
    <script src="~/Backoffice/js/Layout.js"></script>
    <script src="~/Backoffice/js/DatabaseManagement.js"></script>
    <script src="~/Backoffice/js/Wardrobe.js"></script>
    
    <!-- 全域 Lucide 初始化 -->
    <script>
        window.addEventListener('load', function() {
            if (typeof lucide !== 'undefined' && typeof lucide.createIcons === 'function') {
                lucide.createIcons();
            }
        });
    </script>

</head>
<body class="h-100">

    <div class="d-flex h-100">
        <!-- Sidebar -->
        <aside id="sidebar"
               class="bg-white border-end border-2 position-fixed position-lg-relative d-flex flex-column"
               style="height: 100vh; z-index: 40;">
            <div class="d-flex align-items-center justify-content-between px-3 border-bottom header-height">
                <h2 class="mb-0 text-truncate fs-6" data-collapsed-target>
                    管理系統
                </h2>
                <button id="btnToggleSidebar"
                        type="button"
                        class="btn p-0 d-none d-lg-inline-flex align-items-center justify-content-center"
                        style="width: 2rem; height: 2rem; border: none; background: transparent; color: #0f172a;"
                        title="收合/展開">
                    <i id="iconChevron" data-lucide="chevron-left" style="width: 1rem; height: 1rem; transition: transform 0.2s ease-in-out;"></i>
                </button>
            </div>

            <nav class="px-3 py-3 flex-grow-1" style="height: calc(100vh - 4rem); overflow-y: auto; overflow-x: hidden;">
                @{
                    var sidebarNavigation = ViewBag.SidebarNavigation as List<Models.HnbHnbBackoffice.vw_sidebar_navigation> ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
                    var rootItems = sidebarNavigation.Where(n => string.IsNullOrEmpty(n.parent_code)).OrderBy(n => n.sort_order).ToList();
                }
                
                @if (sidebarNavigation.Any())
                {
                    @foreach (var item in rootItems)
                    {
                        @await Html.PartialAsync("_NavigationItem", item, new ViewDataDictionary(ViewData) { { "AllNavigations", sidebarNavigation } })
                    }
                }
                else
                {
                    <!-- 預設導航項目（當沒有資料時） -->
                    <a href="@Url.Action("Index", "Dashboard", new { area = "Backoffice" })"
                       class="w-100 d-flex align-items-center gap-2 rounded px-3 py-2 text-decoration-none nav-item mb-1">
                        <i data-lucide="home" style="width: 1rem; height: 1rem; flex-shrink: 0;"></i>
                        <span class="text-truncate" data-collapsed-target>儀表板</span>
                    </a>
                    
                    @if (ViewBag.SidebarError != null)
                    {
                        <div class="px-3 py-2 text-danger small">
                            @ViewBag.SidebarError
                        </div>
                    }
                }
            </nav>
        </aside>

        <!-- Backdrop for mobile -->
        <div id="sidebarBackdrop" class="sidebar-backdrop position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50" style="z-index: 30;"></div>

        <!-- Main -->
        <div class="app-main flex-grow-1 d-flex flex-column overflow-hidden w-100">
            <!-- Header -->
            <header class="border-bottom bg-white bg-opacity-95 header-height">
                <div class="d-flex align-items-center justify-content-between p-4 h-100">
                    <!-- Mobile menu button -->
                    <button id="btnMobileMenu"
                            type="button"
                            class="btn btn-link p-0 d-lg-none d-inline-flex align-items-center justify-content-center"
                            style="width: 2.5rem; height: 2.5rem; flex-shrink: 0;"
                            title="選單">
                        <i data-lucide="menu" style="width: 1.25rem; height: 1.25rem;"></i>
                    </button>
                    
                    <h1 class="fs-6 mb-0 text-truncate flex-grow-1 text-start" style="min-width: 0;">後台管理系統</h1>
                    <div class="position-relative" style="flex-shrink: 0;">
                        <button id="btnUserMenu"
                                type="button"
                                class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 2rem; height: 2rem;"
                                aria-haspopup="menu"
                                aria-expanded="false">
                            <span class="small fw-medium">@avatarInitial</span>
                        </button>
                        <!-- Dropdown -->
                        <div id="userMenu"
                             class="dropdown-menu position-absolute end-0 mt-2"
                             style="width: 14rem; z-index: 50;"
                             role="menu" aria-labelledby="btnUserMenu">
                            <div class="px-3 py-2">
                                <p class="small fw-medium mb-0">@displayName</p>
                                <p class="small text-muted mb-0">@userEmail</p>
                                <p class="small text-muted mb-0 mt-1">
                                    <i data-lucide="shield" style="width: 0.875rem; height: 0.875rem; display: inline-block; vertical-align: middle;"></i>
                                    角色: @userRole
                                </p>
                                <p class="small text-muted mb-0">
                                    <i data-lucide="building" style="width: 0.875rem; height: 0.875rem; display: inline-block; vertical-align: middle;"></i>
                                    組織: @organizationName
                                </p>
                            </div>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item d-flex align-items-center gap-2" href="@Url.Action("Profile", "Backoffice", new { area = "Backoffice" })">
                                <i data-lucide="user" style="width: 1rem; height: 1rem;"></i> 個人資料
                            </a>
                            <div class="dropdown-divider"></div>
                            <form method="post" action="@Url.Action("Logout", "Authorize", new { area = "Backoffice" })">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="dropdown-item d-flex align-items-center gap-2 w-100 text-start border-0 bg-transparent">
                                    <i data-lucide="log-out" style="width: 1rem; height: 1rem;"></i> 登出
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <main class="flex-grow-1 overflow-auto p-3">
                <!-- Page Header -->
                @if (ViewData["PageTitle"] != null || ViewData["PageDescription"] != null || ViewData["PageIcon"] != null)
                {
                    <header class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between mb-3 gap-3">
                        <div class="w-100">
                            <h1 class="fw-bold d-flex align-items-center" style="font-size: 1.5rem; gap: 0.5rem;">
                                @if (ViewData["PageIcon"] != null)
                                {
                                    <i data-lucide='@ViewData["PageIcon"]' style="width: 1.5rem; height: 1.5rem;"></i>
                                }
                                <span>@(ViewData["PageTitle"] ?? ViewData["Title"])</span>
                            </h1>
                            @if (ViewData["PageDescription"] != null)
                            {
                                <p class="text-muted mb-0 mt-1 small">@ViewData["PageDescription"]</p>
                            }
                        </div>
                    </header>
                }
                
                @RenderBody()
            </main>
        </div>
    </div>

    @RenderSection("Scripts", required: false)
    <link rel="stylesheet" href="~/lib/file-preview/FilePreview.css">
    <script src="~/lib/file-preview/FilePreview.js"></script>
</body>
</html>
