@model Models.HnbHnbBackoffice.vw_sidebar_navigation
@{
    var allNavigations = ViewData["AllNavigations"] as List<Models.HnbHnbBackoffice.vw_sidebar_navigation> ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
    var children = allNavigations
        .Where(n => n.parent_code == Model.code)
        .OrderBy(n => n.sort_order)
        .ToList();
    
    var hasChildren = children.Any();
    
    var isExternalLink = !string.IsNullOrEmpty(Model.url) && 
                         (Model.url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || 
                          Model.url.StartsWith("https://", StringComparison.OrdinalIgnoreCase));
}

@if (hasChildren)
{
    <!-- 父項目 - 有子項目 -->
    <div class="mb-1">
        <button type="button"
                class="w-100 d-flex align-items-center rounded px-3 py-2 border-0 bg-transparent nav-item nav-toggle position-relative"
                data-target="nav-children-@Model.id"
                data-item-id="@Model.id">
            <i data-lucide="@(Model.icon ?? "folder")" style="width: 1rem; height: 1rem; flex-shrink: 0;"></i>
            <span class="text-truncate text-start ms-2" data-collapsed-target>@Model.title</span>
            <i data-lucide="chevron-right" class="nav-chevron-toggle position-absolute p-1" style="right: 0.75rem; transition: all 0.2s ease-in-out;"></i>
        </button>
        
        <div id="nav-children-@Model.id" class="nav-children hidden ms-3">
            @foreach (var child in children)
            {
                @await Html.PartialAsync("_NavigationItem", child, ViewData)
            }
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(Model.url))
{
    @if (isExternalLink)
    {
        <!-- 外部連結 -->
        <a href="@Model.url"
           target="_blank"
           rel="noopener noreferrer"
           class="w-100 d-flex align-items-center gap-2 rounded px-3 py-2 text-decoration-none nav-item mb-1 position-relative"
           data-nav-url="@Model.url"
           title="在新標籤頁開啟">
            <i data-lucide="@(Model.icon ?? "circle")" style="width: 1rem; height: 1rem; flex-shrink: 0;"></i>
            <span class="text-truncate" data-collapsed-target>@Model.title</span>
            <i data-lucide="external-link" class="text-muted position-absolute" style="width: 0.75rem; height: 0.75rem; right: 0.75rem;" data-collapsed-target></i>
        </a>
    }
    else
    {
        <!-- 內部連結 -->
        <a href="@Model.url"
           class="w-100 d-flex align-items-center gap-2 rounded px-3 py-2 text-decoration-none nav-item mb-1"
           data-nav-url="@Model.url">
            <i data-lucide="@(Model.icon ?? "circle")" style="width: 1rem; height: 1rem; flex-shrink: 0;"></i>
            <span class="text-truncate" data-collapsed-target>@Model.title</span>
        </a>
    }
}
else
{
    <!-- 無連結的標題 -->
    <div class="d-flex align-items-center gap-2 rounded px-3 py-2 text-muted mb-1">
        <i data-lucide="@(Model.icon ?? "circle")" style="width: 1rem; height: 1rem; flex-shrink: 0;"></i>
        <span class="text-truncate" data-collapsed-target>@Model.title</span>
    </div>
}
