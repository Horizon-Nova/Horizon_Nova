@model HNB.Areas.Backoffice.Services.NavigationItem
@{
    var hasChildren = Model.HasChildren;
    var itemId = $"nav-item-{Model.Id}";
    var childrenId = $"nav-children-{Model.Id}";
}

@if (hasChildren)
{
    <!-- 有子項目的導航項目 -->
    <div class="space-y-1">
        <button type="button" 
                class="w-full flex items-center gap-2 rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100 nav-toggle"
                data-target="@childrenId"
                data-item-id="@Model.Id">
            <i data-lucide="@(Model.Icon ?? "folder")" class="h-4 w-4 shrink-0"></i>
            <span class="truncate flex-1 text-left" data-collapsed-target>@Model.Title</span>
            <i data-lucide="chevron-right" class="h-4 w-4 shrink-0 transition-transform nav-chevron"></i>
        </button>
        
        <!-- 子項目容器 -->
        <div id="@childrenId" class="ml-6 space-y-1 hidden nav-children">
            @foreach (var child in Model.Children.OrderBy(c => c.SortOrder))
            {
                @if (child.IsActive)
                {
                    @await Html.PartialAsync("_NavigationItem", child, ViewData)
                }
            }
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(Model.Url))
{
    <!-- 有連結的導航項目 -->
    <a href="@Model.Url"
       class="nav-item w-full flex items-center gap-2 rounded-md px-3 py-2 hover:bg-slate-100"
       data-nav-url="@Model.Url">
        <i data-lucide="@(Model.Icon ?? "circle")" class="h-4 w-4 shrink-0"></i>
        <span class="truncate" data-collapsed-target>@Model.Title</span>
    </a>
}
else
{
    <!-- 純顯示的導航項目 -->
    <div class="flex items-center gap-2 rounded-md px-3 py-2 text-slate-600">
        <i data-lucide="@(Model.Icon ?? "circle")" class="h-4 w-4 shrink-0"></i>
        <span class="truncate" data-collapsed-target>@Model.Title</span>
    </div>
}
