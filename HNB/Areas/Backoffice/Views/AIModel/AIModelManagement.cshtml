@using Models.HnbHnbBackoffice
@{
    ViewData["Title"] = "系統管理 - AI模型管理";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
    
    // 從 ViewBag 取得資料
    var aiConfigs = (List<vw_ai_config>)ViewBag.AIConfigs ?? new List<vw_ai_config>();
    var currentAIConfig = (vw_ai_config?)ViewBag.AIConfig;
    var configId = (long?)ViewBag.Id;
    
    // 計算統計資料
    var totalCount = aiConfigs.Count;
    var enabledCount = aiConfigs.Count(c => c.is_enabled == true);
}

<section class="mb-4">
    <!-- 頁面標題 -->
    <header class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between mb-4">
        <div>
            <h1 class="h2 h1-lg d-flex align-items-center gap-2">
                <i data-lucide="brain" style="width: 2rem; height: 2rem;"></i> AI模型管理
            </h1>
            <p class="text-muted mt-1">管理和監控所有AI模型服務</p>
        </div>
        <button type="button" onclick="showModal('helpModal')" class="btn btn-link text-muted p-2" title="操作說明">
            <i data-lucide="help-circle" style="width: 1.25rem; height: 1.25rem;"></i>
        </button>
    </header>

    <!-- 統計卡片 -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="card-subtitle text-muted small mb-0">總使用次數 (今日)</h6>
                        <i data-lucide="activity" class="text-muted" style="width: 1rem; height: 1rem;"></i>
                    </div>
                    <div class="h4 mb-0" id="todayUsageCount">-</div>
                    <p class="small text-muted mb-0">統計中...</p>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="card-subtitle text-muted small mb-0">啟用模型</h6>
                        <i data-lucide="zap" class="text-muted" style="width: 1rem; height: 1rem;"></i>
                    </div>
                    <div class="h4 mb-0">@enabledCount</div>
                    <p class="small text-muted mb-0">共 @totalCount 個模型</p>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="card-subtitle text-muted small mb-0">平均品質分數</h6>
                        <i data-lucide="trending-up" class="text-muted" style="width: 1rem; height: 1rem;"></i>
                    </div>
                    <div class="h4 mb-0">
                        @{
                            var avgQuality = aiConfigs.Any() ? aiConfigs.Average(c => c.quality_score ?? 0) : 0;
                        }
                        @avgQuality.ToString("F1")%
                    </div>
                    <p class="small text-muted mb-0">平均模型品質</p>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="card-subtitle text-muted small mb-0">系統狀態</h6>
                        <i data-lucide="server" class="text-muted" style="width: 1rem; height: 1rem;"></i>
                    </div>
                    <div class="h4 mb-0 @(enabledCount > 0 ? "text-success" : "text-muted")">
                        @(enabledCount > 0 ? "正常" : "無啟用")
                    </div>
                    <p class="small text-muted mb-0">@enabledCount 個服務運行中</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 篩選和搜尋 -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i data-lucide="search" class="text-muted" style="width: 1rem; height: 1rem;"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control" placeholder="搜尋模型名稱或描述...">
                </div>
            </div>
            <div class="row g-2">
                <div class="col-6 col-lg-3">
                    <select id="typeFilter" class="form-select form-select-sm">
                        <option value="all">所有類型</option>
                        <option value="text">文字生成</option>
                        <option value="image">圖像生成</option>
                        <option value="voice">語音處理</option>
                        <option value="video">視頻處理</option>
                        <option value="multimodal">多模態</option>
                    </select>
                </div>
                <div class="col-6 col-lg-3">
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="all">所有狀態</option>
                        <option value="active">啟用</option>
                        <option value="inactive">停用</option>
                        <option value="maintenance">維護中</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- AI控制中心主面板 -->
    <div class="row g-4">
        <!-- AI服務列表 -->
        <div class="col-12 col-xl-8">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-3 mb-4">
                        <h3 class="h5 mb-0">AI服務控制台</h3>
                        <button type="button" onclick="showModal('createModelModal')" class="btn btn-primary btn-sm">
                            <i data-lucide="plus" class="me-2" style="width: 1rem; height: 1rem;"></i>
                            新增AI服務
                        </button>
                    </div>
                    
                    <!-- AI服務卡片列表 -->
                    <div id="aiServicesList" class="vstack gap-3">
                        @if (!aiConfigs.Any())
                        {
                            <!-- 空狀態 -->
                            <div class="text-center py-5 bg-light rounded">
                                <i data-lucide="inbox" class="text-muted mb-3" style="width: 3rem; height: 3rem;"></i>
                                <h5 class="mb-2">尚未配置任何 AI 服務</h5>
                                <p class="text-muted mb-3">點擊「新增AI服務」開始配置您的第一個 AI 模型</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var config in aiConfigs)
                            {
                                var iconName = config.scope?.Contains("image") == true ? "image" : 
                                              config.scope?.Contains("vision") == true ? "eye" :
                                              config.scope?.Contains("text") == true ? "file-text" : "brain";
                                var bgColor = config.is_enabled == true ? "bg-primary bg-opacity-10" : "bg-secondary bg-opacity-10";
                                var iconColor = config.is_enabled == true ? "text-primary" : "text-secondary";
                                var statusClass = config.is_enabled == true ? "bg-success text-white" : "bg-secondary text-white";
                                var statusText = config.is_enabled == true ? "啟用" : "停用";
                                
                                <div class="card" data-service-id="@config.id">
                                    <div class="card-body">
                                        <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-3 mb-2">
                                            <div class="d-flex align-items-center gap-3 flex-grow-1">
                                                <div class="@bgColor rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 2.5rem; height: 2.5rem;">
                                                    <i data-lucide="@iconName" class="@iconColor" style="width: 1.25rem; height: 1.25rem;"></i>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <h6 class="mb-0">@config.service_name</h6>
                                                    <p class="small text-muted mb-0">@config.provider • @config.scope</p>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge @statusClass">@statusText</span>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" onclick="loadAIConfigModal(@config.id)" title="編輯">
                                                        <i data-lucide="edit" style="width: 1rem; height: 1rem;"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" onclick="deleteAIService(@config.id)" title="刪除">
                                                        <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(config.description))
                                        {
                                            <p class="small text-muted mb-2">@config.description</p>
                                        }
                                        <div class="small text-muted d-flex flex-wrap gap-3">
                                            <span>Model: <code class="small">@config.model_key</code></span>
                                            @if (config.version != null)
                                            {
                                                <span>版本: @config.version</span>
                                            }
                                            @if (config.priority != null)
                                            {
                                                <span>優先級: @config.priority</span>
                                            }
                                            @if (config.quality_score != null)
                                            {
                                                <span>品質: @config.quality_score.Value.ToString("F1")%</span>
                                            }
                                            @if (config.daily_limit != null)
                                            {
                                                <span>每日限額: @config.daily_limit</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 控制面板 -->
        <div class="col-12 col-xl-4">
            <div class="vstack gap-4">
                <!-- 快速操作 -->
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">快速操作</h5>
                        <div class="d-grid gap-2">
                            <button type="button" id="testAllConnectionsBtn" class="btn btn-warning btn-sm">
                                <i data-lucide="wifi" class="me-2" style="width: 1rem; height: 1rem;"></i>
                                測試所有連線
                            </button>
                            <button type="button" id="refreshStatsBtn" class="btn btn-success btn-sm">
                                <i data-lucide="refresh-cw" class="me-2" style="width: 1rem; height: 1rem;"></i>
                                刷新統計
                            </button>
                            <button type="button" id="exportConfigBtn" class="btn btn-info btn-sm text-white">
                                <i data-lucide="download" class="me-2" style="width: 1rem; height: 1rem;"></i>
                                匯出配置
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 系統狀態 -->
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">系統狀態</h5>
                        <div class="vstack gap-2">
                            <div class="d-flex justify-content-between">
                                <span class="small text-muted">總服務數</span>
                                <span class="fw-medium" id="totalServices">@totalCount</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="small text-muted">啟用服務</span>
                                <span class="fw-medium text-success" id="activeServices">@enabledCount</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="small text-muted">停用服務</span>
                                <span class="fw-medium text-danger" id="offlineServices">@(totalCount - enabledCount)</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="small text-muted">今日調用</span>
                                <span class="fw-medium text-primary" id="todayCalls">-</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 說明 Modal (靜態) -->
<div id="helpModal" class="modal fade" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="helpModalLabel">AI模型管理操作說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">什麼是AI模型管理？</h6>
                                <p class="small">AI模型管理讓您統一管理系統中所有的AI服務，包括文字生成、圖像生成、語音處理等多模態AI模型，監控使用狀況和效能。</p>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">主要功能</h6>
                                <ul class="small">
                                    <li><strong>模型配置：</strong>新增、編輯、刪除AI模型配置</li>
                                    <li><strong>啟用控制：</strong>快速啟用或停用特定AI模型</li>
                                    <li><strong>使用統計：</strong>查看每日調用次數和使用趨勢</li>
                                    <li><strong>效能監控：</strong>監控回應時間、成功率等指標</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">模型類型</h6>
                                <div class="row g-2 small">
                                    <div class="col-6">
                                        <div class="d-flex align-items-center gap-2 p-2 border rounded">
                                            <i data-lucide="file-text" class="text-primary" style="width: 1rem; height: 1rem;"></i>
                                            <span>文字生成</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center gap-2 p-2 border rounded">
                                            <i data-lucide="image" class="text-success" style="width: 1rem; height: 1rem;"></i>
                                            <span>圖像生成</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center gap-2 p-2 border rounded">
                                            <i data-lucide="mic" class="text-warning" style="width: 1rem; height: 1rem;"></i>
                                            <span>語音處理</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center gap-2 p-2 border rounded">
                                            <i data-lucide="video" class="text-info" style="width: 1rem; height: 1rem;"></i>
                                            <span>視頻處理</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">使用建議</h6>
                                <div class="alert alert-warning small mb-0">
                                    <ul class="mb-0">
                                        <li>定期檢查模型使用統計，優化資源配置</li>
                                        <li>測試環境建議使用品質較低的模型以節省成本</li>
                                        <li>啟用多個備援模型提高服務可用性</li>
                                        <li>注意API密鑰安全，定期更新</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal 空容器（用於動態載入） -->
<div id="aiModal"></div>

@section Scripts {
    <script src="~/Backoffice/js/AIModelManagement.js"></script>
}
