@using Models.HnbHnbBackoffice
@{
    ViewData["Title"] = "系統管理 - AI模型管理";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
    
    // 從 ViewBag 取得資料
    var aiConfigs = (List<vw_ai_config>)ViewBag.AIConfigs ?? new List<vw_ai_config>();
    var currentAIConfig = (vw_ai_config?)ViewBag.AIConfig;
    var configId = (long?)ViewBag.Id;
    
    // 計算統計資料
    var totalCount = aiConfigs.Count;
    var enabledCount = aiConfigs.Count(c => c.is_enabled == true);
}

<section class="space-y-4 lg:space-y-6">
    <!-- 頁面標題 -->
    <header class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-3">
        <div class="w-full lg:w-auto">
            <h1 class="text-2xl lg:text-3xl font-bold flex items-center gap-2 lg:gap-3">
                <i data-lucide="brain" class="h-6 w-6 lg:h-8 lg:w-8"></i> AI模型管理
            </h1>
            <p class="text-sm lg:text-base text-slate-500 mt-1">管理和監控所有AI模型服務</p>
        </div>
        <button type="button" onclick="event.stopPropagation(); showModal('aimodel-help')" class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 p-2 rounded-lg transition-all duration-200" title="操作說明">
            <i data-lucide="help-circle" class="w-5 h-5"></i>
        </button>
    </header>
    <!-- 統計卡片 -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-6">
        <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs lg:text-sm font-medium text-gray-600 truncate">總使用次數 (今日)</h3>
                <i data-lucide="activity" class="h-4 w-4 text-gray-400 flex-shrink-0"></i>
            </div>
            <div class="text-xl lg:text-2xl font-bold text-gray-900" id="todayUsageCount">-</div>
            <p class="text-xs text-gray-500 truncate">統計中...</p>
        </div>

        <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs lg:text-sm font-medium text-gray-600 truncate">啟用模型</h3>
                <i data-lucide="zap" class="h-4 w-4 text-gray-400 flex-shrink-0"></i>
            </div>
            <div class="text-xl lg:text-2xl font-bold text-gray-900">@enabledCount</div>
            <p class="text-xs text-gray-500 truncate">共 @totalCount 個模型</p>
        </div>

        <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs lg:text-sm font-medium text-gray-600 truncate">平均品質分數</h3>
                <i data-lucide="trending-up" class="h-4 w-4 text-gray-400 flex-shrink-0"></i>
            </div>
            <div class="text-xl lg:text-2xl font-bold text-gray-900">
                @{
                    var avgQuality = aiConfigs.Any() ? aiConfigs.Average(c => c.quality_score ?? 0) : 0;
                }
                @avgQuality.ToString("F1")%
            </div>
            <p class="text-xs text-gray-500 truncate">平均模型品質</p>
        </div>

        <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs lg:text-sm font-medium text-gray-600 truncate">系統狀態</h3>
                <i data-lucide="server" class="h-4 w-4 text-gray-400 flex-shrink-0"></i>
            </div>
            <div class="text-xl lg:text-2xl font-bold @(enabledCount > 0 ? "text-green-600" : "text-gray-400")">
                @(enabledCount > 0 ? "正常" : "無啟用")
            </div>
            <p class="text-xs text-gray-500 truncate">@enabledCount 個服務運行中</p>
        </div>
    </div>

    <!-- 篩選和搜尋 -->
    <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
        <div class="flex flex-col gap-3 lg:gap-4">
            <div class="relative w-full">
                    <i data-lucide="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 h-4 w-4"></i>
                    <input type="text" id="searchInput" placeholder="搜尋模型名稱或描述..."
                       class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg w-full text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 lg:gap-3">
                <select id="typeFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <option value="all">所有類型</option>
                    <option value="text">文字生成</option>
                    <option value="image">圖像生成</option>
                    <option value="voice">語音處理</option>
                    <option value="video">視頻處理</option>
                    <option value="multimodal">多模態</option>
                </select>
                <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <option value="all">所有狀態</option>
                    <option value="active">啟用</option>
                    <option value="inactive">停用</option>
                    <option value="maintenance">維護中</option>
                </select>
            </div>
        </div>
    </div>

    <!-- AI控制中心主面板 -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 lg:gap-6">
        <!-- AI服務列表 -->
        <div class="xl:col-span-2">
            <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-4 lg:mb-6">
                    <h3 class="text-lg lg:text-xl font-semibold text-gray-900">AI服務控制台</h3>
                    <button type="button" onclick="event.stopPropagation(); showModal('createModelModal')" class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm">
                        <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
                        新增AI服務
                    </button>
                </div>
                
                <!-- AI服務卡片列表 -->
                <div id="aiServicesList" class="space-y-4">
                    @if (!aiConfigs.Any())
                    {
                        <!-- 空狀態 -->
                        <div class="text-center py-12 bg-gray-50 rounded-lg">
                            <i data-lucide="inbox" class="h-12 w-12 mx-auto text-gray-300 mb-4"></i>
                            <h3 class="text-sm font-medium text-gray-900 mb-2">尚未配置任何 AI 服務</h3>
                            <p class="text-sm text-gray-500 mb-4">點擊「新增AI服務」開始配置您的第一個 AI 模型</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var config in aiConfigs)
                        {
                            var iconName = config.scope?.Contains("image") == true ? "image" : 
                                          config.scope?.Contains("vision") == true ? "eye" :
                                          config.scope?.Contains("text") == true ? "file-text" : "brain";
                            var bgColor = config.is_enabled == true ? "bg-purple-100" : "bg-gray-100";
                            var iconColor = config.is_enabled == true ? "text-purple-600" : "text-gray-400";
                            var statusClass = config.is_enabled == true ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600";
                            var statusText = config.is_enabled == true ? "啟用" : "停用";
                            
                            <div class="border rounded-lg p-3 lg:p-4 hover:shadow-md transition-shadow" data-service-id="@config.id">
                                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-3">
                                    <div class="flex items-center gap-3 min-w-0 flex-1">
                                        <div class="w-10 h-10 @bgColor rounded-full flex items-center justify-center flex-shrink-0">
                                            <i data-lucide="@iconName" class="h-5 w-5 @iconColor"></i>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <h4 class="font-medium text-gray-900 truncate">@config.service_name</h4>
                                            <p class="text-xs lg:text-sm text-gray-500 truncate">@config.provider • @config.scope</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full @statusClass whitespace-nowrap">@statusText</span>
                                        <div class="flex gap-1">
                                            <button class="p-1 text-gray-400 hover:text-blue-600" onclick="event.stopPropagation(); showModal('aiConfigModal')" title="編輯">
                                                <i data-lucide="edit" class="h-4 w-4"></i>
                                            </button>
                                            <button class="p-1 text-gray-400 hover:text-red-600" onclick="deleteAIService(@config.id)" title="刪除">
                                                <i data-lucide="trash-2" class="h-4 w-4"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="space-y-1">
                                    @if (!string.IsNullOrEmpty(config.description))
                                    {
                                        <p class="text-xs lg:text-sm text-gray-600 break-words">@config.description</p>
                                    }
                                    <div class="text-xs lg:text-sm text-gray-600 flex flex-wrap gap-x-3 lg:gap-x-4 gap-y-1">
                                        <span class="truncate">Model: <span class="font-mono text-xs">@config.model_key</span></span>
                                        @if (config.version != null)
                                        {
                                            <span class="whitespace-nowrap">版本: @config.version</span>
                                        }
                                        @if (config.priority != null)
                                        {
                                            <span class="whitespace-nowrap">優先級: @config.priority</span>
                                        }
                                        @if (config.quality_score != null)
                                        {
                                            <span class="whitespace-nowrap">品質: @config.quality_score.Value.ToString("F1")%</span>
                                        }
                                        @if (config.daily_limit != null)
                                        {
                                            <span class="whitespace-nowrap">每日限額: @config.daily_limit</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- 控制面板 -->
        <div class="space-y-4 lg:space-y-6">
            <!-- 快速操作 -->
            <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
                <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4">快速操作</h3>
                <div class="space-y-2 lg:space-y-3">
                    <button type="button" id="testAllConnectionsBtn" class="w-full flex items-center justify-center px-4 py-2 bg-yellow-100 text-yellow-700 rounded-lg hover:bg-yellow-200 transition-colors text-sm">
                        <i data-lucide="wifi" class="h-4 w-4 mr-2"></i>
                        測試所有連線
                    </button>
                    <button type="button" id="refreshStatsBtn" class="w-full flex items-center justify-center px-4 py-2 bg-green-100 text-green-700 rounded-lg hover:bg-green-200 transition-colors text-sm">
                        <i data-lucide="refresh-cw" class="h-4 w-4 mr-2"></i>
                        刷新統計
                    </button>
                    <button type="button" id="exportConfigBtn" class="w-full flex items-center justify-center px-4 py-2 bg-purple-100 text-purple-700 rounded-lg hover:bg-purple-200 transition-colors text-sm">
                        <i data-lucide="download" class="h-4 w-4 mr-2"></i>
                        匯出配置
                    </button>
                </div>
            </div>

            <!-- 系統狀態 -->
            <div class="bg-white border rounded-xl p-4 lg:p-6 shadow-sm">
                <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4">系統狀態</h3>
                <div class="space-y-2 lg:space-y-3">
                    <div class="flex items-center justify-between">
                        <span class="text-xs lg:text-sm text-gray-600">總服務數</span>
                        <span class="font-medium text-gray-900 text-sm" id="totalServices">@totalCount</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs lg:text-sm text-gray-600">啟用服務</span>
                        <span class="font-medium text-green-600 text-sm" id="activeServices">@enabledCount</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs lg:text-sm text-gray-600">停用服務</span>
                        <span class="font-medium text-red-600 text-sm" id="offlineServices">@(totalCount - enabledCount)</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs lg:text-sm text-gray-600">今日調用</span>
                        <span class="font-medium text-blue-600 text-sm" id="todayCalls">-</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_AIModelModal")