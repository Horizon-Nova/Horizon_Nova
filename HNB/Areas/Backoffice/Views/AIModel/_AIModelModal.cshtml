@using Models.HnbHnbBackoffice
@{
    Layout = null;
    var id = ViewBag.Id as long?;
    var aiConfig = ViewBag.AIConfig as vw_ai_config;
}

<!-- AI配置 Modal -->
<div id="aiConfigModal" class="modal fade" tabindex="-1" aria-labelledby="aiConfigModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="aiConfigModalLabel">
                    @(id.HasValue ? "編輯 AI 服務配置" : "新增 AI 服務配置")
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body">
                <form id="aiConfigForm">
                    <input type="hidden" name="id" value="@(id ?? 0)" />
                    
                    <!-- 服務基本資訊 -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h6 class="mb-0">服務基本資訊</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="serviceName" class="form-label">服務名稱 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="serviceName" name="service_name" 
                                           value="@(aiConfig?.service_name ?? "")" required>
                                </div>
                                <div class="col-md-3">
                                    <label for="provider" class="form-label">提供商 <span class="text-danger">*</span></label>
                                    <select class="form-select" id="provider" name="provider" required>
                                        <option value="">選擇提供商</option>
                                        <option value="OpenAI" @(aiConfig?.provider == "OpenAI" ? "selected" : "")>OpenAI</option>
                                        <option value="Anthropic" @(aiConfig?.provider == "Anthropic" ? "selected" : "")>Anthropic</option>
                                        <option value="Google" @(aiConfig?.provider == "Google" ? "selected" : "")>Google</option>
                                        <option value="Microsoft" @(aiConfig?.provider == "Microsoft" ? "selected" : "")>Microsoft</option>
                                        <option value="Custom" @(aiConfig?.provider == "Custom" ? "selected" : "")>自訂</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label for="scope" class="form-label">Scope <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="scope" name="scope" 
                                           value="@(aiConfig?.scope ?? "")" placeholder="例如: image.general" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="modelKey" class="form-label">Model Key <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="modelKey" name="model_key" 
                                           value="@(aiConfig?.model_key ?? "")" placeholder="例如: gpt-4" required>
                                </div>
                                <div class="col-md-3">
                                    <label for="version" class="form-label">版本</label>
                                    <input type="text" class="form-control" id="version" name="version" 
                                           value="@(aiConfig?.version ?? "")">
                                </div>
                                <div class="col-md-3">
                                    <label for="priority" class="form-label">優先級</label>
                                    <select class="form-select" id="priority" name="priority">
                                        <option value="1" @(aiConfig?.priority == 1 ? "selected" : "")>高 (1)</option>
                                        <option value="2" @(aiConfig?.priority == 2 ? "selected" : "")>中 (2)</option>
                                        <option value="3" @(aiConfig?.priority == 3 ? "selected" : "")>低 (3)</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="description" class="form-label">描述</label>
                                    <textarea class="form-control" id="description" name="description" rows="2">@(aiConfig?.description ?? "")</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 使用限制 -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h6 class="mb-0">使用限制</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label for="dailyLimit" class="form-label">每日限額</label>
                                    <input type="number" class="form-control" id="dailyLimit" name="daily_limit" 
                                           value="@(aiConfig?.daily_limit ?? 0)" min="0">
                                </div>
                                <div class="col-md-3">
                                    <label for="monthlyBudget" class="form-label">月度預算</label>
                                    <input type="number" class="form-control" id="monthlyBudget" name="monthly_budget" 
                                           value="@(aiConfig?.monthly_budget ?? 0)" min="0" step="0.01">
                                </div>
                                <div class="col-md-3">
                                    <label for="yearlyBudget" class="form-label">年度預算</label>
                                    <input type="number" class="form-control" id="yearlyBudget" name="yearly_budget" 
                                           value="@(aiConfig?.yearly_budget ?? 0)" min="0" step="0.01">
                                </div>
                                <div class="col-md-3">
                                    <label for="qualityScore" class="form-label">品質分數 (%)</label>
                                    <input type="number" class="form-control" id="qualityScore" name="quality_score" 
                                           value="@(aiConfig?.quality_score ?? 0)" min="0" max="100" step="0.1">
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" id="isEnabled" name="is_enabled" 
                                               @(aiConfig?.is_enabled == true ? "checked" : "")>
                                        <label class="form-check-label" for="isEnabled">啟用服務</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 系統提示詞 -->
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">系統提示詞</h6>
                        </div>
                        <div class="card-body">
                            <label for="systemPrompt" class="form-label">System Prompt</label>
                            <textarea class="form-control font-monospace small" id="systemPrompt" name="system_prompt" rows="6">@(aiConfig?.system_prompt ?? "")</textarea>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="saveAIConfig()">儲存配置</button>
            </div>
        </div>
    </div>
</div>

<!-- 新增 AI 模型 Modal -->
<div id="createModelModal" class="modal fade" tabindex="-1" aria-labelledby="createModelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="createModelModalLabel">新增AI模型</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body">
                <form id="createModelForm">
                    <!-- 基本資訊 -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h6 class="mb-0">基本資訊</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">模型名稱 <span class="text-danger">*</span></label>
                                    <input type="text" name="service_name" class="form-control" 
                                           placeholder="例：GPT-4 Turbo" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">版本</label>
                                    <input type="text" name="version" class="form-control" 
                                           placeholder="例：1.0.0">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">描述</label>
                                    <textarea name="description" rows="2" class="form-control" 
                                              placeholder="請輸入模型描述..."></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">模型類型</label>
                                    <select name="scope" id="modelType" class="form-select">
                                        <option value="text.general">文字生成</option>
                                        <option value="image.general">圖像生成</option>
                                        <option value="audio.general">音訊處理</option>
                                        <option value="video.general">影片處理</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">提供商 <span class="text-danger">*</span></label>
                                    <input type="text" name="provider" class="form-control" 
                                           placeholder="例：OpenAI" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- API 配置 -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h6 class="mb-0">API 配置</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Model Key <span class="text-danger">*</span></label>
                                    <input type="text" name="model_key" class="form-control" 
                                           placeholder="例：gpt-4-turbo" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">每日限額</label>
                                    <input type="number" name="daily_limit" class="form-control" 
                                           placeholder="1000" min="0">
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-success" onclick="saveAIConfig()">創建模型</button>
            </div>
        </div>
    </div>
</div>
