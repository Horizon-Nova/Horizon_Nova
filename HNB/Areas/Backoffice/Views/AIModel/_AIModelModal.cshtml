<script>
    // AI模態框特定邏輯：模型類型切換配置顯示
    document.addEventListener('DOMContentLoaded', function() {
        const modelTypeSelect = document.getElementById('modelType');
        if (modelTypeSelect) {
            modelTypeSelect.addEventListener('change', function() {
                const textConfig = document.getElementById('textConfig');
                const imageConfig = document.getElementById('imageConfig');
                if (this.value === 'text') {
                    textConfig?.classList.remove('hidden');
                    imageConfig?.classList.add('hidden');
                } else if (this.value === 'image') {
                    textConfig?.classList.add('hidden');
                    imageConfig?.classList.remove('hidden');
                } else {
                    textConfig?.classList.add('hidden');
                    imageConfig?.classList.add('hidden');
                }
            });
        }
    });
</script>

