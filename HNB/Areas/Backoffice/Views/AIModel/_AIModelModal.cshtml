<!-- 動態AI配置控制中心 -->
<div id="aiConfigModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50">
    <div class="flex items-center justify-center min-h-screen p-2 lg:p-4">
        <div class="bg-white rounded-xl lg:rounded-2xl shadow-2xl w-full max-w-6xl max-h-[95vh] lg:max-h-[90vh] overflow-hidden flex flex-col">
            <!-- 標題區 -->
            <div class="bg-gradient-to-r from-blue-600 to-blue-700 p-3 lg:p-6 flex-shrink-0">
                <div class="flex items-center justify-between gap-3">
                    <h2 class="text-base lg:text-2xl font-bold text-white truncate min-w-0" id="modalTitle">AI服務配置中心</h2>
                    <button type="button" id="closeModal" class="text-white hover:text-blue-200 flex-shrink-0 transition-colors">
                        <i data-lucide="x" class="h-5 w-5 lg:h-6 lg:w-6"></i>
                    </button>
                </div>
            </div>
            
            <!-- 內容區 -->
            <div class="flex-1 overflow-y-auto">
                <div class="p-4 lg:p-6">
                    <!-- 服務基本資訊 -->
                    <div class="bg-gray-50 rounded-lg p-4 lg:p-6 mb-4 lg:mb-6">
                        <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4">服務基本資訊</h3>
                        <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-3 lg:gap-4">
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">服務名稱 *</label>
                                <input type="text" id="serviceName" required 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                       placeholder="例如: DALL-E 3">
                            </div>
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">提供商 *</label>
                                <select id="provider" required class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                    <option value="">選擇提供商</option>
                                    <option value="OpenAI">OpenAI</option>
                                    <option value="Anthropic">Anthropic</option>
                                    <option value="Google">Google</option>
                                    <option value="Microsoft">Microsoft</option>
                                    <option value="Moondream">Moondream</option>
                                    <option value="Custom">自訂</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">Scope *</label>
                                <input type="text" id="scope" required 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                       placeholder="例如: image.general">
                            </div>
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">Model Key *</label>
                                <input type="text" id="modelKey" required 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                       placeholder="例如: gpt-image-1">
                            </div>
                        </div>
                    </div>

                    <!-- 動態配置區域 -->
                    <div class="bg-white border rounded-lg p-4 lg:p-6 mb-4 lg:mb-6">
                        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-4 lg:mb-6">
                            <h3 class="text-base lg:text-lg font-semibold text-gray-900">動態配置參數</h3>
                            <div class="flex items-center gap-2 lg:gap-3 w-full sm:w-auto">
                                <button type="button" id="sortConfigBtn" class="inline-flex items-center px-2 lg:px-3 py-1.5 lg:py-2 text-xs lg:text-sm border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors flex-1 sm:flex-initial justify-center">
                                    <i data-lucide="arrow-up-down" class="h-3.5 w-3.5 lg:h-4 lg:w-4 mr-1 lg:mr-2"></i>
                                    排序
                                </button>
                                <button type="button" id="addConfigBtn" class="inline-flex items-center px-3 lg:px-4 py-1.5 lg:py-2 text-xs lg:text-sm bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors flex-1 sm:flex-initial justify-center">
                                    <i data-lucide="plus" class="h-3.5 w-3.5 lg:h-4 lg:w-4 mr-1 lg:mr-2"></i>
                                    新增參數
                                </button>
                            </div>
                        </div>
                        
                        <!-- 配置參數表格 -->
                        <div class="overflow-hidden border border-gray-200 rounded-lg">
                            <div class="overflow-x-auto">
                                <table class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50 hidden lg:table-header-group">
                                        <tr>
                                            <th scope="col" class="w-8 px-2 lg:px-3 py-2 lg:py-3 text-left">
                                                <i data-lucide="grip-vertical" class="h-3.5 w-3.5 lg:h-4 lg:w-4 text-gray-400"></i>
                                            </th>
                                            <th scope="col" class="px-3 lg:px-4 py-2 lg:py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                參數名稱
                                            </th>
                                            <th scope="col" class="px-3 lg:px-4 py-2 lg:py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                顯示標籤
                                            </th>
                                            <th scope="col" class="px-3 lg:px-4 py-2 lg:py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                參數值
                                            </th>
                                            <th scope="col" class="px-3 lg:px-4 py-2 lg:py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                類型
                                            </th>
                                            <th scope="col" class="px-3 lg:px-4 py-2 lg:py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                必填
                                            </th>
                                            <th scope="col" class="w-16 px-3 lg:px-4 py-2 lg:py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                操作
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody id="configParameters" class="bg-white divide-y divide-gray-200">
                                        <!-- 動態生成的配置項目會出現在這裡 -->
                                    </tbody>
                                </table>
                            </div>
                            
                        <!-- 空狀態 -->
                        <div id="emptyConfigState" class="text-center py-8 lg:py-12 bg-gray-50">
                            <i data-lucide="settings" class="h-10 w-10 lg:h-12 lg:w-12 mx-auto text-gray-300 mb-3 lg:mb-4"></i>
                            <h3 class="text-xs lg:text-sm font-medium text-gray-900 mb-2">尚未配置任何參數</h3>
                            <p class="text-xs lg:text-sm text-gray-500 px-4">點擊上方「新增參數」按鈕開始配置您的AI服務</p>
                        </div>
                        </div>
                    </div>

                    <!-- 提示詞模板管理 -->
                    <div class="bg-white border rounded-lg p-4 lg:p-6 mb-4 lg:mb-6">
                        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-4">
                            <h3 class="text-base lg:text-lg font-semibold text-gray-900">提示詞模板</h3>
                            <button type="button" id="addPromptBtn" class="inline-flex items-center px-3 py-1.5 lg:py-2 text-xs lg:text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors w-full sm:w-auto justify-center">
                                <i data-lucide="plus" class="h-3.5 w-3.5 lg:h-4 lg:w-4 mr-1 lg:mr-2"></i>
                                新增模板
                            </button>
                        </div>
                        
                        <!-- 提示詞模板容器 -->
                        <div id="promptTemplates" class="space-y-3 lg:space-y-4">
                            <!-- 動態生成的提示詞模板會出現在這裡 -->
                        </div>
                    </div>

                    <!-- 使用限制 -->
                    <div class="bg-white border rounded-lg p-4 lg:p-6 mb-4 lg:mb-6">
                        <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4">使用限制</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">每日限額</label>
                                <input type="number" id="dailyLimit" min="0" 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                       placeholder="1000">
                            </div>
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">優先級</label>
                                <select id="priority" class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                    <option value="1">高 (1)</option>
                                    <option value="2" selected>中 (2)</option>
                                    <option value="3">低 (3)</option>
                                </select>
                            </div>
                            <div class="flex items-center pt-2 lg:pt-6">
                                <input type="checkbox" id="isEnabled" checked
                                       class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                                <label for="isEnabled" class="ml-2 text-xs lg:text-sm text-gray-700">啟用服務</label>
                            </div>
                            <div>
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">描述</label>
                                <input type="text" id="description" 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                       placeholder="服務描述">
                            </div>
                        </div>
                    </div>

                    <!-- 操作按鈕 -->
                    <div class="flex flex-col sm:flex-row justify-end gap-2 lg:gap-3 pt-4 lg:pt-6 border-t">
                        <button type="button" id="cancelBtn" class="px-4 lg:px-6 py-2 text-xs lg:text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors order-last sm:order-first">
                            取消
                        </button>
                        <button type="button" id="testConnectionBtn" class="px-4 lg:px-6 py-2 text-xs lg:text-sm bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition-colors">
                            <i data-lucide="wifi" class="h-3.5 w-3.5 lg:h-4 lg:w-4 mr-1 lg:mr-2 inline"></i>
                            測試連線
                        </button>
                        <button type="button" onclick="event.stopPropagation(); showModal('configPreviewModal')" class="px-4 lg:px-6 py-2 text-xs lg:text-sm bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
                            <i data-lucide="eye" class="h-3.5 w-3.5 lg:h-4 lg:w-4 mr-1 lg:mr-2 inline"></i>
                            預覽配置
                        </button>
                        <button type="button" id="saveConfigBtn" class="px-4 lg:px-6 py-2 text-xs lg:text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                            <i data-lucide="save" class="h-3.5 w-3.5 lg:h-4 lg:w-4 mr-1 lg:mr-2 inline"></i>
                            儲存配置
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 配置預覽模態視窗 -->
<div id="configPreviewModal" class="fixed inset-0 bg-black bg-opacity-50 hidden" style="z-index: 60;">
    <div class="flex items-center justify-center min-h-screen p-2 lg:p-4">
        <div class="bg-white rounded-xl lg:rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col">
            <div class="bg-gradient-to-r from-purple-600 to-purple-700 p-3 lg:p-6 flex-shrink-0">
                <div class="flex items-center justify-between gap-3">
                    <h2 class="text-base lg:text-xl font-bold text-white">配置預覽</h2>
                    <button type="button" id="closePreviewModal" class="text-white hover:text-purple-200 flex-shrink-0 transition-colors">
                        <i data-lucide="x" class="h-5 w-5 lg:h-6 lg:w-6"></i>
                    </button>
                </div>
            </div>
            <div class="p-4 lg:p-6 flex-1 overflow-y-auto">
                <pre id="configPreview" class="bg-gray-100 rounded-lg p-3 lg:p-4 text-xs lg:text-sm overflow-auto max-h-96"></pre>
            </div>
        </div>
    </div>
</div>

<!-- 新增AI模型模態視窗 -->
<div id="createModelModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50">
    <div class="flex items-center justify-center min-h-screen p-2 lg:p-4">
        <div class="bg-white rounded-xl lg:rounded-2xl shadow-2xl w-full max-w-4xl max-h-[95vh] lg:max-h-[90vh] overflow-hidden flex flex-col">
            <!-- 標題區 -->
            <div class="bg-gradient-to-r from-green-600 to-green-700 p-3 lg:p-6 flex-shrink-0">
                <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-2 lg:gap-3 min-w-0">
                        <div class="w-8 h-8 lg:w-10 lg:h-10 bg-white bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i data-lucide="plus" class="h-4 w-4 lg:h-5 lg:w-5 text-white"></i>
                        </div>
                        <div class="min-w-0">
                            <h2 class="text-base lg:text-2xl font-bold text-white truncate">新增AI模型</h2>
                            <p class="text-xs lg:text-sm text-green-100 hidden lg:block">配置新的AI模型服務</p>
                        </div>
                    </div>
                    <button type="button" id="closeCreateModal" class="text-white hover:text-green-200 flex-shrink-0 transition-colors">
                        <i data-lucide="x" class="h-5 w-5 lg:h-6 lg:w-6"></i>
                    </button>
                </div>
            </div>
            
            <!-- 內容區 -->
            <div class="flex-1 overflow-y-auto">
                <div class="p-4 lg:p-6">
                    <form id="createModelForm" class="space-y-4 lg:space-y-6">
                        <!-- 基本資訊 -->
                        <div class="bg-gray-50 rounded-lg p-4 lg:p-6">
                            <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4 pb-2 border-b border-gray-200">基本資訊</h3>
                            
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-6">
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">模型名稱 *</label>
                                    <input type="text" name="Name" required 
                                           class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                           placeholder="例：GPT-4 Turbo" />
                                </div>
                                
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">版本</label>
                                    <input type="text" name="Version" 
                                           class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                           placeholder="例：1.0.0" />
                                </div>
                            </div>

                            <div class="mt-3 lg:mt-6">
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">描述</label>
                                <textarea name="Description" rows="3" 
                                          class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                          placeholder="請輸入模型描述..."></textarea>
                            </div>

                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-6 mt-3 lg:mt-6">
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">模型類型</label>
                                    <select name="Type" id="modelType" 
                                            class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                                        <option value="text">文字生成</option>
                                        <option value="image">圖像生成</option>
                                        <option value="audio">音訊處理</option>
                                        <option value="video">影片處理</option>
                                    </select>
                                </div>
                                
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">狀態</label>
                                    <select name="Status" 
                                            class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                                        <option value="active">啟用</option>
                                        <option value="inactive">停用</option>
                                        <option value="testing">測試中</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- API 配置 -->
                        <div class="bg-gray-50 rounded-lg p-4 lg:p-6">
                            <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4 pb-2 border-b border-gray-200">API 配置</h3>
                            
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-6">
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">提供商 *</label>
                                    <input type="text" name="Provider" required 
                                           class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                           placeholder="例：OpenAI" />
                                </div>
                                
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">請求限額</label>
                                    <input type="number" name="RequestLimit" 
                                           class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                           placeholder="1000" />
                                </div>
                            </div>

                            <div class="mt-3 lg:mt-6">
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">API端點 *</label>
                                <input type="url" name="ApiEndpoint" required 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                       placeholder="https://api.example.com/v1/chat/completions" />
                            </div>

                            <div class="mt-3 lg:mt-6">
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">API金鑰</label>
                                <input type="password" name="ApiKey" 
                                       class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                       placeholder="sk-..." />
                            </div>
                        </div>

                        <!-- 模型配置 -->
                        <div class="bg-gray-50 rounded-lg p-4 lg:p-6">
                            <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4 pb-2 border-b border-gray-200">模型配置</h3>
                            
                            <div id="textConfig" class="space-y-3 lg:space-y-4">
                                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-6">
                                    <div>
                                        <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">Temperature</label>
                                        <input type="number" step="0.1" min="0" max="2" name="Temperature" 
                                               class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                               placeholder="0.7" />
                                    </div>
                                    <div>
                                        <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">最大Token數</label>
                                        <input type="number" name="MaxTokens" 
                                               class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                               placeholder="2048" />
                                    </div>
                                </div>
                            </div>

                            <div id="imageConfig" class="space-y-3 lg:space-y-4 hidden">
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">圖像品質</label>
                                    <select name="ImageQuality" 
                                            class="w-full px-3 py-2 text-sm lg:text-base border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                                        <option value="standard">標準</option>
                                        <option value="hd">高清</option>
                                        <option value="premium">頂級</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mt-3 lg:mt-6">
                                <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-1.5 lg:mb-2">自定義配置 (JSON)</label>
                                <textarea name="CustomConfig" rows="4" 
                                          class="w-full px-3 py-2 text-xs lg:text-sm font-mono border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                                          placeholder='{"temperature": 0.7, "maxTokens": 2048}'></textarea>
                            </div>
                        </div>

                        <!-- 權限設定 -->
                        <div class="bg-gray-50 rounded-lg p-4 lg:p-6">
                            <h3 class="text-base lg:text-lg font-semibold text-gray-900 mb-3 lg:mb-4 pb-2 border-b border-gray-200">權限設定</h3>
                            
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6">
                                <div>
                                    <label class="block text-xs lg:text-sm font-medium text-gray-700 mb-2 lg:mb-3">允許的角色</label>
                                    <div class="space-y-2">
                                        <label class="flex items-center">
                                            <input type="checkbox" name="AllowedRoles" value="admin" 
                                                   class="rounded border-gray-300 text-green-600 focus:ring-green-500" />
                                            <span class="ml-2 text-xs lg:text-sm text-gray-700">管理員</span>
                                        </label>
                                        <label class="flex items-center">
