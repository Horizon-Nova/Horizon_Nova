@{
    ViewData["Title"] = "新增AI模型";
    var modelTypes = ViewBag.ModelTypes as Dictionary<string, string>;
    var modelStatuses = ViewBag.ModelStatuses as Dictionary<string, string>;
}

<section class="min-h-screen bg-gray-50 p-6">
    <div class="max-w-4xl mx-auto">
        <!-- 頁面標題 -->
        <header class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gray-800 rounded-lg mb-4 shadow-sm">
                <i data-lucide="plus" class="h-8 w-8 text-white"></i>
            </div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">
                新增AI模型
            </h1>
            <p class="text-gray-600">配置新的AI模型服務</p>
        </header>

        <!-- 表單 -->
        <div class="bg-white border rounded-xl p-8 shadow-sm">
            <form asp-action="Create" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                
                <!-- 基本資訊 -->
                <div class="space-y-6">
                    <h3 class="text-lg font-semibold text-gray-900 border-b border-gray-200 pb-2">基本資訊</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-2">模型名稱 *</label>
                            <input asp-for="Name" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="例：GPT-4 Turbo" />
                            <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
                        </div>
                        
                        <div>
                            <label asp-for="Version" class="block text-sm font-medium text-gray-700 mb-2">版本</label>
                            <input asp-for="Version" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="例：1.0.0" />
                            <span asp-validation-for="Version" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-2">描述</label>
                        <textarea asp-for="Description" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="請輸入模型描述..."></textarea>
                        <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label asp-for="Type" class="block text-sm font-medium text-gray-700 mb-2">模型類型</label>
                            <select asp-for="Type" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                @foreach (var type in modelTypes)
                                {
                                    <option value="@type.Key">@type.Value</option>
                                }
                            </select>
                            <span asp-validation-for="Type" class="text-red-500 text-sm"></span>
                        </div>
                        
                        <div>
                            <label asp-for="Status" class="block text-sm font-medium text-gray-700 mb-2">狀態</label>
                            <select asp-for="Status" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                @foreach (var status in modelStatuses)
                                {
                                    <option value="@status.Key">@status.Value</option>
                                }
                            </select>
                            <span asp-validation-for="Status" class="text-red-500 text-sm"></span>
                        </div>
                    </div>
                </div>

                <!-- API 配置 -->
                <div class="space-y-6">
                    <h3 class="text-lg font-semibold text-gray-900 border-b border-gray-200 pb-2">API 配置</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label asp-for="Provider" class="block text-sm font-medium text-gray-700 mb-2">提供商 *</label>
                            <input asp-for="Provider" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="例：OpenAI" />
                            <span asp-validation-for="Provider" class="text-red-500 text-sm"></span>
                        </div>
                        
                        <div>
                            <label asp-for="RequestLimit" class="block text-sm font-medium text-gray-700 mb-2">請求限額</label>
                            <input asp-for="RequestLimit" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="1000" />
                            <span asp-validation-for="RequestLimit" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="ApiEndpoint" class="block text-sm font-medium text-gray-700 mb-2">API端點 *</label>
                        <input asp-for="ApiEndpoint" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="https://api.example.com/v1/chat/completions" />
                        <span asp-validation-for="ApiEndpoint" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="ApiKey" class="block text-sm font-medium text-gray-700 mb-2">API金鑰</label>
                        <input asp-for="ApiKey" type="password" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="sk-..." />
                        <span asp-validation-for="ApiKey" class="text-red-500 text-sm"></span>
                    </div>
                </div>

                <!-- 模型配置 -->
                <div class="space-y-6">
                    <h3 class="text-lg font-semibold text-gray-900 border-b border-gray-200 pb-2">模型配置</h3>
                    
                    <div id="textConfig" class="space-y-4" style="display: none;">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Temperature</label>
                                <input type="number" step="0.1" min="0" max="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="0.7" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">最大Token數</label>
                                <input type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="2048" />
                            </div>
                        </div>
                    </div>

                    <div id="imageConfig" class="space-y-4" style="display: none;">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">圖像品質</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                <option value="standard">標準</option>
                                <option value="hd">高清</option>
                                <option value="premium">頂級</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">自定義配置 (JSON)</label>
                        <textarea rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder='{"temperature": 0.7, "maxTokens": 2048}'></textarea>
                    </div>
                </div>

                <!-- 權限設定 -->
                <div class="space-y-6">
                    <h3 class="text-lg font-semibold text-gray-900 border-b border-gray-200 pb-2">權限設定</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">允許的角色</label>
                            <div class="space-y-2">
                                <label class="flex items-center">
                                    <input type="checkbox" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                    <span class="ml-2 text-sm text-gray-700">管理員</span>
                                </label>
                                <label class="flex items-center">
                                    <input type="checkbox" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                    <span class="ml-2 text-sm text-gray-700">開發者</span>
                                </label>
                                <label class="flex items-center">
                                    <input type="checkbox" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                    <span class="ml-2 text-sm text-gray-700">內容創作者</span>
                                </label>
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">允許的用戶</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="輸入用戶ID，用逗號分隔" />
                        </div>
                    </div>
                </div>

                <!-- 按鈕 -->
                <div class="flex justify-end space-x-4 pt-6 border-t border-gray-200">
                    <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                        取消
                    </a>
                    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                        創建模型
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <script>
        // 初始化 Lucide 圖標
        lucide.createIcons();

        // 根據模型類型顯示不同的配置選項
        function toggleConfigSections() {
            const modelType = document.querySelector('select[name="Type"]').value;
            
            // 隱藏所有配置區塊
            document.getElementById('textConfig').style.display = 'none';
            document.getElementById('imageConfig').style.display = 'none';
            
            // 根據類型顯示對應的配置區塊
            if (modelType === 'text') {
                document.getElementById('textConfig').style.display = 'block';
            } else if (modelType === 'image') {
                document.getElementById('imageConfig').style.display = 'block';
            }
        }

        // 綁定模型類型變更事件
        document.querySelector('select[name="Type"]').addEventListener('change', toggleConfigSections);
        
        // 初始化配置區塊顯示
        toggleConfigSections();
    </script>
}
