@{
    ViewData["Title"] = "測試頁面";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">
    <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-md p-6">
        <h1 class="text-2xl font-bold mb-4">@ViewBag.Message</h1>
        
        <div class="space-y-4">
            <div>
                <strong>登入狀態:</strong> 
                <span class="@((User.Identity?.IsAuthenticated ?? false) ? "text-green-600" : "text-red-600")">
                    @((User.Identity?.IsAuthenticated ?? false) ? "已登入" : "未登入")
                </span>
            </div>
            
            <div>
                <strong>用戶名稱:</strong> @(User.Identity?.Name ?? "未登入")
            </div>
            
            <div class="pt-4 border-t">
                <a href="/Backoffice/Authorize/Login" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                    前往登入頁面
                </a>
                
                <a href="/Backoffice/Test/CheckAuth" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 ml-2">
                    檢查認證狀態 (JSON)
                </a>
                
                <a href="/Backoffice/Dashboard/Dashboard" class="bg-purple-500 text-white px-4 py-2 rounded hover:bg-purple-600 ml-2">
                    前往儀表板
                </a>
            </div>
        </div>
    </div>
</body>
</html>
