@{
    ViewData["Title"] = "檔案預覽套件測試";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h2>檔案預覽套件測試</h2>
            <p class="text-muted">使用 FilePreview 套件測試各種檔案格式的預覽功能</p>
            <p><strong>儲存位置：</strong> <code>@ViewBag.StoragePath</code></p>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>上傳測試檔案</h5>
                </div>
                <div class="card-body">
                    <form id="uploadForm" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="fileInput" class="form-label">選擇測試檔案</label>
                            <input type="file" class="form-control" id="fileInput" name="file" required>
                            <small class="form-text text-muted">支援圖片、PDF、Office、文字、影片、音訊等格式</small>
                        </div>
                        <button type="submit" class="btn btn-primary">上傳檔案</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>套件資訊</h5>
                </div>
                <div class="card-body">
                    <p><strong>套件版本：</strong> FilePreview v1.0</p>
                    <p><strong>測試檔案數量：</strong> @ViewBag.Files.Count</p>
                    <p><strong>支援格式：</strong> 圖片、PDF、Office、文字、影片、音訊</p>
                    <button type="button" class="btn btn-secondary" id="btnReload">
                        <i class="fas fa-sync"></i> 重新整理
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5>測試檔案列表</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Files != null && ViewBag.Files.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>檔案名稱</th>
                                        <th>大小</th>
                                        <th>檔案類型</th>
                                        <th>建立時間</th>
                                        <th>操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in ViewBag.Files)
                                    {
                                        <tr>
                                            <td>
                                                <i class="fas fa-file me-2"></i>
                                                @file.FileName
                                            </td>
                                            <td>@((file.Size / 1024.0).ToString("N2")) KB</td>
                                            <td>
                                                @{
                                                    var ext = System.IO.Path.GetExtension(file.FileName).ToLower();
                                                    var fileType = ext switch
                                                    {
                                                        ".jpg" or ".jpeg" or ".png" or ".gif" or ".bmp" or ".webp" or ".svg" => "圖片",
                                                        ".pdf" => "PDF",
                                                        ".txt" or ".md" or ".json" or ".xml" or ".html" or ".css" or ".js" or ".ts" or ".cs" or ".py" or ".java" or ".cpp" or ".c" or ".h" or ".sql" or ".log" or ".ini" or ".cfg" or ".conf" or ".csv" or ".yml" or ".yaml" => "文字",
                                                        ".doc" or ".docx" => "Word",
                                                        ".xls" or ".xlsx" => "Excel",
                                                        ".ppt" or ".pptx" => "PowerPoint",
                                                        ".mp4" or ".webm" or ".ogg" or ".mov" or ".avi" => "影片",
                                                        ".mp3" or ".wav" or ".ogg" or ".aac" or ".flac" => "音訊",
                                                        _ => "其他"
                                                    };
                                                }
                                                <span class="badge bg-info">@fileType</span>
                                            </td>
                                            <td>@file.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                            <td>
                                                <button class="btn btn-sm btn-info btn-preview" data-filename="@file.FileName" title="預覽檔案">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <button class="btn btn-sm btn-danger btn-delete" data-filename="@file.FileName" title="刪除檔案">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-folder-open text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3">目前沒有測試檔案，請上傳檔案進行預覽測試。</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- 引入 FilePreview 套件 -->
    <link rel="stylesheet" href="~/lib/file-preview/FilePreview.css">
    <script src="~/lib/file-preview/FilePreview.js"></script>
    
    <script>
        // FilePreview 套件會自動初始化，無需手動創建實例
        
        $(function() {
            // 預覽檔案按鈕 - 使用 FilePreview 套件的 class 方式
            $('.btn-preview').on('click', function() {
                const fileName = $(this).data('filename');
                const fileUrl = '@Url.Action("GetFile", "Test", new { Area = "Backoffice" })' + '?fileName=' + encodeURIComponent(fileName);
                
                // 使用 jQuery 建立臨時元素（符合規範：不直接使用 createElement）
                const $temp = $('<div class="file-preview" style="display:none;"></div>');
                $temp.attr('data-file-url', fileUrl);
                $temp.attr('data-file-name', fileName);
                $('body').append($temp);
                $temp.trigger('click');
                setTimeout(() => { $temp.remove(); }, 100);
            });
            
            // 上傳檔案
            $('#uploadForm').on('submit', function(e) {
                e.preventDefault();
                
                const formData = new FormData();
                const fileInput = $('#fileInput')[0];
                
                if (fileInput.files.length === 0) {
                    showToast('請選擇檔案', 'warning');
                    return;
                }
                
                formData.append('file', fileInput.files[0]);
                
                const url = '@Url.Action("UploadFile", "Test", new { Area = "Backoffice" })';
                
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            showToast('上傳成功：' + response.message, 'success');
                            location.reload();
                        } else {
                            showToast('上傳失敗：' + response.message, 'error');
                        }
                    },
                    error: function(xhr, status, error) {
                        showToast('上傳失敗：' + error, 'error');
                    }
                });
            });
            
            // 刪除檔案
            $('.btn-delete').on('click', function() {
                const fileName = $(this).data('filename');
                
                if (!confirm('確定要刪除檔案 "' + fileName + '" 嗎？')) {
                    return;
                }
                
                $.ajax({
                    url: '@Url.Action("DeleteFile", "Test", new { Area = "Backoffice" })',
                    type: 'POST',
                    data: { fileName: fileName },
                    success: function(response) {
                        if (response.success) {
                            showToast(response.message, 'success');
                            location.reload();
                        } else {
                            showToast('刪除失敗：' + response.message, 'error');
                        }
                    },
                    error: function() {
                        showToast('刪除失敗，請稍後再試', 'error');
                    }
                });
            });
            // 重新整理列表
            $('#btnReload').on('click', function () {
                location.reload();
            });
        });
    </script>
}