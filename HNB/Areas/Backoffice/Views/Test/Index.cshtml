@{
    ViewData["Title"] = "測試中心";
    ViewData["PageTitle"] = "測試中心";
    ViewData["PageDescription"] = "系統功能測試工具集";
    ViewData["PageIcon"] = "flask-conical";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<div class="space-y-6">
    <!-- 歡迎卡片 -->
    <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl shadow-lg p-6 text-white">
        <div class="flex items-center gap-4">
            <div class="bg-white bg-opacity-20 p-4 rounded-lg">
                <i data-lucide="flask-conical" class="w-12 h-12"></i>
            </div>
            <div>
                <h1 class="text-3xl font-bold mb-2">測試中心</h1>
                <p class="text-blue-100">開發人員專用的功能測試工具，用於驗證系統各項功能的穩定性</p>
            </div>
        </div>
    </div>

    <!-- 測試項目網格 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- 1. Modal 測試 -->
        <a href="@Url.Action("ModalTest", "Test", new { area = "Backoffice" })" 
           class="block bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-lg hover:border-blue-300 transition-all group">
            <div class="flex items-start gap-4">
                <div class="bg-blue-100 p-3 rounded-lg group-hover:bg-blue-600 transition-colors">
                    <i data-lucide="square-stack" class="w-8 h-8 text-blue-600 group-hover:text-white"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-slate-800 mb-1">Modal 測試</h3>
                    <p class="text-sm text-slate-600 mb-3">測試所有彈出視窗的穩定性和功能</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                            <i data-lucide="check-circle" class="w-3 h-3 mr-1"></i>可用
                        </span>
                        <span class="text-xs text-slate-500">5 種風格測試</span>
                    </div>
                </div>
            </div>
        </a>

        <!-- 2. 表單測試 -->
        <a href="@Url.Action("FormTest", "Test", new { area = "Backoffice" })" 
           class="block bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-lg hover:border-purple-300 transition-all group">
            <div class="flex items-start gap-4">
                <div class="bg-purple-100 p-3 rounded-lg group-hover:bg-purple-600 transition-colors">
                    <i data-lucide="file-check" class="w-8 h-8 text-purple-600 group-hover:text-white"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-slate-800 mb-1">表單驗證測試</h3>
                    <p class="text-sm text-slate-600 mb-3">測試表單驗證、提交和錯誤處理</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
                            <i data-lucide="clock" class="w-3 h-3 mr-1"></i>開發中
                        </span>
                    </div>
                </div>
            </div>
        </a>

        <!-- 3. API 測試 -->
        <a href="@Url.Action("ApiTest", "Test", new { area = "Backoffice" })" 
           class="block bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-lg hover:border-green-300 transition-all group">
            <div class="flex items-start gap-4">
                <div class="bg-green-100 p-3 rounded-lg group-hover:bg-green-600 transition-colors">
                    <i data-lucide="network" class="w-8 h-8 text-green-600 group-hover:text-white"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-slate-800 mb-1">API 測試</h3>
                    <p class="text-sm text-slate-600 mb-3">測試後端 API 端點的功能和效能</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
                            <i data-lucide="clock" class="w-3 h-3 mr-1"></i>開發中
                        </span>
                    </div>
                </div>
            </div>
        </a>

        <!-- 4. 元件測試 -->
        <a href="@Url.Action("ComponentTest", "Test", new { area = "Backoffice" })" 
           class="block bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-lg hover:border-orange-300 transition-all group">
            <div class="flex items-start gap-4">
                <div class="bg-orange-100 p-3 rounded-lg group-hover:bg-orange-600 transition-colors">
                    <i data-lucide="boxes" class="w-8 h-8 text-orange-600 group-hover:text-white"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-slate-800 mb-1">UI 元件測試</h3>
                    <p class="text-sm text-slate-600 mb-3">測試按鈕、輸入框、選單等 UI 元件</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
                            <i data-lucide="clock" class="w-3 h-3 mr-1"></i>開發中
                        </span>
                    </div>
                </div>
            </div>
        </a>

        <!-- 5. 效能測試 -->
        <a href="#" 
           class="block bg-white rounded-xl shadow-sm border border-slate-200 p-6 opacity-50 cursor-not-allowed">
            <div class="flex items-start gap-4">
                <div class="bg-red-100 p-3 rounded-lg">
                    <i data-lucide="gauge" class="w-8 h-8 text-red-600"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-slate-800 mb-1">效能測試</h3>
                    <p class="text-sm text-slate-600 mb-3">測試頁面載入速度和資源使用</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                            <i data-lucide="lock" class="w-3 h-3 mr-1"></i>規劃中
                        </span>
                    </div>
                </div>
            </div>
        </a>

        <!-- 6. 資料庫測試 -->
        <a href="#" 
           class="block bg-white rounded-xl shadow-sm border border-slate-200 p-6 opacity-50 cursor-not-allowed">
            <div class="flex items-start gap-4">
                <div class="bg-indigo-100 p-3 rounded-lg">
                    <i data-lucide="database" class="w-8 h-8 text-indigo-600"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-slate-800 mb-1">資料庫測試</h3>
                    <p class="text-sm text-slate-600 mb-3">測試資料庫連線和查詢效能</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                            <i data-lucide="lock" class="w-3 h-3 mr-1"></i>規劃中
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- 使用說明 -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6">
        <div class="flex items-start gap-3">
            <i data-lucide="alert-triangle" class="w-5 h-5 text-yellow-600 mt-0.5"></i>
            <div>
                <h3 class="font-semibold text-yellow-900 mb-2">⚠️ 注意事項</h3>
                <ul class="text-sm text-yellow-800 space-y-1">
                    <li>• 此測試中心僅供開發人員使用，請勿在正式環境啟用</li>
                    <li>• 測試過程中可能會產生測試資料，請定期清理</li>
                    <li>• 如發現任何問題，請記錄錯誤訊息並回報開發團隊</li>
                    <li>• 建議在開發環境或測試環境進行測試</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- 快速操作 -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h3 class="text-lg font-semibold text-slate-800 mb-4">快速操作</h3>
        <div class="flex flex-wrap gap-3">
            <button type="button" onclick="window.location.reload()" class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700">
                <i data-lucide="refresh-cw" class="w-4 h-4 inline mr-2"></i>重新載入頁面
            </button>
            <button type="button" onclick="window.open('/Backoffice/Dashboard/Index', '_blank')" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                <i data-lucide="layout-dashboard" class="w-4 h-4 inline mr-2"></i>返回儀表板
            </button>
            <button type="button" onclick="console.clear()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
                <i data-lucide="trash-2" class="w-4 h-4 inline mr-2"></i>清除 Console
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
            console.log('🧪 測試中心已就緒');
        });
    </script>
}

