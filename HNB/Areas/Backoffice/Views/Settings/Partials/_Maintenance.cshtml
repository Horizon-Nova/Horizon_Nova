@{
    Layout = null;
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h5 class="card-title fw-semibold d-flex align-items-center gap-2 mb-3">
            <i data-lucide="wrench" style="width: 1.25rem; height: 1.25rem;"></i>
            系統維護工具
        </h5>
        <div class="row g-3">
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 border rounded gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-medium mb-1">維護模式</p>
                        <p class="small text-muted mb-0">暫時關閉網站進行維護</p>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="maintenanceMode"
                               style="width: 3rem; height: 1.5rem; cursor: pointer;">
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 border rounded gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-medium mb-1">資料庫優化</p>
                        <p class="small text-muted mb-0">清理和優化資料庫</p>
                    </div>
                    <button type="button" id="btnOptimizeDatabase" class="btn btn-primary btn-sm js-optimize-database">
                        執行優化
                    </button>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 border rounded gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-medium mb-1">系統重啟</p>
                        <p class="small text-muted mb-0">重新啟動應用程式</p>
                    </div>
                    <button type="button" id="btnRestartSystem" class="btn btn-danger btn-sm js-restart-system">
                        重啟系統
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

