@model Models.HnbHnbBackoffice.vw_system_config_server

<div class="bg-white border rounded-xl p-6 space-y-6">
    <header>
        <h2 class="text-xl font-semibold flex items-center gap-2">
            <i data-lucide="server" class="h-5 w-5"></i>
            伺服器資訊
        </h2>
        <p class="text-slate-500">即時伺服器狀態監控和系統資源使用情況</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- 系統資訊 -->
        <div class="space-y-3">
            <h3 class="text-lg font-semibold">系統資訊</h3>
            <div class="flex justify-between"><span class="text-slate-500">主機名稱:</span><span class="font-mono">@(Model?.host_name ?? "載入中...")</span></div>
            <div class="flex justify-between"><span class="text-slate-500">作業系統:</span><span>@(Model?.operating_system ?? "載入中...")</span></div>
            <div class="flex justify-between"><span class="text-slate-500">核心版本:</span><span>@(Model?.kernel_version ?? "載入中...")</span></div>
            <div class="flex justify-between"><span class="text-slate-500">系統運行時間:</span><span>@(Model?.uptime ?? "載入中...")</span></div>
        </div>

        <!-- 網路狀態 -->
        <div class="space-y-3">
            <h3 class="text-lg font-semibold">網路狀態</h3>
            <div class="flex justify-between"><span class="text-slate-500">入站流量:</span><span>@(Model?.inbound_traffic ?? "載入中...")</span></div>
            <div class="flex justify-between"><span class="text-slate-500">出站流量:</span><span>@(Model?.outbound_traffic ?? "載入中...")</span></div>
        </div>
    </div>

    <div class="space-y-6">
        <h3 class="text-lg font-semibold">資源使用率</h3>

        <!-- CPU -->
        <div class="space-y-2">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <i data-lucide="cpu" class="h-5 w-5"></i>
                    <span class="font-medium">CPU 使用率</span>
                </div>
                <span class="text-sm text-slate-500">@ViewBag.CpuCores 核心</span>
            </div>
            <div class="w-full bg-slate-100 rounded h-2">
                <div class="bg-blue-600 h-2 rounded transition-all duration-300" style="width: @ViewBag.CpuUsage%"></div>
            </div>
            <div class="flex justify-between text-sm">
                <span>@ViewBag.CpuUsage%</span>
                <span class="text-slate-500">100%</span>
            </div>
        </div>

        <!-- Memory -->
        <div class="space-y-2">
            <div class="flex items-center gap-2">
                <i data-lucide="memory-stick" class="h-5 w-5"></i>
                <span class="font-medium">記憶體使用率</span>
            </div>
            <div class="w-full bg-slate-100 rounded h-2">
                <div class="bg-green-600 h-2 rounded transition-all duration-300" style="width: @ViewBag.MemoryUsage%"></div>
            </div>
            <div class="flex justify-between text-sm">
                <span>@ViewBag.MemoryUsage%</span>
                <span class="text-slate-500">100%</span>
            </div>
        </div>

        <!-- Disk -->
        <div class="space-y-2">
            <div class="flex items-center gap-2">
                <i data-lucide="hard-drive" class="h-5 w-5"></i>
                <span class="font-medium">磁碟使用率</span>
            </div>
            <div class="w-full bg-slate-100 rounded h-2">
                <div class="bg-purple-600 h-2 rounded transition-all duration-300" style="width: @ViewBag.DiskUsage%"></div>
            </div>
            <div class="flex justify-between text-sm">
                <span>@ViewBag.DiskUsage%</span>
                <span class="text-slate-500">100%</span>
            </div>
        </div>
    </div>
</div>

