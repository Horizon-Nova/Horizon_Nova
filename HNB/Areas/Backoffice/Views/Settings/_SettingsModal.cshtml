@{
    Layout = null;
}

<!-- 錯誤日誌說明 Modal -->
<div class="modal fade" id="error-help" tabindex="-1" aria-labelledby="errorHelpLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
        <!-- Modal Header -->
            <div class="modal-header border-0" style="background: linear-gradient(to right, #fef2f2, #ffedd5);">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-2 rounded" style="background-color: #fee2e2;">
                        <i data-lucide="alert-triangle" class="text-danger" style="width: 1.5rem; height: 1.5rem;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold mb-1" id="errorHelpLabel">錯誤日誌說明</h5>
                        <p class="small text-muted mb-0">了解錯誤日誌的作用與管理方式</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <!-- Modal Body -->
            <div class="modal-body p-4" style="background-color: #f8fafc;">
                <div class="d-flex flex-column gap-4">
                <div>
                        <h6 class="fw-semibold mb-2 d-flex align-items-center">
                            <i data-lucide="info" class="text-danger me-2" style="width: 1rem; height: 1rem;"></i>
                        什麼是錯誤日誌？
                    </h6>
                        <p class="text-muted small mb-0">錯誤日誌記錄系統運行過程中發生的錯誤和異常，是診斷和修復系統問題的重要工具。</p>
                </div>
                
                <div>
                        <h6 class="fw-semibold mb-2 d-flex align-items-center">
                            <i data-lucide="file-text" class="text-primary me-2" style="width: 1rem; height: 1rem;"></i>
                        記錄內容
                    </h6>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex align-items-start mb-2">
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-circle me-2" style="width: 1.25rem; height: 1.25rem; padding: 0.125rem;">•</span>
                                <span class="small text-muted">包含錯誤訊息、堆疊追蹤和時間戳</span>
                        </li>
                            <li class="d-flex align-items-start mb-2">
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-circle me-2" style="width: 1.25rem; height: 1.25rem; padding: 0.125rem;">•</span>
                                <span class="small text-muted">幫助開發者診斷和修復問題</span>
                        </li>
                            <li class="d-flex align-items-start">
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-circle me-2" style="width: 1.25rem; height: 1.25rem; padding: 0.125rem;">•</span>
                                <span class="small text-muted">建議定期清理以節省儲存空間</span>
                        </li>
                    </ul>
                </div>
                
                <div>
                        <h6 class="fw-semibold mb-2 d-flex align-items-center">
                            <i data-lucide="lightbulb" class="text-warning me-2" style="width: 1rem; height: 1rem;"></i>
                        管理建議
                    </h6>
                        <div class="alert alert-warning mb-0" role="alert">
                            <i data-lucide="alert-circle" style="width: 1rem; height: 1rem;" class="me-1"></i>
                            建議定期檢查錯誤日誌，及時發現並修復問題。可使用「30天清理」功能保留近期記錄，或「全部清理」釋放所有空間。
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Footer -->
            <div class="modal-footer border-0" style="background-color: #f8fafc;">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

