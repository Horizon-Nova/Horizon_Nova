@{
    Layout = null;
}

<!-- 錯誤日誌說明 -->
<div id="error-help" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <!-- Modal Header -->
        <div class="bg-gradient-to-r from-red-50 to-orange-50 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-red-100 p-2 rounded-lg">
                        <i data-lucide="alert-triangle" class="w-6 h-6 text-red-600"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-slate-800">錯誤日誌說明</h3>
                        <p class="text-sm text-slate-500 mt-1">了解錯誤日誌的作用與管理方式</p>
                    </div>
                </div>
                <button type="button" class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 p-2 rounded-lg transition-all duration-200" onclick="closeModal('error-help')">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>

        <!-- Modal Body -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-6">
                <div>
                    <h6 class="font-semibold text-slate-900 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-red-600"></i>
                        什麼是錯誤日誌？
                    </h6>
                    <p class="text-slate-600 text-sm leading-relaxed">錯誤日誌記錄系統運行過程中發生的錯誤和異常，是診斷和修復系統問題的重要工具。</p>
                </div>
                
                <div>
                    <h6 class="font-semibold text-slate-900 mb-3 flex items-center">
                        <i data-lucide="file-text" class="w-4 h-4 mr-2 text-blue-600"></i>
                        記錄內容
                    </h6>
                    <ul class="text-slate-600 text-sm space-y-2 leading-relaxed">
                        <li class="flex items-start">
                            <span class="bg-red-100 text-red-600 text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center mr-3 mt-0.5 flex-shrink-0">•</span>
                            包含錯誤訊息、堆疊追蹤和時間戳
                        </li>
                        <li class="flex items-start">
                            <span class="bg-red-100 text-red-600 text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center mr-3 mt-0.5 flex-shrink-0">•</span>
                            幫助開發者診斷和修復問題
                        </li>
                        <li class="flex items-start">
                            <span class="bg-red-100 text-red-600 text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center mr-3 mt-0.5 flex-shrink-0">•</span>
                            建議定期清理以節省儲存空間
                        </li>
                    </ul>
                </div>
                
                <div>
                    <h6 class="font-semibold text-slate-900 mb-3 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2 text-orange-600"></i>
                        管理建議
                    </h6>
                    <div class="bg-amber-50 border border-amber-200 p-4 rounded-lg">
                        <p class="text-sm text-amber-800">
                            <i data-lucide="alert-circle" class="w-4 h-4 inline mr-1"></i>
                            建議定期檢查錯誤日誌，及時發現並修復問題。可使用「30天清理」功能保留近期記錄，或「全部清理」釋放所有空間。
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeModal('error-help')" class="modal-close px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

