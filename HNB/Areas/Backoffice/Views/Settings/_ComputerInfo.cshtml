@model Models.HnbHnbBackoffice.vw_system_config_server

<div class="bg-white border rounded-xl p-6 space-y-6">
    <header>
        <h2 class="text-xl font-semibold flex items-center gap-2">
            <i data-lucide="monitor" class="h-5 w-5"></i>
            電腦資訊
        </h2>
        <p class="text-slate-500">系統硬體規格和運行環境詳細資訊</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- 硬體資訊 -->
        <div class="space-y-3">
            <h3 class="text-lg font-semibold">硬體規格</h3>
            <div class="space-y-2">
                <div class="flex justify-between">
                    <span class="text-slate-500">處理器：</span>
                    <span class="font-mono text-sm">@Environment.ProcessorCount 核心 @Environment.OSVersion.Platform</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">記憶體：</span>
                    <span class="font-mono text-sm">@(GC.GetTotalMemory(false) / 1024 / 1024 / 1024) GB</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">作業系統：</span>
                    <span class="font-mono text-sm">@Environment.OSVersion.VersionString</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">.NET 版本：</span>
                    <span class="font-mono text-sm">@Environment.Version</span>
                </div>
            </div>
        </div>

        <!-- 應用程式資訊 -->
        <div class="space-y-3">
            <h3 class="text-lg font-semibold">應用程式狀態</h3>
            <div class="space-y-2">
                <div class="flex justify-between">
                    <span class="text-slate-500">運行時間：</span>
                    <span class="font-mono text-sm">@TimeSpan.FromMilliseconds(Environment.TickCount).ToString(@"dd\.hh\:mm\:ss")</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">工作目錄：</span>
                    <span class="font-mono text-sm">@Environment.CurrentDirectory</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">機器名稱：</span>
                    <span class="font-mono text-sm">@Environment.MachineName</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">用戶名稱：</span>
                    <span class="font-mono text-sm">@Environment.UserName</span>
                </div>
            </div>
        </div>
    </div>

    <div class="space-y-6">
        <h3 class="text-lg font-semibold">資源使用率</h3>

        <!-- CPU -->
        <div class="space-y-2">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <i data-lucide="cpu" class="h-5 w-5"></i>
                    <span class="font-medium">CPU 使用率</span>
                </div>
                <span class="text-sm text-slate-500">@ViewBag.CpuCores 核心</span>
            </div>
            <div class="w-full bg-slate-100 rounded h-2">
                <div class="bg-blue-600 h-2 rounded transition-all duration-300" style="width: @ViewBag.CpuUsage%"></div>
            </div>
            <div class="flex justify-between text-sm">
                <span>@ViewBag.CpuUsage%</span>
                <span class="text-slate-500">100%</span>
            </div>
        </div>

        <!-- Memory -->
        <div class="space-y-2">
            <div class="flex items-center gap-2">
                <i data-lucide="memory-stick" class="h-5 w-5"></i>
                <span class="font-medium">記憶體使用率</span>
            </div>
            <div class="w-full bg-slate-100 rounded h-2">
                <div class="bg-green-600 h-2 rounded transition-all duration-300" style="width: @ViewBag.MemoryUsage%"></div>
            </div>
            <div class="flex justify-between text-sm">
                <span>@ViewBag.MemoryUsage%</span>
                <span class="text-slate-500">100%</span>
            </div>
        </div>

        <!-- Disk -->
        <div class="space-y-2">
            <div class="flex items-center gap-2">
                <i data-lucide="hard-drive" class="h-5 w-5"></i>
                <span class="font-medium">磁碟使用率</span>
            </div>
            <div class="w-full bg-slate-100 rounded h-2">
                <div class="bg-purple-600 h-2 rounded transition-all duration-300" style="width: @ViewBag.DiskUsage%"></div>
            </div>
            <div class="flex justify-between text-sm">
                <span>@ViewBag.DiskUsage%</span>
                <span class="text-slate-500">100%</span>
            </div>
        </div>
    </div>
</div>
