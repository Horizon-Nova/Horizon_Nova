@{
    ViewData["Title"] = "系統設定";
    ViewData["PageTitle"] = "系統設定";
    ViewData["PageDescription"] = "系統監控、日誌管理、快取清理和維護工具";
    ViewData["PageIcon"] = "settings";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("_SettingsModal")

    <!-- 系統狀態卡片 -->
<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="flex-grow-1" style="min-width: 0;">
                        <p class="text-muted small mb-1 text-truncate">系統狀態</p>
                        <p id="systemStatus" class="fs-5 fw-bold mb-0 text-truncate @(ViewBag.HardwareInfo?.is_active == true ? "text-success" : "text-danger")">
                            @(ViewBag.HardwareInfo?.is_active == true ? "運行中" : "停止")
                        </p>
                    </div>
                    <i id="systemStatusIcon" data-lucide="activity" class="flex-shrink-0 @(ViewBag.HardwareInfo?.is_active == true ? "text-success" : "text-danger")" style="width: 2rem; height: 2rem;"></i>
                </div>
                </div>
            </div>
        </div>
    
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="flex-grow-1" style="min-width: 0;">
                        <p class="text-muted small mb-1">CPU 使用率</p>
                        <p id="cpuUsage" class="fs-5 fw-bold mb-0">@(ViewBag.HardwareInfo?.cpu_usage_percent?.ToString("F1") ?? "--")%</p>
                    </div>
                    <i data-lucide="cpu" class="text-primary flex-shrink-0" style="width: 2rem; height: 2rem;"></i>
                </div>
                </div>
            </div>
        </div>
    
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="flex-grow-1" style="min-width: 0;">
                        <p class="text-muted small mb-1">記憶體使用率</p>
                        <p id="memoryUsage" class="fs-5 fw-bold mb-0">@(ViewBag.HardwareInfo?.memory_usage_percent?.ToString("F1") ?? "--")%</p>
                    </div>
                    <i data-lucide="memory-stick" class="text-purple flex-shrink-0" style="width: 2rem; height: 2rem; color: #9333ea;"></i>
                </div>
                </div>
            </div>
        </div>
    
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="flex-grow-1" style="min-width: 0;">
                        <p class="text-muted small mb-1">GPU 使用率</p>
                        <p id="gpuUsage" class="fs-5 fw-bold mb-0">@(ViewBag.HardwareInfo?.gpu_usage_percent?.ToString("F1") ?? "--")%</p>
                    </div>
                    <i data-lucide="monitor" class="text-warning flex-shrink-0" style="width: 2rem; height: 2rem;"></i>
                </div>
                </div>
            </div>
        </div>
    </div>

<!-- 管理工具 -->
<div class="row g-3 mb-3">
        <!-- 日誌管理 -->
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="card-title mb-0 fw-semibold d-flex align-items-center gap-2">
                        <i data-lucide="file-text" style="width: 1.25rem; height: 1.25rem;"></i>
                        日誌管理
                    </h5>
                    <button type="button" class="btn btn-link btn-sm p-0 text-primary" onclick="refreshLogStats()">
                        <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;" class="me-1"></i>刷新
                </button>
            </div>
                
                <div class="d-flex flex-column gap-2">
                    <!-- 錯誤日誌 -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <p class="mb-0 fw-medium">錯誤日誌</p>
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); showModal('error-help')">
                                    <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                             </button>
                         </div>
                            <p class="small text-muted mb-0" id="errorLogCount">@(ViewBag.ErrorLogsCount ?? 0) 條記錄</p>
                     </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-danger btn-sm" onclick="clearLogs('error', false, $(this))">全部清理</button>
                            <button type="button" class="btn btn-warning btn-sm" onclick="clearLogs('error', true, $(this))">30天清理</button>
                     </div>
                 </div>
                    
                    <!-- 系統日誌 -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <p class="mb-0 fw-medium">系統日誌</p>
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); showModal('system-help')">
                                    <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                             </button>
                         </div>
                            <p class="small text-muted mb-0" id="systemLogCount">@(ViewBag.AccessLogsCount ?? 0) 條記錄</p>
                     </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-primary btn-sm" onclick="clearLogs('system', false, $(this))">全部清理</button>
                            <button type="button" class="btn btn-info btn-sm" onclick="clearLogs('system', true, $(this))">30天清理</button>
                     </div>
                 </div>
                    
                    <!-- 存取日誌 -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <p class="mb-0 fw-medium">存取日誌</p>
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); showModal('access-help')">
                                    <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                             </button>
                         </div>
                            <p class="small text-muted mb-0" id="accessLogCount">@(ViewBag.AccessLogsCount ?? 0) 條記錄</p>
                     </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-success btn-sm" onclick="clearLogs('access', false, $(this))">全部清理</button>
                            <button type="button" class="btn btn-outline-success btn-sm" onclick="clearLogs('access', true, $(this))">30天清理</button>
                        </div>
                    </div>
                     </div>
                 </div>
             </div>
        </div>

        <!-- 快取管理 -->
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="card-title mb-0 fw-semibold d-flex align-items-center gap-2">
                        <i data-lucide="database" style="width: 1.25rem; height: 1.25rem;"></i>
                        快取管理
                    </h5>
                    <button type="button" class="btn btn-link btn-sm p-0 text-primary" onclick="refreshCacheStats()">
                        <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;" class="me-1"></i>刷新
                </button>
            </div>
                
                <div class="d-flex flex-column gap-2">
                    <!-- 記憶體快取 -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <p class="mb-0 fw-medium">記憶體快取</p>
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); showModal('memory-help')">
                                    <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                             </button>
                         </div>
                            <p class="small text-muted mb-0" id="memoryCacheSize">@(ViewBag.MemoryCacheSize != null ? $"{ViewBag.MemoryCacheSize / (1024 * 1024):F1} MB" : "--")</p>
                     </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-primary btn-sm" onclick="clearCache('memory', false, $(this))">全部清理</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="clearCache('memory', true, $(this))">30天清理</button>
                     </div>
                 </div>
                    
                    <!-- 資料庫快取 -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <p class="mb-0 fw-medium">資料庫快取</p>
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); showModal('database-help')">
                                    <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                             </button>
                         </div>
                            <p class="small text-muted mb-0" id="databaseCacheSize">@(ViewBag.CacheEntries ?? 0) 個條目</p>
                     </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-info btn-sm" onclick="clearCache('database', false, $(this))">全部清理</button>
                            <button type="button" class="btn btn-outline-info btn-sm" onclick="clearCache('database', true, $(this))">30天清理</button>
                     </div>
                 </div>
                    
                    <!-- 檔案快取 -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <p class="mb-0 fw-medium">檔案快取</p>
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); showModal('file-help')">
                                    <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                             </button>
                         </div>
                            <p class="small text-muted mb-0" id="fileCacheSize">最後清理：@(ViewBag.LastCacheCleared?.ToString("yyyy-MM-dd HH:mm") ?? "未知")</p>
                     </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-success btn-sm" onclick="clearCache('file', false, $(this))">全部清理</button>
                            <button type="button" class="btn btn-outline-success btn-sm" onclick="clearCache('file', true, $(this))">30天清理</button>
                        </div>
                    </div>
                     </div>
                 </div>
             </div>
        </div>
    </div>

    <!-- 系統維護工具 -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h5 class="card-title fw-semibold d-flex align-items-center gap-2 mb-3">
            <i data-lucide="wrench" style="width: 1.25rem; height: 1.25rem;"></i>
            系統維護工具
        </h5>
        <div class="row g-3">
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 border rounded gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-medium mb-1">維護模式</p>
                        <p class="small text-muted mb-0">暫時關閉網站進行維護</p>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="maintenanceMode" onchange="toggleMaintenanceMode()" style="width: 3rem; height: 1.5rem; cursor: pointer;">
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 border rounded gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-medium mb-1">資料庫優化</p>
                        <p class="small text-muted mb-0">清理和優化資料庫</p>
                </div>
                    <button type="button" id="btnOptimizeDatabase" class="btn btn-primary btn-sm" onclick="optimizeDatabase()">
                    執行優化
                </button>
            </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 border rounded gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-medium mb-1">系統重啟</p>
                        <p class="small text-muted mb-0">重新啟動應用程式</p>
                </div>
                    <button type="button" id="btnRestartSystem" class="btn btn-danger btn-sm" onclick="restartApplication()">
                    重啟系統
                </button>
            </div>
        </div>
    </div>
         </div>
     </div>

     <!-- 硬體資訊 -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h5 class="card-title fw-semibold d-flex align-items-center gap-2 mb-3">
            <i data-lucide="monitor" style="width: 1.25rem; height: 1.25rem;"></i>
            硬體資訊
        </h5>
        <div class="row g-3">
             <!-- CPU 資訊 -->
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="cpu" style="width: 1rem; height: 1rem;"></i>
                     CPU 資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">型號</span>
                            <span class="small fw-medium text-truncate ms-2" style="max-width: 60%;">@(ViewBag.HardwareInfo?.cpu_model ?? "未知")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">核心數</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.cpu_cores ?? 0) 核心 @(ViewBag.HardwareInfo?.cpu_threads ?? 0) 執行緒</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">時脈</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.cpu_base_clock?.ToString("F1") ?? "--") - @(ViewBag.HardwareInfo?.cpu_boost_clock?.ToString("F1") ?? "--") GHz</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">溫度</span>
                            <span class="small fw-medium @(ViewBag.HardwareInfo?.cpu_temperature > 80 ? "text-danger" : ViewBag.HardwareInfo?.cpu_temperature > 60 ? "text-warning" : "text-success")">
                                @(ViewBag.HardwareInfo?.cpu_temperature ?? 0)°C
                            </span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">健康度</span>
                            <span class="small fw-medium @(ViewBag.HardwareInfo?.cpu_health_percentage < 80 ? "text-danger" : ViewBag.HardwareInfo?.cpu_health_percentage < 90 ? "text-warning" : "text-success")">
                                @(ViewBag.HardwareInfo?.cpu_health_percentage ?? 0)%
                            </span>
                     </div>
                     </div>
                 </div>
             </div>
             
             <!-- GPU 資訊 -->
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="monitor" style="width: 1rem; height: 1rem;"></i>
                     GPU 資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">型號</span>
                            <span class="small fw-medium text-truncate ms-2" style="max-width: 60%;">@(ViewBag.HardwareInfo?.gpu_model ?? "未知")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">記憶體</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.gpu_memory_size ?? "未知")</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">製造商</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.gpu_manufacturer ?? "未知")</span>
                    </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">溫度</span>
                            <span class="small fw-medium @(ViewBag.HardwareInfo?.gpu_temperature > 80 ? "text-danger" : ViewBag.HardwareInfo?.gpu_temperature > 60 ? "text-warning" : "text-success")">
                                @(ViewBag.HardwareInfo?.gpu_temperature ?? 0)°C
                            </span>
                    </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">健康度</span>
                            <span class="small fw-medium @(ViewBag.HardwareInfo?.gpu_health_percentage < 80 ? "text-danger" : ViewBag.HardwareInfo?.gpu_health_percentage < 90 ? "text-warning" : "text-success")">
                                @(ViewBag.HardwareInfo?.gpu_health_percentage ?? 0)%
                            </span>
                    </div>
                     </div>
                 </div>
             </div>
             
             <!-- 記憶體資訊 -->
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="memory-stick" style="width: 1rem; height: 1rem;"></i>
                     記憶體資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">總容量</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.memory_total_capacity ?? "未知")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">速度</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.memory_speed ?? "未知")</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">通道數</span>
                            <span class="small fw-medium">4 通道</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">已使用</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.memory_used_gb?.ToString("F1") ?? "0") / @(ViewBag.HardwareInfo?.memory_total_capacity_gb ?? 0) GB</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">健康度</span>
                            <span class="small fw-medium @(ViewBag.HardwareInfo?.memory_health_percentage < 80 ? "text-danger" : ViewBag.HardwareInfo?.memory_health_percentage < 90 ? "text-warning" : "text-success")">
                                @(ViewBag.HardwareInfo?.memory_health_percentage ?? 0)%
                            </span>
                     </div>
                     </div>
                 </div>
             </div>
             
             <!-- 系統資訊 -->
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="server" style="width: 1rem; height: 1rem;"></i>
                        系統資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">主機名稱</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.host_name ?? "未知")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">作業系統</span>
                            <span class="small fw-medium text-truncate ms-2" style="max-width: 60%;">@(ViewBag.HardwareInfo?.operating_system ?? "未知")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">系統版本</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.operating_system ?? "未知")</span>
                     </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">運行時間</span>
                            <span class="small fw-medium">@(ViewBag.HardwareInfo?.uptime ?? "未知")</span>
                    </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">電源狀態</span>
                            <span class="small fw-medium @(ViewBag.HardwareInfo?.power_efficiency == "正常" ? "text-success" : "text-danger")">
                                @(ViewBag.HardwareInfo?.power_efficiency ?? "未知")
                            </span>
                    </div>
                     </div>
                     </div>
                 </div>
             </div>
         </div>
     </div>

@section Scripts {
    <script>
        // 初始化 Lucide 圖示
        $(document).ready(() => {
            window.lucide?.createIcons?.();
        });
        
        // 清理日誌
        function clearLogs(logType, is30Days, $button) {
            const confirmMessage = is30Days 
                ? `確定要清理30天前的${getLogTypeName(logType)}嗎？` 
                : `確定要清理所有${getLogTypeName(logType)}嗎？`;
            
            if (!confirm(confirmMessage)) return;

            const originalText = $button.text();
            $button.prop('disabled', true).text('清理中...');

            $.ajax({
                type: 'POST',
                url: '/Backoffice/Settings/ClearLogs',
                data: { logType: logType, is30Days: is30Days },
                success: (data) => {
                    if (data.success) {
                        showNotification(data.message, 'success');
                        refreshLogStats();
                    } else {
                        showNotification(data.message, 'error');
                    }
                },
                error: (xhr, status, error) => {
                    showNotification('清理失敗：' + error, 'error');
                },
                complete: () => {
                    $button.prop('disabled', false).text(originalText);
                }
            });
        }

        // 清理快取
        function clearCache(cacheType, is30Days, $button) {
            const confirmMessage = is30Days 
                ? `確定要清理30天前的${getCacheTypeName(cacheType)}嗎？` 
                : `確定要清理所有${getCacheTypeName(cacheType)}嗎？`;
            
            if (!confirm(confirmMessage)) return;

            const originalText = $button.text();
            $button.prop('disabled', true).text('清理中...');

            $.ajax({
                type: 'POST',
                url: '/Backoffice/Settings/ClearCache',
                data: { cacheType: cacheType, is30Days: is30Days },
                success: (data) => {
                    if (data.success) {
                        showNotification(data.message, 'success');
                        refreshCacheStats();
                    } else {
                        showNotification(data.message, 'error');
                    }
                },
                error: (xhr, status, error) => {
                    showNotification('清理失敗：' + error, 'error');
                },
                complete: () => {
                    $button.prop('disabled', false).text(originalText);
                }
            });
        }

        // 刷新日誌統計
        function refreshLogStats() {
            $.ajax({
                type: 'GET',
                url: '/Backoffice/Settings/RefreshLogStats',
                success: (data) => {
                    if (data.success) {
                        $('#errorLogCount').text(data.errorLogs + ' 條記錄');
                        $('#accessLogCount').text(data.accessLogs + ' 條記錄');
                        $('#systemLogCount').text(data.accessLogs + ' 條記錄');
                    }
                },
                error: (xhr, status, error) => {
                    console.error('刷新日誌統計失敗：', error);
                }
            });
        }

        // 刷新快取統計
        function refreshCacheStats() {
            $.ajax({
                type: 'GET',
                url: '/Backoffice/Settings/RefreshCacheStats',
                success: (data) => {
                    if (data.success) {
                        $('#memoryCacheSize').text((data.memoryCacheSize / (1024 * 1024)).toFixed(1) + ' MB');
                        $('#databaseCacheSize').text(data.cacheEntries + ' 個條目');
                        $('#fileCacheSize').text('最後清理：' + data.lastCleared);
                    }
                },
                error: (xhr, status, error) => {
                    console.error('刷新快取統計失敗：', error);
                }
            });
        }

        // 獲取日誌類型名稱
        function getLogTypeName(logType) {
            const names = {
                'error': '錯誤日誌',
                'access': '存取記錄',
                'system': '系統日誌'
            };
            return names[logType] || logType;
        }

        // 獲取快取類型名稱
        function getCacheTypeName(cacheType) {
            const names = {
                'memory': '記憶體快取',
                'database': '資料庫快取',
                'file': '檔案快取',
                'all': '所有快取'
            };
            return names[cacheType] || cacheType;
        }   

        // 顯示通知
        function showNotification(message, type = 'info') {
            const bgColor = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
            const $notification = $('<div>')
                .addClass(`position-fixed top-0 end-0 m-3 p-3 rounded shadow-lg text-white ${bgColor}`)
                .css('z-index', '9999')
                .text(message);

            $('body').append($notification);

            setTimeout(() => {
                $notification.remove();
            }, 3000);
        }

        // 切換維護模式
        function toggleMaintenanceMode() {
            const $checkbox = $('#maintenanceMode');
            const enabled = $checkbox.prop('checked');
            
            if (!confirm(enabled ? '確定要啟用維護模式嗎？這將暫時關閉網站。' : '確定要停用維護模式嗎？')) {
                $checkbox.prop('checked', !enabled);
                return;
            }

            $.ajax({
                type: 'POST',
                url: '/Backoffice/Settings/ToggleMaintenanceMode',
                data: { enabled: enabled },
                success: (data) => {
                    if (data.success) {
                        showNotification(data.message, 'success');
                    } else {
                        showNotification(data.message, 'error');
                        $checkbox.prop('checked', !enabled);
                    }
                },
                error: (xhr, status, error) => {
                    showNotification('操作失敗：' + error, 'error');
                    $checkbox.prop('checked', !enabled);
                }
            });
        }

        // 資料庫優化
        function optimizeDatabase() {
            if (!confirm('確定要優化資料庫嗎？這可能需要幾分鐘時間。')) return;
            
            const $button = $('#btnOptimizeDatabase');
            const originalText = $button.text();
            $button.prop('disabled', true).text('優化中...');

            $.ajax({
                type: 'POST',
                url: '/Backoffice/Settings/OptimizeDatabase',
                success: (data) => {
                    if (data.success) {
                        showNotification(data.message, 'success');
                        if (data.details) {
                            console.log('優化詳情：', data.details);
                        }
                    } else {
                        showNotification(data.message, 'error');
                    }
                },
                error: (xhr, status, error) => {
                    showNotification('優化失敗：' + error, 'error');
                },
                complete: () => {
                    $button.prop('disabled', false).text(originalText);
                }
            });
        }

        // 系統重啟
        function restartApplication() {
            if (!confirm('確定要重啟系統嗎？這將中斷所有用戶的連接。')) return;
            
            const $button = $('#btnRestartSystem');
            const originalText = $button.text();
            $button.prop('disabled', true).text('重啟中...');

            $.ajax({
                type: 'POST',
                url: '/Backoffice/Settings/RestartSystem',
                success: (data) => {
                    if (data.success) {
                        showNotification(data.message, 'success');
                    } else {
                        showNotification(data.message, 'error');
                    }
                },
                error: (xhr, status, error) => {
                    showNotification('重啟失敗：' + error, 'error');
                },
                complete: () => {
                    $button.prop('disabled', false).text(originalText);
                }
            });
        }
    </script>
}
