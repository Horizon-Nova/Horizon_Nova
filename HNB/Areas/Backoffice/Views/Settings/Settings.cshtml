@model Models.HnbHnbBackoffice.vw_system_config_server
@{
    ViewData["Title"] = "系統管理 - 後台管理系統";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="space-y-6">
    <header class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold flex items-center gap-3">
                <i data-lucide="settings" class="h-8 w-8"></i> 系統管理
            </h1>
            <p class="text-slate-500">系統監控、日誌管理、快取清理和維護工具</p>
        </div>
    </header>

    <!-- 系統狀態卡片 -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">系統狀態</p>
                    <p class="text-2xl font-bold text-green-600">正常</p>
                </div>
                <i data-lucide="activity" class="h-8 w-8 text-green-500"></i>
            </div>
        </div>
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">CPU 使用率</p>
                    <p class="text-2xl font-bold" id="cpuUsage">--</p>
                </div>
                <i data-lucide="cpu" class="h-8 w-8 text-blue-500"></i>
            </div>
        </div>
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">記憶體使用率</p>
                    <p class="text-2xl font-bold" id="memoryUsage">--</p>
                </div>
                <i data-lucide="memory-stick" class="h-8 w-8 text-purple-500"></i>
            </div>
        </div>
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">磁碟使用率</p>
                    <p class="text-2xl font-bold" id="diskUsage">--</p>
                </div>
                <i data-lucide="hard-drive" class="h-8 w-8 text-orange-500"></i>
            </div>
        </div>
    </div>

    <!-- 管理工具 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- 日誌管理 -->
        <div class="bg-white border rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold flex items-center gap-2">
                    <i data-lucide="file-text" class="h-5 w-5"></i>
                    日誌管理
                </h3>
                <button type="button" class="text-sm text-blue-600 hover:text-blue-800" onclick="refreshLogs()">
                    <i data-lucide="refresh-cw" class="h-4 w-4 inline mr-1"></i>刷新
                </button>
            </div>
             <div class="space-y-3">
                 <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                     <div class="flex-1">
                         <div class="flex items-center gap-2 mb-1">
                             <p class="font-medium">錯誤日誌</p>
                             <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showDetailModal('error')">
                                 <i data-lucide="help-circle" class="h-4 w-4"></i>
                             </button>
                         </div>
                         <p class="text-sm text-gray-500" id="errorLogCount">載入中...</p>
                     </div>
                     <div class="flex gap-2">
                         <button type="button" class="px-3 py-1 bg-red-100 text-red-700 rounded text-sm hover:bg-red-200" onclick="clearLogs('error', false)">
                             全部清理
                         </button>
                         <button type="button" class="px-3 py-1 bg-orange-100 text-orange-700 rounded text-sm hover:bg-orange-200" onclick="clearLogs('error', true)">
                             30天清理
                         </button>
                     </div>
                 </div>
                 <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                     <div class="flex-1">
                         <div class="flex items-center gap-2 mb-1">
                             <p class="font-medium">系統日誌</p>
                             <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showDetailModal('system')">
                                 <i data-lucide="help-circle" class="h-4 w-4"></i>
                             </button>
                         </div>
                         <p class="text-sm text-gray-500" id="systemLogCount">載入中...</p>
                     </div>
                     <div class="flex gap-2">
                         <button type="button" class="px-3 py-1 bg-blue-100 text-blue-700 rounded text-sm hover:bg-blue-200" onclick="clearLogs('system', false)">
                             全部清理
                         </button>
                         <button type="button" class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded text-sm hover:bg-indigo-200" onclick="clearLogs('system', true)">
                             30天清理
                         </button>
                     </div>
                 </div>
                 <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                     <div class="flex-1">
                         <div class="flex items-center gap-2 mb-1">
                             <p class="font-medium">存取日誌</p>
                             <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showDetailModal('access')">
                                 <i data-lucide="help-circle" class="h-4 w-4"></i>
                             </button>
                         </div>
                         <p class="text-sm text-gray-500" id="accessLogCount">載入中...</p>
                     </div>
                     <div class="flex gap-2">
                         <button type="button" class="px-3 py-1 bg-green-100 text-green-700 rounded text-sm hover:bg-green-200" onclick="clearLogs('access', false)">
                             全部清理
                         </button>
                         <button type="button" class="px-3 py-1 bg-teal-100 text-teal-700 rounded text-sm hover:bg-teal-200" onclick="clearLogs('access', true)">
                             30天清理
                         </button>
                     </div>
                 </div>
             </div>
        </div>

        <!-- 快取管理 -->
        <div class="bg-white border rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold flex items-center gap-2">
                    <i data-lucide="database" class="h-5 w-5"></i>
                    快取管理
                </h3>
                <button type="button" class="text-sm text-blue-600 hover:text-blue-800" onclick="refreshCache()">
                    <i data-lucide="refresh-cw" class="h-4 w-4 inline mr-1"></i>刷新
                </button>
            </div>
             <div class="space-y-3">
                 <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                     <div class="flex-1">
                         <div class="flex items-center gap-2 mb-1">
                             <p class="font-medium">記憶體快取</p>
                             <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showDetailModal('memory')">
                                 <i data-lucide="help-circle" class="h-4 w-4"></i>
                             </button>
                         </div>
                         <p class="text-sm text-gray-500" id="memoryCacheSize">載入中...</p>
                     </div>
                     <div class="flex gap-2">
                         <button type="button" class="px-3 py-1 bg-purple-100 text-purple-700 rounded text-sm hover:bg-purple-200" onclick="clearCache('memory', false)">
                             全部清理
                         </button>
                         <button type="button" class="px-3 py-1 bg-pink-100 text-pink-700 rounded text-sm hover:bg-pink-200" onclick="clearCache('memory', true)">
                             30天清理
                         </button>
                     </div>
                 </div>
                 <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                     <div class="flex-1">
                         <div class="flex items-center gap-2 mb-1">
                             <p class="font-medium">資料庫快取</p>
                             <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showDetailModal('database')">
                                 <i data-lucide="help-circle" class="h-4 w-4"></i>
                             </button>
                         </div>
                         <p class="text-sm text-gray-500" id="databaseCacheSize">載入中...</p>
                     </div>
                     <div class="flex gap-2">
                         <button type="button" class="px-3 py-1 bg-blue-100 text-blue-700 rounded text-sm hover:bg-blue-200" onclick="clearCache('database', false)">
                             全部清理
                         </button>
                         <button type="button" class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded text-sm hover:bg-indigo-200" onclick="clearCache('database', true)">
                             30天清理
                         </button>
                     </div>
                 </div>
                 <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                     <div class="flex-1">
                         <div class="flex items-center gap-2 mb-1">
                             <p class="font-medium">檔案快取</p>
                             <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showDetailModal('file')">
                                 <i data-lucide="help-circle" class="h-4 w-4"></i>
                             </button>
                         </div>
                         <p class="text-sm text-gray-500" id="fileCacheSize">載入中...</p>
                     </div>
                     <div class="flex gap-2">
                         <button type="button" class="px-3 py-1 bg-green-100 text-green-700 rounded text-sm hover:bg-green-200" onclick="clearCache('file', false)">
                             全部清理
                         </button>
                         <button type="button" class="px-3 py-1 bg-amber-100 text-amber-700 rounded text-sm hover:bg-amber-200" onclick="clearCache('file', true)">
                             30天清理
                         </button>
                     </div>
                 </div>
             </div>
        </div>
    </div>

    <!-- 系統維護工具 -->
    <div class="bg-white border rounded-xl p-6">
        <h3 class="text-lg font-semibold flex items-center gap-2 mb-4">
            <i data-lucide="wrench" class="h-5 w-5"></i>
            系統維護工具
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="flex items-center justify-between p-4 border rounded-lg">
                <div>
                    <p class="font-medium">維護模式</p>
                    <p class="text-sm text-gray-500">暫時關閉網站進行維護</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" class="sr-only peer" id="maintenanceMode" onchange="toggleMaintenanceMode()">
                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
            </div>
            <div class="flex items-center justify-between p-4 border rounded-lg">
                <div>
                    <p class="font-medium">資料庫優化</p>
                    <p class="text-sm text-gray-500">清理和優化資料庫</p>
                </div>
                <button type="button" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" onclick="optimizeDatabase()">
                    執行優化
                </button>
            </div>
            <div class="flex items-center justify-between p-4 border rounded-lg">
                <div>
                    <p class="font-medium">系統重啟</p>
                    <p class="text-sm text-gray-500">重新啟動應用程式</p>
                </div>
                <button type="button" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" onclick="restartApplication()">
                    重啟系統
                </button>
            </div>
        </div>
    </div>

     <!-- 最近活動 -->
     <div class="bg-white border rounded-xl p-6">
         <h3 class="text-lg font-semibold flex items-center gap-2 mb-4">
             <i data-lucide="activity" class="h-5 w-5"></i>
             最近活動
         </h3>
         <div class="space-y-3">
             <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                 <div class="p-2 bg-green-100 rounded-lg">
                     <i data-lucide="check-circle" class="h-4 w-4 text-green-600"></i>
                 </div>
                 <div class="flex-1">
                     <p class="text-sm font-medium">系統啟動完成</p>
                     <p class="text-xs text-gray-500">系統已成功啟動並運行正常</p>
                 </div>
                 <span class="text-xs text-gray-400">剛剛</span>
             </div>
             <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                 <div class="p-2 bg-blue-100 rounded-lg">
                     <i data-lucide="refresh-cw" class="h-4 w-4 text-blue-600"></i>
                 </div>
                 <div class="flex-1">
                     <p class="text-sm font-medium">快取已更新</p>
                     <p class="text-xs text-gray-500">系統快取已自動更新</p>
                 </div>
                 <span class="text-xs text-gray-400">5 分鐘前</span>
             </div>
             <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                 <div class="p-2 bg-yellow-100 rounded-lg">
                     <i data-lucide="alert-triangle" class="h-4 w-4 text-yellow-600"></i>
                 </div>
                 <div class="flex-1">
                     <p class="text-sm font-medium">記憶體使用率較高</p>
                     <p class="text-xs text-gray-500">建議檢查記憶體使用情況</p>
                 </div>
                 <span class="text-xs text-gray-400">10 分鐘前</span>
             </div>
         </div>
     </div>

     <!-- 快速操作 -->
     <div class="bg-white border rounded-xl p-6">
         <h3 class="text-lg font-semibold flex items-center gap-2 mb-4">
             <i data-lucide="zap" class="h-5 w-5"></i>
             快速操作
         </h3>
         <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
             <button type="button" class="flex flex-col items-center p-4 border rounded-lg hover:bg-gray-50 transition-colors" onclick="systemHealth()">
                 <i data-lucide="heart" class="h-6 w-6 text-pink-500 mb-2"></i>
                 <span class="text-sm font-medium">系統健康檢查</span>
                 <span class="text-xs text-gray-500">檢查系統狀態</span>
             </button>
             <button type="button" class="flex flex-col items-center p-4 border rounded-lg hover:bg-gray-50 transition-colors" onclick="backupDatabase()">
                 <i data-lucide="database" class="h-6 w-6 text-green-500 mb-2"></i>
                 <span class="text-sm font-medium">資料庫備份</span>
                 <span class="text-xs text-gray-500">建立備份檔案</span>
             </button>
             <button type="button" class="flex flex-col items-center p-4 border rounded-lg hover:bg-gray-50 transition-colors" onclick="exportLogs()">
                 <i data-lucide="download" class="h-6 w-6 text-blue-500 mb-2"></i>
                 <span class="text-sm font-medium">匯出日誌</span>
                 <span class="text-xs text-gray-500">下載所有日誌</span>
             </button>
             <button type="button" class="flex flex-col items-center p-4 border rounded-lg hover:bg-gray-50 transition-colors" onclick="clearAllCache()">
                 <i data-lucide="trash-2" class="h-6 w-6 text-red-500 mb-2"></i>
                 <span class="text-sm font-medium">清理所有快取</span>
                 <span class="text-xs text-gray-500">清除全部快取</span>
             </button>
         </div>
     </div>

     <!-- 系統資訊 -->
     <div class="bg-white border rounded-xl p-6">
         <h3 class="text-lg font-semibold flex items-center gap-2 mb-4">
             <i data-lucide="monitor" class="h-5 w-5"></i>
             系統資訊
         </h3>
         <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
             <div class="space-y-3">
                 <div class="flex justify-between items-center py-2 border-b border-gray-100">
                     <span class="text-sm text-gray-600">作業系統</span>
                     <span class="text-sm font-medium" id="osInfo">載入中...</span>
                 </div>
                 <div class="flex justify-between items-center py-2 border-b border-gray-100">
                     <span class="text-sm text-gray-600">.NET 版本</span>
                     <span class="text-sm font-medium" id="dotnetVersion">載入中...</span>
                 </div>
                 <div class="flex justify-between items-center py-2">
                     <span class="text-sm text-gray-600">運行時間</span>
                     <span class="text-sm font-medium" id="uptime">載入中...</span>
                 </div>
             </div>
             <div class="space-y-3">
                 <div class="flex justify-between items-center py-2 border-b border-gray-100">
                     <span class="text-sm text-gray-600">機器名稱</span>
                     <span class="text-sm font-medium" id="machineName">載入中...</span>
                 </div>
                 <div class="flex justify-between items-center py-2">
                     <span class="text-sm text-gray-600">工作目錄</span>
                     <span class="text-sm font-medium text-gray-500 truncate ml-2" id="workingDirectory">載入中...</span>
                 </div>
             </div>
         </div>
     </div>
 </section>

<!-- 詳情彈出視窗 -->
<div id="detailModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl max-w-lg w-full">
        <div class="p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900" id="modalTitle">詳情資訊</h3>
                <button type="button" onclick="closeDetailModal()" class="text-gray-400 hover:text-gray-600">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </button>
            </div>
            <div id="modalContent" class="text-gray-600 space-y-2">
                <!-- 內容將由 JavaScript 動態填入 -->
            </div>
            <div class="mt-6 flex justify-end">
                <button type="button" onclick="closeDetailModal()" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors">
                    關閉
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

}