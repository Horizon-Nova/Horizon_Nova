@{
    Layout = null;
}

<!-- 錯誤日誌說明 -->
<div id="error-help" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg p-6 max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold flex items-center gap-2">
                <i data-lucide="alert-triangle" class="h-5 w-5 text-red-500"></i>
                錯誤日誌說明
            </h3>
            <button type="button" onclick="closeHelpModal('error-help')" class="text-gray-400 hover:text-gray-600">
                <i data-lucide="x" class="h-5 w-5"></i>
            </button>
        </div>
        <div class="space-y-3">
            <p class="text-sm text-gray-600">錯誤日誌記錄系統運行過程中發生的錯誤和異常。</p>
            <ul class="text-sm text-gray-600 space-y-1">
                <li>• 包含錯誤訊息、堆疊追蹤和時間戳</li>
                <li>• 幫助開發者診斷和修復問題</li>
                <li>• 建議定期清理以節省儲存空間</li>
            </ul>
        </div>
    </div>
</div>

<!-- 系統日誌說明 -->
