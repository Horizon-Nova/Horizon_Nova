<!-- 人員管理說明 -->
<div id="user-form-help" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-hidden mx-4">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="help-circle" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">人員管理操作說明</h3>
                </div>
                <button onclick="closeHelpModal('user-form-help')" class="text-white hover:text-blue-200 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(80vh-120px)]">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-blue-600"></i>基本操作
                    </h4>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>必填欄位</strong>：標示紅色星號 (*) 的欄位為必填</li>
                        <li>• <strong>密碼顯示</strong>：點擊密碼欄位右側的眼睛圖標可切換顯示/隱藏</li>
                        <li>• <strong>表單驗證</strong>：系統會自動檢查必填欄位和格式</li>
                        <li>• <strong>儲存變更</strong>：點擊底部「儲存變更」按鈕完成操作</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="user" class="w-4 h-4 mr-2 text-green-600"></i>基本欄位說明
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                        <div>
                            <p><strong>姓名：</strong>使用者的完整姓名</p>
                            <p><strong>電子郵件：</strong>登入帳號和聯絡方式</p>
                            <p><strong>電話：</strong>聯絡電話號碼</p>
                            <p><strong>性別：</strong>使用者性別</p>
                        </div>
                        <div>
                            <p><strong>使用者名稱：</strong>系統登入用的帳號</p>
                            <p><strong>密碼：</strong>登入密碼（編輯時可留空不變更）</p>
                            <p><strong>暱稱：</strong>顯示用的暱稱</p>
                            <p><strong>星座：</strong>個人星座資訊</p>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="shield" class="w-4 h-4 mr-2 text-purple-600"></i>權限設定說明
                    </h4>
                    <div class="space-y-2 text-sm text-slate-600">
                        <p>• <strong>角色：</strong>選擇使用者的角色，決定其系統權限範圍</p>
                        <p>• <strong>組織：</strong>選擇使用者所屬的組織單位，用於群組管理</p>
                        <p>• <strong>必填項目：</strong>角色和組織都是必填欄位，請務必選擇</p>
                        <p>• <strong>權限繼承：</strong>使用者將繼承所選角色的所有權限</p>
                    </div>
                </div>
                
                <div class="bg-blue-50 rounded-lg p-4">
                    <h4 class="font-semibold text-blue-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-blue-700">
                        編輯現有人員時，密碼欄位留空表示不變更現有密碼。所有變更都會即時儲存到系統中。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 角色管理說明 -->
<div id="role-form-help" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-hidden mx-4">
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="help-circle" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">角色管理操作說明</h3>
                </div>
                <button onclick="closeHelpModal('role-form-help')" class="text-white hover:text-green-200 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(80vh-120px)]">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-green-600"></i>基本操作
                    </h4>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>必填欄位</strong>：標示紅色星號 (*) 的欄位為必填</li>
                        <li>• <strong>角色名稱</strong>：系統中唯一識別角色的名稱</li>
                        <li>• <strong>權限類型</strong>：定義角色的權限範圍和等級</li>
                        <li>• <strong>狀態控制</strong>：啟用/停用角色以控制其可用性</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="shield" class="w-4 h-4 mr-2 text-blue-600"></i>欄位說明
                    </h4>
                    <div class="space-y-3 text-sm">
                        <div>
                            <p><strong>角色名稱：</strong>在系統中顯示的角色名稱，建議使用簡潔明確的名稱</p>
                            <p><strong>權限類型：</strong>定義角色的權限範圍，如「管理員」、「使用者」、「訪客」等</p>
                        </div>
                        <div>
                            <p><strong>角色描述：</strong>詳細說明角色的職責和權限範圍</p>
                            <p><strong>備註：</strong>額外的說明或特殊注意事項</p>
                        </div>
                    </div>
                </div>
                
                <div class="bg-green-50 rounded-lg p-4">
                    <h4 class="font-semibold text-green-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-green-700">
                        建議為不同層級的使用者建立對應的角色，並在描述中清楚說明每個角色的權限範圍，以便後續管理。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 組織管理說明 -->
<div id="organization-form-help" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-hidden mx-4">
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="help-circle" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">組織管理操作說明</h3>
                </div>
                <button onclick="closeHelpModal('organization-form-help')" class="text-white hover:text-purple-200 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(80vh-120px)]">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-purple-600"></i>基本操作
                    </h4>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>必填欄位</strong>：標示紅色星號 (*) 的欄位為必填</li>
                        <li>• <strong>組織名稱</strong>：組織單位的正式名稱</li>
                        <li>• <strong>組織層級</strong>：定義組織在階層中的位置（1-10級）</li>
                        <li>• <strong>狀態控制</strong>：啟用/停用組織以控制其可用性</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="building" class="w-4 h-4 mr-2 text-blue-600"></i>欄位說明
                    </h4>
                    <div class="space-y-3 text-sm">
                        <div>
                            <p><strong>組織名稱：</strong>組織單位的完整名稱，建議使用正式名稱</p>
                            <p><strong>組織層級：</strong>數字1-10，表示組織在階層中的層級，數字越小層級越高</p>
                        </div>
                        <div>
                            <p><strong>組織描述：</strong>詳細說明組織的職責、功能和業務範圍</p>
                            <p><strong>備註：</strong>額外的說明或特殊注意事項</p>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="layers" class="w-4 h-4 mr-2 text-orange-600"></i>層級說明
                    </h4>
                    <div class="space-y-2 text-sm text-slate-600">
                        <p>• <strong>1級</strong>：最高層級（如：總公司、總部）</p>
                        <p>• <strong>2-3級</strong>：高層管理（如：事業部、區域總部）</p>
                        <p>• <strong>4-6級</strong>：中層管理（如：部門、分公司）</p>
                        <p>• <strong>7-10級</strong>：基層單位（如：小組、專案團隊）</p>
                    </div>
                </div>
                
                <div class="bg-purple-50 rounded-lg p-4">
                    <h4 class="font-semibold text-purple-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-purple-700">
                        建議根據實際組織架構設定層級，並在描述中清楚說明組織的職責範圍，以便後續進行人員分配和權限管理。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function showHelpModal(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // 防止背景滾動
    }
}

function closeHelpModal(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto'; // 恢復背景滾動
    }
}

// 點擊背景關閉彈出視窗
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('bg-black')) {
        const modal = e.target.closest('.fixed');
        if (modal) {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
    }
});

// ESC 鍵關閉彈出視窗
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const visibleModal = document.querySelector('.fixed:not(.hidden)');
        if (visibleModal) {
            visibleModal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
    }
});
</script>
