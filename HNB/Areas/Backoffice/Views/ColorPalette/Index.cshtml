@{
    ViewData["Title"] = "顏色表";
    ViewData["PageTitle"] = "顏色表";
    ViewData["PageDescription"] = "瀏覽和搜尋顏色，查看顏色代碼和名稱";
    ViewData["PageIcon"] = "palette";
    ViewData["HelpModalId"] = "colorPaletteHelpModal";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- 搜尋框 -->
    <div class="mb-4">
        <div class="input-group">
            <span class="input-group-text">
                <i data-lucide="search" style="width: 1rem; height: 1rem;"></i>
            </span>
            <input type="text" 
                   id="colorSearchInput" 
                   class="form-control" 
                   placeholder="搜尋顏色名稱或顏色代碼（例如：red、#FF0000）"
                   autocomplete="off">
            <button class="btn btn-outline-secondary" type="button" id="clearSearchBtn" style="display: none;">
                清除
            </button>
        </div>
    </div>

    <!-- 顏色列表 -->
    <div id="colorList">
        <!-- 顏色項目將透過 JS 動態生成，按主色系分組 -->
    </div>

    <!-- 無結果提示 -->
    <div id="noResults" class="text-center text-muted py-5" style="display: none;">
        <i data-lucide="search-x" style="width: 3rem; height: 3rem; opacity: 0.5;"></i>
        <p class="mt-3 mb-0">找不到符合的顏色</p>
    </div>
</div>

@await Html.PartialAsync("Partials/Modal/_Help")

@section Scripts {
    <script src="~/Backoffice/js/ColorPalette.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof lucide !== 'undefined' && typeof lucide.createIcons === 'function') {
                lucide.createIcons();
            }
            
            // 初始化顏色表
            if (typeof ColorPalette !== 'undefined') {
                ColorPalette.init();
            }
        });
    </script>
}

