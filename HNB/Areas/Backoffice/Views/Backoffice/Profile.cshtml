@model Models.HnbBackoffice.vw_permission_user
@{
    ViewData["Title"] = "個人資料 - 後台管理系統";
    ViewData["PageTitle"] = "個人資料";
    ViewData["PageDescription"] = "管理您的個人資料和帳號設定";
    ViewData["PageIcon"] = "user";
    ViewData["HelpModalId"] = "profileHelpModal";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("Partials/_Styles")

<section class="mb-3 mb-lg-4">
    <div class="bg-white border rounded-3">
        @await Html.PartialAsync("Partials/_Header", Model)
        
        <!-- 標籤導航 -->
        <div class="border-bottom">
            <ul class="nav nav-tabs border-0 px-3 px-lg-4" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#basicTab" type="button">
                        <i data-lucide="user" style="width: 1rem; height: 1rem;"></i> 基本資料
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#securityTab" type="button">
                        <i data-lucide="shield" style="width: 1rem; height: 1rem;"></i> 安全設定
                    </button>
                </li>
            </ul>
        </div>

        <!-- 標籤內容 -->
        <div class="tab-content p-3 p-lg-4">
            @await Html.PartialAsync("Partials/_BasicInfo", Model)
            @await Html.PartialAsync("Partials/_SecuritySettings", Model)
        </div>
    </div>
</section>

@await Html.PartialAsync("Partials/Modal/_Help")

@section Scripts {
    @await Html.PartialAsync("Partials/_Scripts")
}
