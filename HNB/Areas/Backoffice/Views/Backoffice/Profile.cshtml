@model Models.HnbHnbBackoffice.vw_permission_user
@{
    ViewData["Title"] = "個人資料 - 後台管理系統";
    ViewData["PageTitle"] = "個人資料";
    ViewData["PageDescription"] = "管理您的個人資料和帳號設定";
    ViewData["PageIcon"] = "user";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<div class="space-y-6">
    <!-- 個人資料卡片 -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <!-- 頭部區域 -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-8 text-white">
            <div class="flex items-center space-x-6">
                <div class="relative">
                    @if (!string.IsNullOrEmpty(Model?.avatar_url))
                    {
                        <img class="w-20 h-20 rounded-full border-4 border-white shadow-lg" src="@Model.avatar_url" alt="@Model.full_name">
                    }
                    else
                    {
                        <div class="w-20 h-20 rounded-full border-4 border-white shadow-lg bg-white flex items-center justify-center">
                            <span class="text-2xl font-bold text-blue-600">@((Model?.full_name ?? Model?.username ?? "U").Substring(0, 1).ToUpper())</span>
                        </div>
                    }
                    <button class="absolute bottom-0 right-0 w-6 h-6 bg-white rounded-full flex items-center justify-center text-blue-600 hover:bg-blue-50 transition-colors">
                        <i data-lucide="camera" class="w-3 h-3"></i>
                    </button>
                </div>
                <div>
                    <h2 class="text-2xl font-bold">@(Model?.full_name ?? Model?.username ?? "未設定")</h2>
                    <p class="text-blue-100 text-lg">@(Model?.email ?? "未設定")</p>
                    <div class="flex items-center space-x-4 mt-2">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-white bg-opacity-20 text-white">
                            <i data-lucide="shield" class="w-3 h-3 mr-1"></i>
                            @(Model?.role_name ?? "一般用戶")
                        </span>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-white bg-opacity-20 text-white">
                            <i data-lucide="building" class="w-3 h-3 mr-1"></i>
                            @(Model?.organization_name ?? "未分配")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 標籤導航 -->
        <div class="border-b border-slate-200">
            <nav class="flex space-x-8 px-6">
                <button class="tab-button active py-4 px-2 border-b-2 border-blue-600 text-blue-600 font-medium text-sm" data-tab="basic">
                    <i data-lucide="user" class="w-4 h-4 inline mr-2"></i>基本資料
                </button>
                <button class="tab-button py-4 px-2 border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-medium text-sm" data-tab="security">
                    <i data-lucide="shield" class="w-4 h-4 inline mr-2"></i>安全設定
                </button>
                <button class="tab-button py-4 px-2 border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-medium text-sm" data-tab="preferences">
                    <i data-lucide="settings" class="w-4 h-4 inline mr-2"></i>偏好設定
                </button>
            </nav>
        </div>

        <!-- 標籤內容 -->
        <div class="p-6">
            <!-- 基本資料標籤 -->
            <div id="basic-tab" class="tab-content">
                <form id="profileForm" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@(Model?.id ?? 0)" />
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- 姓名 -->
                        <div>
                            <label for="full_name" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="user" class="w-4 h-4 inline mr-1"></i>完整姓名
                            </label>
                            <input type="text" id="full_name" name="name" value="@(Model?.full_name ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您的完整姓名">
                        </div>

                        <!-- 使用者名稱 -->
                        <div>
                            <label for="username" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="at-sign" class="w-4 h-4 inline mr-1"></i>使用者名稱
                            </label>
                            <input type="text" id="username" name="username" value="@(Model?.username ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg bg-slate-50 text-slate-500" 
                                   placeholder="使用者名稱" readonly>
                            <p class="text-xs text-slate-500 mt-1">使用者名稱無法修改</p>
                        </div>

                        <!-- 電子郵件 -->
                        <div>
                            <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="mail" class="w-4 h-4 inline mr-1"></i>電子郵件
                            </label>
                            <input type="email" id="email" name="email" value="@(Model?.email ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您的電子郵件">
                        </div>

                        <!-- 電話 -->
                        <div>
                            <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="phone" class="w-4 h-4 inline mr-1"></i>聯絡電話
                            </label>
                            <input type="text" id="phone" name="phone" value="@(Model?.phone ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您的聯絡電話">
                        </div>

                        <!-- 性別 -->
                        <div>
                            <label for="gender" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="users" class="w-4 h-4 inline mr-1"></i>性別
                            </label>
                            <select id="gender" name="gender" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                <option value="">請選擇性別</option>
                                <option value="male" @(Model?.gender == "male" ? "selected" : "")>男性</option>
                                <option value="female" @(Model?.gender == "female" ? "selected" : "")>女性</option>
                                <option value="other" @(Model?.gender == "other" ? "selected" : "")>其他</option>
                            </select>
                        </div>

                        <!-- 暱稱 -->
                        <div>
                            <label for="nickname" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="smile" class="w-4 h-4 inline mr-1"></i>暱稱
                            </label>
                            <input type="text" id="nickname" name="nickname" value="@(Model?.nickname ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您的暱稱">
                        </div>

                        <!-- 地點 -->
                        <div>
                            <label for="location" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="map-pin" class="w-4 h-4 inline mr-1"></i>常駐地點
                            </label>
                            <input type="text" id="location" name="location" value="@(Model?.location ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您的常駐地點">
                        </div>

                        <!-- 星座 -->
                        <div>
                            <label for="zodiac_sign" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="star" class="w-4 h-4 inline mr-1"></i>星座
                            </label>
                            <input type="text" id="zodiac_sign" name="zodiac_sign" value="@(Model?.zodiac_sign ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您的星座">
                        </div>

                        <!-- 喜歡顏色 -->
                        <div>
                            <label for="favorite_color" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="palette" class="w-4 h-4 inline mr-1"></i>喜歡顏色
                            </label>
                            <input type="text" id="favorite_color" name="favorite_color" value="@(Model?.favorite_color ?? "")" 
                                   class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                   placeholder="請輸入您喜歡的顏色">
                        </div>
                    </div>

                    <!-- 個人簡介 -->
                    <div>
                        <label for="bio" class="block text-sm font-semibold text-slate-700 mb-2">
                            <i data-lucide="file-text" class="w-4 h-4 inline mr-1"></i>個人簡介
                        </label>
                        <textarea id="bio" name="bio" rows="4" 
                                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none" 
                                  placeholder="請輸入您的個人簡介或工作描述">@(Model?.bio ?? "")</textarea>
                    </div>

                    <!-- 儲存按鈕 -->
                    <div class="flex justify-end">
                        <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium">
                            <i data-lucide="save" class="w-4 h-4 inline mr-2"></i>儲存變更
                        </button>
                    </div>
                </form>
            </div>

            <!-- 安全設定標籤 -->
            <div id="security-tab" class="tab-content hidden">
                <div class="space-y-6">
                    <!-- 變更密碼 -->
                    <div class="bg-slate-50 rounded-lg p-6">
                        <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                            <i data-lucide="lock" class="w-5 h-5 mr-2 text-blue-600"></i>變更密碼
                        </h3>
                        <form id="passwordForm" class="space-y-4">
                            @Html.AntiForgeryToken()
                            <div>
                                <label for="currentPassword" class="block text-sm font-semibold text-slate-700 mb-2">目前密碼</label>
                                <input type="password" id="currentPassword" name="currentPassword" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入目前密碼" required>
                            </div>
                            <div>
                                <label for="newPassword" class="block text-sm font-semibold text-slate-700 mb-2">新密碼</label>
                                <input type="password" id="newPassword" name="newPassword" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入新密碼" required>
                            </div>
                            <div>
                                <label for="confirmPassword" class="block text-sm font-semibold text-slate-700 mb-2">確認新密碼</label>
                                <input type="password" id="confirmPassword" name="confirmPassword" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請再次輸入新密碼" required>
                            </div>
                            <button type="submit" class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium">
                                <i data-lucide="key" class="w-4 h-4 inline mr-2"></i>更新密碼
                            </button>
                        </form>
                    </div>

                    <!-- 登入記錄 -->
                    <div class="bg-slate-50 rounded-lg p-6">
                        <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                            <i data-lucide="activity" class="w-5 h-5 mr-2 text-green-600"></i>登入記錄
                        </h3>
                        <div class="space-y-3">
                            <div class="flex items-center justify-between py-2">
                                <span class="text-slate-600">最後登入時間</span>
                                <span class="font-medium">@(Model?.last_login_at?.ToString("yyyy/MM/dd HH:mm") ?? "未記錄")</span>
                            </div>
                            <div class="flex items-center justify-between py-2">
                                <span class="text-slate-600">登入次數</span>
                                <span class="font-medium">@(Model?.login_count ?? 0) 次</span>
                            </div>
                            <div class="flex items-center justify-between py-2">
                                <span class="text-slate-600">最後登入IP</span>
                                <span class="font-medium">@(Model?.last_login_ip?.ToString() ?? "未記錄")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 偏好設定標籤 -->
            <div id="preferences-tab" class="tab-content hidden">
                <div class="space-y-6">
                    <div class="bg-slate-50 rounded-lg p-6">
                        <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                            <i data-lucide="palette" class="w-5 h-5 mr-2 text-purple-600"></i>外觀設定
                        </h3>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">主題</label>
                                <select class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="light">淺色主題</option>
                                    <option value="dark">深色主題</option>
                                    <option value="auto">跟隨系統</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">語言</label>
                                <select class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="zh-TW">繁體中文</option>
                                    <option value="zh-CN">簡體中文</option>
                                    <option value="en">English</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-50 rounded-lg p-6">
                        <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                            <i data-lucide="bell" class="w-5 h-5 mr-2 text-orange-600"></i>通知設定
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-medium text-slate-800">電子郵件通知</p>
                                    <p class="text-sm text-slate-500">接收重要系統通知</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                </label>
                            </div>
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-medium text-slate-800">系統更新通知</p>
                                    <p class="text-sm text-slate-500">系統維護和更新提醒</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer">
                                    <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // 初始化圖標
            lucide.createIcons();

            // 標籤切換功能
            $('.tab-button').on('click', function() {
                const tabName = $(this).data('tab');
                
                // 更新按鈕狀態
                $('.tab-button').removeClass('active border-blue-600 text-blue-600').addClass('border-transparent text-slate-500');
                $(this).removeClass('border-transparent text-slate-500').addClass('active border-blue-600 text-blue-600');
                
                // 顯示對應內容
                $('.tab-content').addClass('hidden');
                $(`#${tabName}-tab`).removeClass('hidden');
            });

            // 個人資料表單提交
            $('#profileForm').on('submit', function(e) {
                e.preventDefault();
                
                const formData = new FormData(this);
                
                $.ajax({
                    url: '@Url.Action("UpdateProfile", "Backoffice")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            showNotification('個人資料更新成功！', 'success');
                        } else {
                            showNotification('更新失敗：' + response.message, 'error');
                        }
                    },
                    error: function() {
                        showNotification('更新失敗，請稍後再試', 'error');
                    }
                });
            });

            // 密碼變更表單提交
            $('#passwordForm').on('submit', function(e) {
                e.preventDefault();
                
                const currentPassword = $('#currentPassword').val();
                const newPassword = $('#newPassword').val();
                const confirmPassword = $('#confirmPassword').val();
                
                if (newPassword !== confirmPassword) {
                    showNotification('新密碼與確認密碼不符', 'error');
                    return;
                }
                
                $.ajax({
                    url: '@Url.Action("ChangePassword", "Backoffice")',
                    type: 'POST',
                    data: {
                        currentPassword: currentPassword,
                        newPassword: newPassword,
                        confirmPassword: confirmPassword,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            showNotification('密碼更新成功！', 'success');
                            $('#passwordForm')[0].reset();
                        } else {
                            showNotification('密碼更新失敗：' + response.message, 'error');
                        }
                    },
                    error: function() {
                        showNotification('密碼更新失敗，請稍後再試', 'error');
                    }
                });
            });
        });

        // 通知函數
        function showNotification(message, type) {
            const bgColor = type === 'success' ? 'bg-green-500' : 'bg-red-500';
            const notification = $(`
                <div class="fixed top-4 right-4 ${bgColor} text-white px-6 py-3 rounded-lg shadow-lg z-50 notification">
                    <div class="flex items-center">
                        <i data-lucide="${type === 'success' ? 'check-circle' : 'alert-circle'}" class="w-5 h-5 mr-2"></i>
                        <span>${message}</span>
                    </div>
                </div>
            `);
            
            $('body').append(notification);
            lucide.createIcons();
            
            setTimeout(() => {
                notification.fadeOut(300, function() {
                    $(this).remove();
                });
            }, 3000);
        }
    </script>
}
