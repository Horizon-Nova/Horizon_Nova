@{
    Layout = null;
}

<!-- 資料夾操作 Modal -->
<div id="folder-action-modal" class="modal fade" tabindex="-1" aria-labelledby="folderActionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="folderActionModalLabel">資料夾操作</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-outline-primary" onclick="showModal('folder-rename-modal', {url: '@Url.Action("LoadFolderRename", "FileManager")', method: 'GET', data: {name: '@ViewBag.FolderName', currentPath: '@ViewBag.CurrentPath'}, container: 'file-manager-modal-host'})">
                        <i data-lucide="edit-3" style="width:1rem;height:1rem;"></i> 重新命名
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="showModal('folder-delete-modal', {url: '@Url.Action("LoadFolderDelete", "FileManager")', method: 'GET', data: {name: '@ViewBag.FolderName', currentPath: '@ViewBag.CurrentPath'}, container: 'file-manager-modal-host'})">
                        <i data-lucide="trash-2" style="width:1rem;height:1rem;"></i> 刪除
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 檔案預覽 Modal -->
<div id="file-preview-modal" class="modal fade" tabindex="-1" aria-labelledby="filePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="filePreviewModalLabel">檔案預覽</h5>
                <div class="d-flex gap-2">
                    <button type="button" onclick="showModal('file-preview-help-modal')" class="btn btn-sm btn-outline-secondary">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                    </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
            </div>
            <div class="modal-body">
                <!-- 檔案預覽內容將由 AJAX 載入 -->
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">載入中...</span>
                    </div>
                    <p class="mt-2 text-muted">正在載入檔案預覽...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
                <button type="button" class="btn btn-primary" onclick="showModal('file-edit-modal', {url: '@Url.Action("LoadFileEdit", "FileManager")', method: 'GET', data: {name: '@ViewBag.FileName', currentPath: '@ViewBag.CurrentPath'}, container: 'file-manager-modal-host'})">編輯</button>
            </div>
        </div>
    </div>
</div>

<!-- 檔案詳細資訊 Modal -->
<div id="file-detail-modal" class="modal fade" tabindex="-1" aria-labelledby="fileDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fileDetailModalLabel">檔案詳細資訊</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <!-- 檔案詳細資訊內容將由 AJAX 載入 -->
                <div class="text-center py-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">載入中...</span>
                    </div>
                    <p class="mt-2 text-muted">正在載入檔案資訊...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

<!-- 檔案重新命名 Modal -->
<div id="file-rename-modal" class="modal fade" tabindex="-1" aria-labelledby="fileRenameModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fileRenameModalLabel">重新命名檔案</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <!-- 重新命名表單內容將由 AJAX 載入 -->
                <div class="text-center py-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">載入中...</span>
                    </div>
                    <p class="mt-2 text-muted">正在載入重新命名表單...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 檔案下載 Modal -->
<div id="file-download-modal" class="modal fade" tabindex="-1" aria-labelledby="fileDownloadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fileDownloadModalLabel">檔案下載</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <!-- 下載選項內容將由 AJAX 載入 -->
                <div class="text-center py-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">載入中...</span>
                    </div>
                    <p class="mt-2 text-muted">正在準備下載...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 檔案預覽說明 Modal -->
<div id="file-preview-help-modal" class="modal fade" tabindex="-1" aria-labelledby="filePreviewHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="filePreviewHelpModalLabel">檔案預覽說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- 左側：說明內容 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 1. 基本操作流程 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">基本操作流程</h6>
                                <ol class="small mb-0">
                                    <li>點擊檔案名稱或「開啟」按鈕進入預覽模式</li>
                                    <li>支援多種檔案格式：圖片、文件、程式碼等</li>
                                    <li>使用工具列進行編輯、下載等操作</li>
                                    <li>按 ESC 或點擊關閉按鈕退出預覽</li>
                                </ol>
                            </div>
                            
                            <!-- 2. 支援的檔案類型 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">支援的檔案類型</h6>
                                <div class="small">
                                    <p><strong>圖片檔案：</strong> JPG, PNG, GIF, SVG, WebP</p>
                                    <p><strong>文件檔案：</strong> PDF, TXT, MD, DOC, DOCX</p>
                                    <p><strong>程式碼檔案：</strong> JS, CSS, HTML, C#, Python</p>
                                    <p><strong>其他檔案：</strong> 將提供下載連結</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 右側：常見問題 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 常見問題 Q&A -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題 (Q&A)</h6>
                                <div class="small">
                                    <p><strong>Q1：為什麼某些檔案無法預覽？</strong></p>
                                    <p class="ms-3">A：不支援的檔案類型會顯示下載選項，您可以下載到本地查看。</p>
                                    
                                    <p><strong>Q2：如何編輯檔案內容？</strong></p>
                                    <p class="ms-3">A：在預覽模式下點擊「編輯」按鈕，支援文字檔案的線上編輯。</p>
                                    
                                    <p><strong>Q3：預覽模式支援哪些快捷鍵？</strong></p>
                                    <p class="ms-3">A：ESC 關閉預覽，Ctrl+S 儲存編輯，Ctrl+Z 復原操作。</p>
                                </div>
                            </div>
                            
                            <!-- 注意事項 -->
                            <div class="alert alert-warning small mb-0">
                                <h6 class="fw-bold mb-2">重要提醒</h6>
                                <ul class="mb-0">
                                    <li>編輯檔案前請確認有寫入權限</li>
                                    <li>大型檔案可能載入較慢，請耐心等待</li>
                                    <li>編輯後請記得儲存變更</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>