@{
    Layout = null;
    var currentPath = ViewBag.CurrentPath as string ?? "/";
}
<script>
    window.__AF = window.__AF || function(){ return $('input[name="__RequestVerificationToken"]').val(); };
</script>

<!-- 新增資料夾 Modal -->
<div id="createFolderModal" class="modal fade" tabindex="-1" aria-labelledby="createFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createFolderModalLabel">新增資料夾</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <form id="createFolderForm">
                    <div class="mb-3">
                        <label for="folderName" class="form-label">資料夾名稱 <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="folderName" name="Name" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary js-submit-create-folder">建立</button>
            </div>
        </div>
    </div>
</div>

<!-- 檔案預覽 Modal -->
<div id="previewModal" class="modal fade" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="previewModalLabel">檔案預覽</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body p-0" style="min-height:70vh;">
                <div id="filePreviewContainer" class="p-3">
                    <div id="fpLoading" class="fp-section text-center py-5 text-muted">載入中...</div>
                    <div id="fpOffice" class="fp-section d-none">
                        <iframe id="fpOfficeFrame" src="" style="width:100%;height:70vh;border:0;"></iframe>
                    </div>
                    <div id="fpPdf" class="fp-section d-none">
                        <iframe id="fpPdfFrame" src="" style="width:100%;height:70vh;border:0;"></iframe>
                    </div>
                    <div id="fpUnsupported" class="fp-section d-none">
                        <div class="text-center py-5 text-muted">
                            此檔案不支援線上閱讀，請下載後查看。
                            <div class="mt-2">
                                <a id="fpDownloadLink" class="btn btn-sm btn-outline-secondary" href="#" target="_blank">下載檔案</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 圖片預覽（Discord 風格：可縮放/拖移） -->
                <div id="pvImageContainer" class="d-none position-relative" style="height:70vh; background:#111;">
                    <div id="pvImageWrapper" class="w-100 h-100 overflow-hidden position-relative" style="cursor:grab;">
                        <img id="pvImage" alt="preview" style="user-select:none; -webkit-user-drag:none; transform-origin: 0 0;" />
                    </div>
                    <div class="position-absolute end-0 bottom-0 m-3 d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-light js-pv-fit" title="適合視窗"><i data-lucide="maximize"></i></button>
                        <button type="button" class="btn btn-sm btn-light js-pv-zoom-out" title="縮小"><i data-lucide="zoom-out"></i></button>
                        <button type="button" class="btn btn-sm btn-light js-pv-zoom-in" title="放大"><i data-lucide="zoom-in"></i></button>
                    </div>
                </div>

                <!-- 文字編輯器 -->
                <div id="pvTextContainer" class="d-none" style="height:70vh;">
                    <div class="d-flex align-items-center justify-content-between border-bottom px-3 py-2">
                        <div class="small text-muted" id="pvTextMeta"></div>
                        <button type="button" class="btn btn-link btn-sm p-0" id="pvSaveTextBtn" title="儲存"><i data-lucide="save"></i></button>
                    </div>
                    <textarea id="pvTextArea" class="form-control border-0" style="height:calc(70vh - 42px); resize:none; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;"></textarea>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 新增檔案 Modal -->
