<!-- 重新命名資料夾 Modal -->
<div id="renameFolderModal" class="modal fade" tabindex="-1" aria-labelledby="renameFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="renameFolderModalLabel">重新命名資料夾</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <form id="renameFolderForm">
                    <div class="mb-3">
                        <label for="newFolderName" class="form-label">新名稱</label>
                        <input type="text" class="form-control" id="newFolderName" name="NewName" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary js-submit-rename-folder">重新命名</button>
            </div>
        </div>
    </div>
</div>

<script>
    if (typeof window.currentFolderName === 'undefined') window.currentFolderName = '';
    if (typeof window.currentFileName === 'undefined') window.currentFileName = '';
    if (typeof window.currentItemPath === 'undefined') window.currentItemPath = '/';
    if (typeof window.currentItemType === 'undefined') window.currentItemType = 'file';
    function openItem(name, type, path){
        if(type === 'folder'){
            const folderPath = path === '/' ? '/' + name : path + '/' + name;
            location.href = '@Url.Action("FileManager", "FileManager", new { area = "Backoffice" })' + '?path=' + encodeURIComponent(folderPath);
        } else {
            openPreview(path, name);
        }
    }

    function downloadItem(name, type, path){
        if(type === 'folder'){
            alert('目前未提供資料夾下載');
        } else {
            location.href = '@Url.Action("Download", "FileManager", new { area = "Backoffice" })' + `?path=${encodeURIComponent(path)}&name=${encodeURIComponent(name)}`;
        }
    }

    let __pv = { path: '', name: '', image: { scale: 1, fit: 1, x: 0, y: 0, dragging: false, sx: 0, sy: 0 } };

    function openPreview(path, name){
        const previewUrl = '@Url.Action("Preview", "FileManager", new { area = "Backoffice" })' + `?path=${encodeURIComponent(path)}&name=${encodeURIComponent(name)}`;
        const downloadUrl = '@Url.Action("Download", "FileManager", new { area = "Backoffice" })' + `?path=${encodeURIComponent(path)}&name=${encodeURIComponent(name)}`;
        const $container = $('#filePreviewContainer');
        const $fpLoading = $('#fpLoading');
        const $fpOffice = $('#fpOffice');
        const $fpPdf = $('#fpPdf');
        const $fpUnsupported = $('#fpUnsupported');
        const $fpOfficeFrame = $('#fpOfficeFrame');
        const $fpPdfFrame = $('#fpPdfFrame');
        const $fpDownloadLink = $('#fpDownloadLink');
        const $imgWrap = $('#pvImageContainer');
        const $txtWrap = $('#pvTextContainer');
        $container.removeClass('d-none');
        $('.fp-section').addClass('d-none');
        $fpLoading.removeClass('d-none');
        $imgWrap.addClass('d-none');
        $txtWrap.addClass('d-none');
        showModal('previewModal');

        const ext = (name.split('.').pop()||'').toLowerCase();
        const officeExts = ['doc','docx','xls','xlsx','ppt','pptx'];
        const textExts = ['txt','md','json','xml','csv','log','js','ts','css','html','cs','sql','yml','yaml','ini','conf','cfg','py','sh','bat','ps1','properties','toml'];
        const imageExts = ['png','jpg','jpeg','gif','svg','webp','bmp'];
        __pv.path = path; __pv.name = name;

        // 1) Office 線上閱讀
        if (officeExts.includes(ext)){
            const fullUrl = window.location.origin + downloadUrl;
            const officeViewerUrl = `https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(fullUrl)}`;
            $fpOfficeFrame.attr('src', officeViewerUrl);
            $('.fp-section').addClass('d-none');
            $fpOffice.removeClass('d-none');
            return;
        }

        // 2) PDF 直接內嵌
        if (ext === 'pdf'){
            $fpPdfFrame.attr('src', previewUrl);
            $('.fp-section').addClass('d-none');
            $fpPdf.removeClass('d-none');
            return;
        }

        // 3) 圖片閱讀器（可縮放/拖移）
        if (imageExts.includes(ext)){
            $container.addClass('d-none');
            const $img = $('#pvImage');
            const wrap = $('#pvImageWrapper')[0];
            $imgWrap.removeClass('d-none');
            $img.attr('src', previewUrl);
            // 初始化狀態
            __pv.image.scale = 1; __pv.image.x = 0; __pv.image.y = 0; __pv.image.fit = 1; __pv.image.dragging = false;
            $img.off('load').on('load', function(){
                const rect = wrap.getBoundingClientRect();
                const iw = this.naturalWidth, ih = this.naturalHeight;
                const sx = rect.width / iw, sy = rect.height / ih;
                __pv.image.fit = Math.min(sx, sy, 1);
                __pv.image.scale = __pv.image.fit;
                __pv.image.x = Math.round((rect.width - iw * __pv.image.scale)/2);
                __pv.image.y = Math.round((rect.height - ih * __pv.image.scale)/2);
                pvApply();
                window.lucide?.createIcons?.();
            });

            // 事件綁定（一次性）
            $('#pvImageWrapper').off('wheel').on('wheel', function(e){
                e.preventDefault();
                const delta = (e.originalEvent.deltaY < 0) ? 1.1 : 0.9;
                const rect = this.getBoundingClientRect();
                const mx = rect.width/2, my = rect.height/2;
                const img = $('#pvImage')[0];
                const iw = img.naturalWidth, ih = img.naturalHeight;
                const preX = (mx - __pv.image.x) / __pv.image.scale;
                const preY = (my - __pv.image.y) / __pv.image.scale;
                __pv.image.scale = Math.max(0.1, Math.min(5, __pv.image.scale * delta));
                __pv.image.x = Math.round(mx - preX * __pv.image.scale);
                __pv.image.y = Math.round(my - preY * __pv.image.scale);
                pvApply();
            });
            $('#pvImageWrapper').off('mousedown').on('mousedown', function(e){ if(e.button!==0) return; __pv.image.dragging=true; __pv.image.sx = e.clientX - __pv.image.x; __pv.image.sy = e.clientY - __pv.image.y; this.style.cursor='grabbing'; });
            $(window).off('mouseup.pv').on('mouseup.pv', function(){ __pv.image.dragging=false; $('#pvImageWrapper').css('cursor','grab'); });
            $(window).off('mousemove.pv').on('mousemove.pv', function(e){ if(!__pv.image.dragging) return; __pv.image.x = Math.round(e.clientX - __pv.image.sx); __pv.image.y = Math.round(e.clientY - __pv.image.sy); pvApply(); });
            return;
        }

        // 4) 純文字閱讀器（可編輯）
        if (textExts.includes(ext)){
            $container.addClass('d-none');
            $('#pvTextMeta').text(`${name}`);
            const $ta = $('#pvTextArea');
            $('#pvTextContainer').removeClass('d-none');
            $.ajax({ url: previewUrl, method: 'GET', dataType: 'text' })
              .done((text)=>{ $ta.val(text||''); window.lucide?.createIcons?.(); })
              .fail(()=>{ $ta.val(''); alert('讀取檔案失敗'); });
            return;
        }

        // 5) 其餘不支援：顯示無法閱讀
        $fpDownloadLink.attr('href', downloadUrl);
        $('.fp-section').addClass('d-none');
        $fpUnsupported.removeClass('d-none');
    }

    function pvApply(){
        const img = $('#pvImage')[0];
        img.style.transform = `translate(${__pv.image.x}px, ${__pv.image.y}px) scale(${__pv.image.scale})`;
    }
    function pvFit(){ __pv.image.scale = __pv.image.fit || 1; __pv.image.x = 0; __pv.image.y = 0; pvApply(); }
    function pvZoomIn(){ __pv.image.scale = Math.min(5, __pv.image.scale * 1.2); pvApply(); }
    function pvZoomOut(){ __pv.image.scale = Math.max(0.1, __pv.image.scale / 1.2); pvApply(); }

    // 圖片工具列按鈕綁定
    $(document).off('click.fm', '.js-pv-fit').on('click.fm', '.js-pv-fit', function(){ pvFit(); });
    $(document).off('click.fm', '.js-pv-zoom-in').on('click.fm', '.js-pv-zoom-in', function(){ pvZoomIn(); });
    $(document).off('click.fm', '.js-pv-zoom-out').on('click.fm', '.js-pv-zoom-out', function(){ pvZoomOut(); });

    $(document).off('click', '#pvSaveTextBtn').on('click', '#pvSaveTextBtn', function(){
        const token = $('input[name="__RequestVerificationToken"]').val();
        const payload = { Path: __pv.path, Name: __pv.name, Content: $('#pvTextArea').val(), Encoding: 'utf-8', __RequestVerificationToken: token };
        $.ajax({
            type: 'POST',
            url: '/Backoffice/FileManager/SubmitTextFile',
            contentType: 'application/json',
            data: JSON.stringify(payload),
            headers: { 'RequestVerificationToken': token },
            success: (res)=>{ if(res.success){ alert('已儲存'); } else { alert(res.message||'儲存失敗'); } },
            error: ()=> alert('系統發生錯誤')
        });
    });
    function renameItem(name, type, path){
        if(type === 'folder'){
            openRenameFolderModal(name, path);
        } else {
            openRenameFileModal(name, path);
        }
    }

    // 建立/重新命名事件綁定
    $(document).off('click.fm', '.js-submit-create-folder').on('click.fm', '.js-submit-create-folder', function(){ submitCreateFolder(); });
    $(document).off('click.fm', '.js-submit-create-file').on('click.fm', '.js-submit-create-file', function(){ submitCreateFile(); });
    $(document).off('click.fm', '.js-submit-rename-file').on('click.fm', '.js-submit-rename-file', function(){ submitRenameFile(); });
    $(document).off('click.fm', '.js-submit-rename-folder').on('click.fm', '.js-submit-rename-folder', function(){ submitRenameFolder(); });

    function deleteItem(name, type, path){
        if(type === 'folder'){
            deleteFolder(name, path);
        } else {
            deleteFile(name, path);
        }
    }

    // 側欄刪除按鈕（委派）
    $(document).off('click.fm', '.js-fm-delete-item').on('click.fm', '.js-fm-delete-item', function(){
        const name = $(this).data('itemName');
        const type = $(this).data('itemType');
        const path = $(this).data('itemPath');
        deleteItem(name, type, path);
    });

    function submitCreateFolder() {
        const $form = $('#createFolderForm');
        const formElement = $form[0];

        if (!formElement.checkValidity()) {
            formElement.reportValidity();
            return;
        }

        const token = __AF();
        const data = {
            Path: '@currentPath',
            Name: $('#folderName').val(),
            __RequestVerificationToken: token
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("SubmitFolder", "FileManager", new { area = "Backoffice" })',
            contentType: 'application/json',
            data: JSON.stringify(data),
            headers: { 'RequestVerificationToken': token },
            success: (response) => {
                if (response.success) {
                    alert('資料夾已建立');
                    location.reload();
                } else {
                    alert(response.message || '建立失敗');
                }
            },
            error: () => alert('系統發生錯誤')
        });
    }

    function submitCreateFile() {
        const $form = $('#createFileForm');
        const formElement = $form[0];

        if (!formElement.checkValidity()) {
            formElement.reportValidity();
            return;
        }

        const token = __AF();
        const data = {
            Path: '@currentPath',
            Name: $('#fileName').val(),
            __RequestVerificationToken: token
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("SubmitFile", "FileManager", new { area = "Backoffice" })',
            contentType: 'application/json',
            data: JSON.stringify(data),
            headers: { 'RequestVerificationToken': token },
            success: (response) => {
                if (response.success) {
                    alert('檔案已建立');
                    location.reload();
                } else {
                    alert(response.message || '建立失敗');
                }
            },
            error: () => alert('系統發生錯誤')
        });
    }

    function openRenameFileModal(name, path) {
        currentFileName = name;
        currentItemPath = path;
        $('#newFileName').val(name);
        showModal('renameFileModal');
    }

    function openRenameFolderModal(name, path) {
        currentFolderName = name;
        currentItemPath = path;
        $('#newFolderName').val(name);
        showModal('renameFolderModal');
    }

    function submitRenameFile() {
        const $form = $('#renameFileForm');
        const formElement = $form[0];

        if (!formElement.checkValidity()) {
            formElement.reportValidity();
            return;
        }

        const data = {
            Path: currentItemPath,
            OldName: currentFileName,
            NewName: $('#newFileName').val(),
            __RequestVerificationToken: __AF()
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("SubmitRenameFile", "FileManager")',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: (response) => {
                if (response.success) {
                    alert('檔案已重新命名');
                    location.reload();
                } else {
                    alert(response.message || '重新命名失敗');
                }
            },
            error: () => alert('系統發生錯誤')
        });
    }

    function submitRenameFolder() {
        const $form = $('#renameFolderForm');
        const formElement = $form[0];

        if (!formElement.checkValidity()) {
            formElement.reportValidity();
            return;
        }

        const data = {
            Path: currentItemPath,
            OldName: currentFolderName,
            NewName: $('#newFolderName').val(),
            __RequestVerificationToken: __AF()
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("SubmitRename", "FileManager")',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: (response) => {
                if (response.success) {
                    alert('資料夾已重新命名');
                    location.reload();
                } else {
                    alert(response.message || '重新命名失敗');
                }
            },
            error: () => alert('系統發生錯誤')
        });
    }

    function deleteFile(name, path) {
        if (!confirm(`確定要刪除檔案「${name}」嗎？此操作無法復原。`)) {
            return;
        }

        const data = {
            Path: path,
            Name: name,
            __RequestVerificationToken: __AF()
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("DeleteFile", "FileManager")',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: (response) => {
                if (response.success) {
                    alert('檔案已刪除');
                    location.reload();
                } else {
                    alert(response.message || '刪除失敗');
                }
            },
            error: () => alert('系統發生錯誤')
        });
    }

    function deleteFolder(name, path) {
        if (!confirm(`確定要刪除資料夾「${name}」及其所有內容嗎？此操作無法復原。`)) {
            return;
        }

        const data = {
            Path: path,
            Name: name,
            __RequestVerificationToken: __AF()
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("Delete", "FileManager")',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: (response) => {
                if (response.success) {
                    alert('資料夾已刪除');
                    location.reload();
                } else {
                    alert(response.message || '刪除失敗');
                }
            },
            error: () => alert('系統發生錯誤')
        });
    }
</script>
