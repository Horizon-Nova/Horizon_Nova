@model HNB.Areas.Backoffice.Dtos.FileManagerDto
@using System.IO
@{
    Layout = null;
    var currentUser = Model?.CurrentUser ?? User?.Identity?.Name ?? "";
}

@functions {
    string GetFileIcon(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        if (ext == ".pdf" || ext == ".doc" || ext == ".docx" || ext == ".txt" || ext == ".md")
            return "file-text";
        if (ext == ".xls" || ext == ".xlsx")
            return "file-spreadsheet";
        if (ext == ".ppt" || ext == ".pptx")
            return "file-presentation";
        if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".bmp" || ext == ".svg")
            return "image";
        if (ext == ".mp4" || ext == ".avi" || ext == ".mov" || ext == ".wmv")
            return "video";
        if (ext == ".mp3" || ext == ".wav" || ext == ".flac")
            return "music";
        if (ext == ".zip" || ext == ".rar" || ext == ".7z")
            return "archive";
        if (ext == ".html" || ext == ".htm" || ext == ".js" || ext == ".ts" || ext == ".css")
            return "file-code";
        return "file";
    }

    string GetFileIconColor(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        if (ext == ".pdf")
            return "text-danger";
        if (ext == ".doc" || ext == ".docx")
            return "text-primary";
        if (ext == ".xls" || ext == ".xlsx")
            return "text-success";
        if (ext == ".ppt" || ext == ".pptx")
            return "text-warning";
        if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".bmp" || ext == ".svg")
            return "text-info";
        if (ext == ".mp4" || ext == ".avi" || ext == ".mov" || ext == ".wmv")
            return "text-secondary";
        if (ext == ".mp3" || ext == ".wav" || ext == ".flac")
            return "text-secondary";
        if (ext == ".zip" || ext == ".rar" || ext == ".7z")
            return "text-muted";
        return "text-muted";
    }

    string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    string TruncateString(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;
        if (text.Length <= maxLength) return text;
        return text.Substring(0, maxLength) + "...";
    }
}

<div class="row g-3 m-0" style="min-width: max-content;">
    <!-- 左側：檔案列表 -->
    <div class="col-12 col-lg-8 d-flex flex-column p-3 min-h-0" style="min-width: 0;">
        <div id="fileListContainer" class="flex-grow-1 min-h-0" style="min-width: 0;">
            <table id="fileListTable"
                   class="table table-hover align-middle mb-0"
                   data-hnb-datatable="true"
                   data-hnb-options='{"order":[[3,"desc"]]}'>
                <thead class="table-light" style="white-space: nowrap;">
                    <tr>
                        <th scope="col" style="width:10%;">名稱</th>
                        <th scope="col" style="width:15%;">共用</th>
                        <th scope="col" style="width:15%;">擁有者</th>
                        <th scope="col" style="width:20%;">修改日期</th>
                        <th scope="col" class="text-end" style="width:10%;">大小</th>
                    </tr>
                </thead>
                <tbody style="white-space: nowrap;">
                    @foreach (var item in Model?.Items ?? new List<HNB.Areas.Backoffice.Dtos.FileSystemEntry>())
                    {
                        var isFolder = item.Type == "folder";
                        var iconName = isFolder ? "folder" : GetFileIcon(item.Name);
                        var iconColor = isFolder ? "text-warning" : GetFileIconColor(item.Name);
                        var sizeText = isFolder ? "—" : FormatBytes(item.Size ?? 0);
                        var sharedText = item.SharedUsers?.Count > 0 ? "有連結" : "未共用";
                        var sharedCount = item.SharedUsers?.Count ?? 0;
                        var primaryOwner = item.PrimaryOwner ?? item.Owner;
                        var ownerDisplay = string.IsNullOrEmpty(primaryOwner) ? "?" : primaryOwner;
                        
                        <tr onclick="selectItem('@Model?.CurrentPath', '@item.Name', '@item.Type')" 
                            data-item-path="@Model?.CurrentPath" 
                            data-item-name="@item.Name" 
                            data-item-type="@item.Type"
                            style="cursor: pointer;">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <i data-lucide="@iconName" class="@iconColor" style="width:1.1rem;height:1.1rem;flex-shrink:0;"></i>
                                    @if (isFolder)
                                    {
                                        var folderPath = Model?.CurrentPath == "/" ? $"/{item.Name}" : $"{Model?.CurrentPath}/{item.Name}";
                                        var displayName = TruncateString(item.Name, 10);
                                        <a href="javascript:void(0)" class="text-decoration-none" onclick="event.stopPropagation(); switchView(null, '@folderPath')" title="@item.Name">
                                            @displayName
                                        </a>
                                    }
                                    else
                                    {
                                        var displayName = TruncateString(item.Name, 10);
                                        <span title="@item.Name">
                                            @displayName
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                @if (sharedCount > 0)
                                {
                                    <div class="d-flex align-items-center gap-1 text-muted small">
                                        <i data-lucide="link" style="width:0.95rem;height:0.95rem;"></i>
                                        <span>有連結</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="small text-muted">未共用</span>
                                }
                            </td>
                            <td class="small text-muted">@ownerDisplay</td>
                            <td class="small text-muted">@(item.UpdatedAt?.ToString("yyyy/MM/dd HH:mm") ?? item.LastWriteUtc?.ToString("yyyy/MM/dd HH:mm") ?? "—")</td>
                            <td class="text-end small text-muted">@sizeText</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 右側：詳細資料 -->
    <div class="col-12 col-lg-4 d-flex flex-column p-3">
        <div class="border rounded-3 bg-white p-3" id="itemDetailPanel">
            @if (Model?.SelectedItem != null)
            {
                @await Html.PartialAsync("_ItemDetail", Model.SelectedItem)
            }
            else if (Model?.Items != null && Model.Items.Count > 0)
            {
                @await Html.PartialAsync("_ItemDetail", Model.Items.First())
            }
            else
            {
                <div class="text-center text-muted small py-4">
                    <i data-lucide="file-question" style="width:2rem;height:2rem;" class="mb-2"></i>
                    <div>點擊項目查看詳細資訊</div>
                </div>
            }
        </div>
    </div>
</div>


