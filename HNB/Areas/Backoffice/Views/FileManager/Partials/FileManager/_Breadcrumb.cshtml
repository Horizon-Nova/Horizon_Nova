@{
    Layout = null;
    var viewMode = ViewBag.ViewMode as string;
    var currentPath = ViewBag.CurrentPath as string ?? "/";
    var breadcrumb = new List<(string Name, string VirtualPath)>();
    
    if (viewMode == "shared")
    {
        breadcrumb.Add(("與我共用", "/"));
    }
    else if (viewMode == "recent")
    {
        breadcrumb.Add(("最近", "/"));
    }
    else if (viewMode == "trash")
    {
        breadcrumb.Add(("回收桶", "/"));
    }
    else
    {
        breadcrumb = currentPath == "/"
            ? new List<(string Name, string VirtualPath)> { ("我的檔案", "/") }
            : new[] { ("我的檔案", "/") }
                .Concat(currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries)
                    .Aggregate(new List<(string, string)>(), (acc, part) =>
                    {
                        var path = acc.LastOrDefault().Item2 + "/" + part;
                        acc.Add((part, path));
                        return acc;
                    }))
                .ToList();
    }

    var folderCount = ViewBag.FolderCount as int? ?? 0;
    var fileCount = ViewBag.FileCount as int? ?? 0;
    var totalSize = ViewBag.TotalSize as long? ?? 0L;
}

<!-- OneDrive 風格頂部工具列 + 麵包屑 -->
<div class="card-header bg-transparent border-bottom">
    <!-- 第一列：標題 + 搜尋 -->
    <div class="row g-3 align-items-center mb-3">
        <div class="col-12 col-lg-auto">
            <div class="d-flex align-items-center gap-2">
                <h5 class="card-title mb-0 fw-semibold">
                    @(viewMode == "shared" ? "與我共用" :
                      viewMode == "recent" ? "最近" :
                      viewMode == "trash" ? "回收桶" : "我的檔案")
                </h5>
                @if (viewMode == null || viewMode == "")
                {
                    <span class="badge bg-light text-muted border">
                        @folderCount 個資料夾 · @fileCount 個檔案 · @FormatSize(totalSize)
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- 第二列：動作列 + 麵包屑 -->
    <div class="row g-3 align-items-center">
        <div class="col-12 col-lg-auto">
            <div class="btn-toolbar gap-2" role="toolbar">
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-primary d-flex align-items-center gap-1" onclick="openCreateFolderModal()">
                        <i data-lucide="folder-plus" style="width:1rem;height:1rem;"></i>
                        <span>新增</span>
                    </button>
                    <button type="button" class="btn btn-outline-primary d-flex align-items-center gap-1" onclick="openCreateFileModal()">
                        <i data-lucide="upload-cloud" style="width:1rem;height:1rem;"></i>
                        <span>上傳</span>
                    </button>
                </div>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1" disabled>
                        <i data-lucide="share-2" style="width:1rem;height:1rem;"></i>
                        <span>共用</span>
                    </button>
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1" disabled>
                        <i data-lucide="download" style="width:1rem;height:1rem;"></i>
                        <span>下載</span>
                    </button>
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1" disabled>
                        <i data-lucide="trash-2" style="width:1rem;height:1rem;"></i>
                        <span>刪除</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-auto ms-lg-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    @for (int i = 0; i < breadcrumb.Count; i++)
                    {
                        var (name, path) = breadcrumb[i];
                        var isLast = i == breadcrumb.Count - 1;
                        <li class="breadcrumb-item @(isLast ? "active" : "")">
                            @if (isLast)
                            {
                                <span>@name</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", "FileManager", new { area = "Backoffice", path = path })" class="text-decoration-none">@name</a>
                            }
                        </li>
                    }
                </ol>
            </nav>
        </div>
    </div>
</div>

@functions {
    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}


