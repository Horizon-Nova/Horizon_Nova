@{
    Layout = null;
}

<script>
    function getPathFromUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        const path = urlParams.get('path');
        return path ? decodeURIComponent(path) : '/';
    }

    function updateUrl(view, path) {
        const baseUrl = '/Backoffice/FileManager';
        let newUrl = baseUrl;
        
        if (view) {
            newUrl += `?view=${encodeURIComponent(view)}`;
            if (path && path !== '/') {
                newUrl += `&path=${encodeURIComponent(path)}`;
            }
        } else if (path && path !== '/') {
            newUrl += `?path=${encodeURIComponent(path)}`;
        }
        
        window.history.pushState({ view: view, path: path }, '', newUrl);
    }

    window.addEventListener('popstate', function(event) {
        const state = event.state || {};
        const view = state.view || null;
        const path = state.path || getPathFromUrl();
        
        const urlPath = getPathFromUrl();
        const urlParams = new URLSearchParams(window.location.search);
        const urlView = urlParams.get('view');
        
        switchView(urlView, urlPath, false);
    });

    $(document).ready(() => {
        const initialPath = getPathFromUrl();
        const urlParams = new URLSearchParams(window.location.search);
        const initialView = urlParams.get('view');
        
        if (initialPath !== '/' || initialView) {
            window.history.replaceState({ view: initialView, path: initialPath }, '', window.location.href);
        }
        
        LoadSidebar(initialPath, initialView);
        LoadBreadcrumb(initialView, initialPath);
        switchView(initialView, initialPath, false);
    });

    function LoadSidebar(currentPath, viewMode) {
        const $container = $('#fileManagerSidebar');
        let url = '/Backoffice/FileManager/LoadSidebar?currentPath=' + encodeURIComponent(currentPath || '/');
        if (viewMode) {
            url += '&viewMode=' + encodeURIComponent(viewMode);
        }
        
        $.ajax({
            url: url,
            type: 'GET',
            success: (html) => {
                $container.html(html);
                if (window.lucide?.createIcons) {
                    window.lucide.createIcons();
        }
            },
            error: () => {
                showToast('載入失敗', '無法載入側邊欄，請重新整理頁面', 'error');
            }
        });
    }

    function getViewUrl(view, path) {
        var url = '/Backoffice/FileManager/LoadView?';
        if (view) {
            url += 'view=' + encodeURIComponent(view) + '&';
        }
        url += 'path=' + encodeURIComponent(path || '/');
        return url;
    }

    function LoadBreadcrumb(view, path) {
        const $container = $('#fileManagerBreadcrumb');
        if (!$container.length) return;
        
        const url = '/Backoffice/FileManager/LoadBreadcrumb?view=' + encodeURIComponent(view || '') + '&path=' + encodeURIComponent(path || '/');
        
        $.ajax({
            url: url,
            type: 'GET',
            success: (html) => {
                $container.html(html);
                if (window.lucide?.createIcons) {
                    window.lucide.createIcons();
                }
            },
            error: () => {
                console.error('無法載入麵包屑');
            }
        });
    }

    function switchView(view, path, updateUrlFlag = true) {
        const contentContainer = $('#fileManagerContent');
        const viewUrl = getViewUrl(view, path);
        
        contentContainer.css('opacity', '0.5');
        
        $.ajax({
            url: viewUrl,
            method: 'GET',
            success: function(html) {
                contentContainer.html(html).css('opacity', '1');
                
                LoadSidebar(path, view);
                LoadBreadcrumb(view, path);
                
                updateSidebarActive(view);
                
                if (window.lucide?.createIcons) {
                    window.lucide.createIcons();
                }
                
                if (typeof HNBDataTable !== 'undefined' && HNBDataTable.autoInit) {
                    HNBDataTable.autoInit(contentContainer);
                }
                
                selectedItem = { path: null, name: null, type: null };
                updateActionButtons();
                
                if (updateUrlFlag) {
                    updateUrl(view, path);
                }
            },
            error: function() {
                contentContainer.css('opacity', '1');
                showToast('載入失敗', '無法載入畫面，請重新整理頁面', 'error');
                }
            });
        }

    function updateSidebarActive(view) {
        $('.nav-link').removeClass('active').addClass('text-muted');
        
        if (!view || view === '') {
            $('.nav-link').first().removeClass('text-muted').addClass('active');
        } else {
            $('.nav-link').each(function() {
                var onclick = $(this).attr('onclick') || '';
                if (onclick.includes("switchView('" + view + "')") || onclick.includes('switchView("' + view + '")')) {
                    $(this).removeClass('text-muted').addClass('active');
                }
            });
        }
    }

    function updateBreadcrumb(view, path) {
        var titleMap = {
            'shared': '與我共用',
            'recent': '最近',
            '': '我的檔案'
        };
        var title = titleMap[view || ''] || '我的檔案';
        $('.card-title').text(title);
    }

    let selectedItem = {
        path: null,
        name: null,
        type: null
    };

    function selectItem(path, name, type) {
        $('#fileListTable tbody tr').removeClass('table-active');
        
        selectedItem = {
            path: path || '/',
            name: name,
            type: type
        };
        
        $(`tr[data-item-path="${path}"][data-item-name="${name}"]`).addClass('table-active');
        
        loadItemDetail(path, name);
        
        updateActionButtons();
    }

    function updateActionButtons() {
        const hasSelection = selectedItem.name && selectedItem.path;
        const isFolder = selectedItem.type === 'folder';
        
        $('#btnShare').prop('disabled', !hasSelection);
        $('#btnDownload').prop('disabled', !hasSelection);
        $('#btnDelete').prop('disabled', !hasSelection);
        
        if (window.lucide?.createIcons) {
            window.lucide.createIcons();
        }
    }

    function loadItemDetail(path, name) {
        const $panel = $('#itemDetailPanel');
        if (!$panel.length) return;
        
        $panel.css('opacity', '0.5');
        
        $.ajax({
            url: '/Backoffice/FileManager/LoadDetail',
            method: 'GET',
            data: {
                path: path || '/',
                name: name
            },
            success: function(html) {
                $panel.html(html).css('opacity', '1');
                
                if (window.lucide?.createIcons) {
                    window.lucide.createIcons();
                }
            },
            error: function() {
                $panel.css('opacity', '1');
                showToast('載入失敗', '無法載入項目詳細資訊', 'error');
            }
        });
    }

    function shareItem() {
        if (!selectedItem.name || !selectedItem.path) {
            showToast('錯誤', '請先選擇要共用的項目', 'error');
            return;
        }
        
        if (typeof openShareModal === 'function') {
            openShareModal(selectedItem.path, selectedItem.name, selectedItem.type);
        } else {
            showToast('錯誤', '無法開啟共用視窗，請重新整理頁面', 'error');
        }
    }

    function downloadItem() {
        if (!selectedItem.name || !selectedItem.path) {
            showToast('錯誤', '請先選擇要下載的項目', 'error');
            return;
        }
        
        const itemType = selectedItem.type === 'folder' ? '資料夾' : '檔案';
        const confirmMessage = `確定要下載「${selectedItem.name}」這個${itemType}嗎？`;
        
        if (!confirm(confirmMessage)) {
            return;
        }
        
        showToast('提示', '開始下載...', 'info');
        
        const isFolder = selectedItem.type === 'folder';
        const url = isFolder 
            ? `/Backoffice/FileManager/DownloadFolder?path=${encodeURIComponent(selectedItem.path)}&name=${encodeURIComponent(selectedItem.name)}`
            : `/Backoffice/FileManager/Download?path=${encodeURIComponent(selectedItem.path)}&name=${encodeURIComponent(selectedItem.name)}`;
        
        const link = document.createElement('a');
        link.href = url;
        link.download = selectedItem.name;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }

    function deleteItem() {
        if (!selectedItem.name || !selectedItem.path) {
            showToast('錯誤', '請先選擇要刪除的項目', 'error');
            return;
        }
        
        if (typeof openDeleteModal === 'function') {
            openDeleteModal(selectedItem.path, selectedItem.name, selectedItem.type);
        } else {
            showToast('錯誤', '無法開啟刪除確認視窗，請重新整理頁面', 'error');
        }
    }

    window.switchView = switchView;
    window.getViewUrl = getViewUrl;
    window.toggleFolderNode = toggleFolderNode;
    window.loadItemDetail = loadItemDetail;
    window.selectItem = selectItem;
    window.shareItem = shareItem;
    window.downloadItem = downloadItem;
    window.deleteItem = deleteItem;


    function toggleFolderNode(nodeId) {
        var children = document.getElementById(nodeId + '-children');
        var icon = document.getElementById(nodeId + '-icon');
        
        if (children && icon) {
            if (children.style.display === 'none') {
                children.style.display = 'block';
                icon.setAttribute('data-lucide', 'chevron-down');
            } else {
                children.style.display = 'none';
                icon.setAttribute('data-lucide', 'chevron-right');
            }
            if (window.lucide?.createIcons) {
                window.lucide.createIcons();
            }
        }
    }

    function reloadFileManager() {
        const currentPath = getPathFromUrl();
        const urlParams = new URLSearchParams(window.location.search);
        const currentView = urlParams.get('view');
        
        LoadSidebar(currentPath, currentView);
        LoadBreadcrumb(currentView, currentPath);
        switchView(currentView, currentPath, false);
    }

    window.LoadSidebar = LoadSidebar;
    window.reloadFileManager = reloadFileManager;

</script>
