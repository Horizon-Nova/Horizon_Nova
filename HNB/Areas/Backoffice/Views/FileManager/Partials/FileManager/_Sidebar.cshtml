@model HNB.Areas.Backoffice.Dtos.FileManagerIndexDto
@{
    Layout = null;
    var currentPath = Model?.CurrentPath ?? "/";
    var viewMode = Model?.ViewMode;
    var userFolderTree = Model?.UserFolderTree ?? new List<HNB.Areas.Backoffice.Dtos.FolderTreeNode>();
    var userStoragePath = Model?.UserStoragePath ?? "/storage";
}

@functions {
    void RenderFolderNode(HNB.Areas.Backoffice.Dtos.FolderTreeNode node, string currentPath, int depth = 0)
    {
        var isActive = currentPath == node.Path;
        var hasChildren = node.Children.Count > 0;
        var nodeId = "folder-" + node.Path.Replace("/", "-").Replace("\\", "-").TrimStart('-');
        var indent = depth * 1.25;
        
        <div class="folder-node" data-depth="@depth">
            <div class="d-flex align-items-center gap-1" style="padding-left: @(indent)rem;">
                @if (hasChildren)
                {
                    <button type="button" class="btn btn-link btn-sm p-0 text-muted folder-toggle" 
                            onclick="toggleFolderNode('@nodeId')" 
                            style="width:0.875rem;height:0.875rem;line-height:1;">
                        <i data-lucide="chevron-right" id="@nodeId-icon" style="width:0.875rem;height:0.875rem;"></i>
                    </button>
                }
                else
                {
                    <span style="width:0.875rem;height:0.875rem;display:inline-block;"></span>
                }
                <a href="javascript:void(0)" onclick="switchView(null, '@node.Path')"
                   class="text-decoration-none d-flex align-items-center gap-1 flex-grow-1 @(isActive ? "text-primary" : "text-muted")">
                    <i data-lucide="@(isActive ? "folder-open" : "folder")" style="width:1rem;height:1rem;"></i>
                    <span class="text-truncate">@node.Name</span>
                </a>
            </div>
            @if (hasChildren)
            {
                <div class="folder-children" id="@nodeId-children" style="display:none;">
                    @foreach (var child in node.Children)
                    {
                        RenderFolderNode(child, currentPath, depth + 1);
                    }
                </div>
            }
        </div>
    }

    string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<!-- 左側：OneDrive 風格導覽 + 資料夾區 -->
<div class="card border-0 shadow-sm h-100">
    <!-- 快速動作 -->
    <div class="card-header bg-transparent border-bottom p-3">
        <div class="dropdown w-100">
            <button type="button" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2" data-bs-toggle="dropdown" aria-expanded="false">
                <i data-lucide="plus" style="width:1rem;height:1rem;"></i>
                <span>建立或上傳</span>
                <i data-lucide="chevron-down" style="width:0.875rem;height:0.875rem;"></i>
            </button>
            <ul class="dropdown-menu w-100" style="min-width: 200px;">
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openCreateFolderModal()">
                        <i data-lucide="folder" style="width:1rem;height:1rem;"></i>
                        <span>資料夾</span>
                    </button>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openUploadFileModal()">
                        <i data-lucide="upload" style="width:1rem;height:1rem;"></i>
                        <span>檔案上傳</span>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openUploadFolderModal()">
                        <i data-lucide="folder-up" style="width:1rem;height:1rem;"></i>
                        <span>資料夾上傳</span>
                    </button>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openCreateFileModal('docx')">
                        <i data-lucide="file-text" class="text-primary" style="width:1rem;height:1rem;"></i>
                        <span>Word 文件</span>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openCreateFileModal('xlsx')">
                        <i data-lucide="file-spreadsheet" class="text-success" style="width:1rem;height:1rem;"></i>
                        <span>Excel 活頁簿</span>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openCreateFileModal('txt')">
                        <i data-lucide="file-text" class="text-muted" style="width:1rem;height:1rem;"></i>
                        <span>文字檔</span>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openCreateFileModal('md')">
                        <i data-lucide="file-code" class="text-muted" style="width:1rem;height:1rem;"></i>
                        <span>Markdown</span>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item d-flex align-items-center gap-2" onclick="openCreateLinkModal()">
                        <i data-lucide="link" class="text-info" style="width:1rem;height:1rem;"></i>
                        <span>連結</span>
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <!-- Logo / 標題列 -->
    <div class="card-header bg-transparent border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="cloud" class="text-primary" style="width:1.2rem;height:1.2rem;"></i>
            <span class="fw-semibold small">Horizon Drive</span>
        </div>
    </div>

    <div class="card-body p-0 d-flex flex-column">
        <!-- 主導覽 -->
        <nav class="p-3 border-bottom">
            <ul class="nav nav-pills flex-column small">
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center gap-2 @(viewMode != "shared" && viewMode != "recent" && viewMode != "trash" && currentPath == "/" ? "active" : "text-muted")"
                       href="javascript:void(0)" onclick="switchView(null, '/')">
                        <i data-lucide="folder" style="width:1rem;height:1rem;"></i>
                        <span>我的檔案</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center gap-2 @(viewMode == "shared" ? "active" : "text-muted")"
                       href="javascript:void(0)" onclick="switchView('shared')">
                        <i data-lucide="users" style="width:1rem;height:1rem;"></i>
                        <span>與我共用</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center gap-2 @(viewMode == "recent" ? "active" : "text-muted")"
                       href="javascript:void(0)" onclick="switchView('recent')">
                        <i data-lucide="clock" style="width:1rem;height:1rem;"></i>
                        <span>最近</span>
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <a class="nav-link d-flex align-items-center gap-2 @(viewMode == "trash" ? "active" : "text-muted")"
                       href="javascript:void(0)" onclick="switchView('trash')">
                        <i data-lucide="trash-2" style="width:1rem;height:1rem;"></i>
                        <span>回收桶</span>
                    </a>
                </li>
            </ul>
        </nav>

        <!-- 資料夾區 -->
        <div class="flex-grow-1 overflow-auto p-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <span class="small text-muted fw-semibold">資料夾</span>
                <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="reloadFileManager()" title="重新整理">
                    <i data-lucide="refresh-cw" style="width:1rem;height:1rem;"></i>
                </button>
            </div>

            <div class="d-flex flex-column gap-1">
                <a href="javascript:void(0)" onclick="switchView(null, '/')"
                   class="text-decoration-none d-flex align-items-center gap-2 @(currentPath == "/" ? "text-primary" : "text-muted")">
                    <i data-lucide="@(currentPath == "/" ? "folder-open" : "folder")" style="width:1rem;height:1rem;"></i>
                    <span>根目錄</span>
                </a>

                @foreach (var node in userFolderTree)
                {
                    RenderFolderNode(node, currentPath, 0);
                }
            </div>
        </div>
    </div>

    <!-- 儲存空間資訊 -->
    <div class="card-footer bg-transparent border-top">
        <div class="small text-muted mb-2">
            @{
                var usedStorage = Model?.UsedStorage ?? 0L;
                var totalStorage = Model?.TotalStorage ?? 0L;
                var usedStorageFormatted = FormatBytes(usedStorage);
                var totalStorageFormatted = FormatBytes(totalStorage);
                var percentage = totalStorage > 0 ? (int)((usedStorage * 100) / totalStorage) : 0;
            }
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span>儲存空間</span>
                <span class="fw-semibold">@usedStorageFormatted / @totalStorageFormatted</span>
            </div>
            <div class="progress" style="height: 4px;">
                <div class="progress-bar bg-primary" role="progressbar" style="width: @percentage%;"></div>
            </div>
        </div>
    </div>
</div>


