@{
    Layout = null;
    var currentPath = ViewBag.CurrentPath as string ?? "/";
    var tree = ViewBag.Tree as List<object> ?? new();
}

<!-- 手機目錄樹（Offcanvas） -->
<div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="mobileTree" aria-labelledby="mobileTreeLabel">
    <div class="offcanvas-header">
        <h6 class="offcanvas-title" id="mobileTreeLabel">目錄</h6>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="關閉"></button>
    </div>
    <div class="offcanvas-body p-2">
        <!-- 根目錄 -->
        <div class="tree-item @(currentPath == "/" ? "active" : "")" data-level="0">
            <a href="@Url.Action("Index", "FileManager", new { area = "Backoffice", path = "/" })" class="tree-link">
                <i data-lucide="@(currentPath == "/" ? "folder-open" : "folder")" class="tree-icon"></i>
                <span class="tree-text">根目錄</span>
            </a>
        </div>

        <!-- 目錄樹 -->
        @await Html.PartialAsync("Partials/FileManager/_TreeNodes", tree)
    </div>
</div>

