@{
    Layout = null;
    var itemDetail = ViewBag.ItemDetail as HNB.Areas.Backoffice.Dtos.FileSystemEntry;
    var users = ViewBag.Users as List<Models.HnbHnbBackoffice.vw_permission_user> ?? new List<Models.HnbHnbBackoffice.vw_permission_user>();
    var currentUser = Context.User.Identity?.Name;
    var sharedUsers = itemDetail?.SharedUsers ?? new List<string>();
    var primaryOwner = itemDetail?.PrimaryOwner ?? itemDetail?.Owner ?? currentUser;
}

<div id="shareItemModal" class="modal fade" tabindex="-1" aria-labelledby="shareItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="shareItemModalLabel">共用項目</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i data-lucide="@(itemDetail?.Type == "folder" ? "folder" : "file")" class="text-primary" style="width:1.5rem;height:1.5rem;"></i>
                        <span class="fw-semibold" id="shareItemName">@itemDetail?.Name</span>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label for="shareUserSearch" class="form-label small">搜尋並新增使用者</label>
                    <div class="position-relative">
                        <input type="text" 
                               class="form-control form-control-sm" 
                               id="shareUserSearch" 
                               placeholder="輸入姓名或電子郵件搜尋..."
                               autocomplete="off">
                        <div id="shareUserDropdown" class="position-absolute w-100 bg-white border rounded shadow-lg" style="top: 100%; left: 0; z-index: 1050; max-height: 300px; overflow-y: auto; display: none; margin-top: 2px;">
                            <div id="shareUserDropdownList" class="list-group list-group-flush">
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label small">已選擇的使用者</label>
                    <div id="shareSelectedUsers" class="d-flex flex-wrap gap-2 mb-2">
                    </div>
                </div>
                
                <div class="mb-3" style="max-height: 300px; overflow-y: auto;">
                    <label class="form-label small">所有可用使用者</label>
                    <div id="shareUserList" class="list-group">
                        @foreach (var user in users)
                        {
                            if (user.name == primaryOwner || string.IsNullOrEmpty(user.name)) continue;
                            
                            var isShared = sharedUsers.Contains(user.name);
                            var userId = $"share-user-{user.name}";
                            <div class="list-group-item list-group-item-action d-flex align-items-center gap-2 share-user-item" data-user-name="@(user.name ?? "")" data-user-email="@(user.email ?? "")">
                                <input type="checkbox" 
                                       class="form-check-input" 
                                       id="@userId" 
                                       @(isShared ? "checked" : "")
                                       data-user-name="@(user.name ?? "")">
                                <label class="form-check-label flex-grow-1" for="@userId" style="cursor: pointer;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:2rem;height:2rem;font-size:0.9rem;">
                                            @(user.full_name?.Substring(0, 1).ToUpper() ?? user.name?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <div>
                                            <div class="small fw-semibold">@(user.full_name ?? user.name)</div>
                                            <div class="small text-muted">@user.email</div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary btn-sm" id="shareItemConfirmBtn" onclick="confirmShareItem()">
                    <i data-lucide="share-2" style="width:1rem;height:1rem;"></i>
                    確認共用
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let shareConfirmItem = { path: null, name: null, type: null };

    function openShareModal(path, name, type) {
        shareConfirmItem = { path, name, type };
        
        const $modal = $('#shareItemModal');
        
        $.ajax({
            url: '/Backoffice/FileManager/LoadShareModal',
            method: 'GET',
            data: {
                path: path || '/',
                name: name
            },
            success: function(html) {
                if ($modal.length) {
                    $modal.replaceWith(html);
                } else {
                    $('body').append(html);
                }
                
                const $newModal = $('#shareItemModal');
                $newModal.modal('show');
                
                if (window.lucide?.createIcons) {
                    window.lucide.createIcons();
                }
                
                bindShareModalEvents();
            },
            error: function() {
                showToast('錯誤', '無法載入共用設定，請重新整理頁面', 'error');
            }
        });
    }

    let allUsers = [];
    let selectedUsers = new Set();

    function bindShareModalEvents() {
        allUsers = [];
        $('.share-user-item').each(function() {
            const userName = String($(this).data('user-name') || '');
            const userEmail = String($(this).data('user-email') || '');
            const userFullName = $(this).find('.fw-semibold').text().trim();
            const userInitial = $(this).find('.rounded-circle').text().trim();
            
            if (userName) {
                allUsers.push({
                    name: userName,
                    email: userEmail,
                    fullName: userFullName,
                    initial: userInitial
                });
            }
        });

        const $searchInput = $('#shareUserSearch');
        const $dropdown = $('#shareUserDropdown');
        const $dropdownList = $('#shareUserDropdownList');
        const $selectedUsers = $('#shareSelectedUsers');
        const $userList = $('#shareUserList');

        function updateSelectedUsersDisplay() {
            $selectedUsers.empty();
            selectedUsers.forEach(userName => {
                const user = allUsers.find(u => u.name === userName);
                if (user) {
                    const $badge = $(`
                        <span class="badge bg-primary d-flex align-items-center gap-1" style="font-size: 0.875rem;">
                            <span>${user.fullName || user.name}</span>
                            <button type="button" class="btn-close btn-close-white" style="font-size: 0.6rem;" data-user-name="${user.name}"></button>
                        </span>
                    `);
                    $badge.find('button').on('click', function() {
                        const name = $(this).data('user-name');
                        selectedUsers.delete(name);
                        $(`#share-user-${name}`).prop('checked', false);
                        updateSelectedUsersDisplay();
                    });
                    $selectedUsers.append($badge);
                }
            });
        }

        function showDropdown() {
            $dropdown.show();
        }

        function hideDropdown() {
            $dropdown.hide();
        }

        function filterUsers(searchTerm) {
            if (!searchTerm) {
                $dropdownList.empty();
                hideDropdown();
                return;
            }

            const term = searchTerm.toLowerCase();
            const filtered = allUsers.filter(user => {
                const name = String(user.name || '').toLowerCase();
                const email = String(user.email || '').toLowerCase();
                const fullName = String(user.fullName || '').toLowerCase();
                return name.includes(term) || email.includes(term) || fullName.includes(term);
            });

            $dropdownList.empty();
            
            if (filtered.length === 0) {
                $dropdownList.append('<div class="list-group-item text-muted text-center small">找不到符合的使用者</div>');
            } else {
                filtered.forEach(user => {
                    const isSelected = selectedUsers.has(user.name);
                    const $item = $(`
                        <button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-2 ${isSelected ? 'disabled' : ''}" data-user-name="${user.name}">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:2rem;height:2rem;font-size:0.9rem;">
                                ${user.initial}
                            </div>
                            <div class="flex-grow-1 text-start">
                                <div class="small fw-semibold">${user.fullName || user.name}</div>
                                <div class="small text-muted">${user.email}</div>
                            </div>
                            ${isSelected ? '<i data-lucide="check" class="text-success" style="width:1rem;height:1rem;"></i>' : ''}
                        </button>
                    `);
                    
                    if (!isSelected) {
                        $item.on('click', function() {
                            const userName = $(this).data('user-name');
                            selectedUsers.add(userName);
                            $(`#share-user-${userName}`).prop('checked', true);
                            $searchInput.val('');
                            hideDropdown();
                            updateSelectedUsersDisplay();
                            if (window.lucide?.createIcons) {
                                window.lucide.createIcons();
                            }
                        });
                    }
                    
                    $dropdownList.append($item);
                });
            }

            if (window.lucide?.createIcons) {
                window.lucide.createIcons();
            }

            showDropdown();
        }

        $searchInput.off('input.shareModal focus.shareModal').on('input.shareModal focus.shareModal', function() {
            const searchTerm = ($(this).val() || '').trim();
            filterUsers(searchTerm);
        });

        $searchInput.off('blur.shareModal').on('blur.shareModal', function() {
            setTimeout(() => hideDropdown(), 200);
        });

        $('.share-user-item input[type="checkbox"]').off('change.shareModal').on('change.shareModal', function() {
            const userName = String($(this).data('user-name') || '');
            if ($(this).is(':checked')) {
                selectedUsers.add(userName);
            } else {
                selectedUsers.delete(userName);
            }
            updateSelectedUsersDisplay();
        });

        $(document).off('click.shareModal').on('click.shareModal', function(e) {
            if (!$(e.target).closest('#shareUserSearch, #shareUserDropdown').length) {
                hideDropdown();
            }
        });

        $('.share-user-item input[type="checkbox"]:checked').each(function() {
            const userName = String($(this).data('user-name') || '');
            if (userName) {
                selectedUsers.add(userName);
            }
        });

        updateSelectedUsersDisplay();
    }

    function confirmShareItem() {
        const usersArray = Array.from(selectedUsers);
        
        const token = $('input[name="__RequestVerificationToken"]').val() || $('meta[name="__RequestVerificationToken"]').attr('content');
        if (!token) {
            showToast('錯誤', '無法取得驗證 Token，請重新整理頁面', 'error');
            return;
        }
        
        $.ajax({
            url: '/Backoffice/FileManager/SubmitShare',
            method: 'POST',
            headers: {
                'RequestVerificationToken': token
            },
            contentType: 'application/json',
            data: JSON.stringify({
                path: shareConfirmItem.path,
                name: shareConfirmItem.name,
                owners: usersArray
            }),
            success: function(response) {
                if (response.success) {
                    showToast('成功', response.message, 'success');
                    $('#shareItemModal').modal('hide');
                    
                    loadItemDetail(shareConfirmItem.path, shareConfirmItem.name);
                    switchView(null, shareConfirmItem.path || '/');
                } else {
                    showToast('失敗', response.message || '共用設定失敗', 'error');
                }
            },
            error: function() {
                showToast('錯誤', '共用設定時發生錯誤', 'error');
            }
        });
    }

    window.openShareModal = openShareModal;
</script>

