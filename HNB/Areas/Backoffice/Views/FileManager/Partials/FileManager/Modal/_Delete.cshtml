@{
    Layout = null;
}

<!-- 刪除確認 Modal -->
<div id="deleteItemModal" class="modal fade" tabindex="-1" aria-labelledby="deleteItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="deleteItemModalLabel">確認刪除</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <i data-lucide="alert-triangle" class="text-danger" style="width:3rem;height:3rem;"></i>
                </div>
                <p class="text-center mb-3">
                    您即將刪除以下項目，此操作<strong class="text-danger">無法復原</strong>：
                </p>
                <div class="alert alert-warning mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <i data-lucide="file" id="deleteItemIcon" style="width:1.2rem;height:1.2rem;"></i>
                        <span id="deleteItemName" class="fw-semibold"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="deleteItemNameInput" class="form-label small">
                        請輸入項目名稱以確認刪除：<span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="deleteItemNameInput" 
                           placeholder="請輸入完整的項目名稱"
                           autocomplete="off">
                    <div class="invalid-feedback" id="deleteItemNameError" style="display:none;">
                        輸入的名稱與項目名稱不符
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger btn-sm" id="deleteItemConfirmBtn" onclick="confirmDeleteItem()" disabled>
                    <i data-lucide="trash-2" style="width:1rem;height:1rem;"></i>
                    確認刪除
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // 儲存要刪除的項目資訊
    let deleteItemData = {
        path: null,
        name: null,
        type: null
    };

    // 開啟刪除 Modal
    function openDeleteModal(path, name, type) {
        deleteItemData = {
            path: path || '/',
            name: name,
            type: type
        };

        const itemType = type === 'folder' ? '資料夾' : '檔案';
        const iconName = type === 'folder' ? 'folder' : 'file';
        
        // 更新 Modal 內容
        $('#deleteItemName').text(name);
        $('#deleteItemIcon').attr('data-lucide', iconName);
        $('#deleteItemNameInput').val('');
        $('#deleteItemNameInput').removeClass('is-invalid');
        $('#deleteItemNameError').hide();
        $('#deleteItemConfirmBtn').prop('disabled', true);

        // 更新圖示
        if (window.lucide?.createIcons) {
            window.lucide.createIcons();
        }

        // 顯示 Modal
        const modal = new bootstrap.Modal(document.getElementById('deleteItemModal'));
        modal.show();

        // 聚焦到輸入框
        setTimeout(() => {
            $('#deleteItemNameInput').focus();
        }, 300);
    }

    // 監聽輸入框變化，驗證名稱
    $(document).ready(function() {
        $('#deleteItemNameInput').on('input', function() {
            const inputValue = $(this).val().trim();
            const itemName = deleteItemData.name;
            const $input = $(this);
            const $error = $('#deleteItemNameError');
            const $btn = $('#deleteItemConfirmBtn');

            if (inputValue === itemName) {
                $input.removeClass('is-invalid');
                $error.hide();
                $btn.prop('disabled', false);
            } else {
                $input.addClass('is-invalid');
                $error.show();
                $btn.prop('disabled', true);
            }
        });

        // 按 Enter 鍵確認刪除
        $('#deleteItemNameInput').on('keypress', function(e) {
            if (e.which === 13 && !$('#deleteItemConfirmBtn').prop('disabled')) {
                confirmDeleteItem();
            }
        });

        // Modal 關閉時清除資料
        $('#deleteItemModal').on('hidden.bs.modal', function() {
            deleteItemData = { path: null, name: null, type: null };
            $('#deleteItemNameInput').val('');
            $('#deleteItemNameInput').removeClass('is-invalid');
            $('#deleteItemNameError').hide();
        });
    });

    // 確認刪除
    function confirmDeleteItem() {
        if (!$('#deleteItemConfirmBtn').prop('disabled') && deleteItemData.name && deleteItemData.path) {
            const isFolder = deleteItemData.type === 'folder';
            const url = isFolder 
                ? '/Backoffice/FileManager/Delete'
                : '/Backoffice/FileManager/DeleteFile';
            
            const token = $('input[name="__RequestVerificationToken"]').val() || $('meta[name="__RequestVerificationToken"]').attr('content');
            if (!token) {
                showToast('錯誤', '無法取得驗證 Token，請重新整理頁面', 'error');
                return;
            }

            // 關閉 Modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('deleteItemModal'));
            modal.hide();

            $.ajax({
                url: url,
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token
                },
                contentType: 'application/json',
                data: JSON.stringify({
                    path: deleteItemData.path,
                    name: deleteItemData.name
                }),
                success: function(response) {
                    if (response.success) {
                        showToast('成功', response.message, 'success');
                        
                        // 儲存當前路徑
                        const currentPath = deleteItemData.path || '/';
                        
                        // 清除選中狀態
                        if (window.selectedItem) {
                            window.selectedItem = { path: null, name: null, type: null };
                        }
                        if (typeof updateActionButtons === 'function') {
                            updateActionButtons();
                        }
                        $('#fileListTable tbody tr').removeClass('table-active');
                        
                        // 重新載入畫面
                        if (typeof switchView === 'function') {
                            switchView(null, currentPath);
                        }
                    } else {
                        showToast('失敗', response.message || '刪除失敗', 'error');
                    }
                },
                error: function() {
                    showToast('錯誤', '刪除時發生錯誤', 'error');
                }
            });
        }
    }

    // 暴露為全域函數
    window.openDeleteModal = openDeleteModal;
    window.confirmDeleteItem = confirmDeleteItem;
</script>

