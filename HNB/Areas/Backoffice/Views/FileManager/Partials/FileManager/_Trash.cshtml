@model HNB.Areas.Backoffice.Dtos.FileManagerDto
@{
    Layout = null;
}

<div class="row g-3">
    <!-- 左側：檔案列表 -->
    <div class="col-12 col-lg-8">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" style="width:40%;">
                        <div class="d-flex align-items-center gap-2">
                            <span>名稱</span>
                            <i data-lucide="chevron-up" class="text-muted" style="width:0.9rem;height:0.9rem;"></i>
                        </div>
                    </th>
                    <th scope="col" style="width:15%;">共用</th>
                    <th scope="col" style="width:15%;">擁有者</th>
                    <th scope="col" style="width:20%;">刪除日期</th>
                    <th scope="col" class="text-end" style="width:10%;">大小</th>
                </tr>
            </thead>
            <tbody>
                <!-- 模擬資料：已刪除的檔案 -->
                <tr class="table-active">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="file-text" class="text-muted" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none text-muted">舊版需求文件.docx</a>
                        </div>
                    </td>
                    <td class="small text-muted">未共用</td>
                    <td class="small text-muted">Ming</td>
                    <td class="small text-muted">2025/02/25 下午 03:15</td>
                    <td class="text-end small text-muted">850 KB</td>
                </tr>

                <!-- 模擬資料：已刪除的資料夾 -->
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="folder" class="text-muted" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none text-muted">測試資料夾</a>
                        </div>
                    </td>
                    <td class="small text-muted">未共用</td>
                    <td class="small text-muted">Ming</td>
                    <td class="small text-muted">2025/02/24 上午 10:30</td>
                    <td class="text-end small text-muted">—</td>
                </tr>

                <!-- 模擬資料：已刪除的圖片 -->
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="image" class="text-muted" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none text-muted">備份圖片.png</a>
                        </div>
                    </td>
                    <td class="small text-muted">未共用</td>
                    <td class="small text-muted">Ming</td>
                    <td class="small text-muted">2025/02/23 下午 02:45</td>
                    <td class="text-end small text-muted">1.5 MB</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 右側：詳細資料 -->
    <div class="col-12 col-lg-4">
        <div class="border rounded-3 bg-white p-3">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i data-lucide="file-text" class="text-muted" style="width:1.5rem;height:1.5rem;"></i>
                <div>
                    <div class="fw-semibold small text-muted">舊版需求文件.docx</div>
                    <div class="text-muted small">Word 文件</div>
                </div>
            </div>

            <hr class="my-2">

            <div class="small mb-2">
                <div class="text-muted mb-1">原始位置</div>
                <div class="d-flex align-items-center gap-1">
                    <i data-lucide="folder" class="text-muted" style="width:0.9rem;height:0.9rem;"></i>
                    <span class="text-truncate">/我的檔案/專案文件</span>
                </div>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">擁有者</div>
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:1.5rem;height:1.5rem;font-size:0.8rem;">
                        M
                    </div>
                    <span>Ming</span>
                </div>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">刪除日期</div>
                <span>2025/02/25 下午 03:15</span>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">大小</div>
                <span>850 KB</span>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">建立時間</div>
                <span>2025/01/10 上午 09:00</span>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">上次修改</div>
                <span>2025/02/20 下午 04:30</span>
            </div>

            <hr class="my-2">

            <div class="d-grid gap-2">
                <button type="button" class="btn btn-primary btn-sm">
                    <i data-lucide="rotate-ccw" style="width:0.875rem;height:0.875rem;"></i>
                    還原
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm">
                    <i data-lucide="trash-2" style="width:0.875rem;height:0.875rem;"></i>
                    永久刪除
                </button>
            </div>
        </div>
    </div>
</div>

