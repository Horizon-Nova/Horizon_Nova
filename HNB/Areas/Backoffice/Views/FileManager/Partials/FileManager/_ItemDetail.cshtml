@model HNB.Areas.Backoffice.Dtos.FileSystemEntry
@using System.IO
@{
    Layout = null;
}

@functions {
    string GetFileIcon(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        if (ext == ".pdf" || ext == ".doc" || ext == ".docx" || ext == ".txt" || ext == ".md")
            return "file-text";
        if (ext == ".xls" || ext == ".xlsx")
            return "file-spreadsheet";
        if (ext == ".ppt" || ext == ".pptx")
            return "file-presentation";
        if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".bmp" || ext == ".svg")
            return "image";
        if (ext == ".mp4" || ext == ".avi" || ext == ".mov" || ext == ".wmv")
            return "video";
        if (ext == ".mp3" || ext == ".wav" || ext == ".flac")
            return "music";
        if (ext == ".zip" || ext == ".rar" || ext == ".7z")
            return "archive";
        if (ext == ".html" || ext == ".htm" || ext == ".js" || ext == ".ts" || ext == ".css")
            return "file-code";
        return "file";
    }

    string GetFileIconColor(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        if (ext == ".pdf")
            return "text-danger";
        if (ext == ".doc" || ext == ".docx")
            return "text-primary";
        if (ext == ".xls" || ext == ".xlsx")
            return "text-success";
        if (ext == ".ppt" || ext == ".pptx")
            return "text-warning";
        if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".bmp" || ext == ".svg")
            return "text-info";
        if (ext == ".mp4" || ext == ".avi" || ext == ".mov" || ext == ".wmv")
            return "text-secondary";
        if (ext == ".mp3" || ext == ".wav" || ext == ".flac")
            return "text-secondary";
        if (ext == ".zip" || ext == ".rar" || ext == ".7z")
            return "text-muted";
        return "text-muted";
    }

    string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

@if (Model != null)
{
    var isFolder = Model.Type == "folder";
    var iconName = isFolder ? "folder" : GetFileIcon(Model.Name);
    var iconColor = isFolder ? "text-warning" : GetFileIconColor(Model.Name);
    var sizeText = isFolder ? "—" : FormatBytes(Model.Size ?? 0);
    var owner = Model.Owner ?? Model.PrimaryOwner ?? "—";
    var ownerInitial = !string.IsNullOrEmpty(owner) && owner != "—" ? owner.Substring(0, 1).ToUpper() : "?";
    var sharedCount = Model.SharedUsers?.Count ?? 0;
    var path = Model.VirtualPath ?? "/我的檔案";
    if (path.StartsWith("/storage/", StringComparison.OrdinalIgnoreCase))
    {
        path = "/我的檔案" + path.Substring("/storage".Length);
    }
    else if (!path.StartsWith("/我的檔案"))
    {
        path = "/我的檔案" + (path == "/" ? "" : path);
    }
    
    <div class="d-flex align-items-center gap-2 mb-2">
        <i data-lucide="@iconName" class="@iconColor" style="width:1.5rem;height:1.5rem;"></i>
        <div>
            <div class="fw-semibold small">@Model.Name</div>
            <div class="text-muted small">@(isFolder ? "資料夾" : Model.MimeType ?? "檔案")</div>
        </div>
    </div>

    <hr class="my-2">

    <div class="small mb-2">
        <div class="text-muted mb-1">位置</div>
        <div class="d-flex align-items-center gap-1">
            <i data-lucide="folder" class="text-muted" style="width:0.9rem;height:0.9rem;"></i>
            <span class="text-truncate">@path</span>
        </div>
    </div>

    <div class="small mb-2">
        <div class="text-muted mb-1">擁有者</div>
        <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:1.5rem;height:1.5rem;font-size:0.8rem;">
                @ownerInitial
            </div>
            <span>@owner</span>
        </div>
    </div>

    @if (sharedCount > 0)
    {
        <div class="small mb-2">
            <div class="text-muted mb-1">共用</div>
            <div class="d-flex align-items-center gap-2">
                <div class="d-flex">
                    @for (int i = 0; i < Math.Min(sharedCount, 3); i++)
                    {
                        var sharedUser = Model.SharedUsers?[i] ?? "";
                        var sharedInitial = !string.IsNullOrEmpty(sharedUser) ? sharedUser.Substring(0, 1).ToUpper() : "?";
                        <div class="rounded-circle @(i == 0 ? "bg-primary" : "bg-secondary") text-white d-flex align-items-center justify-content-center @(i > 0 ? "ms-n1" : "")" style="width:1.4rem;height:1.4rem;font-size:0.75rem;">
                            @sharedInitial
                        </div>
                    }
                </div>
                <span class="small text-muted">與 @sharedCount 個人共用</span>
            </div>
        </div>
    }

    @if (!isFolder)
    {
        <div class="small mb-2">
            <div class="text-muted mb-1">大小</div>
            <span>@sizeText</span>
        </div>
    }

    @if (Model.CreatedAt.HasValue)
    {
        <div class="small mb-2">
            <div class="text-muted mb-1">建立時間</div>
            <span>@Model.CreatedAt.Value.ToString("yyyy/MM/dd HH:mm")</span>
        </div>
    }

    @if (Model.UpdatedAt.HasValue || Model.LastWriteUtc.HasValue)
    {
        <div class="small mb-2">
            <div class="text-muted mb-1">上次修改</div>
            <span>@((Model.UpdatedAt ?? Model.LastWriteUtc)?.ToString("yyyy/MM/dd HH:mm") ?? "—")</span>
        </div>
    }
}
else
{
    <div class="text-center text-muted small py-4">
        <i data-lucide="file-question" style="width:2rem;height:2rem;" class="mb-2"></i>
        <div>點擊項目查看詳細資訊</div>
    </div>
}

