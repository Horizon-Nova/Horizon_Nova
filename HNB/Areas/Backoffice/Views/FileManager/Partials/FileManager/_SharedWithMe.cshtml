@model HNB.Areas.Backoffice.Dtos.FileManagerDto
@{
    Layout = null;
}

<div class="row g-3">
    <!-- 左側：檔案列表 -->
    <div class="col-12 col-lg-8">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" style="width:40%;">
                        <div class="d-flex align-items-center gap-2">
                            <span>名稱</span>
                            <i data-lucide="chevron-up" class="text-muted" style="width:0.9rem;height:0.9rem;"></i>
                        </div>
                    </th>
                    <th scope="col" style="width:20%;">共用者</th>
                    <th scope="col" style="width:20%;">修改日期</th>
                    <th scope="col" class="text-end" style="width:20%;">大小</th>
                </tr>
            </thead>
            <tbody>
                <!-- 模擬資料：資料夾（由 Alice 共用） -->
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="folder" class="text-warning" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none">專案文件</a>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-1">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:1.4rem;height:1.4rem;font-size:0.75rem;">
                                A
                            </div>
                            <span class="small text-muted">Alice</span>
                        </div>
                    </td>
                    <td class="small text-muted">2025/01/15 下午 02:30</td>
                    <td class="text-end small text-muted">—</td>
                </tr>

                <!-- 模擬資料：檔案（由 Bob 共用） -->
                <tr class="table-active">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="file-text" class="text-primary" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none">會議記錄.pdf</a>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-1">
                            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center" style="width:1.4rem;height:1.4rem;font-size:0.75rem;">
                                B
                            </div>
                            <span class="small text-muted">Bob</span>
                        </div>
                    </td>
                    <td class="small text-muted">2025/01/20 上午 10:15</td>
                    <td class="text-end small text-muted">2.3 MB</td>
                </tr>

                <!-- 模擬資料：檔案（由 Charlie 共用） -->
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="image" class="text-info" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none">設計稿.png</a>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-1">
                            <div class="rounded-circle bg-info text-white d-flex align-items-center justify-content-center" style="width:1.4rem;height:1.4rem;font-size:0.75rem;">
                                C
                            </div>
                            <span class="small text-muted">Charlie</span>
                        </div>
                    </td>
                    <td class="small text-muted">2025/01/18 下午 04:45</td>
                    <td class="text-end small text-muted">5.7 MB</td>
                </tr>

                <!-- 模擬資料：資料夾（由 David 共用） -->
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="folder" class="text-warning" style="width:1.1rem;height:1.1rem;"></i>
                            <a href="javascript:void(0)" class="text-decoration-none">團隊資源</a>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-1">
                            <div class="rounded-circle bg-warning text-white d-flex align-items-center justify-content-center" style="width:1.4rem;height:1.4rem;font-size:0.75rem;">
                                D
                            </div>
                            <span class="small text-muted">David</span>
                        </div>
                    </td>
                    <td class="small text-muted">2025/01/22 上午 09:20</td>
                    <td class="text-end small text-muted">—</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 右側：詳細資料 -->
    <div class="col-12 col-lg-4">
        <div class="border rounded-3 bg-white p-3">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i data-lucide="file-text" class="text-primary" style="width:1.5rem;height:1.5rem;"></i>
                <div>
                    <div class="fw-semibold small">會議記錄.pdf</div>
                    <div class="text-muted small">PDF 文件</div>
                </div>
            </div>

            <hr class="my-2">

            <div class="small mb-2">
                <div class="text-muted mb-1">位置</div>
                <div class="d-flex align-items-center gap-1">
                    <i data-lucide="folder" class="text-muted" style="width:0.9rem;height:0.9rem;"></i>
                    <span class="text-truncate">/與我共用/會議記錄.pdf</span>
                </div>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">共用者</div>
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center" style="width:1.5rem;height:1.5rem;font-size:0.8rem;">
                        B
                    </div>
                    <span>Bob</span>
                </div>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">共用權限</div>
                <div class="d-flex align-items-center gap-1">
                    <i data-lucide="eye" class="text-muted" style="width:0.9rem;height:0.9rem;"></i>
                    <span class="small">可檢視</span>
                </div>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">大小</div>
                <span>2.3 MB</span>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">共用時間</div>
                <span>2025/01/20 上午 10:15</span>
            </div>

            <div class="small mb-2">
                <div class="text-muted mb-1">上次修改</div>
                <span>2025/01/20 上午 10:15</span>
            </div>

            <hr class="my-2">

            <div class="small mb-1 text-muted">描述</div>
            <p class="small mb-0 text-muted">
                這是 Bob 分享給我的會議記錄文件，包含上週團隊會議的重要決議事項。
            </p>
        </div>
    </div>
</div>
