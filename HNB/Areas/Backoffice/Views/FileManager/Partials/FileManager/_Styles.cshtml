@{
    Layout = null;
}

<style>
    /* 檔案總管根容器：以白色為主、藍色為輔 */
    .file-manager-root {
        background-color: #f9fafb;
    }

    /* 左側主選單：以白為主、藍為輔，active 只用淡藍底 */
    .file-manager-root .nav-pills .nav-link {
        color: #4b5563;
    }

    .file-manager-root .nav-pills .nav-link.active {
        background-color: #eef2ff;
        color: #1d4ed8;
    }

    .file-manager-root .nav-pills .nav-link.disabled {
        opacity: 0.7;
    }

    /* 主要按鈕：改成白底藍框藍字，減少整片藍色 */
    .file-manager-root .btn-primary {
        background-color: #ffffff;
        color: #0d6efd;
        border-color: #cfe2ff;
    }

    .file-manager-root .btn-primary:hover {
        background-color: #f3f6ff;
        border-color: #bfdbfe;
    }

    /* 次要按鈕：降低對比，保持白系為主 */
    .file-manager-root .btn-outline-secondary {
        border-color: #e5e7eb;
        color: #6b7280;
    }

    .file-manager-root .btn-outline-secondary:disabled {
        background-color: #ffffff;
        color: #9ca3af;
    }

    /* 儲存空間進度條：改用較淡的藍色 */
    .file-manager-root .progress-bar.bg-primary {
        background-color: #bfdbfe;
    }
</style>
