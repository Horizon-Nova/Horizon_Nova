@{
    Layout = null;
}

<style>
    /* 檔案總管根容器：以白色為主、藍色為輔 */
    .file-manager-root {
        background-color: var(--Slate-50-alt);
    }

    /* 左側主選單：以白為主、藍為輔，active 只用淡藍底 */
    .file-manager-root .nav-pills .nav-link {
        color: var(--Gray-600);
    }

    .file-manager-root .nav-pills .nav-link.active {
        background-color: var(--Indigo-50);
        color: var(--Blue-700);
    }

    .file-manager-root .nav-pills .nav-link.disabled {
        opacity: 0.7;
    }

    /* 主要按鈕：改成白底藍框藍字，減少整片藍色 */
    .file-manager-root .btn-primary {
        background-color: var(--White);
        color: var(--Bootstrap-Primary);
        border-color: var(--Blue-200);
    }

    .file-manager-root .btn-primary:hover {
        background-color: var(--Indigo-50);
        border-color: var(--Blue-300);
    }

    /* 次要按鈕：降低對比，保持白系為主 */
    .file-manager-root .btn-outline-secondary {
        border-color: var(--Gray-200);
        color: var(--Gray-500);
    }

    .file-manager-root .btn-outline-secondary:disabled {
        background-color: var(--White);
        color: var(--Gray-400);
    }

    /* 儲存空間進度條：改用較淡的藍色 */
    .file-manager-root .progress-bar.bg-primary {
        background-color: var(--Blue-300);
    }
</style>
