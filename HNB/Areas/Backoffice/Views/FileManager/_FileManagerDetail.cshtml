@model Models.HnbHnbBackoffice.vw_file_manager

@{
    Layout = null;
}

<div id="itemDetailModal" class="modal fade" tabindex="-1" aria-labelledby="itemDetailLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="itemDetailLabel"><i id="detailIcon" data-lucide="@(Model.item_type == "folder" ? "folder" : "file")" class="me-2" style="width:1rem;height:1rem;"></i>詳細資料</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <table class="table table-sm table-borderless small mb-0">
                    <tr><td class="text-muted" style="width: 90px;">名稱</td><td class="fw-semibold text-break">@Model.file_name</td></tr>
                    <tr><td class="text-muted">類型</td><td>@(Model.item_type == "folder" ? "資料夾" : "檔案")</td></tr>
                    <tr><td class="text-muted">路徑</td><td class="text-break">@Model.file_path/@Model.file_name</td></tr>
                    <tr><td class="text-muted">大小</td><td>@(Model.item_type == "folder" ? "—" : (Model.file_size.HasValue ? Model.file_size.Value.ToString("N0") + " B" : "—"))</td></tr>
                    <tr><td class="text-muted">擁有者</td><td>@Model.owner_username</td></tr>
                    <tr><td class="text-muted">共享使用者</td><td class="text-break">@(Model.shared_users != null && Model.shared_users.Any() ? string.Join(", ", Model.shared_users) : "—")</td></tr>
                    <tr><td class="text-muted">建立時間</td><td>@Model.created_at?.ToString("yyyy/MM/dd HH:mm")</td></tr>
                    <tr><td class="text-muted">更新時間</td><td>@Model.updated_at?.ToString("yyyy/MM/dd HH:mm")</td></tr>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>


