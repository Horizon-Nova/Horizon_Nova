@model Models.HnbHnbBackoffice.vw_file_manager

@{
    Layout = null;
}

<div id="itemDetailModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden transform transition-all duration-300 ease-out">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-200">
            <div class="flex items-center gap-2">
                <i id="detailIcon" data-lucide="@(Model.item_type == "folder" ? "folder" : "file")" class="h-5 w-5 text-slate-600"></i>
                <h2 class="text-base font-semibold text-slate-900">詳細資料</h2>
            </div>
            <button onclick="closeModal('itemDetailModal')" class="w-8 h-8 flex items-center justify-center hover:bg-slate-100 rounded">
                <i data-lucide="x" class="h-5 w-5 text-slate-500"></i>
            </button>
        </div>
        <div class="px-5 py-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                <div>
                    <div class="text-slate-500">名稱</div>
                    <div class="text-slate-900 font-medium break-all">@Model.file_name</div>
                </div>
                <div>
                    <div class="text-slate-500">類型</div>
                    <div class="text-slate-900">@(Model.item_type == "folder" ? "資料夾" : "檔案")</div>
                </div>
                <div class="sm:col-span-2">
                    <div class="text-slate-500">路徑</div>
                    <div class="text-slate-900 break-all">@Model.file_path/@Model.file_name</div>
                </div>
                <div>
                    <div class="text-slate-500">大小</div>
                    <div class="text-slate-900">@(Model.item_type == "folder" ? "—" : (Model.file_size.HasValue ? Model.file_size.Value.ToString("N0") + " B" : "—"))</div>
                </div>
                <div>
                    <div class="text-slate-500">擁有者</div>
                    <div class="text-slate-900">@Model.owner_username</div>
                </div>
                <div class="sm:col-span-2">
                    <div class="text-slate-500">共享使用者</div>
                    <div class="text-slate-900 break-words">@(Model.shared_users != null && Model.shared_users.Any() ? string.Join(", ", Model.shared_users) : "—")</div>
                </div>
                <div>
                    <div class="text-slate-500">建立時間</div>
                    <div class="text-slate-900">@Model.created_at?.ToString("yyyy/MM/dd HH:mm")</div>
                </div>
                <div>
                    <div class="text-slate-500">更新時間</div>
                    <div class="text-slate-900">@Model.updated_at?.ToString("yyyy/MM/dd HH:mm")</div>
                </div>
            </div>
        </div>
        <div class="flex items-center justify-end gap-2 px-5 py-4 bg-slate-50 border-t border-slate-200">
            <button onclick="closeModal('itemDetailModal')" class="px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 rounded-lg">關閉</button>
        </div>
    </div>
</div>


