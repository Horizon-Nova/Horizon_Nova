@{
    ViewData["Title"] = "檔案總管 - 後台管理系統";
    ViewData["PageTitle"] = "檔案總管 - 後台管理系統";
    ViewData["PageDescription"] = "管理後端檔案與資料夾";
    ViewData["PageIcon"] = "folder-tree";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="space-y-6">
    <form id="fmTokens">@Html.AntiForgeryToken()</form>

    <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 bg-white border rounded-xl p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                <!-- 左側資料夾樹 -->
                <aside class="col-span-12 md:col-span-3 md:sticky md:top-2 bg-white border rounded-lg p-4 space-y-3 order-1">
                    <div class="flex items-center justify-between">
                        <h3 class="text-sm font-semibold flex items-center gap-1">
                            <i data-lucide="folders" class="w-4 h-4"></i> 資料夾
                        </h3>
                        <div class="flex gap-1">
                            <button id="btnAddFolder" class="p-1.5 rounded hover:bg-slate-100"
                                    title="新增資料夾" onclick="return fmAddFolder();">
                                <i data-lucide="folder-plus" class="w-4 h-4"></i>
                            </button>
                            <button id="btnAddFile" class="p-1.5 rounded hover:bg-slate-100"
                                    title="新增檔案" onclick="return fmAddFile();">
                                <i data-lucide="file-plus" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                    <ul id="tree" class="space-y-1 text-sm"></ul>

                </aside>

                <!-- 右側檔案清單 -->
                <main class="col-span-12 md:col-span-9 bg-white border rounded-lg p-4 space-y-6 order-2">

                    <!-- 拖曳上傳 -->
                    <form id="uploadForm" class="space-y-2" onsubmit="return false;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="path" id="uploadPath" value="/" />

                        <!-- 拖曳/點擊區 -->
                        <div id="dropzone" class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:bg-slate-50 cursor-pointer transition">
                            <i data-lucide="upload-cloud" class="w-10 h-10 mx-auto text-slate-400"></i>
                            <p class="mt-2 text-sm text-slate-600">
                                拖曳檔案到這裡，或
                                <label for="fileInput" class="text-blue-600 cursor-pointer hover:underline">點擊上傳</label>
                            </p>
                            <input id="fileInput" name="files" type="file" class="hidden" multiple />
                        </div>

                        <!-- 進度列-->
                        <div id="uploadPanel" class="hidden mt-3 rounded border p-3 text-sm">
                            <div class="flex items-center justify-between mb-2">
                                <div>上傳進度：<span id="upPct">0%</span>（<span id="upBytes">0 / 0</span>）</div>
                                <div>預估剩餘：<span id="upEta">—</span></div>
                            </div>
                            <div class="w-full h-2 bg-slate-200 rounded overflow-hidden">
                                <div id="upBar" class="h-2 bg-blue-500" style="width:0%"></div>
                            </div>
                            <div class="mt-2">
                                <button id="btnCancelUpload" type="button" class="px-3 py-1 rounded border">中斷上傳</button>
                            </div>
                        </div>

                        <!-- 重新整理 -->
                        <div class="flex items-center gap-3">
                            <button id="btnRefresh" class="text-sm text-gray-600 hover:text-gray-800" type="button" onclick="location.reload()">
                                重新整理
                            </button>
                        </div>

                    </form>


                    <div id="fileListPanel"></div>

                    <!-- 預覽 / 編輯面板（保留結構；未啟用） -->
                    <div id="previewPanel" class="hidden fixed inset-0 bg-black/40 z-50">
                        <div class="absolute inset-0 flex items-center justify-center p-4">
                            <div class="bg-white light:bg-slate-900 w-full max-w-5xl rounded-xl shadow-xl overflow-hidden">
                                <div class="flex items-center justify-between px-4 py-3 border-b">
                                    <div class="font-semibold" id="pvTitle">預覽</div>
                                    <div class="flex items-center gap-2">
                                        <button class="px-2 py-1 text-sm rounded bg-slate-100 hover:bg-slate-200" onclick="document.getElementById('previewPanel').classList.add('hidden')">關閉</button>
                                    </div>
                                </div>
                                <div id="pvBody" class="p-4 max-h-[70vh] overflow-auto text-sm"></div>
                                <div id="pvEditBar" class="hidden border-t px-4 py-3 flex justify-end gap-2">
                                    <select id="pvEncoding" class="border rounded px-2 py-1 text-sm">
                                        <option value="utf-8">UTF-8</option>
                                        <option value="utf-8-bom">UTF-8 (BOM)</option>
                                    </select>
                                    <button class="px-3 py-1.5 text-sm rounded bg-blue-600 text-white hover:bg-blue-700">儲存</button>
                                    <button class="px-3 py-1.5 text-sm rounded bg-slate-100 hover:bg-slate-200" onclick="document.getElementById('previewPanel').classList.add('hidden')">取消</button>
                                </div>
                            </div>
                        </div>
                    </div>

                </main>
            </div>
        </div>
    </div>
</section>
@section Scripts {

}
