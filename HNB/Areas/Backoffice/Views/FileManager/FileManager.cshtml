@model List<HNB.Areas.Backoffice.Dtos.FileSystemEntry>
@{
    ViewData["Title"] = "檔案總管";
    ViewData["PageTitle"] = "檔案總管";
    ViewData["PageDescription"] = "管理檔案和資料夾、上傳下載、預覽編輯";
    ViewData["PageIcon"] = "folder";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";

    var currentPath = ViewBag.CurrentPath as string ?? "/";
    var currentUser = ViewBag.CurrentUser as string ?? "guest";
    var tree = ViewBag.Tree as List<object> ?? new();
    var allItems = Model ?? new();

    var itemsByType = allItems.GroupBy(item => item.Type).ToDictionary(g => g.Key, g => g.ToList());
    var folders = itemsByType.GetValueOrDefault("folder", new List<HNB.Areas.Backoffice.Dtos.FileSystemEntry>());
    var files = itemsByType.GetValueOrDefault("file", new List<HNB.Areas.Backoffice.Dtos.FileSystemEntry>());

    var (folderCount, fileCount, totalSize) = (
        ViewBag.FolderCount as int? ?? folders.Count,
        ViewBag.FileCount as int? ?? files.Count,
        ViewBag.TotalSize as long? ?? files.Sum(f => f.Size ?? 0L)
    );
    var breadcrumb = currentPath == "/"
        ? new List<(string Name, string VirtualPath)> { ("根目錄", "/") }
        : new[] { ("根目錄", "/") }
            .Concat(currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries)
                .Aggregate(new List<(string, string)>(), (acc, part) =>
                {
                    var path = acc.LastOrDefault().Item2 + "/" + part;
                    acc.Add((part, path));
                    return acc;
                }))
            .ToList();
}

<div class="bg-white border rounded-3 p-3">
    <div class="row g-0">
        <!-- 左側：目錄樹 -->
        <aside class="col-md-3 d-none d-md-block border-end">
            <div class="d-flex flex-column">
                <div class="d-flex align-items-center justify-content-between border-bottom p-3" style="min-height: 54px;">
                    <span class="small fw-semibold">檔案總管</span>
                    <div class="d-flex align-items-center gap-1">
                        <button type="button" onclick="showModal('fileManagerHelpModal')" class="btn btn-link btn-sm p-0" title="操作說明">
                            <i data-lucide="help-circle" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                        <button type="button" onclick="showModal('createFileModal')" class="btn btn-link btn-sm p-0" title="新增檔案">
                            <i data-lucide="file-plus" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                        <button type="button" onclick="showModal('createFolderModal')" class="btn btn-link btn-sm p-0" title="新增資料夾">
                            <i data-lucide="folder-plus" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                        <button type="button" onclick="location.reload()" class="btn btn-link btn-sm p-0" title="重新整理">
                            <i data-lucide="refresh-cw" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                    </div>
                </div>
                <div class="flex-grow-1 overflow-auto p-2">
                    <!-- 根目錄 -->
                    <div class="tree-item @(currentPath == "/" ? "active" : "")" data-level="0">
                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = "/" })" class="tree-link">
                            <i data-lucide="@(currentPath == "/" ? "folder-open" : "folder")" class="tree-icon"></i>
                            <span class="tree-text">根目錄</span>
                        </a>
                    </div>

                    <!-- 目錄樹 -->
                    @await Html.PartialAsync("_TreeNodes", tree)
                </div>
            </div>
        </aside>

        <!-- 右側：內容區 -->
        <div class="col-md-9">
            <!-- 頂部導航列 -->
            <div class="d-flex align-items-center justify-content-between border-bottom p-3" style="min-height: 54px;">
                <!-- 麵包屑 -->
                <nav class="d-flex align-items-center gap-1 small">
                    <button type="button" class="btn btn-outline-secondary btn-sm d-md-none me-2" data-bs-toggle="offcanvas" data-bs-target="#mobileTree">
                        <i data-lucide="panel-left" style="width:1rem;height:1rem;"></i>
                        <span class="ms-1">目錄</span>
                    </button>
                    @for (int i = 0; i < breadcrumb.Count; i++)
                    {
                        var (name, path) = breadcrumb[i];
                        var isLast = i == breadcrumb.Count - 1;

                        if (i > 0)
                        {
                            <i data-lucide="chevron-right" class="text-muted" style="width:1rem;height:1rem;"></i>
                        }

                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = path })" class="text-decoration-none px-2 py-1 rounded @(isLast ? "fw-semibold text-dark" : "text-muted")">@name</a>
                    }
                </nav>

                <!-- 統計資訊 -->
                <div class="text-muted small">@folderCount 個資料夾 · @fileCount 個檔案 · @FormatSize(totalSize)</div>
            </div>

            <!-- 手機目錄樹（Offcanvas） -->
            <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="mobileTree" aria-labelledby="mobileTreeLabel">
                <div class="offcanvas-header">
                    <h6 class="offcanvas-title" id="mobileTreeLabel">目錄</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="關閉"></button>
                </div>
                <div class="offcanvas-body p-2">
                    <!-- 根目錄 -->
                    <div class="tree-item @(currentPath == "/" ? "active" : "")" data-level="0">
                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = "/" })" class="tree-link">
                            <i data-lucide="@(currentPath == "/" ? "folder-open" : "folder")" class="tree-icon"></i>
                            <span class="tree-text">根目錄</span>
                        </a>
                    </div>

                    <!-- 目錄樹 -->
                    @await Html.PartialAsync("_TreeNodes", tree)
                </div>
            </div>

            <!-- 檔案上傳區 -->
            <div class="p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="mb-0 fw-semibold">檔案上傳</h6>
                    <div class="small text-muted">
                        <i data-lucide="info" style="width:1rem;height:1rem;"></i>
                        支援拖放檔案或資料夾
                    </div>
                </div>

                <form id="FormDataFileUpload" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div id="fileUploadDropZone" class="border border-2 border-dashed rounded p-4 text-center" style="cursor:pointer;">
                        <i data-lucide="upload-cloud" class="text-muted d-block mx-auto mb-2" style="width:2rem;height:2rem;"></i>
                        <p class="small fw-semibold text-muted mb-1">拖曳檔案或資料夾到這裡上傳</p>
                        <p class="small text-muted mb-0">或點擊選擇多個檔案</p>
                    </div>
                </form>
            </div>

            <!-- 檔案列表 -->
            <div class="p-3 h-100" style="overflow-x:auto;">
                <table id="filesTable" class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>類型</th>
                            <th>名稱</th>
                            <th>大小</th>
                            <th>擁有者</th>
                            <th>共享對象</th>
                            <th>修改時間</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in folders.Concat(files))
                        {
                            var isFile = item.Type == "file";
                            var name = item.Name;
                            var size = item.Size ?? 0L;
                            var sharedUsers = item.SharedUsers;
                            var modified = item.UpdatedAt;
                            var sharedCount = sharedUsers?.Count ?? 0;
                            var modifiedTimestamp = (modified?.ToString("yyyy-MM-dd HH:mm:ss")) ?? "";
                            var icon = isFile ? "file" : "folder";
                            var iconClass = isFile ? "text-muted" : "text-warning";
                            var folderPath = currentPath == "/" ? "/" + name : currentPath + "/" + name;

                            <tr>
                                <td data-order="@(isFile ? 1 : 0)">
                                    @if (isFile)
                                    {
                                        <a href="javascript:void(0)" class="text-decoration-none" onclick="openPreview('@currentPath', '@(name?.Replace("'", "\\'").Replace("\"", "&quot;") ?? "")')">
                                            <i data-lucide="@icon" class="@iconClass" style="width:1rem;height:1rem;"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = folderPath })" class="text-decoration-none">
                                            <i data-lucide="@icon" class="@iconClass" style="width:1rem;height:1rem;"></i>
                                        </a>
                                    }
                                </td>
                                <td>@name</td>
                                <td data-order="@size">@(isFile ? FormatSize(size) : "—")</td>
                                <td>
                                    @{
                                        var ownerToShow = !string.IsNullOrWhiteSpace(item.PrimaryOwner)
                                            ? item.PrimaryOwner
                                            : (sharedUsers?.FirstOrDefault() ?? "");
                                    }
                                    @if (string.IsNullOrWhiteSpace(ownerToShow))
                                    {
                                        <span class="text-muted">未設定</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary me-1">@ownerToShow</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var sharedIcon = sharedCount > 1 ? "users" : (sharedCount == 1 ? "lock" : "");
                                        var sharedText = sharedCount > 1 ? $"共享 ({sharedCount}人)" : (sharedCount == 1 ? "私有" : "—");
                                    }
                                    <span class="badge rounded-pill bg-light text-muted @(sharedCount > 0 ? "" : "opacity-75")">
                                        <i data-lucide="@sharedIcon" class="@(sharedCount > 0 ? "" : "d-none")" style="width:0.8rem;height:0.8rem;"></i> @sharedText
                                    </span>
                                </td>
                                <td data-order="@modifiedTimestamp">@((modified?.ToString("yyyy/MM/dd HH:mm")) ?? "—")</td>
                                <td class="text-end">
                                    <button class="btn btn-light btn-sm" type="button" title="更多"
                                            onclick="openItemPanel('@(name?.Replace("'", "\\'").Replace("\"", "&quot;") ?? "")', '@(isFile ? "file" : "folder")', '@currentPath')">
                                        <i data-lucide="ellipsis-vertical" class="text-muted" style="width:1rem;height:1rem;"></i>
                                    </button>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- 右側欄 Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="itemSidePanel" aria-labelledby="itemSidePanelLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="itemSidePanelLabel">詳細資訊</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="關閉"></button>
    </div>
    <div class="offcanvas-body" id="itemSidePanelBody">
        <div class="text-center py-3">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">載入中...</span>
            </div>
        </div>
    </div>

</div>

@functions {
    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<!-- 引入所有 Modal 視圖 -->
@await Html.PartialAsync("_FileManagerModal")

<!-- 上傳進度 Modal -->
<div id="uploadProgress" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="uploadProgressLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="uploadProgressLabel">正在上傳檔案</h5>
            </div>
            <div class="modal-body" style="max-height:400px; overflow-y:auto;">
                <div id="uploadItems" class="vstack gap-3"></div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/Backoffice/css/FileManager.css">
<script src="~/Backoffice/js/FileManager.js"></script>

<script>
    $(function(){
        // 確保 Lucide 載入完成
        if (typeof lucide !== 'undefined' && typeof lucide.createIcons === 'function') {
            lucide.createIcons();
        }

        // 初始化 DataTable
        if ($('#filesTable').length) {
            HNBDataTable.init('#filesTable', {
                initComplete: function() {
                    $('.dataTables_length').hide();

                    // DataTable 初始化完成後再次初始化 icons
                    if (typeof lucide !== 'undefined' && typeof lucide.createIcons === 'function') {
                        lucide.createIcons();
                    }
                }
            });
        }
    });
</script>