@{
    ViewData["Title"] = "檔案總管";
    ViewData["PageTitle"] = "檔案總管";
    ViewData["PageDescription"] = "管理檔案和資料夾、上傳下載、預覽編輯";
    ViewData["PageIcon"] = "folder";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";

    var currentPath = ViewBag.CurrentPath as string ?? "/";
    var currentUser = User?.Identity?.Name ?? "guest";
    var allItems = ViewBag.Items as List<HNB.Areas.Backoffice.Models.FileSystemItem> ?? new();
    var folders = allItems.Where(f => f.Type == "folder" && f.VirtualPath == currentPath).ToList();
    var files = allItems.Where(f => f.Type == "file" && f.VirtualPath == currentPath).ToList();

    var folderCount = folders.Count;
    var fileCount = files.Count;
    var totalSize = files.Sum(f => f.Size ?? 0L);

    // 使用從後端載入的目錄樹（已包含權限控制）
    var tree = ViewBag.Tree as List<(string Name, string VirtualPath, int Depth)> ?? new();

    var breadcrumb = new List<(string Name, string VirtualPath)>();
    if (currentPath == "/")
    {
        breadcrumb.Add(("根目錄", "/"));
    }
    else
    {
        breadcrumb.Add(("根目錄", "/"));
        var parts = currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var accumulated = "";
        foreach (var part in parts)
        {
            accumulated += "/" + part;
            breadcrumb.Add((part, accumulated));
        }
    }
}

<div class="bg-white border rounded-3 p-3">
    <div class="row g-0">
        <!-- 左側：目錄樹 -->
        <aside class="col-md-3 d-none d-md-block border-end">
            <div class="d-flex flex-column">
                <div class="d-flex align-items-center justify-content-between border-bottom p-3" style="min-height: 54px;">
                    <span class="small fw-semibold">檔案總管</span>
                    <div class="d-flex align-items-center gap-1">
                        <button type="button" onclick="showModal('filemanager-help')" class="btn btn-link btn-sm p-0" title="操作說明">
                            <i data-lucide="help-circle" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                        <button type="button" onclick="showModal('createFileModal')" class="btn btn-link btn-sm p-0" title="新增檔案">
                            <i data-lucide="file-plus" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                        <button type="button" onclick="showModal('createFolderModal')" class="btn btn-link btn-sm p-0" title="新增資料夾">
                            <i data-lucide="folder-plus" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                        <button type="button" onclick="location.reload()" class="btn btn-link btn-sm p-0" title="重新整理">
                            <i data-lucide="refresh-cw" class="text-muted" style="width:1rem;height:1rem;"></i>
                        </button>
                    </div>
                </div>
                <div class="flex-grow-1 overflow-auto p-2">
                    <!-- 根目錄 -->
                    <div class="tree-item @(currentPath == "/" ? "active" : "")" data-level="0">
                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = "/" })" class="tree-link">
                            <i data-lucide="@(currentPath == "/" ? "folder-open" : "folder")" class="tree-icon"></i>
                            <span class="tree-text">根目錄</span>
                        </a>
                    </div>
                    
                    <!-- 目錄樹 -->
                    @for (int i = 0; i < tree.Count; i++)
                    {
                        var (name, path, depth) = tree[i];
                        var isActive = currentPath == path;
                        var isRootChild = depth <= 1;
                        var hasChildren = i < tree.Count - 1 && tree.Skip(i + 1).Any(t => t.Depth > depth && t.VirtualPath.StartsWith(path + "/"));
                        
                        <div class="tree-item @(isRootChild ? "" : "hidden")" data-level="@depth" data-path="@path">
                            <div class="tree-content" style="padding-left: @(depth * 1.5)rem;">
                                @if (hasChildren)
                                {
                                    <button type="button" class="tree-toggle" onclick="toggleTreeNode(event, this)" title="展開/收合">
                                        <i data-lucide="chevron-right" class="tree-chevron"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="tree-spacer"></span>
                                }
                                <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = path })" class="tree-link @(isActive ? "active" : "")">
                                    <i data-lucide="@(isActive ? "folder-open" : "folder")" class="tree-icon"></i>
                                    <span class="tree-text">@name</span>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </aside>

        <!-- 右側：內容區 -->
        <div class="col-md-9">
            <!-- 頂部導航列 -->
            <div class="d-flex align-items-center justify-content-between border-bottom p-3" style="min-height: 54px;">
                <!-- 麵包屑 -->
                <nav class="d-flex align-items-center gap-1 small">
                    <button type="button" class="btn btn-outline-secondary btn-sm d-md-none me-2" data-bs-toggle="offcanvas" data-bs-target="#mobileTree">
                        <i data-lucide="panel-left" style="width:1rem;height:1rem;"></i>
                        <span class="ms-1">目錄</span>
                    </button>
                    @for (int i = 0; i < breadcrumb.Count; i++)
                    {
                        var (name, path) = breadcrumb[i];
                        var isLast = i == breadcrumb.Count - 1;

                        if (i > 0)
                        {
                            <i data-lucide="chevron-right" class="text-muted" style="width:1rem;height:1rem;"></i>
                        }

                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = path })" class="text-decoration-none px-2 py-1 rounded @(isLast ? "fw-semibold text-dark" : "text-muted")">@name</a>
                    }
                </nav>

                <!-- 統計資訊 -->
                <div class="text-muted small">@folderCount 個資料夾 · @fileCount 個檔案 · @FormatSize(totalSize)</div>
            </div>

            <!-- 手機目錄樹（Offcanvas） -->
            <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="mobileTree" aria-labelledby="mobileTreeLabel">
                <div class="offcanvas-header">
                    <h6 class="offcanvas-title" id="mobileTreeLabel">目錄</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="關閉"></button>
                </div>
                <div class="offcanvas-body p-2">
                    <!-- 根目錄 -->
                    <div class="tree-item @(currentPath == "/" ? "active" : "")" data-level="0">
                        <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = "/" })" class="tree-link">
                            <i data-lucide="@(currentPath == "/" ? "folder-open" : "folder")" class="tree-icon"></i>
                            <span class="tree-text">根目錄</span>
                        </a>
                    </div>
                    
                    <!-- 目錄樹 -->
                    @for (int i = 0; i < tree.Count; i++)
                    {
                        var (name, path, depth) = tree[i];
                        var isActive = currentPath == path;
                        var isRootChild = depth <= 1;
                        var hasChildren = i < tree.Count - 1 && tree.Skip(i + 1).Any(t => t.Depth > depth && t.VirtualPath.StartsWith(path + "/"));
                        
                        <div class="tree-item @(isRootChild ? "" : "hidden")" data-level="@depth" data-path="@path">
                            <div class="tree-content" style="padding-left: @(depth * 1.5)rem;">
                                @if (hasChildren)
                                {
                                    <button type="button" class="tree-toggle" onclick="toggleTreeNode(event, this)" title="展開/收合">
                                        <i data-lucide="chevron-right" class="tree-chevron"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="tree-spacer"></span>
                                }
                                <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = path })" class="tree-link @(isActive ? "active" : "")">
                                    <i data-lucide="@(isActive ? "folder-open" : "folder")" class="tree-icon"></i>
                                    <span class="tree-text">@name</span>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Dropzone 上傳區 -->
            <div class="p-3">
                <div id="dropZone" class="border border-2 rounded-3 p-4 text-center" style="border-style: dashed; cursor: pointer;" onclick="$('#fileInput').trigger('click')">
                    <i data-lucide="upload-cloud" class="text-muted d-block mx-auto mb-2" style="width:2rem;height:2rem;"></i>
                    <p class="small fw-semibold text-muted mb-1">拖曳檔案或資料夾到這裡上傳</p>
                    <p class="small text-muted">或點擊選擇檔案</p>
                </div>
            </div>

            <!-- 隱藏的檔案輸入 -->
            <input type="file" id="fileInput" multiple class="d-none">

            <!-- 檔案列表 -->
            <div class="p-3">
                <table id="filesTable" class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>類型</th>
                            <th>名稱</th>
                            <th>大小</th>
                            <th>擁有者</th>
                            <th>共享狀態</th>
                            <th>修改時間</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var folder in folders)
                        {
                            var name = folder.Name;
                            var owner = folder.Owner;
                            var sharedUsers = folder.SharedUsers;
                            var modified = folder.UpdatedAt;
                            var folderPath = currentPath == "/" ? "/" + name : currentPath + "/" + name;
                            var isOwner = owner == currentUser;
                            var sharedCount = sharedUsers?.Count ?? 0;
                            var modifiedTimestamp = modified.ToString("yyyy-MM-dd HH:mm:ss");

                            <tr onclick="window.location.href='@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = folderPath })'">
                                <td data-order="0">
                                    <i data-lucide="folder" class="text-warning" style="width:1rem;height:1rem;"></i>
                                </td>
                                <td class="fw-semibold">@name</td>
                                <td data-order="0">—</td>
                                <td>
                                    @if (sharedUsers != null && sharedUsers.Count > 0)
                                    {
                                        foreach (var sharedOwner in sharedUsers)
                                        {
                                            <span class="badge bg-primary me-1">@sharedOwner</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">未設定</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var sharedIcon = sharedCount > 1 ? "users" : (sharedCount == 1 ? "lock" : "");
                                        var sharedText = sharedCount > 1 ? $"共享 ({sharedCount}人)" : (sharedCount == 1 ? "私有" : "—");
                                    }
                                    <span class="badge rounded-pill bg-light text-muted @(sharedCount > 0 ? "" : "opacity-75")">
                                        <i data-lucide="@sharedIcon" class="@(sharedCount > 0 ? "" : "d-none")" style="width:0.8rem;height:0.8rem;"></i> @sharedText
                                    </span>
                                </td>
                                <td data-order="@modifiedTimestamp">@(modified.ToString("yyyy/MM/dd HH:mm"))</td>
                                <td class="text-end">
                                    <button onclick="openItemMenu(event, 'folder', '@(name?.Replace("'", "\\'").Replace("\"", "&quot;") ?? "")', '@currentPath')"
                                            class="btn btn-light btn-sm" title="更多">
                                        <i data-lucide="more-vertical" class="text-muted" style="width:1rem;height:1rem;"></i>
                                    </button>
                                </td>
                            </tr>
                        }

                        @foreach (var file in files)
                        {
                            var name = file.Name;
                            var size = file.Size ?? 0L;
                            var mimeType = file.MimeType;
                            var owner = file.Owner;
                            var sharedUsers = file.SharedUsers;
                            var modified = file.UpdatedAt;
                            var isOwner = owner == currentUser;
                            var sharedCount = sharedUsers?.Count ?? 0;
                            var modifiedTimestamp = modified.ToString("yyyy-MM-dd HH:mm:ss");

                            <tr onclick="openFile('@(name?.Replace("'", "\\'").Replace("\"", "&quot;") ?? "")')">
                                <td data-order="1">
                                    <i data-lucide="file" class="text-muted" style="width:1rem;height:1rem;"></i>
                                </td>
                                <td>@name</td>
                                <td data-order="@size">@FormatSize(size)</td>
                                <td>
                                    @if (sharedUsers != null && sharedUsers.Count > 0)
                                    {
                                        foreach (var sharedOwner in sharedUsers)
                                        {
                                            <span class="badge bg-primary me-1">@sharedOwner</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">未設定</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var sharedIconF = sharedCount > 1 ? "users" : (sharedCount == 1 ? "lock" : "");
                                        var sharedTextF = sharedCount > 1 ? $"共享 ({sharedCount}人)" : (sharedCount == 1 ? "私有" : "—");
                                    }
                                    <span class="badge rounded-pill bg-light text-muted @(sharedCount > 0 ? "" : "opacity-75")">
                                        <i data-lucide="@sharedIconF" class="@(sharedCount > 0 ? "" : "d-none")" style="width:0.8rem;height:0.8rem;"></i> @sharedTextF
                                    </span>
                                </td>
                                <td data-order="@modifiedTimestamp">@(modified.ToString("yyyy/MM/dd HH:mm"))</td>
                                <td class="text-end">
                                    <button onclick="openItemMenu(event, 'file', '@(name?.Replace("'", "\\'").Replace("\"", "&quot;") ?? "")', '@currentPath')"
                                            class="btn btn-light btn-sm" title="更多">
                                        <i data-lucide="more-vertical" class="text-muted" style="width:1rem;height:1rem;"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@functions {
    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<!-- 引入所有 Modal 視圖 -->
@await Html.PartialAsync("_FileManagerModal")

<div id="fileManagerModalHost"></div>

<link rel="stylesheet" href="~/Backoffice/css/FileManager.css">
<script src="~/Backoffice/js/FileManager.js"></script>
<script>
    $(function(){
        if ($('#filesTable').length) {
            HNBDataTable.init('#filesTable', {
                initComplete: function() {
                    $('.dataTables_length').hide();
                }
            });
        }
    });
</script>