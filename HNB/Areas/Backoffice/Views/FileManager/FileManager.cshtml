@{
    ViewData["Title"] = "檔案總管 - 後台管理系統";
    ViewData["PageTitle"] = "檔案總管 - 後台管理系統";
    ViewData["PageDescription"] = "管理後端檔案與資料夾";
    ViewData["PageIcon"] = "folder-tree";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}


<section class="space-y-6">
    <form id="fmTokens">@Html.AntiForgeryToken()</form>

    <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 bg-white border rounded-xl p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                <!-- 左側資料夾樹 -->
                <aside class="col-span-12 md:col-span-3 md:sticky md:top-2 bg-white border rounded-lg p-4 space-y-3 order-1">
                    <div class="flex items-center justify-between">
                        <h3 class="text-sm font-semibold flex items-center gap-1">
                            <i data-lucide="folders" class="w-4 h-4"></i> 資料夾
                        </h3>
                        <div class="flex gap-1">
                            <button onclick="showFileManagerHelp()" class="p-1.5 rounded hover:bg-slate-100"
                                    title="說明">
                                <i data-lucide="help-circle" class="w-4 h-4"></i>
                            </button>
                            <button onclick="showFolderAdd()" class="p-1.5 rounded hover:bg-slate-100"
                                    title="新增資料夾">
                                <i data-lucide="folder-plus" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                    <ul id="tree" class="space-y-1 text-sm">
                        @foreach (var (name, path, depth) in (List<(string Name, string VirtualPath, int Depth)>)ViewData["Tree"])
                        {
                            <li style="padding-left: @(depth * 16)px">
                                <a href="@Url.Action("FileManager")?path=@Uri.EscapeDataString(path)" 
                                   class="flex items-center space-x-2 hover:bg-slate-100 p-1 rounded @(path == ViewData["CurrentPath"] ? "bg-blue-50 text-blue-600" : "")">
                                    <i data-lucide="@(depth == 0 ? "home" : "folder")" class="w-4 h-4"></i>
                                    <span>@name</span>
                                </a>
                            </li>
                        }
                    </ul>
                </aside>

                <!-- 右側檔案清單 -->
                <main class="col-span-12 md:col-span-9 bg-white border rounded-lg p-4 space-y-6 order-2">
                    
                    <!-- 麵包屑導航 -->
                    <nav class="flex items-center space-x-2 text-sm text-gray-600">
                        <a href="@Url.Action("FileManager")" class="hover:text-blue-600">
                            <i data-lucide="home" class="w-4 h-4"></i>
                        </a>
                        @foreach (var (name, path) in (List<(string Name, string VirtualPath)>)ViewData["Breadcrumb"])
                        {
                            <i data-lucide="chevron-right" class="w-4 h-4 text-gray-400"></i>
                            if (path == ViewData["CurrentPath"])
                            {
                                <span class="text-gray-900 font-medium">@name</span>
                            }
                            else
                            {
                                <a href="@Url.Action("FileManager")?path=@Uri.EscapeDataString(path)" class="hover:text-blue-600">@name</a>
                            }
                        }
                    </nav>

                    <!-- 拖曳上傳 -->
                    <form id="uploadForm" class="space-y-2" onsubmit="return false;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="path" id="uploadPath" value="/" />

                        <!-- 拖曳/點擊區 -->
                        <div id="dropzone" class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:bg-slate-50 cursor-pointer transition">
                            <i data-lucide="upload-cloud" class="w-10 h-10 mx-auto text-slate-400"></i>
                            <p class="mt-2 text-sm text-slate-600">
                                拖曳檔案到這裡，或
                                <label for="fileInput" class="text-blue-600 cursor-pointer hover:underline">點擊上傳</label>
                            </p>
                            <input id="fileInput" name="files" type="file" class="hidden" multiple />
                        </div>

                        <!-- 重新整理 -->
                        <div class="flex items-center gap-3">
                            <button id="btnRefresh" class="text-sm text-gray-600 hover:text-gray-800" type="button" onclick="location.reload()">
                                重新整理
                            </button>
                        </div>
                    </form>

                    <!-- 資料夾清單 -->
                    @if (((List<(string Name, DateTime? LastWriteUtc)>)ViewData["Folders"]).Any())
                    {
                        <div class="space-y-2">
                            <h4 class="text-sm font-semibold text-slate-700 flex items-center">
                                <i data-lucide="folder" class="w-4 h-4 mr-2"></i>資料夾
                            </h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
                                @foreach (var (name, lastWrite) in (List<(string Name, DateTime? LastWriteUtc)>)ViewData["Folders"])
                                {
                                    <div class="flex items-center space-x-3 p-3 border rounded-lg hover:bg-slate-50">
                                        <i data-lucide="folder" class="w-5 h-5 text-blue-500"></i>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-slate-900 truncate">@name</p>
                                            @if (lastWrite.HasValue)
                                            {
                                                <p class="text-xs text-slate-500">@lastWrite.Value.ToString("yyyy-MM-dd HH:mm")</p>
                                            }
                                        </div>
                                            <div class="flex space-x-1">
                                                <button onclick="showRename('@name', 'folder', currentPath)" class="p-1 text-slate-400 hover:text-slate-600" title="重新命名">
                                                    <i data-lucide="edit" class="w-4 h-4"></i>
                                                </button>
                                                <button onclick="showDeleteConfirm('@name', 'folder', currentPath)" class="p-1 text-slate-400 hover:text-red-600" title="刪除">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                        <!-- 檔案清單 -->
                        @if (((List<HNB.Areas.Backoffice.Services.FileItemViewModel>)ViewData["Files"]).Any())
                        {
                            <div class="space-y-2">
                                <h4 class="text-sm font-semibold text-slate-700 flex items-center">
                                    <i data-lucide="file" class="w-4 h-4 mr-2"></i>檔案
                                </h4>
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
                                    @foreach (var file in (List<HNB.Areas.Backoffice.Services.FileItemViewModel>)ViewData["Files"])
                                    {
                                        <div class="flex items-center space-x-3 p-3 border rounded-lg hover:bg-slate-50">
                                            <i data-lucide="file" class="w-5 h-5 text-slate-500"></i>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-sm font-medium text-slate-900 truncate">@file.Name</p>
                                                <p class="text-xs text-slate-500">
                                                    @if (file.LastWriteUtc.HasValue)
                                                    {
                                                        @file.LastWriteUtc.Value.ToString("yyyy-MM-dd HH:mm")
                                                    }
                                                    • @file.FormattedSize
                                                </p>
                                            </div>
                                            <div class="flex space-x-1">
                                                <button onclick="showFilePreview('@file.Name')" class="p-1 text-slate-400 hover:text-blue-600" title="預覽">
                                                    <i data-lucide="eye" class="w-4 h-4"></i>
                                                </button>
                                                <button onclick="showRename('@file.Name', 'file', currentPath)" class="p-1 text-slate-400 hover:text-slate-600" title="重新命名">
                                                    <i data-lucide="edit" class="w-4 h-4"></i>
                                                </button>
                                                <button onclick="showDeleteConfirm('@file.Name', 'file', currentPath)" class="p-1 text-slate-400 hover:text-red-600" title="刪除">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                </main>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
// 全域變數
let currentPath = '@ViewData["CurrentPath"]';

// 簡化的檔案管理器功能
function initFileManager() {
    // 拖拽上傳功能
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('fileInput');
    
    if (dropzone && fileInput) {
        dropzone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('border-blue-400', 'bg-blue-50');
        });

        dropzone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            dropzone.classList.remove('border-blue-400', 'bg-blue-50');
        });

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('border-blue-400', 'bg-blue-50');
            const files = Array.from(e.dataTransfer.files);
            handleFileUpload(files);
        });

        dropzone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', (e) => {
            const files = Array.from(e.target.files);
            handleFileUpload(files);
        });
    }
}

async function handleFileUpload(files) {
    if (files.length === 0) return;

    const formData = new FormData();
    formData.append('path', currentPath);
    files.forEach(file => formData.append('files', file));

    try {
        const response = await fetch('@Url.Action("UploadMany", "FileManager")', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: formData
        });

        const result = await response.json();
        if (result.ok) {
            showToast(`成功上傳 ${result.data.uploadedCount} 個檔案`, 'success');
            location.reload();
        } else {
            showToast('上傳失敗：' + result.error, 'error');
        }
    } catch (error) {
        showToast('上傳失敗：' + error.message, 'error');
    }
}

function showToast(message, type = 'info') {
    const toast = document.createElement('div');
    toast.className = `fixed top-4 right-4 px-6 py-3 rounded-lg shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500 text-white' : 
        type === 'error' ? 'bg-red-500 text-white' : 
        'bg-blue-500 text-white'
    }`;
    toast.textContent = message;
    
    document.body.appendChild(toast);
    setTimeout(() => {
        toast.remove();
    }, 3000);
}

// 檔案操作函數
function showFilePreview(fileName) {
    window.open('@Url.Action("Raw", "FileManager")?name=' + encodeURIComponent(fileName) + '&path=' + encodeURIComponent(currentPath), '_blank');
}


// Modal 相關函數
function showFileManagerHelp() {
    $('#fileManagerHelpModal').removeClass('hidden');
}

function showFolderAdd() {
    $('#folderFormModal').removeClass('hidden');
}


function closeModal(modalId) {
    $('#' + modalId).addClass('hidden');
}

// 表單提交處理
$(document).on('submit', '#folderForm', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    formData.append('path', currentPath);
    
    $.ajax({
        url: '@Url.Action("CreateFolder", "FileManager")',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function(response) {
            if (response.ok) {
                showToast('資料夾建立成功', 'success');
                closeModal('folderFormModal');
                location.reload();
            } else {
                showToast('建立失敗：' + response.error, 'error');
            }
        },
        error: function(xhr, status, error) {
            showToast('建立失敗：' + error, 'error');
        }
    });
});

// 初始化
document.addEventListener('DOMContentLoaded', function() {
    lucide.createIcons();
    initFileManager();
});
</script>

<!-- 載入所有Modal -->
@await Html.PartialAsync("_HelpDetail")
}