@model List<Models.HnbHnbBackoffice.vw_file_manager>
@{
    ViewData["Title"] = "檔案總管";
    ViewData["PageTitle"] = "檔案總管";
    ViewData["PageDescription"] = "管理檔案和資料夾、上傳下載、預覽編輯";
    ViewData["PageIcon"] = "folder";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
    
    var currentParentCode = ViewBag.CurrentParentCode as string;
    var currentFolder = ViewBag.CurrentFolder as Models.HnbHnbBackoffice.vw_file_manager;
    var allFolders = ViewBag.AllFolders as List<Models.HnbHnbBackoffice.vw_file_manager> ?? new();
    
    var folders = Model.Where(f => f.item_type == "folder").ToList();
    var files = Model.Where(f => f.item_type == "file").ToList();
}

<link rel="stylesheet" href="~/Backoffice/css/FileManager.css" asp-append-version="true">

<div class="flex flex-col lg:flex-row gap-0">
    <!-- 左側：目錄樹 -->
    <aside class="w-full lg:w-64 bg-white border-r border-slate-200 flex flex-col lg:max-h-screen">
        <!-- 標題列 -->
        <div class="h-12 px-3 flex items-center justify-between border-b border-slate-200">
            <span class="text-xs lg:text-sm font-medium text-slate-900">檔案總管</span>
            <div class="flex items-center gap-0.5">
                <button onclick="event.stopPropagation(); showModal('filemanager-help')" class="w-7 h-7 flex items-center justify-center hover:bg-slate-100 rounded" title="操作說明">
                    <i data-lucide="help-circle" class="h-3 w-3 lg:h-4 lg:w-4 text-slate-600"></i>
                </button>
                <button onclick="showCreateFileModal()" class="w-7 h-7 flex items-center justify-center hover:bg-slate-100 rounded" title="新增檔案">
                    <i data-lucide="file-plus" class="h-3 w-3 lg:h-4 lg:w-4 text-slate-600"></i>
                </button>
                <button onclick="showCreateFolderModal()" class="w-7 h-7 flex items-center justify-center hover:bg-slate-100 rounded" title="新增資料夾">
                    <i data-lucide="folder-plus" class="h-3 w-3 lg:h-4 lg:w-4 text-slate-600"></i>
                </button>
                <button onclick="location.reload()" class="w-7 h-7 flex items-center justify-center hover:bg-slate-100 rounded" title="重新整理">
                    <i data-lucide="refresh-cw" class="h-3 w-3 lg:h-4 lg:w-4 text-slate-600"></i>
                </button>
            </div>
        </div>
        
        <!-- 目錄樹 -->
        <div class="flex-1 overflow-y-auto py-2 max-h-60 lg:max-h-none">
            <!-- 根目錄 -->
            <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice" })" 
               class="flex items-center gap-1.5 px-3 py-1.5 hover:bg-slate-50 cursor-pointer @(string.IsNullOrEmpty(currentParentCode) ? "bg-slate-100" : "")">
                <i data-lucide="@(string.IsNullOrEmpty(currentParentCode) ? "folder-open" : "folder")" class="h-4 w-4 text-amber-500"></i>
                <span class="text-sm @(string.IsNullOrEmpty(currentParentCode) ? "font-medium text-slate-900" : "text-slate-700")">根目錄</span>
            </a>
            
            @if (allFolders != null && allFolders.Any())
            {
                @foreach (var folder1 in allFolders.Where(f => string.IsNullOrEmpty(f.parent_code)))
                {
                    var children1 = allFolders.Where(f => f.parent_code == folder1.code).ToList();
                    var hasChildren1 = children1.Any();
                    var isActive1 = currentParentCode == folder1.code;
                    var isInPath1 = IsInPath(folder1.code, currentParentCode, allFolders);
                    var isExpanded1 = isActive1 || isInPath1;
                    
                    <div class="tree-folder" data-code="@folder1.code">
                        <div class="flex items-center gap-1.5 px-3 py-1.5 hover:bg-slate-50 @(isActive1 ? "bg-slate-100" : "")" style="padding-left: 0.75rem">
                            @if (hasChildren1)
                            {
                                <button onclick="toggleTreeFolder(event, '@folder1.code')" class="w-4 h-4 flex-shrink-0 hover:bg-slate-200 rounded tree-toggle">
                                    <i data-lucide="chevron-right" class="h-4 w-4 text-slate-600 tree-chevron @(isExpanded1 ? "rotate-90" : "")"></i>
                                </button>
                            }
                            else
                            {
                                <span class="w-4"></span>
                            }
                            <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", parentCode = folder1.code })" 
                               class="flex items-center gap-1.5 flex-1 min-w-0">
                                <i data-lucide="@(isActive1 ? "folder-open" : "folder")" class="h-4 w-4 text-amber-500"></i>
                                <span class="text-sm truncate @(isActive1 ? "font-medium text-slate-900" : "text-slate-700")">@folder1.file_name</span>
                            </a>
                        </div>
                        
                        @if (hasChildren1)
                        {
                            <div class="tree-children @(isExpanded1 ? "" : "hidden")">
                                @foreach (var folder2 in children1)
                                {
                                    var children2 = allFolders.Where(f => f.parent_code == folder2.code).ToList();
                                    var hasChildren2 = children2.Any();
                                    var isActive2 = currentParentCode == folder2.code;
                                    var isInPath2 = IsInPath(folder2.code, currentParentCode, allFolders);
                                    var isExpanded2 = isActive2 || isInPath2;
                                    
                                    <div class="tree-folder" data-code="@folder2.code">
                                        <div class="flex items-center gap-1.5 px-3 py-1.5 hover:bg-slate-50 @(isActive2 ? "bg-slate-100" : "")" style="padding-left: 1.25rem">
                                            @if (hasChildren2)
                                            {
                                                <button onclick="toggleTreeFolder(event, '@folder2.code')" class="w-4 h-4 flex-shrink-0 hover:bg-slate-200 rounded tree-toggle">
                                                    <i data-lucide="chevron-right" class="h-4 w-4 text-slate-600 tree-chevron @(isExpanded2 ? "rotate-90" : "")"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="w-4"></span>
                                            }
                                            <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", parentCode = folder2.code })" 
                                               class="flex items-center gap-1.5 flex-1 min-w-0">
                                                <i data-lucide="@(isActive2 ? "folder-open" : "folder")" class="h-4 w-4 text-amber-500"></i>
                                                <span class="text-sm truncate @(isActive2 ? "font-medium text-slate-900" : "text-slate-700")">@folder2.file_name</span>
                                            </a>
                                        </div>
                                        
                                        @if (hasChildren2)
                                        {
                                            <div class="tree-children @(isExpanded2 ? "" : "hidden")">
                                                @foreach (var folder3 in children2)
                                                {
                                                    var isActive3 = currentParentCode == folder3.code;
                                                    
                                                    <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", parentCode = folder3.code })" 
                                                       class="flex items-center gap-1.5 px-3 py-1.5 hover:bg-slate-50 @(isActive3 ? "bg-slate-100" : "")" style="padding-left: 1.75rem">
                                                        <span class="w-4"></span>
                                                        <i data-lucide="folder" class="h-4 w-4 text-amber-500"></i>
                                                        <span class="text-sm truncate @(isActive3 ? "font-medium text-slate-900" : "text-slate-700")">@folder3.file_name</span>
                                                    </a>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </aside>

    <!-- 右側：內容區 -->
    <div class="flex-1 flex flex-col bg-white min-w-0">
        <!-- 頂部導航列 -->
        <div class="h-12 px-3 lg:px-6 flex items-center justify-between border-b border-slate-200">
            <!-- 麵包屑 -->
            <nav class="flex items-center gap-1 text-xs lg:text-sm overflow-x-auto">
                <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice" })" 
                   class="px-2 py-1 hover:bg-slate-100 rounded @(string.IsNullOrEmpty(currentParentCode) ? "font-medium text-slate-900" : "text-slate-700")">
                    根目錄
                </a>
                @if (currentFolder != null)
                {
                    <i data-lucide="chevron-right" class="h-4 w-4 text-slate-400"></i>
                    <span class="px-2 py-1 font-medium text-slate-900">@currentFolder.file_name</span>
                }
            </nav>
            
            <!-- 統計資訊 -->
            <div class="text-xs text-slate-500 hidden lg:block whitespace-nowrap">
                @folders.Count 個資料夾 · @files.Count 個檔案 · @FormatSize(files.Sum(f => f.file_size ?? 0))
            </div>
        </div>

        <!-- Dropzone 上傳區 -->
        <div class="mx-3 lg:mx-6 mt-4">
            <div id="dropZone" class="border-2 border-dashed border-slate-300 rounded-lg px-4 lg:px-6 py-6 lg:py-8 text-center hover:border-slate-400 hover:bg-slate-50/50 cursor-pointer group"
                 onclick="document.getElementById('fileInput').click()">
                <i data-lucide="upload-cloud" class="h-8 w-8 lg:h-10 lg:w-10 mx-auto mb-2 lg:mb-3 text-slate-400 group-hover:text-slate-500"></i>
                <p class="text-xs lg:text-sm font-medium text-slate-700 mb-1">拖曳檔案或資料夾到這裡上傳</p>
                <p class="text-xs text-slate-500">或點擊選擇檔案</p>
            </div>
        </div>
        
        <!-- 隱藏的檔案輸入 -->
        <input type="file" id="fileInput" multiple class="hidden">

        <!-- 檔案列表 -->
        <div class="flex-1 overflow-y-auto px-3 lg:px-6 py-4">
            <!-- 表格標題 -->
            <div class="hidden lg:grid grid-cols-[2fr_140px_140px_180px_120px] gap-4 px-3 py-2 text-xs font-medium text-slate-500 border-b border-slate-200">
                <div>名稱</div>
                <div>擁有者</div>
                <div>大小</div>
                <div>修改時間</div>
                <div class="text-right">操作</div>
            </div>

            <!-- 檔案項目 -->
            <div class="divide-y divide-slate-100">
                @if (!folders.Any() && !files.Any())
                {
                    <!-- 空狀態 -->
                    <div class="py-16 text-center">
                        <i data-lucide="folder-open" class="h-16 w-16 mx-auto mb-3 text-slate-300"></i>
                        <p class="text-sm text-slate-500">此資料夾是空的</p>
                    </div>
                }
                else
                {
                    <!-- 資料夾列表 -->
                    @if (folders.Any())
                    {
                        @foreach (var folder in folders)
                        {
                            <div onclick="window.location.href='@Url.Action("FileManager", "FileManager", new { area = "Backoffice", parentCode = folder.code })'" 
                                 class="grid grid-cols-1 lg:grid-cols-[2fr_140px_140px_180px_120px] gap-2 lg:gap-4 px-3 py-3 hover:bg-slate-50 cursor-pointer group rounded-lg">
                                <div class="flex items-center gap-3 min-w-0">
                                    <i data-lucide="folder" class="h-5 w-5 text-amber-500 shrink-0"></i>
                                    <span class="text-sm text-slate-900 truncate flex-1">@folder.file_name</span>
                                    <div class="flex items-center gap-1 lg:hidden">
                                        <button onclick="event.preventDefault(); event.stopPropagation(); showRenameModal('@folder.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")', 'folder')" 
                                                class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="重新命名">
                                            <i data-lucide="edit-3" class="h-4 w-4 text-slate-600"></i>
                                        </button>
                                        <button onclick="event.preventDefault(); event.stopPropagation(); deleteItem('@folder.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")', 'folder')" 
                                                class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="刪除">
                                            <i data-lucide="trash-2" class="h-4 w-4 text-slate-600"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="text-xs lg:text-sm text-slate-600 hidden lg:block truncate">@folder.owner_username</div>
                                <div class="text-xs lg:text-sm text-slate-600 hidden lg:block">—</div>
                                <div class="text-xs lg:text-sm text-slate-600 hidden lg:block">@(folder.created_at.HasValue ? folder.created_at.Value.ToString("yyyy/MM/dd HH:mm") : "—")</div>
                                <div class="hidden lg:flex items-center justify-end gap-1">
                                    <button onclick="event.preventDefault(); event.stopPropagation(); showRenameModal('@folder.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")', 'folder')" 
                                            class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="重新命名">
                                        <i data-lucide="edit-3" class="h-4 w-4 text-slate-600"></i>
                                    </button>
                                    <button onclick="event.preventDefault(); event.stopPropagation(); deleteItem('@folder.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")', 'folder')" 
                                            class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="刪除">
                                        <i data-lucide="trash-2" class="h-4 w-4 text-slate-600"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    
                    <!-- 檔案列表 -->
                    @if (files.Any())
                    {
                        @foreach (var file in files)
                        {
                            <div onclick="openFile('@file.code', '@file.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")')" 
                                 class="grid grid-cols-[2fr_140px_140px_180px_120px] gap-4 px-3 py-3 hover:bg-slate-50 cursor-pointer group rounded-lg items-center">
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="w-5 h-5 shrink-0"></div>
                                    <span class="text-sm text-slate-900 truncate">@file.file_name</span>
                                </div>
                                <div class="text-sm text-slate-600 truncate">@file.owner_username</div>
                                <div class="text-sm text-slate-600">@FormatSize(file.file_size ?? 0)</div>
                                <div class="text-sm text-slate-600">@(file.created_at.HasValue ? file.created_at.Value.ToString("yyyy/MM/dd HH:mm") : "—")</div>
                                <div class="flex items-center justify-end gap-1">
                                    <button onclick="event.preventDefault(); event.stopPropagation(); showRenameModal('@file.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")', 'file')" 
                                            class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="重新命名">
                                        <i data-lucide="edit-3" class="h-4 w-4 text-slate-600"></i>
                                    </button>
                                    <a href="@Url.Action("Download", "FileManager", new { area = "Backoffice", code = file.code })" 
                                       onclick="event.stopPropagation()"
                                       class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="下載">
                                        <i data-lucide="download" class="h-4 w-4 text-slate-600"></i>
                                    </a>
                                    <button onclick="event.preventDefault(); event.stopPropagation(); deleteItem('@file.file_name?.Replace("'", "\\'").Replace("\"", "&quot;")', 'file')" 
                                            class="w-8 h-8 flex items-center justify-center hover:bg-slate-200 rounded" title="刪除">
                                        <i data-lucide="trash-2" class="h-4 w-4 text-slate-600"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    bool IsInPath(string? folderCode, string? targetCode, List<Models.HnbHnbBackoffice.vw_file_manager> allFolders)
    {
        if (string.IsNullOrEmpty(targetCode) || string.IsNullOrEmpty(folderCode)) return false;
        
        var current = allFolders.FirstOrDefault(f => f.code == targetCode);
        while (current != null)
        {
            if (current.parent_code == folderCode) return true;
            current = allFolders.FirstOrDefault(f => f.code == current.parent_code);
        }
        
        return false;
    }
}

@await Html.PartialAsync("_FileManagerModal")

<script src="~/Backoffice/js/FileManager.js"></script>
