@model HNB.Areas.Backoffice.Dtos.FileSystemEntry
@{
    Layout = null;
    var isFile = Model?.Type == "file";
    var currentUser = ViewBag.CurrentUser as string ?? "";
    var isOwnerStr = ((Model?.PrimaryOwner ?? "") == currentUser) ? "true" : "false";
    var locationPath = Model?.VirtualPath ?? (ViewBag.CurrentPath as string ?? "/");
    var sharedUsers = Model?.SharedUsers ?? new List<string>();
    var primaryOwner = Model?.PrimaryOwner ?? "";
    var sharedOthers = sharedUsers.Where(u => u != (Model?.PrimaryOwner ?? "")).ToList();
}

<div class="vstack gap-3" id="sidePanelRoot" data-is-owner="@isOwnerStr">
    <div>
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h6 class="fw-semibold mb-0">基本資訊</h6>
            @{
                var downloadUrl = isFile 
                    ? Url.Action("Download", "FileManager", new { area = "Backoffice", path = locationPath, name = Model?.Name })
                    : Url.Action("DownloadFolder", "FileManager", new { area = "Backoffice", path = locationPath, name = Model?.Name });
            }
            <a href="@downloadUrl" class="btn btn-link btn-sm p-0" title="下載">
                <i data-lucide="download" style="width:1rem;height:1rem;"></i>
            </a>
        </div>
        <table class="table table-bordered table-sm mb-0">
            <tbody>
                <tr>
                    <th style="width: 150px;">類型</th>
                    <td>
                        <i data-lucide="@(isFile ? "file" : "folder")" style="width:1rem;height:1rem;"></i>
                        @(isFile ? "檔案" : "資料夾")
                    </td>
                </tr>
                <tr>
                    <th>名稱</th>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <input type="text" class="form-control form-control-sm" id="spNameInput" value="@(Model?.Name ?? "")" style="max-width: 60%;">
                            <button type="button" class="btn btn-sm btn-link p-0" id="btnSaveName" data-type="@(isFile ? "file" : "folder")" data-current-path="@locationPath" data-old-name="@(Model?.Name ?? "")" title="儲存名稱">
                                <i data-lucide="save" style="width:1rem;height:1rem;"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <th>位置</th>
                    <td class="small text-break">@locationPath</td>
                </tr>
                <tr>
                    <th>完整路徑</th>
                    <td class="small text-break">@(Model?.FullPath ?? "—")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div>
        <h6 class="fw-semibold mb-2">容量與內容</h6>
        <table class="table table-bordered table-sm mb-0">
            <tbody>
                @if (isFile)
                {
                    <tr>
                        <th style="width: 150px;">大小</th>
                        <td>@(Model?.FormattedSize ?? (Model?.Size?.ToString() ?? "—"))</td>
                    </tr>
                    <tr>
                        <th>檔案類型</th>
                        <td>@(Model?.MimeType ?? "—")</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <th style="width: 150px;">包含</th>
                        <td>—</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div>
        <h6 class="fw-semibold mb-2">時間</h6>
        <table class="table table-bordered table-sm mb-0">
            <tbody>
                <tr>
                    <th style="width: 150px;">建立時間</th>
                    <td>@(Model?.CreatedAt?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</td>
                </tr>
                <tr>
                    <th>修改時間</th>
                    <td>@(Model?.UpdatedAt?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</td>
                </tr>
                <tr>
                    <th>最近存取</th>
                    <td>@(Model?.LastWriteUtc?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div>
        <h6 class="fw-semibold mb-2">擁有權與分享</h6>
        <table class="table table-bordered table-sm mb-0">
            <tbody>
                <tr>
                    <th style="width: 150px;">原擁有者</th>
                    <td>@(Model?.PrimaryOwner ?? "—")</td>
                </tr>
                <tr>
                    <th>擁有者</th>
                    <td>
                        @foreach (var user in sharedUsers)
                        {
                            <span class="badge bg-primary me-1">@user</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>共享對象</th>
                    <td>
                        <div class="d-flex align-items-start gap-2">
                            <div class="flex-grow-1">
                                <div id="shareSelected" class="d-flex flex-wrap gap-1 mb-1">
                                    @foreach (var u in sharedOthers)
                                    {
                                        <span class="badge bg-primary share-badge" data-user="@u" data-is-primary="false">
                                            @u 
                                            <button type="button" class="btn btn-sm btn-link text-white p-0 ms-1 remove-share" data-user="@u" style="font-size:1.2em; line-height:1;">×</button>
                                        </span>
                                    }
                                </div>
                                <input type="text" class="form-control form-control-sm" id="shareEditor" placeholder="輸入使用者，逗號分隔" autocomplete="off">
                            </div>
                            <button type="button" class="btn btn-sm btn-link p-0 align-self-start" id="btnSaveShare" data-item-name="@(Model?.Name ?? "")" data-current-path="@(ViewBag.CurrentPath as string ?? "/")" data-primary-owner="@(Model?.PrimaryOwner ?? "")" title="儲存變更">
                                <i data-lucide="save" style="width:1rem;height:1rem;"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div>
        <h6 class="fw-semibold mb-2">檔案屬性</h6>
        <table class="table table-bordered table-sm mb-0">
            <tbody>
                <tr>
                    <th style="width: 150px;">MIME 類型</th>
                    <td>@(Model?.MimeType ?? "—")</td>
                </tr>
                <tr>
                    <th>只讀/隱藏/系統</th>
                    <td>— / — / —</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="mt-2">
        <div class="d-flex justify-content-end">
            <button type="button" class="btn bg-white btn-sm p-0 d-inline-flex align-items-center justify-content-center w-100 border border-secondary" onclick="deleteItem('@(Model?.Name?.Replace("'", "\\'") ?? "")', '@(isFile ? "file" : "folder")', '@locationPath')" style="height:35px;" title="刪除">
                <i data-lucide="trash-2" style="width:1rem;height:1rem;"></i>
            </button>
        </div>
    </div>
</div>


