@model HNB.Areas.Backoffice.Dtos.FileSystemEntry
@{
    var detail = Model;
    var isFile = detail?.Type == "file";
    var sharedCount = detail?.SharedUsers?.Count ?? 0;
    var sharedStatus = sharedCount > 1 ? $"共享 ({sharedCount}人)" : (sharedCount == 1 ? "私有" : "未設定");
    var currentUser = ViewBag.CurrentUser as string ?? "";
    var isOwner = detail != null && (detail?.PrimaryOwner ?? "") == currentUser;
    var locationPath = detail?.VirtualPath ?? (ViewBag.CurrentPath as string ?? "/");
}

<div class="vstack gap-2">
    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">類型</div>
        <div class="col">
            <i data-lucide="@((detail?.Type == "file") ? "file" : "folder")" style="width:1rem;height:1rem;"></i>
            @((detail?.Type == "file") ? "檔案" : "資料夾")
        </div>
    </div>

    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">名稱</div>
        <div class="col">@(detail?.Name ?? "—")</div>
    </div>

    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">位置</div>
        <div class="col small text-break">@locationPath</div>
    </div>

    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">完整路徑</div>
        <div class="col small text-break">@(detail?.FullPath ?? "—")</div>
    </div>

    @if ((detail?.Type == "file"))
    {
        <div class="row align-items-center">
            <div class="col-3 col-sm-2 text-muted small">大小</div>
            <div class="col">@(detail?.FormattedSize ?? (detail?.Size?.ToString() ?? "—"))</div>
        </div>
        <div class="row align-items-center">
            <div class="col-3 col-sm-2 text-muted small">檔案類型</div>
            <div class="col">@(detail?.MimeType ?? "—")</div>
        </div>
    }
    else
    {
        <div class="row align-items-center">
            <div class="col-3 col-sm-2 text-muted small">包含</div>
            <div class="col">—</div>
        </div>
    }

    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">擁有者</div>
        <div class="col">
            @{
                var owners = detail?.SharedUsers ?? new List<string>();
                if ((owners?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(detail?.PrimaryOwner))
                {
                    owners = new List<string> { detail!.PrimaryOwner };
                }
            }
            @if ((owners?.Count ?? 0) > 0)
            {
                foreach (var user in owners)
                {
                    <span class="badge bg-primary me-1">@user</span>
                }
            }
            else
            {
                <span class="text-muted">未設定</span>
            }
        </div>
    </div>

    <div class="row align-items-start">
        <div class="col-3 col-sm-2 text-muted small">共享對象</div>
        <div class="col">
            @if (isOwner)
            {
                <div class="d-flex align-items-start gap-2">
                    <div class="flex-grow-1">
                        <div id="shareSelected" class="d-flex flex-wrap gap-1">
                            @if (detail?.SharedUsers != null && detail.SharedUsers.Count > 0)
                            {
                                foreach (var u in detail.SharedUsers)
                                {
                                    var isPrimary = u == detail?.PrimaryOwner;
                                    <span class="badge bg-primary share-badge" data-user="@u" data-is-primary="@(isPrimary ? "true" : "false")">
                                        @u 
                                        @if (!isPrimary)
                                        {
                                            <button type="button" class="btn btn-sm btn-link text-white p-0 ms-1 remove-share" data-user="@u" style="font-size:1.2em; line-height:1;">×</button>
                                        }
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">尚未設定</span>
                            }
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-success align-self-start" id="btnSaveShare" data-item-name="@(detail?.Name ?? "")" data-current-path="@(ViewBag.CurrentPath as string ?? "/")" data-primary-owner="@(detail?.PrimaryOwner ?? "")" title="儲存變更">
                        <i data-lucide="check" style="width:1rem;height:1rem;"></i>
                    </button>
                </div>
            }
            else
            {
                <span>@sharedStatus</span>
            }
        </div>
    </div>

    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">建立時間</div>
        <div class="col">@(detail?.CreatedAt?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</div>
    </div>

    <div class="row align-items-center">
        <div class="col-3 col-sm-2 text-muted small">修改時間</div>
        <div class="col">@(detail?.UpdatedAt?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</div>
    </div>
</div>

