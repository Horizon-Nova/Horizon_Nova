@{
    Layout = null;
}

<!-- 說明Modal -->
<div id="fileManagerHelpModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4" onclick="closeModal('fileManagerHelpModal')">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-hidden" onclick="event.stopPropagation()">
        <!-- Header -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="folder-tree" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">檔案總管說明</h3>
                </div>
                <button onclick="closeModal('fileManagerHelpModal')" class="text-white hover:opacity-80 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        
        <!-- Content -->
        <div class="p-6 overflow-y-auto max-h-[calc(80vh-120px)]">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-blue-600"></i>基本操作
                    </h4>
                    <p class="text-sm text-slate-600 mb-4">檔案總管提供完整的檔案和資料夾管理功能。</p>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>上傳檔案</strong>：支援單一檔案和批量上傳</li>
                        <li>• <strong>建立資料夾</strong>：建立新的資料夾結構</li>
                        <li>• <strong>重新命名</strong>：重新命名檔案或資料夾</li>
                        <li>• <strong>刪除項目</strong>：刪除不需要的檔案或資料夾</li>
                        <li>• <strong>下載檔案</strong>：下載單一檔案或整個資料夾ZIP</li>
                        <li>• <strong>編輯文字</strong>：線上編輯文字檔案</li>
                    </ul>
                </div>
                
                <div class="bg-blue-50 rounded-lg p-4">
                    <h4 class="font-semibold text-blue-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-blue-700">
                        支援拖拽上傳、進度顯示、檔案預覽等進階功能。重要檔案和資料夾會受到保護。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 新增資料夾Modal -->
<div id="folderFormModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4" onclick="closeModal('folderFormModal')">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full" onclick="event.stopPropagation()">
        <!-- Header -->
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="folder-plus" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">新增資料夾</h3>
                </div>
                <button onclick="closeModal('folderFormModal')" class="text-white hover:opacity-80 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        
        <!-- Form -->
        <form id="folderForm" class="p-6">
            <div class="space-y-4">
                <div>
                    <label for="folderName" class="block text-sm font-semibold text-slate-700 mb-2">
                        資料夾名稱 <span class="text-red-500">*</span>
                    </label>
                    <input type="text" id="folderName" name="folderName" required
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"
                           placeholder="請輸入資料夾名稱">
                    <p class="text-xs text-slate-500 mt-1">僅限英文、數字、空白、.-_（不允許中文）</p>
                </div>
            </div>
            
            <div class="flex justify-end space-x-3 mt-6">
                <button type="button" onclick="closeModal('folderFormModal')" 
                        class="px-4 py-2 text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50">
                    取消
                </button>
                <button type="submit" 
                        class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
                    建立
                </button>
            </div>
        </form>
    </div>
</div>

<!-- 刪除確認Modal -->
<div id="deleteConfirmModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4" onclick="closeModal('deleteConfirmModal')">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full" onclick="event.stopPropagation()">
        <!-- Header -->
        <div class="bg-gradient-to-r from-red-600 to-red-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="trash-2" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">刪除確認</h3>
                </div>
                <button onclick="closeModal('deleteConfirmModal')" class="text-white hover:opacity-80 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        
        <!-- Content -->
        <div class="p-6">
            <div class="text-center mb-4">
                <i data-lucide="alert-triangle" class="w-12 h-12 text-red-500 mx-auto mb-3"></i>
                <p class="text-sm text-slate-600 mb-2">請輸入完整名稱以確認刪除：</p>
                <p class="font-semibold text-slate-800" id="deleteItemName"></p>
            </div>
            
            <div class="space-y-4">
                <div>
                    <input type="text" id="deleteConfirmInput" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500"
                           placeholder="請輸入完整名稱">
                    <input type="hidden" id="deleteItemType">
                    <input type="hidden" id="deleteItemPath">
                </div>
            </div>
            
            <div class="flex justify-end space-x-3 mt-6">
                <button type="button" onclick="closeModal('deleteConfirmModal')" 
                        class="px-4 py-2 text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50">
                    取消
                </button>
                <button type="button" id="btnDeleteConfirm" disabled
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50"
                        onclick="confirmDelete()">
                    刪除
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 重新命名Modal -->
<div id="renameModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4" onclick="closeModal('renameModal')">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full" onclick="event.stopPropagation()">
        <!-- Header -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <i data-lucide="edit-3" class="w-6 h-6"></i>
                    <h3 class="text-lg font-bold">重新命名</h3>
                </div>
                <button onclick="closeModal('renameModal')" class="text-white hover:opacity-80 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        
        <!-- Content -->
        <div class="p-6">
            <div class="text-center mb-4">
                <i data-lucide="edit" class="w-12 h-12 text-blue-500 mx-auto mb-3"></i>
                <p class="text-sm text-slate-600 mb-2">請輸入新名稱：</p>
                <p class="text-xs text-slate-500">不允許 \ / : * ? " < > |</p>
            </div>
            
            <div class="space-y-4">
                <div>
                    <input type="text" id="renameInput" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                           placeholder="請輸入新名稱">
                    <input type="hidden" id="renameOldName">
                    <input type="hidden" id="renameItemType">
                    <input type="hidden" id="renameItemPath">
                </div>
            </div>
            
            <div class="flex justify-end space-x-3 mt-6">
                <button type="button" onclick="closeModal('renameModal')" 
                        class="px-4 py-2 text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50">
                    取消
                </button>
                <button type="button" id="btnRenameConfirm" disabled
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50"
                        onclick="confirmRename()">
                    確定
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function closeModal(modalId) {
    $('#' + modalId).addClass('hidden');
}

// 刪除確認相關函數
function showDeleteConfirm(name, type, path) {
    document.getElementById('deleteItemName').textContent = name;
    document.getElementById('deleteItemType').value = type;
    document.getElementById('deleteItemPath').value = path;
    document.getElementById('deleteConfirmInput').value = '';
    document.getElementById('btnDeleteConfirm').disabled = true;
    $('#deleteConfirmModal').removeClass('hidden');
}

function onDeleteInputChange() {
    const expected = document.getElementById('deleteItemName').textContent;
    const input = document.getElementById('deleteConfirmInput').value.trim();
    const isValid = input === expected;
    document.getElementById('btnDeleteConfirm').disabled = !isValid;
}

async function confirmDelete() {
    const name = document.getElementById('deleteItemName').textContent;
    const type = document.getElementById('deleteItemType').value;
    const path = document.getElementById('deleteItemPath').value;
    
    try {
        const url = type === 'folder' ? 
            '@Url.Action("DeleteFolder", "FileManager")' : 
            '@Url.Action("DeleteFile", "FileManager")';
            
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: `name=${encodeURIComponent(name)}&path=${encodeURIComponent(path)}`
        });
        
        const result = await response.json();
        if (result.ok) {
            showToast(result.data.message, 'success');
            closeModal('deleteConfirmModal');
            location.reload();
        } else {
            showToast(result.error, 'error');
        }
    } catch (error) {
        showToast('刪除失敗：' + error.message, 'error');
    }
}

// 重新命名相關函數
function showRename(oldName, type, path) {
    document.getElementById('renameOldName').value = oldName;
    document.getElementById('renameItemType').value = type;
    document.getElementById('renameItemPath').value = path;
    document.getElementById('renameInput').value = oldName;
    document.getElementById('btnRenameConfirm').disabled = true;
    $('#renameModal').removeClass('hidden');
    setTimeout(() => document.getElementById('renameInput').select(), 100);
}

function onRenameInputChange() {
    const oldName = document.getElementById('renameOldName').value;
    const newName = document.getElementById('renameInput').value.trim();
    const isValid = newName && newName !== oldName && !/[\\/:*?"<>|]/.test(newName);
    document.getElementById('btnRenameConfirm').disabled = !isValid;
}

async function confirmRename() {
    const oldName = document.getElementById('renameOldName').value;
    const newName = document.getElementById('renameInput').value.trim();
    const type = document.getElementById('renameItemType').value;
    const path = document.getElementById('renameItemPath').value;
    
    if (!newName || /[\\/:*?"<>|]/.test(newName)) {
        showToast('名稱不合法', 'error');
        return;
    }
    
    try {
        const url = type === 'folder' ? 
            '@Url.Action("RenameFolder", "FileManager")' : 
            '@Url.Action("RenameFile", "FileManager")';
            
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: `oldName=${encodeURIComponent(oldName)}&newName=${encodeURIComponent(newName)}&path=${encodeURIComponent(path)}`
        });
        
        const result = await response.json();
        if (result.ok) {
            showToast(result.data.message, 'success');
            closeModal('renameModal');
            location.reload();
        } else {
            showToast(result.error, 'error');
        }
    } catch (error) {
        showToast('重新命名失敗：' + error.message, 'error');
    }
}

// 綁定輸入事件
document.addEventListener('DOMContentLoaded', function() {
    const deleteInput = document.getElementById('deleteConfirmInput');
    const renameInput = document.getElementById('renameInput');
    
    if (deleteInput) {
        deleteInput.addEventListener('input', onDeleteInputChange);
    }
    if (renameInput) {
        renameInput.addEventListener('input', onRenameInputChange);
    }
});
</script>