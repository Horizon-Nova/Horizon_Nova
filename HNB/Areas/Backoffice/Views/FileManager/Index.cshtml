@{
    ViewData["Title"] = "檔案總管";
    ViewData["PageTitle"] = "檔案總管";
    ViewData["PageDescription"] = "管理檔案和資料夾、上傳下載、預覽編輯";
    ViewData["PageIcon"] = "folder";
    ViewData["HelpModalId"] = "";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("Partials/FileManager/_Styles")

<div class="row g-3 file-manager-root">
    <!-- 左側：OneDrive 導覽 -->
    <div class="col-12 col-md-3" id="fileManagerSidebar">
        <!-- 側邊欄將透過 AJAX 載入 -->
    </div>

    <!-- 右側：頂部工具列 + 檔案列表區 -->
    <div class="col-12 col-md-9">
        <div class="card border-0 shadow-sm h-100 d-flex flex-column">
            @await Html.PartialAsync("Partials/FileManager/_Breadcrumb")
            
            <div class="card-body overflow-auto p-0" id="fileManagerContent" style="min-height: 0;">
                <!-- 內容將透過 AJAX 載入 -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("Partials/FileManager/_Scripts")
}

