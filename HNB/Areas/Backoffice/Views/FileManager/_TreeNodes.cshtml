@model List<object>
@{
    var currentPath = ViewBag.CurrentPath as string ?? "/";
    
    // 智慧邏輯：統一處理樹節點屬性提取（避免重複反射）
    Func<object, (string Name, string Path, int Depth)> extractNodeProps = item => (
        item.GetType().GetProperty("name")?.GetValue(item)?.ToString() ?? "",
        item.GetType().GetProperty("path")?.GetValue(item)?.ToString() ?? "",
        (int)(item.GetType().GetProperty("depth")?.GetValue(item) ?? 0)
    );
    
    // 智慧邏輯：預處理所有樹節點（一次性完成所有邏輯判斷）
    var processedNodes = Model.Select((item, index) => {
        var (name, path, depth) = extractNodeProps(item);
        return new {
            Index = index,
            Name = name,
            Path = path,
            Depth = depth,
            IsActive = currentPath == path,
            IsRootChild = depth <= 1,
            HasChildren = index < Model.Count - 1 && Model.Skip(index + 1).Any(t => {
                var (_, tPath, tDepth) = extractNodeProps(t);
                return tDepth > depth && tPath.StartsWith(path + "/");
            })
        };
    }).ToList();
}

@foreach (var node in processedNodes)
{
    <div class="tree-item @(node.IsRootChild ? "" : "hidden")" data-level="@node.Depth" data-path="@node.Path">
        <div class="tree-content" style="padding-left: @(node.Depth * 1.5)rem;">
            @if (node.HasChildren)
            {
                <button type="button" class="tree-toggle js-tree-toggle" title="展開/收合">
                    <i data-lucide="chevron-right" class="tree-chevron"></i>
                </button>
            }
            else
            {
                <span class="tree-spacer"></span>
            }
            <a href="@Url.Action("FileManager", "FileManager", new { area = "Backoffice", path = node.Path })" class="tree-link @(node.IsActive ? "active" : "")">
                <i data-lucide="@(node.IsActive ? "folder-open" : "folder")" class="tree-icon"></i>
                <span class="tree-text">@node.Name</span>
            </a>
        </div>
    </div>
}
