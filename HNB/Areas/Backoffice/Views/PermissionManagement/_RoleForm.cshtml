@model Models.HnbHnbBackoffice.vw_permission_role

<!-- 角色表單模態框 -->
<div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[95vh] overflow-hidden">
        <!-- 標題區域 -->
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-8 py-6 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="p-2 bg-white bg-opacity-20 rounded-lg">
                        <i data-lucide="shield" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">@(Model?.id > 0 ? "編輯角色" : "新增角色")</h3>
                        <p class="text-green-100 text-sm">@(Model?.id > 0 ? "修改角色權限設定" : "建立新的系統角色")</p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button onclick="showRoleFormHelp()" class="text-white hover:text-green-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="操作說明">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                    </button>
                    <button data-modal-close class="text-white hover:text-green-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="關閉">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 表單內容 -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-180px)]">
            <form id="FormData">
                <input type="hidden" name="id" value="@(Model?.id ?? 0)" />
                
                <div class="space-y-8">
                    <!-- 基本資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="shield" class="w-5 h-5 text-green-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">角色基本資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="shield" class="w-4 h-4 inline mr-1"></i>角色名稱 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" value="@(Model?.name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入角色名稱" required>
                            </div>
                            <div>
                                <label for="status" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="key" class="w-4 h-4 inline mr-1"></i>權限類型
                                </label>
                                <input type="text" id="status" name="status" value="@(Model?.status ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入權限類型">
                            </div>
                        </div>
                    </div>

                    <!-- 描述資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="file-text" class="w-5 h-5 text-blue-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">角色描述</h4>
                        </div>
                        <div class="space-y-6">
                            <div>
                                <label for="description" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="align-left" class="w-4 h-4 inline mr-1"></i>角色描述
                                </label>
                                <textarea id="description" name="description" rows="4" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入角色描述和職責說明">@(Model?.description ?? "")</textarea>
                            </div>
                            <div>
                                <label for="notes" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="sticky-note" class="w-4 h-4 inline mr-1"></i>備註
                                </label>
                                <textarea id="notes" name="notes" rows="3" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入相關備註或特殊說明">@(Model?.notes ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="settings" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">狀態設定</h4>
                        </div>
                        <div>
                            <label for="is_active" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="toggle-right" class="w-4 h-4 inline mr-1"></i>角色狀態
                            </label>
                            <select id="is_active" name="is_active" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all">
                                <option value="true" @(Model?.is_active == true ? "selected" : "")>✓ 啟用</option>
                                <option value="false" @(Model?.is_active == false ? "selected" : "")>✗ 停用</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
        <div class="flex justify-end gap-4 px-8 py-6 border-t bg-slate-50">
            <button data-modal-close class="px-6 py-3 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors font-medium">
                <i data-lucide="x" class="w-4 h-4 inline mr-2"></i>取消
            </button>
            <button type="button" class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium" onclick="submitRoleForm()">
                <i data-lucide="@(Model?.id > 0 ? "save" : "plus")" class="w-4 h-4 inline mr-2"></i>@(Model?.id > 0 ? "儲存變更" : "新增角色")
            </button>
        </div>
    </div>
</div>

<script>
function showRoleFormHelp() {
    // 檢查是否已經有說明視窗存在
    if (document.querySelector('.z-\\[9999\\]')) {
        return; // 如果已存在，直接返回
    }
    
    $.ajax({
        url: '@Url.Action("LoadHelp", "PermissionManagement")',
        type: 'GET',
        data: { type: 'roleform' },
        success: function(response) {
            document.body.insertAdjacentHTML('beforeend', response);
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        },
        error: function() {
            alert('載入說明失敗，請稍後再試');
        }
    });
}

function closeHelp() {
    const helpModal = document.querySelector('.z-\\[9999\\]');
    if (helpModal) {
        helpModal.remove();
    }
}

// 提交角色表單
function submitRoleForm() {
    const formData = new FormData(document.getElementById('FormData'));
    formData.append('type', 'role');
    
    $.ajax({
        url: '@Url.Action("SaveData", "PermissionManagement")',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                $('#roleModal').addClass('hidden');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}
</script>
