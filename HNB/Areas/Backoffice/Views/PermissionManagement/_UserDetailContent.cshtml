<!-- 使用者詳細資訊模態框 -->
<div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
        <div class="flex items-center justify-between p-6 border-b">
            <h3 class="text-lg font-semibold">人員詳細資訊</h3>
            <div class="flex items-center space-x-2">
                <button onclick="showUserDetailHelp()" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="操作說明">
                    <i data-lucide="help-circle" class="w-5 h-5"></i>
                </button>
                <button data-modal-close class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="關閉">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
            @if (ViewBag.Error != null)
            {
                <div class="text-center py-4">
                    <i data-lucide="alert-circle" class="w-12 h-12 text-red-500 mx-auto mb-3"></i>
                    <p class="text-red-600">@ViewBag.Error</p>
                </div>
            }
            else if (ViewBag.User != null)
            {
                var user = ViewBag.User as Models.HnbHnbBackoffice.vw_permission_user;
                <div class="space-y-6">
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0 h-20 w-20">
                            @if (!string.IsNullOrEmpty(user.avatar_url))
                            {
                                <img class="h-20 w-20 rounded-full" src="@user.avatar_url" alt="@user.full_name">
                            }
                            else
                            {
                                <div class="h-20 w-20 rounded-full bg-slate-200 flex items-center justify-center">
                                    <span class="text-slate-600 font-medium text-xl">@(user.full_name?.Substring(0, 1).ToUpper() ?? "?")</span>
                                </div>
                            }
                        </div>
                        <div>
                            <h4 class="text-xl font-semibold text-slate-900">@user.full_name</h4>
                            <p class="text-slate-600">@user.email</p>
                            <p class="text-sm text-slate-500">@user.phone</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">基本資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">使用者名稱</dt>
                                    <dd class="text-sm text-slate-900">@user.username</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">暱稱</dt>
                                    <dd class="text-sm text-slate-900">@user.nickname</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">性別</dt>
                                    <dd class="text-sm text-slate-900">@user.gender</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">星座</dt>
                                    <dd class="text-sm text-slate-900">@user.zodiac_sign</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">狀態</dt>
                                    <dd class="text-sm">
                                        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @(user.is_active == true ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                            @(user.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">最後登入</dt>
                                    <dd class="text-sm text-slate-900">@(user.last_login_at?.ToString("yyyy/MM/dd HH:mm") ?? "從未登入")</dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">組織資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">組織</dt>
                                    <dd class="text-sm text-slate-900">@user.organization_name</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">角色</dt>
                                    <dd class="text-sm text-slate-900">@user.role_name</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">建立時間</dt>
                                    <dd class="text-sm text-slate-900">@(user.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(user.bio))
                    {
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">個人簡介</h5>
                            <p class="text-sm text-slate-600">@user.bio</p>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="flex justify-end gap-3 p-6 border-t bg-slate-50">
            <button data-modal-close class="px-4 py-2 bg-slate-300 text-slate-700 rounded-md hover:bg-slate-400">
                關閉
            </button>
            @if (ViewBag.User != null)
            {
                var user = ViewBag.User as Models.HnbHnbBackoffice.vw_permission_user;
                <button onclick="showUserEdit(@user.id)" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 flex items-center gap-2">
                    <i data-lucide="edit" class="w-4 h-4"></i>
                    編輯
                </button>
            }
        </div>
    </div>
</div>

<script>
function showUserDetailHelp() {
    // 檢查是否已經有說明視窗存在
    if (document.querySelector('.z-\\[9999\\]')) {
        return; // 如果已存在，直接返回
    }
    
    $.ajax({
        url: '@Url.Action("LoadHelp", "PermissionManagement")',
        type: 'GET',
        data: { type: 'userdetail' },
        success: function(response) {
            document.body.insertAdjacentHTML('beforeend', response);
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        },
        error: function() {
            alert('載入說明失敗，請稍後再試');
        }
    });
}

function closeHelp() {
    const helpModal = document.querySelector('.z-\\[9999\\]');
    if (helpModal) {
        helpModal.remove();
    }
}
</script>
