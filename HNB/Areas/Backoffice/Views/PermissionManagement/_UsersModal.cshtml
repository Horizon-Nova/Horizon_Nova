@{
    Layout = null;
}

<!-- 使用者表單彈出視窗 -->
<div id="userFormModal" class="modal fade" tabindex="-1" aria-labelledby="userFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
        <!-- 標題區域 -->
            <div class="modal-header">
                <h5 class="modal-title" id="userFormModalLabel">@(ViewBag.User?.id > 0 ? "編輯帳號" : "新增帳號")</h5>
                <div class="d-flex gap-2">
                    <button type="button" onclick="showModal('userFormHelpModal')" class="btn btn-sm btn-outline-secondary" title="操作說明">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                    </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
        </div>
        
        <!-- 表單內容 -->
            <div class="modal-body p-4">
            <form id="FormDataUser" autocomplete="off">
                <input type="hidden" name="id" value="@(ViewBag.User?.id ?? 0)" />
                
                <div class="vstack gap-3">
                    <!-- 基本資訊區塊 -->
                            <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">基本資訊</h6>
                        <div class="row g-2 align-items-center">
                            <div class="col-auto" style="width: 90px;"><label for="full_name" class="col-form-label col-form-label-sm mb-0">姓名<span class="text-danger">*</span></label></div>
                            <div class="col"><input type="text" id="full_name" name="full_name" value="@(ViewBag.User?.full_name ?? "")" class="form-control form-control-sm" placeholder="請輸入完整姓名" required></div>
                            <div class="col-auto" style="width: 90px;"><label for="email" class="col-form-label col-form-label-sm mb-0">電子郵件<span class="text-danger">*</span></label></div>
                            <div class="col"><input type="email" id="email" name="email" value="@(ViewBag.User?.email ?? "")" class="form-control form-control-sm" placeholder="example@email.com" required></div>
                            </div>
                        <div class="row g-2 align-items-center mt-2">
                            <div class="col-auto" style="width: 90px;"><label for="phone" class="col-form-label col-form-label-sm mb-0">電話</label></div>
                            <div class="col"><input type="text" id="phone" name="phone" value="@(ViewBag.User?.phone ?? "")" class="form-control form-control-sm" placeholder="請輸入聯絡電話"></div>
                            <div class="col-auto" style="width: 90px;"><label for="gender" class="col-form-label col-form-label-sm mb-0">性別<span class="text-danger">*</span></label></div>
                            <div class="col">
                                <select id="gender" name="gender" class="form-select form-select-sm">
                                    <option value="">請選擇性別</option>
                                    <option value="male" @(ViewBag.User?.gender == "male" ? "selected" : "")>男性</option>
                                    <option value="female" @(ViewBag.User?.gender == "female" ? "selected" : "")>女性</option>
                                    <option value="other" @(ViewBag.User?.gender == "other" ? "selected" : "")>其他</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- 帳號資訊區塊 -->
                            <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">帳號資訊</h6>
                        <div class="row g-2 align-items-center">
                            <div class="col-auto" style="width: 90px;"><label for="name" class="col-form-label col-form-label-sm mb-0">使用者名稱<span class="text-danger">*</span></label></div>
                            <div class="col"><input type="text" id="name" name="name" value="@(ViewBag.User?.name ?? "")" class="form-control form-control-sm @(ViewBag.User?.id > 0 ? "bg-light" : "")" placeholder="請輸入使用者名稱" @(ViewBag.User?.id > 0 ? "readonly" : "") required></div>
                            <div class="col-auto" style="width: 90px;"><label for="password_hash" class="col-form-label col-form-label-sm mb-0">密碼@(ViewBag.User?.id > 0 ? "" : Html.Raw("<span class=\"text-danger\">*</span>"))</label></div>
                            <div class="col">
                                <input type="password" id="password_hash" name="password_hash" class="form-control form-control-sm @(ViewBag.User?.id > 0 ? "bg-light" : "")" placeholder="@(ViewBag.User?.id > 0 ? "**********" : "請輸入密碼")" @(ViewBag.User?.id > 0 ? "readonly" : "required")>
                            </div>
                        </div>
                    </div>

                    <!-- 個人資訊區塊 -->
                            <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">個人資訊</h6>
                        <div class="row g-2 align-items-center">
                            <div class="col-auto" style="width: 90px;"><label for="nickname" class="col-form-label col-form-label-sm mb-0">暱稱</label></div>
                            <div class="col"><input type="text" id="nickname" name="nickname" value="@(ViewBag.User?.nickname ?? "")" class="form-control form-control-sm" placeholder="請輸入暱稱"></div>
                            <div class="col-auto" style="width: 90px;"><label for="zodiac_sign" class="col-form-label col-form-label-sm mb-0">星座</label></div>
                            <div class="col"><input type="text" id="zodiac_sign" name="zodiac_sign" value="@(ViewBag.User?.zodiac_sign ?? "")" class="form-control form-control-sm" placeholder="請輸入星座"></div>
                            </div>
                        <div class="row g-2 align-items-center mt-2">
                            <div class="col-auto" style="width: 90px;"><label for="favorite_color" class="col-form-label col-form-label-sm mb-0">喜歡顏色</label></div>
                            <div class="col"><input type="text" id="favorite_color" name="favorite_color" value="@(ViewBag.User?.favorite_color ?? "")" class="form-control form-control-sm" placeholder="請輸入喜歡的顏色"></div>
                            <div class="col-auto" style="width: 90px;"><label for="location" class="col-form-label col-form-label-sm mb-0">常駐地點</label></div>
                            <div class="col"><input type="text" id="location" name="location" value="@(ViewBag.User?.location ?? "")" class="form-control form-control-sm" placeholder="請輸入常駐地點"></div>
                            </div>
                        <div class="row g-2 align-items-start mt-2">
                            <div class="col-auto" style="width: 90px;"><label for="bio" class="col-form-label col-form-label-sm mb-0">個人簡介</label></div>
                            <div class="col"><textarea id="bio" name="bio" rows="2" class="form-control form-control-sm" placeholder="請輸入個人簡介或工作描述">@(ViewBag.User?.bio ?? "")</textarea></div>
                        </div>
                    </div>

                    <!-- 權限設定區塊 -->
                            <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">權限設定</h6>
                        <div class="vstack gap-3">
                            <div class="row g-2 align-items-start">
                                <div class="col-auto" style="width: 90px;"><label class="col-form-label col-form-label-sm mb-0">角色<span class="text-danger">*</span></label></div>
                                <div class="col">
                                    <div class="d-flex flex-wrap gap-2">
                                    @if (ViewBag.Roles != null)
                                    {
                                        @foreach (var role in ViewBag.Roles)
                                        {
                                            var isChecked = ViewBag.User?.roles != null && ViewBag.User.roles.Contains(role.id.ToString());
                                                <div>
                                                    <input type="checkbox" name="role_ids" value="@role.id" @(isChecked ? "checked" : "") class="btn-check" id="role_@role.id" autocomplete="off">
                                                    <label class="btn btn-outline-primary btn-sm" for="role_@role.id">@role.name</label>
                                                </div>
                                        }
                                    }
                                </div>
                            </div>
                            </div>
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 90px;"><label for="parent_id" class="col-form-label col-form-label-sm mb-0">組織<span class="text-danger">*</span></label></div>
                                <div class="col"><select id="parent_id" name="parent_id" required class="form-select form-select-sm">
                                    <option value="">請選擇組織</option>
                                    @if (ViewBag.Organizations != null)
                                    {
                                        @foreach (var org in ViewBag.Organizations)
                                        {
                                            <option value="@org.id" @(ViewBag.User?.parent_id == org.id ? "selected" : "")>@org.organization_name</option>
                                        }
                                    }
                                </select></div>
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                        <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">狀態設定</h6>
                        <div class="row g-2 align-items-center">
                            <div class="col-auto" style="width: 90px;"><label for="is_active" class="col-form-label col-form-label-sm mb-0">帳號狀態</label></div>
                            <div class="col"><select id="is_active" name="is_active" class="form-select form-select-sm">
                                <option value="true" @(ViewBag.User?.is_active == true ? "selected" : "")>啟用</option>
                                <option value="false" @(ViewBag.User?.is_active == false ? "selected" : "")>停用</option>
                            </select></div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="submitUserForm()">@(ViewBag.User?.id > 0 ? "儲存變更" : "新增帳號")</button>
            </div>
        </div>
    </div>
</div>

<!-- 使用者詳情查看視窗 -->
<div id="userDetailModal" class="modal fade" tabindex="-1" aria-labelledby="userDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userDetailModalLabel">帳號詳細資訊</h5>
                <div class="d-flex gap-2">
                    <button type="button" onclick="showModal('userDetailHelpModal')" class="btn btn-sm btn-outline-secondary" title="操作說明">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
        </div>
            <div class="modal-body">
            @if (ViewBag.User != null)
            {
                <div class="vstack gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="flex-shrink-0" style="width: 5rem; height: 5rem;">
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 5rem; height: 5rem;">
                                <span class="text-secondary fw-medium fs-3">@(ViewBag.User?.full_name?.Substring(0, 1).ToUpper() ?? "?")</span>
                            </div>
                        </div>
                        <div>
                            <h4 class="fs-5 fw-semibold mb-1">@ViewBag.User?.full_name</h4>
                            <p class="text-muted mb-0">@ViewBag.User?.email</p>
                            <p class="small text-muted mb-0">@ViewBag.User?.phone</p>
                        </div>
                    </div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-medium mb-2">基本資訊</h6>
                            <dl class="row row-cols-1 g-2">
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">使用者名稱</dt>
                                    <dd class="small mb-0">@ViewBag.User?.name</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">暱稱</dt>
                                    <dd class="small mb-0">@ViewBag.User?.nickname</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">性別</dt>
                                    <dd class="small mb-0">@ViewBag.User?.gender</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">星座</dt>
                                    <dd class="small mb-0">@ViewBag.User?.zodiac_sign</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">狀態</dt>
                                    <dd class="small mb-0">
                                        <span class="badge rounded-pill @(ViewBag.User?.is_active == true ? "bg-success bg-opacity-10 text-success" : "bg-danger bg-opacity-10 text-danger")">
                                            @(ViewBag.User?.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div class="col-md-6">
                            <h6 class="fw-medium mb-2">組織資訊</h6>
                            <dl class="row row-cols-1 g-2">
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">組織</dt>
                                    <dd class="small mb-0">@ViewBag.User?.organization_name</dd>
                                </div>
                                <div>
                                    <dt class="small text-muted mb-1">角色</dt>
                                    <dd class="small mb-0">
                                        @if (ViewBag.User?.role_name != null)
                                        {
                                            @if (ViewBag.User.role_name.Contains(","))
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var role in ViewBag.User.role_name.Split(','))
                                                    {
                                                        <span class="badge bg-primary bg-opacity-10 text-primary">@role.Trim()</span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary bg-opacity-10 text-primary">@ViewBag.User.role_name</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">未分配</span>
                                        }
                                    </dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">建立時間</dt>
                                    <dd class="small mb-0">@(ViewBag.User?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.User?.bio))
                    {
                        <div>
                            <h6 class="fw-medium mb-2">個人簡介</h6>
                            <p class="small text-muted mb-0">@ViewBag.User?.bio</p>
                        </div>
                    }
                </div>
            }
        </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            @if (ViewBag.User != null)
            {
                    <button type="button" onclick="closeModal('userDetailModal'); showModal('userFormModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: @ViewBag.User.id, type: 'user'}, container: 'userModal'})" class="btn btn-primary">編輯</button>
                }
            </div>
        </div>
    </div>
</div>

<script>

// 密碼顯示切換
function togglePassword() {
    const $passwordInput = $('#password_hash');
    const $eyeIcon = $('#password-eye');
    
    if ($passwordInput.attr('type') === 'password') {
        $passwordInput.attr('type', 'text');
        $eyeIcon.attr('data-lucide', 'eye-off');
    } else {
        $passwordInput.attr('type', 'password');
        $eyeIcon.attr('data-lucide', 'eye');
    }
    
    // 重新初始化 Lucide 圖標
    lucide.createIcons();
}

// 提交使用者表單
function submitUserForm() {
    const formElement = document.getElementById('FormDataUser');
    
    // 使用 HTML5 原生驗證
    if (!formElement.checkValidity()) {
        formElement.reportValidity();
        return;
    }
    
    // 序列化表單資料
    const formData = $('#FormDataUser').serialize();
    
    $.ajax({
        url: '@Url.Action("SubmitUser", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                location.reload();
            } else {
                alert('操作失敗：' + (response.message || '系統錯誤'));
            }
        },
        error: function() {
            alert('操作失敗，請稍後再試');
        }
    });
}

// 提交使用者表單
function submitUserForm() {
    const formElement = document.getElementById('FormDataUser');
    
    // 使用 HTML5 原生驗證
    if (!formElement.checkValidity()) {
        formElement.reportValidity();
        return;
    }
    
    const formData = $('#FormDataUser').serialize();
    
    $.ajax({
        url: '@Url.Action("SubmitUser", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                location.reload();
            } else {
                alert('操作失敗：' + (response.message || '系統錯誤'));
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}

</script>

<!-- 使用者表單說明視窗 -->
<div id="userFormHelpModal" class="modal fade" tabindex="-1" aria-labelledby="userFormHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userFormHelpModalLabel">帳號管理操作說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- 左側：說明內容 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 基本操作 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">基本操作流程</h6>
                                <ol class="small mb-0">
                                    <li>填寫必填欄位（標示紅色星號 *）</li>
                                    <li>選擇至少一個角色（可多選）</li>
                                    <li>選擇使用者所屬組織</li>
                                    <li>點擊「儲存變更」或「新增帳號」完成</li>
                                </ol>
                            </div>
                            
                            <!-- 權限控制說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">權限控制說明</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>你可以管理的範圍：</strong></p>
                                    <ul class="mb-2">
                                        <li>只能新增/編輯<strong>自己組織</strong>內的使用者</li>
                                        <li>只能指派<strong>自己組織</strong>內的角色</li>
                                        <li>無法跨組織管理或查看其他組織的資料</li>
                                    </ul>
                                    <p class="mb-2"><strong>角色與權限關係：</strong></p>
                                    <ul class="mb-0">
                                        <li><strong>單一角色：</strong>使用者繼承該角色的所有導航權限</li>
                                        <li><strong>多個角色：</strong>使用者擁有所有角色的權限（權限取聯集）</li>
                                        <li><strong>權限變更：</strong>修改角色權限後，所有擁有該角色的使用者會立即生效</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <!-- 欄位說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">欄位說明</h6>
                                <table class="table table-sm table-bordered small mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 100px;">欄位名稱</th>
                                            <th>說明</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>姓名 *</strong></td>
                                            <td>使用者的完整姓名</td>
                                        </tr>
                                        <tr>
                                            <td><strong>電子郵件 *</strong></td>
                                            <td>聯絡信箱，系統通知會發送至此</td>
                                        </tr>
                                        <tr>
                                            <td><strong>使用者名稱 *</strong></td>
                                            <td>登入帳號（建立後無法修改）</td>
                                        </tr>
                                        <tr>
                                            <td><strong>密碼</strong></td>
                                            <td>新增時必填 | 編輯時留空=不變更</td>
                                        </tr>
                                        <tr>
                                            <td><strong>角色 *</strong></td>
                                            <td>可多選，權限會自動合併</td>
                                        </tr>
                                        <tr>
                                            <td><strong>組織 *</strong></td>
                                            <td>使用者所屬組織，決定資料可見範圍</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 右側：常見問題 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 常見問題 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題 (Q&A)</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>Q1：為什麼我建立使用者後，在列表中沒有看到？</strong></p>
                                    <p class="ms-3 mb-3">A：請檢查你建立的使用者是否屬於<strong>你的組織</strong>。系統基於權限控制，你只能看到自己組織內的使用者。如果選錯組織，該使用者會被其他組織的管理員看到。</p>
                                    
                                    <p class="mb-2"><strong>Q2：為什麼我看不到某些組織或角色選項？</strong></p>
                                    <p class="ms-3 mb-3">A：下拉選單只會顯示<strong>你有權限管理的組織和角色</strong>（即你自己的組織）。這是為了防止跨組織的資料混亂。</p>
                                    
                                    <p class="mb-2"><strong>Q3：使用者可以有多個角色嗎？權限如何計算？</strong></p>
                                    <p class="ms-3 mb-3">A：可以。使用者會<strong>繼承所有勾選角色的權限</strong>（取聯集）。例如：角色A有導航1、2，角色B有導航2、3，則使用者擁有導航1、2、3。</p>
                                    
                                    <p class="mb-2"><strong>Q4：編輯使用者時，密碼欄位要怎麼填？</strong></p>
                                    <p class="ms-3 mb-3">A：<strong>留空</strong>表示不變更現有密碼；<strong>填入新密碼</strong>則會覆蓋舊密碼。密碼欄位在編輯模式下會自動鎖定，需至個人資料頁面修改。</p>
                                    
                                    <p class="mb-2"><strong>Q5：為什麼使用者名稱無法修改？</strong></p>
                                    <p class="ms-3 mb-0">A：使用者名稱是系統的<strong>唯一識別碼</strong>，用於登入驗證和權限判斷。如需修改，請建立新帳號並停用舊帳號。</p>
                                </div>
                            </div>
                            
                            <!-- 注意事項 -->
                            <div class="alert alert-info small mb-0">
                                <h6 class="fw-bold mb-2">💡 重要提醒</h6>
                                <ul class="mb-0">
                                    <li>建立帳號前請確認組織選擇正確，否則會導致權限錯誤</li>
                                    <li>角色和組織的變更會<strong>立即生效</strong>，使用者需重新登入才能看到新權限</li>
                                    <li>停用帳號不會刪除資料，僅禁止登入</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

