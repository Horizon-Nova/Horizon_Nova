@{
    Layout = null;
}

<!-- 使用者表單彈出視窗 -->
<div id="userFormModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[95vh] overflow-hidden">
        <!-- 標題區域 -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="p-2 bg-white bg-opacity-20 rounded-lg">
                        <i data-lucide="user-plus" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">@(ViewBag.User?.id > 0 ? "編輯帳號" : "新增帳號")</h3>
                        <p class="text-blue-100 text-sm">@(ViewBag.User?.id > 0 ? "修改帳號基本資訊" : "建立新的系統使用者")</p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button onclick="showModal('userFormHelpModal')" class="text-white hover:text-blue-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="操作說明">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                    </button>
                    <button onclick="closeModal('userFormModal')" class="text-white hover:text-blue-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="關閉">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 表單內容 -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-180px)]">
            <form id="FormDataUser" autocomplete="off">
                <input type="hidden" name="id" value="@(ViewBag.User?.id ?? 0)" />
                
                <div class="space-y-8">
                    <!-- 基本資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="user" class="w-5 h-5 text-blue-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">基本資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="full_name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="user" class="w-4 h-4 inline mr-1"></i>姓名 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="full_name" name="full_name" value="@(ViewBag.User?.full_name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入完整姓名" required>
                            </div>
                            <div>
                                <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="mail" class="w-4 h-4 inline mr-1"></i>電子郵件 <span class="text-red-500">*</span>
                                </label>
                                <input type="email" id="email" name="email" value="@(ViewBag.User?.email ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="user@example.com" required>
                            </div>
                            <div>
                                <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="phone" class="w-4 h-4 inline mr-1"></i>電話
                                </label>
                                <input type="text" id="phone" name="phone" value="@(ViewBag.User?.phone ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入聯絡電話">
                            </div>
                            <div>
                                <label for="gender" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="users" class="w-4 h-4 inline mr-1"></i>性別 <span class="text-red-500">*</span>
                                </label>
                                <select id="gender" name="gender" 
                                        class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="">請選擇性別</option>
                                    <option value="male" @(ViewBag.User?.gender == "male" ? "selected" : "")>男性</option>
                                    <option value="female" @(ViewBag.User?.gender == "female" ? "selected" : "")>女性</option>
                                    <option value="other" @(ViewBag.User?.gender == "other" ? "selected" : "")>其他</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- 帳號資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="key" class="w-5 h-5 text-green-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">帳號資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="at-sign" class="w-4 h-4 inline mr-1"></i>使用者名稱 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" value="@(ViewBag.User?.name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all @(ViewBag.User?.id > 0 ? "bg-slate-100 cursor-not-allowed" : "")" 
                                       placeholder="請輸入使用者名稱" 
                                       @(ViewBag.User?.id > 0 ? "readonly" : "") required>
                            </div>
                            <div>
                                <label for="password_hash" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="lock" class="w-4 h-4 inline mr-1"></i>密碼 
                                    @(ViewBag.User?.id > 0 
                                        ? Html.Raw("<span class=\"text-slate-500 text-xs\">(密碼變更請至個人資料頁面)</span>")
                                        : Html.Raw("<span class=\"text-red-500\">*</span>"))
                                </label>
                                <div class="relative">
                                    <input type="password" id="password_hash" name="password_hash" 
                                           class="w-full px-4 py-3 @(ViewBag.User?.id == 0 ? "pr-12" : "") border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all @(ViewBag.User?.id > 0 ? "bg-slate-100 cursor-not-allowed" : "")" 
                                           placeholder="@(ViewBag.User?.id > 0 ? (!string.IsNullOrEmpty(ViewBag.User?.password_hash) ? "**********" : "請輸入密碼") : "請輸入密碼")" 
                                           @(ViewBag.User?.id > 0 ? "readonly" : "required")>
                                    @(ViewBag.User?.id == 0 
                                        ? Html.Raw("<button type=\"button\" onclick=\"togglePassword()\" class=\"absolute right-3 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors\"><i data-lucide=\"eye\" id=\"password-eye\" class=\"w-5 h-5\"></i></button>")
                                        : Html.Raw(""))
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 個人資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="heart" class="w-5 h-5 text-pink-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">個人資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="nickname" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="smile" class="w-4 h-4 inline mr-1"></i>暱稱
                                </label>
                                <input type="text" id="nickname" name="nickname" value="@(ViewBag.User?.nickname ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入暱稱">
                            </div>
                            <div>
                                <label for="zodiac_sign" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="star" class="w-4 h-4 inline mr-1"></i>星座
                                </label>
                                <input type="text" id="zodiac_sign" name="zodiac_sign" value="@(ViewBag.User?.zodiac_sign ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入星座">
                            </div>
                            <div>
                                <label for="favorite_color" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="palette" class="w-4 h-4 inline mr-1"></i>喜歡顏色
                                </label>
                                <input type="text" id="favorite_color" name="favorite_color" value="@(ViewBag.User?.favorite_color ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入喜歡的顏色">
                            </div>
                            <div>
                                <label for="location" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="map-pin" class="w-4 h-4 inline mr-1"></i>常駐地點
                                </label>
                                <input type="text" id="location" name="location" value="@(ViewBag.User?.location ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入常駐地點">
                            </div>
                            <div class="col-span-full">
                                <label for="bio" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="file-text" class="w-4 h-4 inline mr-1"></i>個人簡介
                                </label>
                                <textarea id="bio" name="bio" rows="4" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入個人簡介或工作描述">@(ViewBag.User?.bio ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 權限設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="shield" class="w-5 h-5 text-purple-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">權限設定</h4>
                        </div>
                        <div class="space-y-6">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-3">
                                    <i data-lucide="user-check" class="w-4 h-4 inline mr-1"></i>角色 <span class="text-red-500">*</span>
                                    <span class="text-slate-500 text-xs ml-2">(可多選)</span>
                                </label>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-h-48 overflow-y-auto border border-slate-200 rounded-lg p-4 bg-white">
                                    @if (ViewBag.Roles != null)
                                    {
                                        @foreach (var role in ViewBag.Roles)
                                        {
                                            var isChecked = ViewBag.User?.roles != null && ViewBag.User.roles.Contains(role.id.ToString());
                                            <label class="flex items-center space-x-2 p-2 border border-slate-200 rounded-lg hover:bg-blue-50 cursor-pointer transition-colors">
                                                <input type="checkbox" name="role_ids" value="@role.id" 
                                                       @(isChecked ? "checked" : "")
                                                       class="w-4 h-4 text-blue-600 border-slate-300 rounded focus:ring-blue-500" />
                                                <span class="text-sm text-slate-700">@role.name</span>
                                            </label>
                                        }
                                    }
                                </div>
                            </div>
                            <div>
                                <label for="parent_id" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="building" class="w-4 h-4 inline mr-1"></i>組織 <span class="text-red-500">*</span>
                                </label>
                                <select id="parent_id" name="parent_id" required
                                        class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="">請選擇組織</option>
                                    @if (ViewBag.Organizations != null)
                                    {
                                        @foreach (var org in ViewBag.Organizations)
                                        {
                                            <option value="@org.id" @(ViewBag.User?.parent_id == org.id ? "selected" : "")>@org.organization_name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="settings" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">狀態設定</h4>
                        </div>
                        <div>
                            <label for="is_active" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="toggle-right" class="w-4 h-4 inline mr-1"></i>帳號狀態
                            </label>
                            <select id="is_active" name="is_active" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                <option value="true" @(ViewBag.User?.is_active == true ? "selected" : "")>✓ 啟用</option>
                                <option value="false" @(ViewBag.User?.is_active == false ? "selected" : "")>✗ 停用</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
        <div class="flex justify-end gap-4 px-8 py-6 border-t bg-slate-50">
            <button onclick="closeModal('userFormModal')" class="px-6 py-3 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors font-medium">
                <i data-lucide="x" class="w-4 h-4 inline mr-2"></i>取消
            </button>
            <button type="button" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" onclick="submitUserForm()">
                <i data-lucide="@(ViewBag.User?.id > 0 ? "save" : "plus")" class="w-4 h-4 inline mr-2"></i>@(ViewBag.User?.id > 0 ? "儲存變更" : "新增帳號")
            </button>
        </div>
    </div>
</div>

<!-- 使用者詳情查看視窗 -->
<div id="userDetailModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
        <div class="flex items-center justify-between p-6 border-b">
            <h3 class="text-lg font-semibold">帳號詳細資訊</h3>
            <div class="flex items-center space-x-2">
                <button onclick="showModal('userDetailHelpModal')" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="操作說明">
                    <i data-lucide="help-circle" class="w-5 h-5"></i>
                </button>
                <button onclick="closeModal('userDetailModal')" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="關閉">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
            @if (ViewBag.User != null)
            {
                <div class="space-y-6">
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0 h-20 w-20">
                            <div class="h-20 w-20 rounded-full bg-slate-200 flex items-center justify-center">
                                <span class="text-slate-600 font-medium text-xl">@(ViewBag.User?.full_name?.Substring(0, 1).ToUpper() ?? "?")</span>
                            </div>
                        </div>
                        <div>
                            <h4 class="text-xl font-semibold text-slate-900">@ViewBag.User?.full_name</h4>
                            <p class="text-slate-600">@ViewBag.User?.email</p>
                            <p class="text-sm text-slate-500">@ViewBag.User?.phone</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">基本資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">使用者名稱</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.User?.name</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">暱稱</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.User?.nickname</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">性別</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.User?.gender</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">星座</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.User?.zodiac_sign</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">狀態</dt>
                                    <dd class="text-sm">
                                        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @(ViewBag.User?.is_active == true ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                            @(ViewBag.User?.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">組織資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">組織</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.User?.organization_name</dd>
                                </div>
                                <div>
                                    <dt class="text-sm text-slate-500 mb-1">角色</dt>
                                    <dd class="text-sm text-slate-900">
                                        @if (ViewBag.User?.role_name != null)
                                        {
                                            @if (ViewBag.User.role_name.Contains(","))
                                            {
                                                <div class="flex flex-wrap gap-1">
                                                    @foreach (var role in ViewBag.User.role_name.Split(','))
                                                    {
                                                        <span class="inline-flex px-2 py-1 text-xs font-medium bg-purple-100 text-purple-800 rounded">@role.Trim()</span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="inline-flex px-2 py-1 text-xs font-medium bg-purple-100 text-purple-800 rounded">@ViewBag.User.role_name</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">未分配</span>
                                        }
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">建立時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.User?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.User?.bio))
                    {
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">個人簡介</h5>
                            <p class="text-sm text-slate-600">@ViewBag.User?.bio</p>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="flex justify-end gap-3 p-6 border-t bg-slate-50">
            <button onclick="closeModal('userDetailModal')" class="px-4 py-2 bg-slate-300 text-slate-700 rounded-md hover:bg-slate-400">
                關閉
            </button>
            @if (ViewBag.User != null)
            {
                <button onclick="closeModal('userDetailModal'); showModal('userFormModal')" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 flex items-center gap-2">
                    <i data-lucide="edit" class="w-4 h-4"></i>
                    編輯
                </button>
            }
        </div>
    </div>
</div>

<!-- 使用者表單說明視窗 -->
<div id="userFormHelpModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-blue-500 p-2 rounded-lg">
                        <i data-lucide="help-circle" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">帳號管理操作說明</h3>
                        <p class="text-sm text-blue-100 mt-1">了解如何管理系統使用者</p>
                    </div>
                </div>
                <button onclick="closeModal('userFormHelpModal')" class="text-white hover:text-blue-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-blue-600"></i>基本操作
                    </h4>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>必填欄位</strong>：標示紅色星號 (*) 的欄位為必填</li>
                        <li>• <strong>密碼顯示</strong>：點擊密碼欄位右側的眼睛圖標可切換顯示/隱藏</li>
