@{
    Layout = null;
}

<!-- 角色表單彈出視窗 -->
<div id="roleFormModal" class="modal fade" tabindex="-1" aria-labelledby="roleFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
        <!-- 標題區域 -->
            <div class="modal-header">
                <h5 class="modal-title" id="roleFormModalLabel">@(ViewBag.Role?.id > 0 ? "編輯角色" : "新增角色")</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary js-open-role-form-help" title="操作說明">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                    </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
        </div>
        
        <!-- 表單內容 -->
            <div class="modal-body p-4">
            <form id="FormDataRole" autocomplete="off">
                <input type="hidden" name="id" value="@(ViewBag.Role?.id ?? 0)" />
                
                <div class="vstack gap-3">
                    <!-- 基本資訊區塊 -->
                            <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">角色基本資訊</h6>
                        <div class="row g-2 align-items-center">
                            <div class="col-3 col-md-2 col-lg-2"><label for="name" class="col-form-label col-form-label-sm mb-0">角色名稱<span class="text-danger">*</span></label></div>
                            <div class="col"><input type="text" id="name" name="name" value="@(ViewBag.Role?.name ?? "")" class="form-control form-control-sm" placeholder="請輸入角色名稱" required></div>
                            <div class="col-3 col-md-2 col-lg-2"><label for="status" class="col-form-label col-form-label-sm mb-0">權限類型</label></div>
                            <div class="col"><input type="text" id="status" name="status" value="@(ViewBag.Role?.status ?? "")" class="form-control form-control-sm" placeholder="請輸入權限類型"></div>
                        </div>
                        <div class="row g-2 align-items-center mt-2">
                            <div class="col-3 col-md-2 col-lg-2"><label for="parent_id" class="col-form-label col-form-label-sm mb-0">所屬組織<span class="text-danger">*</span></label></div>
                            <div class="col">
                                <select id="parent_id" name="parent_id" class="form-select form-select-sm" required>
                                    <option value="">請選擇組織</option>
                                    @if (ViewBag.Organizations != null)
                                    {
                                        @foreach (var org in ViewBag.Organizations)
                                        {
                                            var isSelected = ViewBag.Role?.organization_id == org.id;
                                            <option value="@org.id" @(isSelected ? "selected" : "")>@org.organization_name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- 描述資訊區塊 -->
                            <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">角色描述</h6>
                        <div class="row g-2 align-items-start">
                            <div class="col-3 col-md-2 col-lg-2"><label for="description" class="col-form-label col-form-label-sm mb-0">角色描述</label></div>
                            <div class="col"><textarea id="description" name="description" rows="2" class="form-control form-control-sm" placeholder="請輸入角色描述和職責說明">@(ViewBag.Role?.description ?? "")</textarea></div>
                            </div>
                        <div class="row g-2 align-items-start mt-2">
                            <div class="col-3 col-md-2 col-lg-2"><label for="notes" class="col-form-label col-form-label-sm mb-0">備註</label></div>
                            <div class="col"><textarea id="notes" name="notes" rows="2" class="form-control form-control-sm" placeholder="請輸入相關備註或特殊說明">@(ViewBag.Role?.notes ?? "")</textarea></div>
                        </div>
                    </div>

                    <!-- 導航權限區塊 -->
                    <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">導航權限</h6>
                        <div class="row g-2 align-items-start">
                            <div class="col-3 col-md-2 col-lg-2"><label class="col-form-label col-form-label-sm mb-0">導航項目</label></div>
                            <div class="col">
                                @if (ViewBag.Navigations != null)
                                {
                                    var navList = ((IEnumerable<dynamic>)ViewBag.Navigations).ToList();
                                    var parents = navList.Where(n => string.IsNullOrEmpty((string)n.parent_code)).OrderBy(n => (int?)(n.sort_order ?? 0)).ToList();
                                    var childrenMap = navList.Where(n => !string.IsNullOrEmpty((string)n.parent_code))
                                        .GroupBy(n => (string)n.parent_code)
                                        .ToDictionary(g => g.Key, g => g.OrderBy(n => (int?)(n.sort_order ?? 0)).ToList());
                                    var selectedPerms = ViewBag.RoleNavigationPermissions as IEnumerable<string> ?? new List<string>();

                                    <div class="border rounded p-2 bg-white mb-2">
                                        <div id="selectedNavList" class="d-flex flex-wrap gap-2">
                                            @foreach (var code in selectedPerms)
                                            {
                                                var nav = navList.FirstOrDefault(n => (string)n.code == code);
                                                if (nav != null)
                                                {
                                                    var title = (string)(nav.title ?? "");
                                                    <span class="badge bg-secondary d-inline-flex align-items-center gap-1">
                                                        <span>@title</span>
                                                        <input type="hidden" name="navigation_permissions" value="@code">
                                                        <button type="button" class="btn-close btn-close-white btn-close-sm" data-code="@code"></button>
                                                    </span>
                                                }
                                            }
                                        </div>
                                        <!-- Razor 產出的徽章模板（供 JS 複製，不在 JS 組裝 HTML） -->
                                        <span id="navBadgeTemplate" class="badge bg-secondary d-inline-flex align-items-center gap-1 d-none">
                                            <span class="title"></span>
                                            <input type="hidden" name="navigation_permissions" value="">
                                            <button type="button" class="btn-close btn-close-white btn-close-sm" data-code=""></button>
                                        </span>
                                    </div>

                                    <select id="navSelect" class="form-select form-select-sm" style="height: auto;" size="8">
                                        @foreach (var parent in parents)
                                        {
                                            var parentCode = (string)parent.code;
                                            var parentTitle = (string)(parent.title ?? "");
                                            var hasChildren = childrenMap.ContainsKey(parentCode);
                                            
                                            if (hasChildren)
                                            {
                                                <optgroup label="@parentTitle">
                                                    @foreach (var child in childrenMap[parentCode])
                                                    {
                                                        var childCode = (string)child.code;
                                                        var childTitle = (string)(child.title ?? "");
                                                        <option value="@childCode">@childTitle</option>
                                                    }
                                                </optgroup>
                                            }
                                            else
                                            {
                                                <option value="@parentCode">@parentTitle</option>
                                            }
                                        }
                                    </select>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                        <div>
                        <h6 class="fw-bold mb-3 pb-2 border-bottom">狀態設定</h6>
                        <div class="row g-2 align-items-center">
                            <div class="col-3 col-md-2 col-lg-2"><label for="is_active" class="col-form-label col-form-label-sm mb-0">角色狀態</label></div>
                            <div class="col">
                                <select id="is_active" name="is_active" class="form-select form-select-sm">
                                    <option value="true" @(ViewBag.Role?.is_active == true ? "selected" : "")>啟用</option>
                                    <option value="false" @(ViewBag.Role?.is_active == false ? "selected" : "")>停用</option>
                            </select>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-success js-submit-role-form">@(ViewBag.Role?.id > 0 ? "儲存變更" : "新增角色")</button>
            </div>
        </div>
    </div>
</div>

<!-- 角色詳情查看視窗 -->
<div id="roleDetailModal" class="modal fade" tabindex="-1" aria-labelledby="roleDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="roleDetailModalLabel">角色詳細資訊</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary js-open-role-detail-help" title="操作說明">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
        </div>
            <div class="modal-body">
            @if (ViewBag.Role != null)
            {
                <div class="vstack gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="flex-shrink-0" style="width: 5rem; height: 5rem;">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 5rem; height: 5rem;">
                                <i data-lucide="shield" class="text-success" style="width: 2rem; height: 2rem;"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="fs-5 fw-semibold mb-1">@ViewBag.Role?.name</h4>
                            <p class="text-muted mb-0">@ViewBag.Role?.description</p>
                        </div>
                    </div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-medium mb-2">基本資訊</h6>
                            <dl class="row row-cols-1 g-2">
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">角色名稱</dt>
                                    <dd class="small mb-0">@ViewBag.Role?.name</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">狀態</dt>
                                    <dd class="small mb-0">
                                        <span class="badge rounded-pill @(ViewBag.Role?.is_active == true ? "bg-success bg-opacity-10 text-success" : "bg-danger bg-opacity-10 text-danger")">
                                            @(ViewBag.Role?.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">權限類型</dt>
                                    <dd class="small mb-0">@ViewBag.Role?.status</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">建立時間</dt>
                                    <dd class="small mb-0">@(ViewBag.Role?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div class="col-md-6">
                            <h6 class="fw-medium mb-2">統計資訊</h6>
                            <dl class="row row-cols-1 g-2">
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">組織</dt>
                                    <dd class="small mb-0">@ViewBag.Role?.organization_name</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">使用者數量</dt>
                                    <dd class="small mb-0">@ViewBag.Role?.user_count</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">權限數量</dt>
                                    <dd class="small mb-0">@ViewBag.Role?.permission_count</dd>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <dt class="small text-muted">更新時間</dt>
                                    <dd class="small mb-0">@(ViewBag.Role?.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Role?.notes))
                    {
                        <div>
                            <h6 class="fw-medium mb-2">備註</h6>
                            <p class="small text-muted mb-0">@ViewBag.Role?.notes</p>
                        </div>
                    }
                </div>
            }
        </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            @if (ViewBag.Role != null)
            {
                    <button type="button" class="btn btn-success js-edit-role-from-detail" data-role-id="@ViewBag.Role?.id">編輯</button>
                }
            </div>
        </div>
    </div>
</div>

<script>

$(function () {
    $(document).off('click.roleModal', '.js-open-role-form-help')
        .on('click.roleModal', '.js-open-role-form-help', function (e) {
        e.preventDefault();
        showModal('roleFormHelpModal');
    });

    $(document).off('click.roleModal', '.js-open-role-detail-help')
        .on('click.roleModal', '.js-open-role-detail-help', function (e) {
        e.preventDefault();
        showModal('roleDetailHelpModal');
    });

    $(document).off('click.roleModal', '.js-submit-role-form')
        .on('click.roleModal', '.js-submit-role-form', function () {
        submitRoleForm();
    });

    $(document).off('click.roleModal', '.js-edit-role-from-detail')
        .on('click.roleModal', '.js-edit-role-from-detail', function () {
        const roleId = $(this).data('roleId');
        closeModal('roleDetailModal');
        showModal('roleFormModal', {
            url: '@Url.Action("LoadDetail", "PermissionManagement")',
            method: 'GET',
            data: { id: roleId, type: 'role' },
            
        });
    });
});

// 提交角色表單
function submitRoleForm() {
    const formElement = $('#FormDataRole')[0];
    
    // 使用 HTML5 原生驗證
    if (!formElement.checkValidity()) {
        formElement.reportValidity();
        return;
    }
    
    const formData = $('#FormDataRole').serialize();
    
    $.ajax({
        url: '@Url.Action("SubmitRole", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                location.reload();
            } else {
                alert('操作失敗：' + (response.message || '系統錯誤'));
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}

// 導航下拉選單操作（立即執行）
(function () {
    // 等待 DOM 就緒
    const initNavSelect = function() {
        const $navSelect = $('#navSelect');
        const $selectedNavList = $('#selectedNavList');
        const $template = $('#navBadgeTemplate');

        if ($navSelect.length === 0 || $selectedNavList.length === 0 || $template.length === 0) return;

        // 下拉選單改變時自動新增
        $navSelect.on('change', function () {
            const code = $(this).val();
            const title = $(this).find('option:selected').text();

            if (code && title && !isNavAdded(code)) addNavBadge(code, title);
            $(this).val('');
        });

        // 移除徽章
        $selectedNavList.on('click', '.btn-close', function () {
            $(this).closest('.badge').remove();
        });

        function isNavAdded(code) {
            return $selectedNavList.find(`input[name="navigation_permissions"][value="${code}"]`).length > 0;
        }

        function addNavBadge(code, title) {
            const $badge = $template.clone().removeAttr('id').removeClass('d-none');
            $badge.find('.title').text(title);
            $badge.find('input[name="navigation_permissions"]').val(code);
            $badge.find('.btn-close').attr('data-code', code);
            $selectedNavList.append($badge);
        }
    };

    $(initNavSelect);
})();

</script>

<!-- 角色表單說明視窗 -->
<div id="roleFormHelpModal" class="modal fade" tabindex="-1" aria-labelledby="roleFormHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="roleFormHelpModalLabel">角色管理操作說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- 左側：說明內容 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 基本操作 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">基本操作流程</h6>
                                <ol class="small mb-0">
                                    <li>輸入角色名稱（必填）</li>
                                    <li>填寫角色描述和備註（選填）</li>
                                    <li>勾選此角色可訪問的導航項目（至少一個）</li>
                                    <li>設定角色狀態（啟用/停用）</li>
                                    <li>點擊「儲存變更」或「新增角色」完成</li>
                                </ol>
                            </div>
                            
                            <!-- 權限控制說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">權限控制說明</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>你可以管理的範圍：</strong></p>
                                    <ul class="mb-2">
                                        <li>只能新增/編輯<strong>自己組織</strong>內的角色</li>
                                        <li>只能指派<strong>自己組織</strong>可見的導航權限</li>
                                        <li>無法修改或查看其他組織的角色設定</li>
                                    </ul>
                                    <p class="mb-2"><strong>角色與使用者的關係：</strong></p>
                                    <ul class="mb-2">
                                        <li><strong>角色 → 使用者：</strong>一個角色可以指派給多個使用者</li>
                                        <li><strong>使用者 → 角色：</strong>一個使用者可以擁有多個角色</li>
                                        <li><strong>權限合併：</strong>使用者擁有所有角色的權限（取聯集）</li>
                                    </ul>
                                    <p class="mb-2"><strong>導航權限說明：</strong></p>
                                    <ul class="mb-0">
                                        <li><strong>勾選導航項目：</strong>代表此角色可以訪問該功能頁面</li>
                                        <li><strong>未勾選項目：</strong>使用者無法在側邊欄看到該導航項目</li>
                                        <li><strong>即時生效：</strong>權限變更後，使用者需重新登入才能看到新權限</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <!-- 欄位說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">欄位說明</h6>
                                <table class="table table-sm table-bordered small mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 100px;">欄位名稱</th>
                                            <th>說明</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>角色名稱 *</strong></td>
                                            <td>角色的顯示名稱</td>
                                        </tr>
                                        <tr>
                                            <td><strong>權限類型</strong></td>
                                            <td>權限範圍或等級（選填）</td>
                                        </tr>
                                        <tr>
                                            <td><strong>角色描述</strong></td>
                                            <td>詳細說明職責和權限範圍</td>
                                        </tr>
                                        <tr>
                                            <td><strong>導航權限</strong></td>
                                            <td>可訪問的導航項目（可多選）</td>
                                        </tr>
                                        <tr>
                                            <td><strong>角色狀態</strong></td>
                                            <td>啟用/停用</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 右側：常見問題 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 常見問題 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題 (Q&A)</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>Q1：為什麼我建立角色後，在列表中沒有看到？</strong></p>
                                    <p class="ms-3 mb-3">A：請檢查你建立的角色是否屬於<strong>你的組織</strong>。系統會自動將新建立的角色歸屬於你的組織，若你看不到，可能是組織篩選器設定有誤。</p>
                                    
                                    <p class="mb-2"><strong>Q2：為什麼我看不到某些導航項目可以勾選？</strong></p>
                                    <p class="ms-3 mb-3">A：導航權限清單顯示的是<strong>系統所有可用的導航項目</strong>。如果你看不到某個項目，可能該導航尚未建立或已被停用。</p>
                                    
                                    <p class="mb-2"><strong>Q3：如果我修改角色的導航權限，已有的使用者會受影響嗎？</strong></p>
                                    <p class="ms-3 mb-3">A：會。角色權限的變更會<strong>立即影響所有擁有該角色的使用者</strong>。使用者需重新登入才能看到新的導航項目。建議在非上班時間進行重大權限調整。</p>
                                    
                                    <p class="mb-2"><strong>Q4：停用角色後，原本擁有該角色的使用者會怎樣？</strong></p>
                                    <p class="ms-3 mb-3">A：已指派給使用者的角色<strong>不會被移除</strong>，使用者仍保有該角色的權限。停用只是防止將此角色指派給新使用者。</p>
                                    
                                    <p class="mb-2"><strong>Q5：角色、組織、使用者之間的關係是什麼？</strong></p>
                                    <p class="ms-3 mb-0">A：<strong>組織</strong>是最上層的權限隔離單位；<strong>角色</strong>屬於某個組織，定義了導航權限；<strong>使用者</strong>屬於某個組織，並可擁有多個角色。權限流向：組織 → 角色 → 導航權限 → 使用者。</p>
                                </div>
                            </div>
                            
                            <!-- 注意事項 -->
                            <div class="alert alert-warning small mb-0">
                                <h6 class="fw-bold mb-2">⚠️ 重要提醒</h6>
                                <ul class="mb-0">
                                    <li>修改角色權限會立即影響所有擁有該角色的使用者</li>
                                    <li>建議在角色描述中詳細記錄設計意圖，方便未來維護</li>
                                    <li>刪除角色前請確認沒有使用者正在使用該角色</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

