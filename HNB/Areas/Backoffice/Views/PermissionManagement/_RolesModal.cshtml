@{
    Layout = null;
}

<!-- 角色表單彈出視窗 -->
<div id="roleFormModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[95vh] overflow-hidden">
        <!-- 標題區域 -->
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-8 py-6 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="p-2 bg-white bg-opacity-20 rounded-lg">
                        <i data-lucide="shield" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">@(ViewBag.Role?.id > 0 ? "編輯角色" : "新增角色")</h3>
                        <p class="text-green-100 text-sm">@(ViewBag.Role?.id > 0 ? "修改角色權限設定" : "建立新的系統角色")</p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button onclick="showModal('roleFormHelpModal')" class="text-white hover:text-green-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="操作說明">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                    </button>
                    <button onclick="closeModal('roleFormModal')" class="text-white hover:text-green-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="關閉">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 表單內容 -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-180px)]">
            <form id="FormDataRole" autocomplete="off">
                <input type="hidden" name="id" value="@(ViewBag.Role?.id ?? 0)" />
                
                <div class="space-y-8">
                    <!-- 基本資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="shield" class="w-5 h-5 text-green-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">角色基本資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="shield" class="w-4 h-4 inline mr-1"></i>角色名稱 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" value="@(ViewBag.Role?.name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入角色名稱" required>
                            </div>
                            <div>
                                <label for="status" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="key" class="w-4 h-4 inline mr-1"></i>權限類型
                                </label>
                                <input type="text" id="status" name="status" value="@(ViewBag.Role?.status ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入權限類型">
                            </div>
                        </div>
                    </div>

                    <!-- 描述資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="file-text" class="w-5 h-5 text-blue-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">角色描述</h4>
                        </div>
                        <div class="space-y-6">
                            <div>
                                <label for="description" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="align-left" class="w-4 h-4 inline mr-1"></i>角色描述
                                </label>
                                <textarea id="description" name="description" rows="4" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入角色描述和職責說明">@(ViewBag.Role?.description ?? "")</textarea>
                            </div>
                            <div>
                                <label for="notes" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="sticky-note" class="w-4 h-4 inline mr-1"></i>備註
                                </label>
                                <textarea id="notes" name="notes" rows="3" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入相關備註或特殊說明">@(ViewBag.Role?.notes ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 導航權限區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="navigation" class="w-5 h-5 text-purple-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">導航權限</h4>
                        </div>
                        <div class="space-y-4">
                            <p class="text-sm text-slate-600">選擇此角色可以訪問的導航項目：</p>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-60 overflow-y-auto">
                                @if (ViewBag.Navigations != null)
                                {
                                    @foreach (var nav in ViewBag.Navigations)
                                    {
                                        var isChecked = false;
                                        if (ViewBag.RoleNavigationPermissions != null)
                                        {
                                            isChecked = ViewBag.RoleNavigationPermissions.Contains(nav.code);
                                        }
                                        <label class="flex items-center space-x-2 p-3 border border-slate-200 rounded-lg hover:bg-slate-50 cursor-pointer">
                                            <input type="checkbox" name="navigation_permissions" value="@nav.code" 
                                                   @(isChecked ? "checked" : "")
                                                   class="w-4 h-4 text-green-600 border-slate-300 rounded focus:ring-green-500" />
                                            <span class="text-sm text-slate-700">@nav.title</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="settings" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">狀態設定</h4>
                        </div>
                        <div>
                            <label for="is_active" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="toggle-right" class="w-4 h-4 inline mr-1"></i>角色狀態
                            </label>
                            <select id="is_active" name="is_active" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all">
                                <option value="true" @(ViewBag.Role?.is_active == true ? "selected" : "")>✓ 啟用</option>
                                <option value="false" @(ViewBag.Role?.is_active == false ? "selected" : "")>✗ 停用</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
        <div class="flex justify-end gap-4 px-8 py-6 border-t bg-slate-50">
            <button onclick="closeModal('roleFormModal')" class="px-6 py-3 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors font-medium">
                <i data-lucide="x" class="w-4 h-4 inline mr-2"></i>取消
            </button>
            <button type="button" class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium" onclick="submitRoleForm()">
                <i data-lucide="@(ViewBag.Role?.id > 0 ? "save" : "plus")" class="w-4 h-4 inline mr-2"></i>@(ViewBag.Role?.id > 0 ? "儲存變更" : "新增角色")
            </button>
        </div>
    </div>
</div>

<!-- 角色詳情查看視窗 -->
<div id="roleDetailModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
        <div class="flex items-center justify-between p-6 border-b">
            <h3 class="text-lg font-semibold">角色詳細資訊</h3>
            <div class="flex items-center space-x-2">
                <button onclick="showModal('roleDetailHelpModal')" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="操作說明">
                    <i data-lucide="help-circle" class="w-5 h-5"></i>
                </button>
                <button onclick="closeModal('roleDetailModal')" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="關閉">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
            @if (ViewBag.Role != null)
            {
                <div class="space-y-6">
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0 h-20 w-20">
                            <div class="h-20 w-20 rounded-full bg-purple-100 flex items-center justify-center">
                                <i data-lucide="shield" class="w-8 h-8 text-purple-600"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="text-xl font-semibold text-slate-900">@ViewBag.Role?.name</h4>
                            <p class="text-slate-600">@ViewBag.Role?.description</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">基本資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">角色名稱</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Role?.name</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">狀態</dt>
                                    <dd class="text-sm">
                                        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @(ViewBag.Role?.is_active == true ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                            @(ViewBag.Role?.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">權限類型</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Role?.status</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">建立時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Role?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">統計資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">組織</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Role?.organization_name</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">使用者數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Role?.user_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">權限數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Role?.permission_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">更新時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Role?.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Role?.notes))
                    {
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">備註</h5>
                            <p class="text-sm text-slate-600">@ViewBag.Role?.notes</p>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="flex justify-end gap-3 p-6 border-t bg-slate-50">
            <button onclick="closeModal('roleDetailModal')" class="px-4 py-2 bg-slate-300 text-slate-700 rounded-md hover:bg-slate-400">
                關閉
            </button>
            @if (ViewBag.Role != null)
            {
                <button onclick="closeModal('roleDetailModal'); showModal('roleFormModal')" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 flex items-center gap-2">
                    <i data-lucide="edit" class="w-4 h-4"></i>
                    編輯
                </button>
            }
        </div>
    </div>
</div>

<!-- 角色表單說明視窗 -->
<div id="roleFormHelpModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-green-500 p-2 rounded-lg">
                        <i data-lucide="help-circle" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">角色管理操作說明</h3>
                        <p class="text-sm text-green-100 mt-1">了解如何管理系統角色</p>
                    </div>
                </div>
                <button onclick="closeModal('roleFormHelpModal')" class="text-white hover:text-green-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-green-600"></i>基本操作
                    </h4>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>必填欄位</strong>：標示紅色星號 (*) 的欄位為必填</li>
                        <li>• <strong>角色名稱</strong>：系統中唯一識別角色的名稱</li>
                        <li>• <strong>權限類型</strong>：定義角色的權限範圍和等級</li>
                        <li>• <strong>狀態控制</strong>：啟用/停用角色以控制其可用性</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="shield" class="w-4 h-4 mr-2 text-blue-600"></i>欄位說明
                    </h4>
                    <div class="space-y-3 text-sm">
                        <div>
                            <p><strong>角色名稱：</strong>在系統中顯示的角色名稱，建議使用簡潔明確的名稱</p>
                            <p><strong>權限類型：</strong>定義角色的權限範圍，如「管理員」、「使用者」、「訪客」等</p>
                        </div>
                        <div>
                            <p><strong>角色描述：</strong>詳細說明角色的職責和權限範圍</p>
                            <p><strong>備註：</strong>額外的說明或特殊注意事項</p>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="navigation" class="w-4 h-4 mr-2 text-purple-600"></i>導航權限
                    </h4>
                    <div class="space-y-2 text-sm text-slate-600">
                        <p>• <strong>選擇權限</strong>：勾選此角色可以訪問的導航項目</p>
                        <p>• <strong>權限繼承</strong>：使用者將繼承所選角色的所有導航權限</p>
                        <p>• <strong>動態更新</strong>：權限變更會即時影響使用者的可訪問功能</p>
                    </div>
                </div>
                
                <div class="bg-green-50 rounded-lg p-4">
                    <h4 class="font-semibold text-green-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-green-700">
                        建議為不同層級的使用者建立對應的角色，並在描述中清楚說明每個角色的權限範圍，以便後續管理。
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeModal('roleFormHelpModal')" class="modal-close px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 角色詳情說明視窗 -->
<div id="roleDetailHelpModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-green-500 p-2 rounded-lg">
                        <i data-lucide="help-circle" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">角色詳情說明</h3>
                        <p class="text-sm text-green-100 mt-1">了解詳情頁面的操作方式</p>
                    </div>
                </div>
                <button onclick="closeModal('roleDetailHelpModal')" class="text-white hover:text-green-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-4">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-2 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-green-600"></i>操作說明
                    </h4>
                    <ul class="space-y-1 text-sm text-slate-600">
                        <li>• <strong>編輯</strong>：點擊「編輯」按鈕修改角色資訊</li>
                        <li>• <strong>關閉</strong>：點擊「關閉」按鈕或右上角 X 關閉視窗</li>
                        <li>• <strong>統計資訊</strong>：查看角色相關的使用者和權限數量</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-2 flex items-center">
                        <i data-lucide="eye" class="w-4 h-4 mr-2 text-blue-600"></i>資訊顯示
                    </h4>
                    <p class="text-sm text-slate-600">
                        此頁面顯示角色的完整資訊，包括基本資料、權限設定、統計資訊等。所有資訊均為唯讀，如需修改請點擊「編輯」按鈕。
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeModal('roleDetailHelpModal')" class="modal-close px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

<script>

// 提交角色表單
function submitRoleForm() {
    const formData = $("#FormDataRole").serialize();
    
    $.ajax({
        url: '@Url.Action("SubmitRole", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                closeModal('roleFormModal');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}
</script>

