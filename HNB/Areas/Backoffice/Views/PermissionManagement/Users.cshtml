@{
    ViewData["Title"] = "帳號管理 - 權限管理系統";
    ViewData["PageTitle"] = "帳號管理";
    ViewData["PageDescription"] = "管理系統使用者帳號與權限";
    ViewData["PageIcon"] = "users";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}



<section class="space-y-6">

    <!-- 控制面板 -->
    <div class="bg-white border rounded-xl p-6">
        <div class="flex flex-col lg:flex-row gap-4">
            <div class="flex-1">
                <div class="relative">
                    <input type="text" id="searchInput" placeholder="搜尋姓名或電子郵件..." 
                           class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3 top-3 text-slate-400"></i>
                </div>
            </div>
            <div class="flex gap-4">
                <select id="organizationFilter" class="px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有組織</option>
                    @if (ViewBag.Organizations != null)
                    {
                        @foreach (var org in ViewBag.Organizations)
                        {
                            <option value="@org.organization_name">@org.organization_name</option>
                        }
                    }
                </select>
                <select id="roleFilter" class="px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有角色</option>
                    @if (ViewBag.Roles != null)
                    {
                        @foreach (var role in ViewBag.Roles)
                        {
                            <option value="@role.name">@role.name</option>
                        }
                    }
                </select>
                <select id="statusFilter" class="px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有狀態</option>
                    <option value="true">啟用</option>
                    <option value="false">停用</option>
                </select>
                <button onclick="showUserAdd()" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 flex items-center gap-2">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    新增人員
                </button>
            </div>
        </div>
    </div>

    <!-- 人員列表 -->
    <div class="bg-white border rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table id="usersTable" class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">帳號</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">組織</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">角色</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">狀態</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">最後登入</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">建立時間</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">操作</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var user in ViewBag.Users)
                    {
                        <tr class="user-row hover:bg-slate-50 cursor-pointer" onclick="showUserDetails(@user.id)">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10">
                                        @if (!string.IsNullOrEmpty(user.avatar_url))
                                        {
                                            <img class="h-10 w-10 rounded-full" src="@user.avatar_url" alt="@user.full_name">
                                        }
                                        else
                                        {
                                            <div class="h-10 w-10 rounded-full bg-slate-200 flex items-center justify-center">
                                                <span class="text-slate-600 font-medium text-sm">@(user.full_name?.Substring(0, 1).ToUpper() ?? "?")</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-slate-900">@user.full_name</div>
                                        <div class="text-sm text-slate-500">@user.email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                @(user.organization_name ?? "未分配")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                @if (user.role_name != null)
                                {
                                    @if (user.role_name.Contains(","))
                                    {
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var role in user.role_name.Split(','))
                                            {
                                                <span class="inline-flex px-2 py-1 text-xs font-medium bg-purple-100 text-purple-800 rounded">@role.Trim()</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="inline-flex px-2 py-1 text-xs font-medium bg-purple-100 text-purple-800 rounded">@user.role_name</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-slate-400">未分配</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @(user.is_active == true ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                    @(user.is_active == true ? "啟用" : "停用")
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                @(user.last_login_at?.ToString("yyyy/MM/dd HH:mm") ?? "從未登入")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                @(user.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button class="text-red-600 hover:text-red-900" onclick="event.stopPropagation(); if(confirm('確定要刪除這個使用者嗎？')) deleteItem(@user.id);">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- 使用者模態框容器 -->
<div id="userModal" class=""></div>

@section Scripts {
    <script>
        let usersTable;

        $(document).ready(function() {
            lucide.createIcons();

            initializeDataTable();

            $('#searchInput').on('input', function() {
                usersTable.search(this.value).draw();
            });

            $('#organizationFilter, #roleFilter, #statusFilter').on('change', function() {
                applyFilters();
            });

        });

        function initializeDataTable() {
            usersTable = $('#usersTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/zh-HANT.json'
                },
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                order: [[5, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [6] }
                ],
                dom: 'rt<"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mt-4"<"text-sm text-slate-600"i><"flex items-center gap-2"p>>',
                initComplete: function() {
                    $('.dataTables_filter').hide();
                    $('.dataTables_length').hide();
                    
                    // 美化資訊顯示樣式
                    $('.dataTables_info').addClass('px-3 py-1 text-sm text-slate-600');
                    
                    // 美化分頁樣式
                    $('.dataTables_paginate').addClass('flex items-center space-x-1');
                    $('.dataTables_paginate .paginate_button').addClass('px-3 py-1 text-sm border border-slate-300 rounded-md hover:bg-slate-50 transition-colors');
                    $('.dataTables_paginate .paginate_button.current').addClass('bg-blue-600 text-white border-blue-600 hover:bg-blue-700');
                    $('.dataTables_paginate .paginate_button.disabled').addClass('opacity-50 cursor-not-allowed hover:bg-transparent');
                }
            });
        }

        function applyFilters() {
            const organizationFilter = $('#organizationFilter').val();
            const roleFilter = $('#roleFilter').val();
            const statusFilter = $('#statusFilter').val();

            $.fn.dataTable.ext.search.pop();

            if (organizationFilter || roleFilter || statusFilter) {
                $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                    const organization = data[1];
                    const role = data[2];
                    const status = data[3];

                    const matchesOrganization = !organizationFilter || organization.includes(organizationFilter);
                    const matchesRole = !roleFilter || role.includes(roleFilter);
                    const matchesStatus = !statusFilter || 
                        (statusFilter === 'true' && status.includes('啟用')) ||
                        (statusFilter === 'false' && status.includes('停用'));

                    return matchesOrganization && matchesRole && matchesStatus;
                });
            }

            usersTable.draw();
        }

        function showUserDetails(userId) {
            loadAndShowModal('user', userId, 'userDetailModal');
        }

        function showUserAdd() {
            loadAndShowModal('user', null, 'userFormModal');
        }

        function showUserEdit(userId) {
            loadAndShowModal('user', userId, 'userFormModal');
        }

        function loadAndShowModal(type, id, modalId) {
            $.ajax({
                url: '@Url.Action("LoadDetail", "PermissionManagement")',
                type: 'GET',
                data: { id: id },
                success: function(response) {
                    $('#userModal').html(response);
                    lucide.createIcons();
                    $('#' + modalId).removeClass('hidden');
                },
                error: function(xhr, status, error) {
                    $('#userModal').html(`
                        <div class="text-center py-4">
                            <i data-lucide="alert-circle" class="w-12 h-12 text-red-500 mx-auto mb-3"></i>
                            <p class="text-red-600">載入失敗，請稍後再試</p>
                            <p class="text-red-500 text-sm">錯誤: ${error}</p>
                        </div>
                    `);
                    lucide.createIcons();
                    $('#userModal').removeClass('hidden');
                }
            });
        }

        function deleteItem(id) {
            $.ajax({
                url: '@Url.Action("Delete", "PermissionManagement")',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (response.success) {
                        alert('刪除成功');
                        location.reload();
                    } else {
                        alert('刪除失敗：' + response.message);
                    }
                },
                error: function() {
                    alert('刪除失敗，請稍後再試');
                }
            });
        }

        $(document).on('click', '[data-modal-close]', function() {
            $('#userModal').addClass('hidden');
        });
    </script>
}