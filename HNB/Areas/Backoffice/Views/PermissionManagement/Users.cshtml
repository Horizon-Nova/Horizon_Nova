@{
    ViewData["Title"] = "帳號管理 - 權限管理系統";
    ViewData["PageTitle"] = "帳號管理";
    ViewData["PageDescription"] = "管理系統使用者帳號與權限";
    ViewData["PageIcon"] = "users";
    ViewData["HelpModalId"] = "userHelpModal";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="mb-3 mb-lg-4">
    @await Html.PartialAsync("Partials/Users/_Control")
    @await Html.PartialAsync("Partials/Users/_SearchResults")
</section>

@await Html.PartialAsync("Partials/Users/Modal/_FormData")
@await Html.PartialAsync("Partials/Users/Modal/_Help")
@await Html.PartialAsync("Partials/Users/Modal/_Permissions")

@section Scripts {
    @await Html.PartialAsync("Partials/Users/_Scripts")
}
