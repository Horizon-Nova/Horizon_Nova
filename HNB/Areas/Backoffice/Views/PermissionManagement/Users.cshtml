@model List<Models.HnbHnbBackoffice.vw_permission_user>
@{
    ViewData["Title"] = "帳號管理 - 權限管理系統";
    ViewData["PageTitle"] = "帳號管理";
    ViewData["PageDescription"] = "管理系統使用者帳號與權限";
    ViewData["PageIcon"] = "users";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="mb-3 mb-lg-4">

    <!-- 控制面板 -->
    <div class="bg-white border rounded-3 p-3 p-lg-4 mb-3 mb-lg-4">
        <div class="d-flex flex-column gap-3">
            <div class="w-100">
                <div class="position-relative">
                    <input type="text" id="searchInput" placeholder="搜尋姓名或電子郵件..."
                           class="form-control form-control-sm ps-5">
                    <i data-lucide="search" class="position-absolute top-50 translate-middle-y text-muted" style="left: 0.75rem; width: 1rem; height: 1rem;"></i>
                </div>
            </div>
            <div class="row g-2 g-lg-3">
                <div class="col-6 col-lg-3">
                    <select id="organizationFilter" class="form-select form-select-sm">
                        <option value="">所有組織</option>
                        @if (ViewBag.Organizations != null)
                        {
                            @foreach (var org in ViewBag.Organizations)
                            {
                                <option value="@org.organization_name">@org.organization_name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-6 col-lg-3">
                    <select id="roleFilter" class="form-select form-select-sm">
                        <option value="">所有角色</option>
                        @if (ViewBag.Roles != null)
                        {
                            @foreach (var role in ViewBag.Roles)
                            {
                                <option value="@role.name">@role.name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-6 col-lg-3">
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="">所有狀態</option>
                        <option value="true">啟用</option>
                        <option value="false">停用</option>
                    </select>
                </div>
                <div class="col-12 col-lg-3">
                    <button onclick="showModal('userFormModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: null, type: 'user'}, container: 'userModal'})" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2">
                        <i data-lucide="plus" style="width: 1rem; height: 1rem;"></i>
                        新增人員
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 人員列表 -->
    <table id="usersTable" class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>帳號</th>
                <th>組織</th>
                <th>角色</th>
                <th>狀態</th>
                <th class="d-none d-lg-table-cell">最後登入</th>
                <th class="d-none d-lg-table-cell">建立時間</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model ?? new List<Models.HnbHnbBackoffice.vw_permission_user>())
            {
                <tr style="cursor: pointer;" onclick="showModal('userDetailModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: @user.id, type: 'user'}, container: 'userModal'})">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="flex-shrink-0" style="width: 2.5rem; height: 2.5rem;">
                                @if (!string.IsNullOrEmpty(user.avatar_url))
                                {
                                    <img class="rounded-circle" style="width: 2.5rem; height: 2.5rem; object-fit: cover;" src="@user.avatar_url" alt="@user.full_name">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 2.5rem; height: 2.5rem;">
                                        <span class="text-secondary fw-medium small">@(user.full_name?.Substring(0, 1).ToUpper() ?? "?")</span>
                                    </div>
                                }
                            </div>
                            <div class="overflow-hidden">
                                <div class="fw-medium text-truncate">@user.full_name</div>
                                <div class="small text-muted text-truncate">@user.email</div>
                            </div>
                        </div>
                    </td>
                    <td>@(user.organization_name ?? "未分配")</td>
                    <td>
                        @if (string.IsNullOrEmpty(user.role_name))
                        {
                            <span class="text-muted">未分配</span>
                        }
                        else if (user.role_name.Contains(","))
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var role in user.role_name.Split(','))
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary text-nowrap">@role.Trim()</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-primary bg-opacity-10 text-primary text-nowrap">@user.role_name</span>
                        }
                    </td>
                    <td>
                        <span class="badge rounded-pill @(user.is_active == true ? "bg-success" : "bg-danger")">
                            @(user.is_active == true ? "啟用" : "停用")
                        </span>
                    </td>
                    <td class="small text-muted d-none d-lg-table-cell">@(user.last_login_at?.ToString("yyyy/MM/dd HH:mm") ?? "從未登入")</td>
                    <td class="small text-muted d-none d-lg-table-cell">@(user.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); if(confirm('確定要刪除這個使用者嗎？')) deleteItem(@user.id);">
                            <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</section>

@section Scripts {
    <script>
        let usersTable;

        $(document).ready(function() {
            window.lucide?.createIcons?.();

            initializeDataTable();

            $('#searchInput').on('input', function() {
                usersTable.search(this.value).draw();
            });

            $('#organizationFilter, #roleFilter, #statusFilter').on('change', function() {
                applyFilters();
            });

        });

        function initializeDataTable() {
            usersTable = HNBDataTable.init('#usersTable', {
                order: [[5, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [6] }
                ],
                initComplete: function() {
                    $('.dataTables_filter').hide();
                    $('.dataTables_length').hide();
                }
            });
        }

        function applyFilters() {
            const organizationFilter = $('#organizationFilter').val();
            const roleFilter = $('#roleFilter').val();
            const statusFilter = $('#statusFilter').val();

            $.fn.dataTable.ext.search.pop();

            if (organizationFilter || roleFilter || statusFilter) {
                $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                    const organization = data[1];
                    const role = data[2];
                    const status = data[3];

                    const matchesOrganization = !organizationFilter || organization.includes(organizationFilter);
                    const matchesRole = !roleFilter || role.includes(roleFilter);
                    const matchesStatus = !statusFilter ||
                        (statusFilter === 'true' && status.includes('啟用')) ||
                        (statusFilter === 'false' && status.includes('停用'));

                    return matchesOrganization && matchesRole && matchesStatus;
                });
            }

            usersTable.draw();
        }

        function deleteItem(id) {
            $.ajax({
                url: '@Url.Action("Delete", "PermissionManagement")',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (response.success) {
                        alert('刪除成功');
                        location.reload();
                    } else {
                        alert('刪除失敗：' + response.message);
                    }
                },
                error: function() {
                    alert('刪除失敗，請稍後再試');
                }
            });
        }

    </script>
}

<!-- Modal 容器 -->
<div id="userModal"></div>
