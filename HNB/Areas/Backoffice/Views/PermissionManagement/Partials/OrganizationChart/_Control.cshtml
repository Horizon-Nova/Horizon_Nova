@{
    Layout = null;
}

<div class="bg-white border rounded-3 p-3 p-lg-4 mb-3 mb-lg-4">
    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3">
        <div class="d-flex gap-2">
            <button id="btnResetView" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;"></i>
                重置視圖
            </button>
            <button id="btnFitToScreen" class="btn btn-success btn-sm d-flex align-items-center gap-2">
                <i data-lucide="maximize" style="width: 1rem; height: 1rem;"></i>
                適應螢幕
            </button>
        </div>
        <div class="d-flex gap-3">
            <div class="form-check">
                <input type="checkbox" id="showUserCount" checked class="form-check-input">
                <label class="form-check-label small" for="showUserCount">顯示人員數量</label>
            </div>
            <div class="form-check">
                <input type="checkbox" id="showRoleCount" checked class="form-check-input">
                <label class="form-check-label small" for="showRoleCount">顯示角色數量</label>
            </div>
        </div>
    </div>
</div>

