@{
    Layout = null;
}

<div id="organizationChartHelpModal" class="modal fade" tabindex="-1" aria-labelledby="organizationChartHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationChartHelpModalLabel">組織圖使用說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="vstack gap-3">
                            <section>
                                <h6 class="fw-semibold pb-2 border-bottom mb-3">功能說明</h6>
                                <p class="small mb-0">
                                    組織圖提供視覺化的層級展示，可快速掌握各單位的上下層關係、
                                    人員與角色負載情況，並支援即時節點詳情檢視與快速維護。
                                </p>
                            </section>

                            <section>
                                <h6 class="fw-semibold pb-2 border-bottom mb-3">操作指南</h6>
                                <ul class="small mb-0 ps-3">
                                    <li>拖曳畫面可移動視角，滑鼠滾輪可縮放圖表。</li>
                                    <li>點擊「重置視圖」回復預設位置與縮放倍率。</li>
                                    <li>點擊「適應螢幕」可自動計算最佳視角。</li>
                                    <li>勾選或取消「顯示人員數量 / 角色數量」切換額外資訊。</li>
                                    <li>點擊節點開啟組織詳細資訊視窗，可直接進行編輯。</li>
                                </ul>
                            </section>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="vstack gap-3">
                            <section>
                                <h6 class="fw-semibold pb-2 border-bottom mb-3">視覺提示</h6>
                                <ul class="small mb-0 ps-3">
                                    <li>藍色節點代表組織單位名稱。</li>
                                    <li>綠色文字顯示使用者數量，紫色文字顯示角色數量。</li>
                                    <li>連線由上而下呈現隸屬關係，節點間距可隨層級增減。</li>
                                </ul>
                            </section>

                            <section class="alert alert-info small mb-0">
                                <h6 class="fw-semibold mb-2">使用建議</h6>
                                <ul class="mb-0 ps-3">
                                    <li>遇到節點過多時，先利用「組織管理」篩選後再查看組織圖。</li>
                                    <li>利用節點詳情視窗的「編輯」快捷鍵，加速完成組織調整。</li>
                                    <li>建議定期檢查階層深度與人員負載，避免單位過度傾斜。</li>
                                </ul>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">我了解了</button>
            </div>
        </div>
    </div>
</div>
