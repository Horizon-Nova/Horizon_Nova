@{
    Layout = null;
}

<script>
    $(function () {
        $(document).off('click.userModal', '.js-submit-user-form')
            .on('click.userModal', '.js-submit-user-form', function () {
                submitUserForm();
            });

        $(document).off('click.userModal', '.js-edit-user-from-detail')
            .on('click.userModal', '.js-edit-user-from-detail', function () {
                const userId = $(this).data('userId');
                closeModal('userDetailModal');
        showModal('userFormModal', {
            url: '@Url.Action("LoadDetail", "PermissionManagement")',
            method: 'GET',
            data: { id: userId, type: 'user', view: 'form' },
            container: 'userFormModalContent'
        });
            });
    });

    function togglePassword() {
        const $passwordInput = $('#password_hash');
        const $eyeIcon = $('#password-eye');

        if ($passwordInput.attr('type') === 'password') {
            $passwordInput.attr('type', 'text');
            $eyeIcon.attr('data-lucide', 'eye-off');
        } else {
            $passwordInput.attr('type', 'password');
            $eyeIcon.attr('data-lucide', 'eye');
        }

        lucide.createIcons();
    }

    function submitUserForm() {
        const formElement = $('#FormDataUser')[0];

        if (!formElement.checkValidity()) {
            formElement.reportValidity();
            return;
        }

        const formData = $('#FormDataUser').serialize();

        $.ajax({
            url: '@Url.Action("SubmitUser", "PermissionManagement")',
            type: 'POST',
            data: formData,
            success: function (response) {
                if (response.success) {
                    alert(response.message);
                    location.reload();
                } else {
                    alert('操作失敗：' + (response.message || '系統錯誤'));
                }
            },
            error: function () {
                alert('提交失敗，請稍後再試');
            }
        });
    }
</script>


