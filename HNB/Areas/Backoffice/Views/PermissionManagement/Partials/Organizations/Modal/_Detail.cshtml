@{
    Layout = null;

    var organization = ViewBag.Organization as Models.HnbHnbBackoffice.vw_permission_organization;
}

<div id="organizationDetailModal" class="modal fade" tabindex="-1" aria-labelledby="organizationDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" id="organizationDetailModalContent">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationDetailModalLabel">組織詳細資訊</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body">
                @if (organization != null)
                {
                    <div class="vstack gap-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width: 5rem; height: 5rem;">
                                <i data-lucide="building" class="text-primary" style="width: 2rem; height: 2rem;"></i>
                            </div>
                            <div>
                                <h4 class="fs-5 fw-semibold mb-1">@organization.organization_name</h4>
                                <p class="text-muted mb-0">@organization.organization_description</p>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="fw-semibold mb-2">基本資訊</h6>
                                <table class="table table-sm table-borderless small mb-0">
                                    <tr>
                                        <td class="text-muted">組織名稱</td>
                                        <td>@organization.organization_name</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">層級</td>
                                        <td>@organization.organization_level</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">狀態</td>
                                        <td>
                                            <span class="badge rounded-pill @(organization.is_active == true ? "bg-success" : "bg-danger")">
                                                @(organization.is_active == true ? "啟用" : "停用")
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">上級組織</td>
                                        <td>@(organization.parent_organization_name ?? "根組織")</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">建立時間</td>
                                        <td>@(organization.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-semibold mb-2">統計資訊</h6>
                                <table class="table table-sm table-borderless small mb-0">
                                    <tr>
                                        <td class="text-muted">使用者數量</td>
                                        <td>@(organization.total_users_count ?? 0)</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">角色數量</td>
                                        <td>@(organization.total_roles_count ?? 0)</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">子組織數量</td>
                                        <td>@(organization.total_sub_organizations_count ?? 0)</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">更新時間</td>
                                        <td>@(organization.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(organization.public_notes))
                        {
                            <div>
                                <h6 class="fw-semibold mb-2">備註</h6>
                                <p class="small text-muted mb-0">@organization.public_notes</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mb-0" role="alert">
                        [提醒] 無法載入組織詳細資料，請稍後再試。
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
                @if (organization != null)
                {
                    <button type="button"
                            class="btn btn-primary btn-sm"
                            onclick="closeModal('organizationDetailModal'); showModal('organizationFormModal', { url: '@Url.Action("LoadOrganizationForm", "PermissionManagement")', method: 'GET', data: { id: @(organization.id ?? 0) }, container: 'organizationFormModalContent' })">
                        編輯
                    </button>
                }
            </div>
        </div>
    </div>
</div>

