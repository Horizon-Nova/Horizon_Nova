@{
    Layout = null;

    var role = ViewBag.Role as Models.HnbHnbBackoffice.vw_permission_role;

    var organizations = (IEnumerable<dynamic>)(ViewBag.Organizations ?? Enumerable.Empty<dynamic>());
    var navigationItems = (IEnumerable<dynamic>)(ViewBag.Navigations ?? Enumerable.Empty<dynamic>());
    var navigationList = navigationItems.ToList();
    var roleNavigationPermissions = (IEnumerable<string>)(ViewBag.RoleNavigationPermissions ?? new List<string>());

    var selectedNavigationCodes = new HashSet<string>(
        (role?.navigation_permissions ?? new List<string>())
            .Concat(roleNavigationPermissions ?? Enumerable.Empty<string>()),
        StringComparer.OrdinalIgnoreCase);

    var parentNavigations = navigationList
        .Where(nav => string.IsNullOrWhiteSpace((string?)nav.parent_code))
        .OrderBy(nav => (string?)(nav.title ?? string.Empty))
        .ToList();

    var childNavigations = navigationList
        .Where(nav => !string.IsNullOrWhiteSpace((string?)nav.parent_code))
        .GroupBy(nav => (string)nav.parent_code)
        .ToDictionary(g => g.Key, g => g.OrderBy(item => (string?)(item.title ?? string.Empty)).ToList());

    string SanitizeCode(string? code)
        => string.IsNullOrWhiteSpace(code)
            ? Guid.NewGuid().ToString("N")
            : new string(code.Select(ch => char.IsLetterOrDigit(ch) ? ch : '_').ToArray());

    var organizationId = role?.organization_id ?? role?.parent_id;
}

<div id="roleFormModal" class="modal fade" tabindex="-1" aria-labelledby="roleFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content" id="roleFormModalContent">
                <div class="modal-header">
                    <h5 class="modal-title" id="roleFormModalLabel">@(role?.id > 0 ? "編輯角色" : "新增角色")</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body p-4">
                <form id="FormDataRole" autocomplete="off">
                    <input type="hidden" name="id" value="@(role?.id ?? 0)" />

                    <div class="vstack gap-3">
                        <div>
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">角色基本資訊</h6>
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 110px;">
                                    <label for="name" class="col-form-label col-form-label-sm mb-0">角色名稱<span class="text-danger">*</span></label>
                                </div>
                                <div class="col">
                                    <input type="text"
                                           id="name"
                                           name="name"
                                           value="@(role?.name ?? string.Empty)"
                                           class="form-control form-control-sm"
                                           placeholder="請輸入角色名稱"
                                           required>
                                </div>
                            </div>
                            <div class="row g-2 align-items-center mt-2">
                                <div class="col-auto" style="width: 110px;">
                                    <label for="status" class="col-form-label col-form-label-sm mb-0">權限類型</label>
                                </div>
                                <div class="col">
                                    <input type="text"
                                           id="status"
                                           name="status"
                                           value="@(role?.status ?? string.Empty)"
                                           class="form-control form-control-sm"
                                           placeholder="請輸入權限類型">
                                </div>
                            </div>
                            <div class="row g-2 align-items-center mt-2">
                                <div class="col-auto" style="width: 110px;">
                                    <label for="parent_id" class="col-form-label col-form-label-sm mb-0">所屬組織<span class="text-danger">*</span></label>
                                </div>
                                <div class="col">
                                    <select id="parent_id" name="parent_id" class="form-select form-select-sm" required>
                                        <option value="">請選擇組織</option>
                                        @foreach (var org in organizations)
                                        {
                                            var id = (int?)org.id ?? 0;
                                            var isSelected = organizationId == id;
                                            <option value="@id" @(isSelected ? "selected" : string.Empty)>@((string?)(org.organization_name ?? string.Empty))</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div>
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">角色描述</h6>
                            <div class="row g-2 align-items-start">
                                <div class="col-auto" style="width: 110px;">
                                    <label for="description" class="col-form-label col-form-label-sm mb-0">角色描述</label>
                                </div>
                                <div class="col">
                                    <textarea id="description"
                                              name="description"
                                              rows="2"
                                              class="form-control form-control-sm"
                                              placeholder="請輸入角色描述和職責說明">@((role?.description) ?? string.Empty)</textarea>
                                </div>
                            </div>
                            <div class="row g-2 align-items-start mt-2">
                                <div class="col-auto" style="width: 110px;">
                                    <label for="notes" class="col-form-label col-form-label-sm mb-0">備註</label>
                                </div>
                                <div class="col">
                                    <textarea id="notes"
                                              name="notes"
                                              rows="2"
                                              class="form-control form-control-sm"
                                              placeholder="請輸入相關備註或特殊說明">@((role?.notes) ?? string.Empty)</textarea>
                                </div>
                            </div>
                        </div>

                        <div>
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">導航權限</h6>
                            @if (!navigationList.Any())
                            {
                                <div class="alert alert-warning mb-0" role="alert">
                                    [提醒] 尚無可指派的導航項目，請先建立導航。
                                </div>
                            }
                            else
                            {
                                <div class="border rounded-3 bg-white">
                                    <div class="p-2 border-bottom d-flex align-items-center justify-content-between">
                                        <span class="small text-muted">展開對應模組以勾選頁面權限，已勾選的模組會自動展開。</span>
                                    </div>
                                    <div class="nav-permissions-list vstack gap-2 p-2" style="max-height: 320px; overflow-y: auto;">
                                        @foreach (var parent in parentNavigations)
                                        {
                                            var parentCode = (string?)parent.code ?? string.Empty;
                                            var parentTitle = (string?)(parent.title ?? string.Empty);
                                            var children = childNavigations.ContainsKey(parentCode)
                                            ? childNavigations[parentCode]
                                            : new List<dynamic>();
                                            var isGroupSelected = selectedNavigationCodes.Contains(parentCode)
                                            || children.Any(child =>
                                            selectedNavigationCodes.Contains((string?)(child.code ?? string.Empty) ?? string.Empty));

                                            <details class="border rounded-3 bg-light-subtle"
                                                     @(isGroupSelected ? "open" : string.Empty)>
                                                <summary class="px-3 py-2 d-flex align-items-center justify-content-between">
                                                    <span class="fw-semibold text-primary">@parentTitle</span>
                                                    <span class="badge bg-secondary-subtle text-secondary">
                                                        @(children.Any() ? children.Count : 1) 項
                                                    </span>
                                                </summary>
                                                <div class="px-3 pb-3">
                                                    @if (children.Any())
                                                    {
                                                        <div class="row g-2">
                                                            @foreach (var child in children)
                                                            {
                                                                var code = (string?)child.code ?? string.Empty;
                                                                var title = (string?)(child.title ?? string.Empty);
                                                                var checkboxId = $"nav_{SanitizeCode(code)}";
                                                                var isChecked = selectedNavigationCodes.Contains(code);

                                                                <div class="col-12 col-md-6 col-lg-4">
                                                                    <div class="form-check form-check-sm">
                                                                        <input class="form-check-input"
                                                                               type="checkbox"
                                                                               id="@checkboxId"
                                                                               name="navigation_permissions"
                                                                               value="@code"
                                                                               @(isChecked ? "checked" : string.Empty)>
                                                                        <label class="form-check-label small" for="@checkboxId">@title</label>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        var checkboxId = $"nav_{SanitizeCode(parentCode)}";
                                                        var isChecked = selectedNavigationCodes.Contains(parentCode);

                                                        <div class="form-check form-check-sm">
                                                            <input class="form-check-input"
                                                                   type="checkbox"
                                                                   id="@checkboxId"
                                                                   name="navigation_permissions"
                                                                   value="@parentCode"
                                                                   @(isChecked ? "checked" : string.Empty)>
                                                            <label class="form-check-label small" for="@checkboxId">@parentTitle</label>
                                                        </div>
                                                    }
                                                </div>
                                            </details>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div>
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">狀態設定</h6>
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 110px;">
                                    <label for="is_active" class="col-form-label col-form-label-sm mb-0">角色狀態</label>
                                </div>
                                <div class="col">
                                    <select id="is_active" name="is_active" class="form-select form-select-sm">
                                        <option value="true" @((role?.is_active ?? true) ? "selected" : string.Empty)>啟用</option>
                                        <option value="false" @(role?.is_active == false ? "selected" : string.Empty)>停用</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="submitRoleFormData()">@(role?.id > 0 ? "儲存變更" : "新增角色")</button>
            </div>
        </div>
    </div>
</div>

