@model Models.HnbBackoffice.vw_permission_role?
@{
    Layout = null;

    var navigationItems = (IEnumerable<dynamic>)(ViewBag.Navigations ?? Enumerable.Empty<dynamic>());
    var navigationMap = navigationItems.ToDictionary(
        nav => (string)(nav.code ?? string.Empty),
        nav => (string)(nav.title ?? string.Empty),
        StringComparer.OrdinalIgnoreCase);

    var navigationCodes = new HashSet<string>(
        Model?.navigation_permissions ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);

    var navigationTitles = navigationCodes
        .Select(code => navigationMap.TryGetValue(code, out var title) ? title : code)
        .Where(title => !string.IsNullOrWhiteSpace(title))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
}

<div id="roleDetailModal" class="modal fade" tabindex="-1" aria-labelledby="roleDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" id="roleDetailModalContent">
            <div class="modal-header">
                <h5 class="modal-title" id="roleDetailModalLabel">角色詳細資訊</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body p-4">
                <div class="vstack gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="flex-shrink-0" style="width: 5rem; height: 5rem;">
                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                 style="width: 5rem; height: 5rem;">
                                <i data-lucide="shield" class="text-primary" style="width: 2rem; height: 2rem;"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="fs-5 fw-semibold mb-1">@(Model?.name ?? "未命名角色")</h4>
                            <p class="text-muted mb-0">@(Model?.description ?? "尚未提供描述")</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <h6 class="fw-semibold mb-2">基本資訊</h6>
                            <div class="vstack gap-2">
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">角色名稱</span>
                                    <span class="small">@(Model?.name ?? "-")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">狀態</span>
                                    <span class="small">
                                        <span class="badge rounded-pill @(Model?.is_active == true ? "bg-success bg-opacity-10 text-success" : "bg-danger bg-opacity-10 text-danger")">
                                            @(Model?.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">權限類型</span>
                                    <span class="small">@(Model?.status ?? "-")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">建立時間</span>
                                    <span class="small">@(Model?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-semibold mb-2">統計資訊</h6>
                            <div class="vstack gap-2">
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">所屬組織</span>
                                    <span class="small">@(Model?.organization_name ?? "未分配")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">人員數量</span>
                                    <span class="small">@((Model?.user_count ?? 0).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="small text-muted">權限數量</span>
                                    <span class="small">@((Model?.permission_count ?? 0).ToString("N0"))</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <h6 class="fw-semibold mb-2">導航權限</h6>
                            @if (navigationTitles.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var navTitle in navigationTitles)
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary text-nowrap">@navTitle</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="small text-muted">尚未指派導航權限</span>
                            }
                        </div>
                        <div class="col-12">
                            <h6 class="fw-semibold mb-2">備註</h6>
                            <p class="small text-muted mb-0">@(Model?.notes ?? "尚未填寫備註資訊")</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
                <button type="button"
                        class="btn btn-primary btn-sm"
                        onclick="closeModal('roleDetailModal'); showModal('roleFormModal', { url: '@Url.Action("LoadRoleForm", "PermissionManagement")', method: 'GET', data: { id: @(Model?.id ?? 0) }, container: 'roleFormModalContent' })">
                    編輯
                </button>
            </div>
        </div>
    </div>
</div>
