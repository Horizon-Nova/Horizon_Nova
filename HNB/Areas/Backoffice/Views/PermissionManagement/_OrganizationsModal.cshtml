@{
    Layout = null;
}

<!-- 組織表單彈出視窗 -->
<div id="organizationFormModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[95vh] overflow-hidden">
        <!-- 標題區域 -->
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-8 py-6 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="p-2 bg-white bg-opacity-20 rounded-lg">
                        <i data-lucide="building" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">@(ViewBag.Organization?.id > 0 ? "編輯組織" : "新增組織")</h3>
                        <p class="text-purple-100 text-sm">@(ViewBag.Organization?.id > 0 ? "修改組織結構設定" : "建立新的組織單位")</p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button onclick="showModal('organizationFormHelpModal')" class="text-white hover:text-purple-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="操作說明">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                    </button>
                    <button onclick="closeModal('organizationFormModal')" class="text-white hover:text-purple-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="關閉">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 表單內容 -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-180px)]">
            <form id="FormDataOrganization" autocomplete="off">
                <input type="hidden" name="id" value="@(ViewBag.Organization?.id ?? 0)" />
                
                <div class="space-y-8">
                    <!-- 基本資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="building" class="w-5 h-5 text-purple-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">組織基本資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="building" class="w-4 h-4 inline mr-1"></i>組織名稱 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" value="@(ViewBag.Organization?.organization_name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入組織名稱" required>
                            </div>
                            <div>
                                <label for="level" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="layers" class="w-4 h-4 inline mr-1"></i>組織層級 <span class="text-red-500">*</span>
                                </label>
                                <input type="number" id="level" name="level" value="@(ViewBag.Organization?.organization_level ?? 1)" min="1" max="10"
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入組織層級" required>
                            </div>
                        </div>
                        
                        <div class="mt-6">
                            <label for="parent_id" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="building-2" class="w-4 h-4 inline mr-1"></i>上級組織
                            </label>
                            <select id="parent_id" name="parent_id" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all">
                                <option value="">請選擇上級組織（可選）</option>
                                @if (ViewBag.Organizations != null)
                                {
                                    @foreach (var org in ViewBag.Organizations)
                                    {
                                        if (ViewBag.Organization?.id != org.id)
                                        {
                                            <option value="@org.id" @(ViewBag.Organization?.parent_id == org.id ? "selected" : "")>@org.organization_name</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <!-- 描述資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="file-text" class="w-5 h-5 text-blue-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">組織描述</h4>
                        </div>
                        <div class="space-y-6">
                            <div>
                                <label for="description" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="align-left" class="w-4 h-4 inline mr-1"></i>組織描述
                                </label>
                                <textarea id="description" name="description" rows="4" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入組織描述和職責說明">@(ViewBag.Organization?.organization_description ?? "")</textarea>
                            </div>
                            <div>
                                <label for="notes" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="sticky-note" class="w-4 h-4 inline mr-1"></i>備註
                                </label>
                                <textarea id="notes" name="notes" rows="3" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入相關備註或特殊說明">@(ViewBag.Organization?.public_notes ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 角色分配區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="users" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">角色分配</h4>
                        </div>
                        <div class="space-y-4">
                            <p class="text-sm text-slate-600">選擇要分配給此組織的角色（每個角色僅能分配給一個組織）：</p>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-60 overflow-y-auto">
                                @if (ViewBag.Roles != null)
                                {
                                    @foreach (var role in ViewBag.Roles)
                                    {
                                        var isChecked = false;
                                        var isOccupied = false;
                                        
                                        if (ViewBag.OrganizationRoles != null)
                                        {
                                            isChecked = ViewBag.OrganizationRoles.Contains(role.id.ToString());
                                        }
                                        
                                        // 檢查角色是否已被其他組織占用
                                        if (ViewBag.OccupiedRoleIds != null && ViewBag.OccupiedRoleIds.Contains(role.id.ToString()))
                                        {
                                            isOccupied = !isChecked; // 如果當前組織已擁有，則不算被占用
                                        }
                                        
                                        <label class="flex items-center space-x-2 p-3 border rounded-lg @(isOccupied ? "border-red-300 bg-red-50 cursor-not-allowed" : "border-slate-200 hover:bg-slate-50 cursor-pointer")">
                                            <input type="checkbox" name="assigned_roles" value="@role.id" 
                                                   @(isChecked ? "checked" : "")
                                                   @(isOccupied ? "disabled" : "")
                                                   class="w-4 h-4 text-purple-600 border-slate-300 rounded focus:ring-purple-500 @(isOccupied ? "opacity-50 cursor-not-allowed" : "")" />
                                            <span class="text-sm @(isOccupied ? "text-red-600" : "text-slate-700")">
                                                @role.name
                                                @if (isOccupied)
                                                {
                                                    <span class="text-xs text-red-500 ml-1">(已被占用)</span>
                                                }
                                            </span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="settings" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">狀態設定</h4>
                        </div>
                        <div>
                            <label for="is_active" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="toggle-right" class="w-4 h-4 inline mr-1"></i>組織狀態
                            </label>
                            <select id="is_active" name="is_active" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all">
                                <option value="true" @(ViewBag.Organization?.is_active == true ? "selected" : "")>✓ 啟用</option>
                                <option value="false" @(ViewBag.Organization?.is_active == false ? "selected" : "")>✗ 停用</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
        <div class="flex justify-end gap-4 px-8 py-6 border-t bg-slate-50">
            <button onclick="closeModal('organizationFormModal')" class="px-6 py-3 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors font-medium">
                <i data-lucide="x" class="w-4 h-4 inline mr-2"></i>取消
            </button>
            <button type="button" class="px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors font-medium" onclick="submitOrganizationForm()">
                <i data-lucide="@(ViewBag.Organization?.id > 0 ? "save" : "plus")" class="w-4 h-4 inline mr-2"></i>@(ViewBag.Organization?.id > 0 ? "儲存變更" : "新增組織")
            </button>
        </div>
    </div>
</div>

<!-- 組織詳情查看視窗 -->
<div id="organizationDetailModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
        <div class="flex items-center justify-between p-6 border-b">
            <h3 class="text-lg font-semibold">組織詳細資訊</h3>
            <div class="flex items-center space-x-2">
                <button onclick="showModal('organizationDetailHelpModal')" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="操作說明">
                    <i data-lucide="help-circle" class="w-5 h-5"></i>
                </button>
                <button onclick="closeModal('organizationDetailModal')" class="text-slate-400 hover:text-slate-600 p-2 rounded-lg hover:bg-slate-100" title="關閉">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
            @if (ViewBag.Organization != null)
            {
                <div class="space-y-6">
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0 h-20 w-20">
                            <div class="h-20 w-20 rounded-full bg-blue-100 flex items-center justify-center">
                                <i data-lucide="building" class="w-8 h-8 text-blue-600"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="text-xl font-semibold text-slate-900">@ViewBag.Organization?.organization_name</h4>
                            <p class="text-slate-600">@ViewBag.Organization?.organization_description</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">基本資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">組織名稱</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.organization_name</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">層級</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.organization_level</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">狀態</dt>
                                    <dd class="text-sm">
                                        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @(ViewBag.Organization?.is_active == true ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                            @(ViewBag.Organization?.is_active == true ? "啟用" : "停用")
                                        </span>
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">上級組織</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Organization?.parent_organization_name ?? "根組織")</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">建立時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Organization?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">統計資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">使用者數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.total_users_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">角色數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.total_roles_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">子組織數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.total_sub_organizations_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">更新時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Organization?.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Organization?.public_notes))
                    {
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">備註</h5>
                            <p class="text-sm text-slate-600">@ViewBag.Organization?.public_notes</p>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="flex justify-end gap-3 p-6 border-t bg-slate-50">
            <button onclick="closeModal('organizationDetailModal')" class="px-4 py-2 bg-slate-300 text-slate-700 rounded-md hover:bg-slate-400">
                關閉
            </button>
            @if (ViewBag.Organization != null)
            {
                <button onclick="closeModal('organizationDetailModal'); showModal('organizationFormModal')" class="px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700 flex items-center gap-2">
                    <i data-lucide="edit" class="w-4 h-4"></i>
                    編輯
                </button>
            }
        </div>
    </div>
</div>

<!-- 組織表單說明視窗 -->
<div id="organizationFormHelpModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-purple-500 p-2 rounded-lg">
                        <i data-lucide="help-circle" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">組織管理操作說明</h3>
                        <p class="text-sm text-purple-100 mt-1">了解如何管理組織架構</p>
                    </div>
                </div>
                <button onclick="closeModal('organizationFormHelpModal')" class="text-white hover:text-purple-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-purple-600"></i>基本操作
                    </h4>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>必填欄位</strong>：標示紅色星號 (*) 的欄位為必填</li>
                        <li>• <strong>組織名稱</strong>：組織單位的正式名稱</li>
                        <li>• <strong>組織層級</strong>：定義組織在階層中的位置（1-10級）</li>
                        <li>• <strong>狀態控制</strong>：啟用/停用組織以控制其可用性</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="building" class="w-4 h-4 mr-2 text-blue-600"></i>欄位說明
                    </h4>
                    <div class="space-y-3 text-sm">
                        <div>
                            <p><strong>組織名稱：</strong>組織單位的完整名稱，建議使用正式名稱</p>
                            <p><strong>組織層級：</strong>數字1-10，表示組織在階層中的層級，數字越小層級越高</p>
                        </div>
                        <div>
                            <p><strong>組織描述：</strong>詳細說明組織的職責、功能和業務範圍</p>
                            <p><strong>備註：</strong>額外的說明或特殊注意事項</p>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="users" class="w-4 h-4 mr-2 text-orange-600"></i>角色分配
                    </h4>
                    <div class="space-y-2 text-sm text-slate-600">
                        <p>• <strong>選擇角色</strong>：勾選要分配給此組織的角色</p>
                        <p>• <strong>唯一性規則</strong>：每個角色僅能分配給一個組織，已被占用的角色將顯示為紅色且無法選擇</p>
                        <p>• <strong>權限管理</strong>：組織內的使用者將可以使用分配的角色</p>
                        <p>• <strong>動態更新</strong>：角色分配變更會即時影響組織權限</p>
                    </div>
                </div>
                
                <div class="bg-purple-50 rounded-lg p-4">
                    <h4 class="font-semibold text-purple-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-purple-700">
                        建議根據實際組織架構設定層級，並在描述中清楚說明組織的職責範圍，以便後續進行人員分配和權限管理。
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeModal('organizationFormHelpModal')" class="modal-close px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 組織詳情說明視窗 -->
<div id="organizationDetailHelpModal" class="hidden fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center p-2 lg:p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-purple-500 p-2 rounded-lg">
                        <i data-lucide="help-circle" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">組織詳情說明</h3>
                        <p class="text-sm text-purple-100 mt-1">了解詳情頁面的操作方式</p>
                    </div>
                </div>
                <button onclick="closeModal('organizationDetailHelpModal')" class="text-white hover:text-purple-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-4">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-2 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-purple-600"></i>操作說明
                    </h4>
                    <ul class="space-y-1 text-sm text-slate-600">
                        <li>• <strong>編輯</strong>：點擊「編輯」按鈕修改組織資訊</li>
                        <li>• <strong>關閉</strong>：點擊「關閉」按鈕或右上角 X 關閉視窗</li>
                        <li>• <strong>統計資訊</strong>：查看組織相關的使用者、角色和子組織數量</li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-slate-800 mb-2 flex items-center">
                        <i data-lucide="eye" class="w-4 h-4 mr-2 text-green-600"></i>資訊顯示
                    </h4>
                    <p class="text-sm text-slate-600">
                        此頁面顯示組織的完整資訊，包括組織名稱、人員數量、角色數量、描述等。所有資訊均為唯讀，如需修改請點擊「編輯」按鈕。
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeModal('organizationDetailHelpModal')" class="modal-close px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

<script>

// 提交組織表單
function submitOrganizationForm() {
    const formData = $("#FormDataOrganization").serialize();
    
    $.ajax({
        url: '@Url.Action("SubmitOrganization", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                closeModal('organizationFormModal');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}
</script>

