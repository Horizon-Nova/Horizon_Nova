@{
    Layout = null;
}

<!-- 組織表單 Modal -->
<div id="organizationFormModal" class="modal fade" tabindex="-1" aria-labelledby="organizationFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationFormModalLabel">@(ViewBag.Organization?.id > 0 ? "編輯組織" : "新增組織")</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary js-open-organization-form-help">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                    </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-4">
            <form id="FormDataOrganization" autocomplete="off">
                <input type="hidden" name="id" value="@(ViewBag.Organization?.id ?? 0)" />
                
                    <div class="vstack gap-4">
                        <!-- 基本資訊 -->
                            <div>
                            <h6 class="fw-semibold pb-2 border-bottom mb-3">基本資訊</h6>
                            <div class="vstack gap-2">
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="name" class="col-form-label col-form-label-sm mb-0">組織名稱<span class="text-danger">*</span></label></div>
                                    <div class="col"><input type="text" id="name" name="name" value="@(ViewBag.Organization?.organization_name ?? "")" class="form-control form-control-sm" placeholder="請輸入組織名稱" required></div>
                                    <div class="col-auto" style="width: 90px;"><label for="level" class="col-form-label col-form-label-sm mb-0">組織層級<span class="text-danger">*</span></label></div>
                                    <div class="col"><input type="number" id="level" name="level" value="@(ViewBag.Organization?.organization_level ?? 1)" min="1" max="10" class="form-control form-control-sm" placeholder="1-10" required></div>
                            </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="parent_id" class="col-form-label col-form-label-sm mb-0">上級組織</label></div>
                                    <div class="col">
                                        <select id="parent_id" name="parent_id" class="form-select form-select-sm">
                                            <option value="">無（根組織）</option>
                                @if (ViewBag.Organizations != null)
                                {
                                    @foreach (var org in ViewBag.Organizations)
                                    {
                                        if (ViewBag.Organization?.id != org.id)
                                        {
                                            <option value="@org.id" @(ViewBag.Organization?.parent_id == org.id ? "selected" : "")>@org.organization_name</option>
                                        }
                                    }
                                }
                            </select>
                                    </div>
                                </div>
                        </div>
                    </div>

                        <!-- 描述資訊 -->
                            <div>
                            <h6 class="fw-semibold pb-2 border-bottom mb-3">描述資訊</h6>
                            <div class="vstack gap-2">
                                <div class="row g-2">
                                    <div class="col-auto" style="width: 90px;"><label for="description" class="col-form-label col-form-label-sm mb-0">組織描述</label></div>
                                    <div class="col"><textarea id="description" name="description" rows="3" class="form-control form-control-sm" placeholder="請輸入組織描述和職責說明">@(ViewBag.Organization?.organization_description ?? "")</textarea></div>
                            </div>
                                <div class="row g-2">
                                    <div class="col-auto" style="width: 90px;"><label for="notes" class="col-form-label col-form-label-sm mb-0">備註</label></div>
                                    <div class="col"><textarea id="notes" name="notes" rows="2" class="form-control form-control-sm" placeholder="請輸入相關備註或特殊說明">@(ViewBag.Organization?.public_notes ?? "")</textarea></div>
                            </div>
                        </div>
                    </div>

                        <!-- 狀態設定 -->
                        <div>
                            <h6 class="fw-semibold pb-2 border-bottom mb-3">狀態設定</h6>
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 90px;"><label for="is_active" class="col-form-label col-form-label-sm mb-0">組織狀態</label></div>
                                <div class="col">
                                    <select id="is_active" name="is_active" class="form-select form-select-sm">
                                        <option value="true" @(ViewBag.Organization?.is_active == true ? "selected" : "")>啟用</option>
                                        <option value="false" @(ViewBag.Organization?.is_active == false ? "selected" : "")>停用</option>
                            </select>
                                </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary btn-sm js-submit-organization-form">儲存</button>
            </div>
        </div>
    </div>
</div>

<!-- 組織詳情 Modal -->
<div id="organizationDetailModal" class="modal fade" tabindex="-1" aria-labelledby="organizationDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationDetailModalLabel">組織詳細資訊</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary js-open-organization-detail-help">
                        <i data-lucide="help-circle" style="width: 1rem; height: 1rem;"></i>
                </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
        </div>
            <div class="modal-body">
            @if (ViewBag.Organization != null)
            {
                    <div class="vstack gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 5rem; height: 5rem;">
                                <i data-lucide="building" class="text-primary" style="width: 2rem; height: 2rem;"></i>
                        </div>
                        <div>
                                <h4 class="fs-5 fw-semibold mb-1">@ViewBag.Organization?.organization_name</h4>
                                <p class="text-muted mb-0">@ViewBag.Organization?.organization_description</p>
                        </div>
                    </div>
                    
                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="fw-semibold mb-2">基本資訊</h6>
                                <table class="table table-sm table-borderless small">
                                    <tr><td class="text-muted">組織名稱</td><td>@ViewBag.Organization?.organization_name</td></tr>
                                    <tr><td class="text-muted">層級</td><td>@ViewBag.Organization?.organization_level</td></tr>
                                    <tr><td class="text-muted">狀態</td><td><span class="badge rounded-pill @(ViewBag.Organization?.is_active == true ? "bg-success" : "bg-danger")">@(ViewBag.Organization?.is_active == true ? "啟用" : "停用")</span></td></tr>
                                    <tr><td class="text-muted">上級組織</td><td>@(ViewBag.Organization?.parent_organization_name ?? "根組織")</td></tr>
                                    <tr><td class="text-muted">建立時間</td><td>@(ViewBag.Organization?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td></tr>
                                </table>
                                </div>
                            <div class="col-md-6">
                                <h6 class="fw-semibold mb-2">統計資訊</h6>
                                <table class="table table-sm table-borderless small">
                                    <tr><td class="text-muted">使用者數量</td><td>@ViewBag.Organization?.total_users_count</td></tr>
                                    <tr><td class="text-muted">角色數量</td><td>@ViewBag.Organization?.total_roles_count</td></tr>
                                    <tr><td class="text-muted">子組織數量</td><td>@ViewBag.Organization?.total_sub_organizations_count</td></tr>
                                    <tr><td class="text-muted">更新時間</td><td>@(ViewBag.Organization?.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td></tr>
                                </table>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Organization?.public_notes))
                    {
                        <div>
                                <h6 class="fw-semibold mb-2">備註</h6>
                                <p class="small text-muted mb-0">@ViewBag.Organization?.public_notes</p>
                        </div>
                    }
                </div>
            }
        </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
            @if (ViewBag.Organization != null)
            {
                    <button type="button" class="btn btn-primary btn-sm js-edit-organization-from-detail" data-organization-id="@ViewBag.Organization?.id">編輯</button>
            }
            </div>
        </div>
    </div>
</div>

<!-- 組織表單說明 Modal -->
<div id="organizationFormHelpModal" class="modal fade" tabindex="-1" aria-labelledby="organizationFormHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationFormHelpModalLabel">組織管理操作說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- 左側：說明內容 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 基本操作流程 -->
                    <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">基本操作流程</h6>
                                <ol class="small mb-0">
                                    <li>填寫組織名稱與層級（必填）</li>
                                    <li>選擇上級組織（可選，不選擇則為根組織）</li>
                                    <li>輸入組織描述與備註</li>
                                    <li>設定組織狀態（啟用/停用）</li>
                                    <li>點擊儲存完成新增或編輯</li>
                                </ol>
                    </div>
                            
                            <!-- 權限控制說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">權限控制說明</h6>
                                <div class="small">
                                    <p><strong>組織管理說明：</strong></p>
                                    <p>組織是權限系統的基礎架構，用於管理使用者與角色的歸屬關係。</p>
                                    <p class="mt-2"><strong>組織階層：</strong></p>
                                    <p>組織可以建立階層關係，上層組織可以管理下層組織的所有資源。</p>
            </div>
                </div>
                
                            <!-- 欄位說明 -->
                <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">欄位說明</h6>
                                <table class="table table-sm table-bordered small mb-0">
                                    <thead class="table-light">
                                        <tr><th>欄位</th><th>說明</th></tr>
                                    </thead>
                                    <tbody>
                                        <tr><td>組織名稱</td><td>組織單位的正式名稱（必填）</td></tr>
                                        <tr><td>組織層級</td><td>組織在階層中的位置，1-10（必填）</td></tr>
                                        <tr><td>上級組織</td><td>所屬的上級組織，不選則為根組織</td></tr>
                                        <tr><td>組織描述</td><td>詳細說明組織的職責和業務範圍</td></tr>
                                        <tr><td>備註</td><td>額外的說明或特殊注意事項</td></tr>
                                        <tr><td>組織狀態</td><td>控制組織是否可用</td></tr>
                                    </tbody>
                                </table>
                        </div>
                    </div>
                </div>
                
                    <!-- 右側：常見問題 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 常見問題 -->
                <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題 (Q&A)</h6>
                                <div class="small">
                                    <p><strong>Q1：組織層級有什麼作用？</strong></p>
                                    <p class="ms-3 mb-2">A：層級定義組織在架構中的位置，數字越小層級越高（1為最高層級）。</p>
                                    
                                    <p><strong>Q2：停用組織會發生什麼事？</strong></p>
                                    <p class="ms-3 mb-2">A：停用後，該組織將不會出現在選單中，但資料仍會保留。</p>
                                    
                                    <p><strong>Q3：如何建立子組織？</strong></p>
                                    <p class="ms-3 mb-2">A：在「上級組織」欄位選擇父組織，並設定適當的層級數字。</p>
                                    
                                    <p><strong>Q4：為什麼建立組織後沒有出現在清單中？</strong></p>
                                    <p class="ms-3 mb-2">A：請檢查組織狀態是否為「啟用」，以及是否符合當前的篩選條件。</p>
                    </div>
                </div>
                
                            <!-- 注意事項 -->
                            <div class="alert alert-warning small mb-0">
                                <h6 class="fw-bold mb-2">重要提醒</h6>
                                <ul class="mb-0">
                                    <li>組織名稱應具唯一性，避免混淆</li>
                                    <li>組織層級應符合實際架構（建議1-5層）</li>
                                    <li>上層組織可以管理下層組織的所有資源</li>
                                    <li>停用組織不會影響已存在的使用者與角色</li>
                                    <li>刪除組織前請先移除子組織與使用者</li>
                                </ul>
                            </div>
                        </div>
                </div>
            </div>
        </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

<!-- 組織詳情說明 Modal -->
<div id="organizationDetailHelpModal" class="modal fade" tabindex="-1" aria-labelledby="organizationDetailHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationDetailHelpModalLabel">組織詳情操作說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- 左側：說明內容 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                    <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">基本操作流程</h6>
                                <ol class="small mb-0">
                                    <li>查看組織完整資訊（名稱、層級、狀態等）</li>
                                    <li>檢視統計資訊（使用者數、角色數、子組織數）</li>
                                    <li>點擊「編輯」按鈕修改組織資料</li>
                                    <li>點擊「關閉」按鈕離開詳情頁</li>
                                </ol>
                </div>
                
                <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">資訊顯示說明</h6>
                                <div class="small">
                                    <p><strong>基本資訊：</strong>組織的基礎設定，包含名稱、層級、狀態、上級組織</p>
                                    <p><strong>統計資訊：</strong>組織相關的數據統計，包含使用者、角色、子組織數量</p>
                                    <p><strong>備註：</strong>組織的額外說明或特殊注意事項</p>
                                </div>
                </div>
            </div>
        </div>
        
                    <!-- 右側：常見問題 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題 (Q&A)</h6>
                                <div class="small">
                                    <p><strong>Q1：如何編輯組織資料？</strong></p>
                                    <p class="ms-3 mb-2">A：點擊右下角「編輯」按鈕即可進入編輯模式。</p>
                                    
                                    <p><strong>Q2：統計資訊多久更新一次？</strong></p>
                                    <p class="ms-3 mb-2">A：即時更新，每次開啟詳情頁都會顯示最新數據。</p>
                                    
                                    <p><strong>Q3：為什麼無法編輯組織？</strong></p>
                                    <p class="ms-3 mb-2">A：可能因為權限不足或組織已被停用。請聯絡系統管理員。</p>
                                </div>
                            </div>
                            
                            <div class="alert alert-info small mb-0">
                                <h6 class="fw-bold mb-2">提示</h6>
                                <ul class="mb-0">
                                    <li>詳情頁為唯讀，不可直接修改</li>
                                    <li>統計資訊包含所有子層級的數據</li>
                                    <li>點擊任意處可關閉詳情頁</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

<script>
(() => {
    const bindOrganizationModalHandlers = () => {
        $(document).off('click.organizationModal', '.js-open-organization-form-help')
            .on('click.organizationModal', '.js-open-organization-form-help', function (e) {
                e.preventDefault();
                showModal('organizationFormHelpModal');
            });

        $(document).off('click.organizationModal', '.js-open-organization-detail-help')
            .on('click.organizationModal', '.js-open-organization-detail-help', function (e) {
                e.preventDefault();
                showModal('organizationDetailHelpModal');
            });

        $(document).off('click.organizationModal', '.js-submit-organization-form')
            .on('click.organizationModal', '.js-submit-organization-form', function () {
                submitOrganizationForm();
            });

        $(document).off('click.organizationModal', '.js-edit-organization-from-detail')
            .on('click.organizationModal', '.js-edit-organization-from-detail', function () {
                const organizationId = $(this).data('organizationId');
                closeModal('organizationDetailModal');
                showModal('organizationFormModal', {
                    url: '@Url.Action("LoadDetail", "PermissionManagement")',
                    data: { id: organizationId, type: 'organization' },
                    
                });
            });
    };

    window.bindOrganizationModalHandlers = bindOrganizationModalHandlers;
    $(bindOrganizationModalHandlers);
})();

// 提交組織表單
function submitOrganizationForm() {
    const formData = $("#FormDataOrganization").serialize();
    
    $.ajax({
        type: 'POST',
        url: '@Url.Action("SubmitOrganization", "PermissionManagement")',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                closeModal('organizationFormModal');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: () => alert('提交失敗，請稍後再試')
    });
}
</script>
