@model Models.HnbHnbBackoffice.vw_permission_user

<!-- 使用者表單模態框 -->
<div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[95vh] overflow-hidden">
        <!-- 標題區域 -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="p-2 bg-white bg-opacity-20 rounded-lg">
                        <i data-lucide="user-plus" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">@(Model?.id > 0 ? "編輯人員" : "新增人員")</h3>
                        <p class="text-blue-100 text-sm">@(Model?.id > 0 ? "修改人員基本資訊" : "建立新的系統使用者")</p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button onclick="showUserFormHelp()" class="text-white hover:text-blue-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="操作說明">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                    </button>
                    <button data-modal-close class="text-white hover:text-blue-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="關閉">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 表單內容 -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-180px)]">
            <form id="FormData">
                <input type="hidden" name="id" value="@(Model?.id ?? 0)" />
                
                <div class="space-y-8">
                    <!-- 基本資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="user" class="w-5 h-5 text-blue-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">基本資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="user" class="w-4 h-4 inline mr-1"></i>姓名 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" value="@(Model?.full_name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入完整姓名" required>
                            </div>
                            <div>
                                <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="mail" class="w-4 h-4 inline mr-1"></i>電子郵件 <span class="text-red-500">*</span>
                                </label>
                                <input type="email" id="email" name="email" value="@(Model?.email ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="user@example.com" required>
                            </div>
                            <div>
                                <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="phone" class="w-4 h-4 inline mr-1"></i>電話
                                </label>
                                <input type="text" id="phone" name="phone" value="@(Model?.phone ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入聯絡電話">
                            </div>
                            <div>
                                <label for="gender" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="users" class="w-4 h-4 inline mr-1"></i>性別
                                </label>
                                <select id="gender" name="gender" 
                                        class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="">請選擇性別</option>
                                    <option value="male" @(Model?.gender == "male" ? "selected" : "")>男性</option>
                                    <option value="female" @(Model?.gender == "female" ? "selected" : "")>女性</option>
                                    <option value="other" @(Model?.gender == "other" ? "selected" : "")>其他</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- 帳號資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="key" class="w-5 h-5 text-green-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">帳號資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="username" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="at-sign" class="w-4 h-4 inline mr-1"></i>使用者名稱 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="username" name="username" value="@(Model?.username ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入使用者名稱" required>
                            </div>
                            <div>
                                <label for="password" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="lock" class="w-4 h-4 inline mr-1"></i>密碼 
                                    @if (Model?.id > 0)
                                    {
                                        <span class="text-slate-500 text-xs">(留空則不變更)</span>
                                    }
                                    else
                                    {
                                        <span class="text-red-500">*</span>
                                    }
                                </label>
                                <div class="relative">
                                    <input type="password" id="password" name="password" 
                                           class="w-full px-4 py-3 pr-12 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                           placeholder="@(Model?.id > 0 ? "留空則不變更密碼" : "請輸入密碼")" 
                                           @(Model?.id == 0 ? "required" : "")>
                                    <button type="button" onclick="togglePassword()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                                        <i data-lucide="eye" id="password-eye" class="w-5 h-5"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 個人資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="heart" class="w-5 h-5 text-pink-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">個人資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="nickname" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="smile" class="w-4 h-4 inline mr-1"></i>暱稱
                                </label>
                                <input type="text" id="nickname" name="nickname" value="@(Model?.nickname ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入暱稱">
                            </div>
                            <div>
                                <label for="zodiac_sign" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="star" class="w-4 h-4 inline mr-1"></i>星座
                                </label>
                                <input type="text" id="zodiac_sign" name="zodiac_sign" value="@(Model?.zodiac_sign ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入星座">
                            </div>
                            <div>
                                <label for="favorite_color" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="palette" class="w-4 h-4 inline mr-1"></i>喜歡顏色
                                </label>
                                <input type="text" id="favorite_color" name="favorite_color" value="@(Model?.favorite_color ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入喜歡的顏色">
                            </div>
                            <div>
                                <label for="location" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="map-pin" class="w-4 h-4 inline mr-1"></i>常駐地點
                                </label>
                                <input type="text" id="location" name="location" value="@(Model?.location ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入常駐地點">
                            </div>
                            <div class="col-span-full">
                                <label for="bio" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="file-text" class="w-4 h-4 inline mr-1"></i>個人簡介
                                </label>
                                <textarea id="bio" name="bio" rows="4" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入個人簡介或工作描述">@(Model?.bio ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 權限設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="shield" class="w-5 h-5 text-purple-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">權限設定</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="role_id" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="user-check" class="w-4 h-4 inline mr-1"></i>角色 <span class="text-red-500">*</span>
                                </label>
                                <select id="role_id" name="role_id" required
                                        class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="">請選擇角色</option>
                                    <!-- 角色選項將由 JavaScript 動態載入 -->
                                </select>
                            </div>
                            <div>
                                <label for="organization_id" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="building" class="w-4 h-4 inline mr-1"></i>組織 <span class="text-red-500">*</span>
                                </label>
                                <select id="organization_id" name="organization_id" required
                                        class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                    <option value="">請選擇組織</option>
                                    <!-- 組織選項將由 JavaScript 動態載入 -->
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="settings" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">狀態設定</h4>
                        </div>
                        <div>
                            <label for="is_active" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="toggle-right" class="w-4 h-4 inline mr-1"></i>帳號狀態
                            </label>
                            <select id="is_active" name="is_active" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                <option value="true" @(Model?.is_active == true ? "selected" : "")>✓ 啟用</option>
                                <option value="false" @(Model?.is_active == false ? "selected" : "")>✗ 停用</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
        <div class="flex justify-end gap-4 px-8 py-6 border-t bg-slate-50">
            <button data-modal-close class="px-6 py-3 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors font-medium">
                <i data-lucide="x" class="w-4 h-4 inline mr-2"></i>取消
            </button>
            <button type="button" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" onclick="submitUserForm()">
                <i data-lucide="@(Model?.id > 0 ? "save" : "plus")" class="w-4 h-4 inline mr-2"></i>@(Model?.id > 0 ? "儲存變更" : "新增人員")
            </button>
        </div>
    </div>
</div>

<script>
function togglePassword() {
    const passwordInput = document.getElementById('password');
    const eyeIcon = document.getElementById('password-eye');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        eyeIcon.setAttribute('data-lucide', 'eye-off');
    } else {
        passwordInput.type = 'password';
        eyeIcon.setAttribute('data-lucide', 'eye');
    }
    
    // 重新初始化 Lucide 圖標
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
}

function showUserFormHelp() {
    // 檢查是否已經有說明視窗存在
    if (document.querySelector('.z-\\[9999\\]')) {
        return; // 如果已存在，直接返回
    }
    
    $.ajax({
        url: '@Url.Action("LoadHelp", "PermissionManagement")',
        type: 'GET',
        data: { type: 'userform' },
        success: function(response) {
            document.body.insertAdjacentHTML('beforeend', response);
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        },
        error: function() {
            alert('載入說明失敗，請稍後再試');
        }
    });
}

function closeHelp() {
    const helpModal = document.querySelector('.z-\\[9999\\]');
    if (helpModal) {
        helpModal.remove();
    }
}

// 載入角色和組織選項
function loadUserOptions() {
    $.ajax({
        url: '@Url.Action("LoadUserOptions", "PermissionManagement")',
        type: 'GET',
        success: function(response) {
            if (response.success) {
                // 載入角色選項
                const roleSelect = document.getElementById('role_id');
                if (roleSelect) {
                    // 清空現有選項（保留預設選項）
                    roleSelect.innerHTML = '<option value="">請選擇角色</option>';
                    
                    // 添加角色選項
                    response.roles.forEach(function(role) {
                        const option = document.createElement('option');
                        option.value = role.id;
                        option.textContent = role.name;
                        roleSelect.appendChild(option);
                    });
                    
                    // 設定預設選中的角色
                    const selectedRoleId = '@ViewBag.SelectedRoleId';
                    if (selectedRoleId) {
                        roleSelect.value = selectedRoleId;
                    }
                }
                
                // 載入組織選項
                const orgSelect = document.getElementById('organization_id');
                if (orgSelect) {
                    // 清空現有選項（保留預設選項）
                    orgSelect.innerHTML = '<option value="">請選擇組織</option>';
                    
                    // 添加組織選項
                    response.organizations.forEach(function(org) {
                        const option = document.createElement('option');
                        option.value = org.id;
                        option.textContent = org.name;
                        orgSelect.appendChild(option);
                    });
                    
                    // 設定預設選中的組織
                    const selectedOrgId = '@ViewBag.SelectedOrganizationId';
                    if (selectedOrgId) {
                        orgSelect.value = selectedOrgId;
                    }
                }
            }
        },
        error: function() {
            console.error('載入選項失敗');
        }
    });
}

// 提交使用者表單
function submitUserForm() {
    // 使用 FormData 和 serialize() 方法
    const formData = new FormData(document.getElementById('FormData'));
    
    // 特別處理 textarea 欄位
    const bioTextarea = document.getElementById('bio');
    if (bioTextarea) {
        formData.append('bio', bioTextarea.value);
    }
    
    // 添加類型標識
    formData.append('type', 'user');
    
    $.ajax({
        url: '@Url.Action("SaveData", "PermissionManagement")',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                // 關閉模態框並重新載入頁面
                $('#userModal').addClass('hidden');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}

// 頁面載入時執行
$(document).ready(function() {
    loadUserOptions();
});
</script>
