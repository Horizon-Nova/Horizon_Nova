@model List<Models.HnbHnbBackoffice.vw_permission_role>
@{
    ViewData["Title"] = "角色管理 - 權限管理系統";
    ViewData["PageTitle"] = "角色管理";
    ViewData["PageDescription"] = "管理系統角色與權限設定";
    ViewData["PageIcon"] = "shield";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="mb-3 mb-lg-4">
    <!-- 控制面板 -->
    <div class="bg-white border rounded-3 p-3 p-lg-4 mb-3 mb-lg-4">
        <div class="d-flex flex-column gap-3">
            <div class="w-100">
                <div class="position-relative">
                    <input type="text" id="searchInput" placeholder="搜尋角色名稱..."
                           class="form-control form-control-sm ps-5">
                    <i data-lucide="search" class="position-absolute top-50 translate-middle-y text-muted" style="left: 0.75rem; width: 1rem; height: 1rem;"></i>
                </div>
            </div>
            <div class="row g-2 g-lg-3">
                <div class="col-6 col-lg-4">
                    <select id="organizationFilter" class="form-select form-select-sm">
                        <option value="">所有組織</option>
                        @if (ViewBag.Organizations != null)
                        {
                            @foreach (var org in ViewBag.Organizations)
                            {
                                <option value="@org.organization_name">@org.organization_name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-6 col-lg-4">
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="">所有狀態</option>
                        <option value="true">啟用</option>
                        <option value="false">停用</option>
                    </select>
                </div>
                <div class="col-12 col-lg-4">
                    <button onclick="showModal('roleFormModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: null, type: 'role'}, container: 'roleModal'})" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2">
                        <i data-lucide="plus" style="width: 1rem; height: 1rem;"></i>
                        新增角色
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 角色列表 -->
    <table id="rolesTable" class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>角色</th>
                <th>組織</th>
                <th class="d-none d-lg-table-cell">等級</th>
                <th>狀態</th>
                <th class="d-none d-lg-table-cell">人員數量</th>
                <th class="d-none d-lg-table-cell">建立時間</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model ?? new List<Models.HnbHnbBackoffice.vw_permission_role>())
            {
                    <tr style="cursor: pointer;" onclick="showModal('roleDetailModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: @role.id, type: 'role'}, container: 'roleModal'})">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="flex-shrink-0" style="width: 2.5rem; height: 2.5rem;">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 2.5rem; height: 2.5rem;">
                                    <i data-lucide="shield" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                                </div>
                            </div>
                            <div class="overflow-hidden">
                                <div class="fw-medium text-truncate">@role.name</div>
                                <div class="small text-muted text-truncate">@role.description</div>
                            </div>
                        </div>
                    </td>
                    <td>@(role.organization_name ?? "未分配")</td>
                    <td class="d-none d-lg-table-cell">@(role.level ?? 1)</td>
                    <td>
                        <span class="badge rounded-pill @(role.is_active == true ? "bg-success" : "bg-danger")">
                            @(role.is_active == true ? "啟用" : "停用")
                        </span>
                    </td>
                    <td class="d-none d-lg-table-cell">@(role.user_count ?? 0)</td>
                    <td class="small text-muted d-none d-lg-table-cell">@(role.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); if(confirm('確定要刪除這個角色嗎？')) deleteItem(@role.id);">
                            <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</section>

@section Scripts {
    <script>
        let rolesTable;

        $(document).ready(function() {
            // 初始化圖標
            window.lucide?.createIcons?.();

            // 初始化 DataTable
            initializeDataTable();

            // 綁定篩選事件
            $('#searchInput').on('input', function() {
                rolesTable.search(this.value).draw();
            });

            $('#organizationFilter, #statusFilter').on('change', function() {
                applyFilters();
            });

        });

        function initializeDataTable() {
            rolesTable = HNBDataTable.init('#rolesTable', {
                order: [[5, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [6] }
                ],
                initComplete: function() {
                    // 隱藏預設的搜尋和長度選擇器（使用自定義篩選器）
                    $('.dataTables_filter').hide();
                    $('.dataTables_length').hide();
                }
            });
        }

        function applyFilters() {
            const organizationFilter = $('#organizationFilter').val();
            const statusFilter = $('#statusFilter').val();

            $.fn.dataTable.ext.search.pop(); // 清除之前的篩選

            if (organizationFilter || statusFilter) {
                $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                    const organization = data[1]; // 組織欄位
                    const status = data[3]; // 狀態欄位

                    const matchesOrganization = !organizationFilter || organization.includes(organizationFilter);
                    const matchesStatus = !statusFilter ||
                        (statusFilter === 'true' && status.includes('啟用')) ||
                        (statusFilter === 'false' && status.includes('停用'));

                    return matchesOrganization && matchesStatus;
                });
            }

            rolesTable.draw();
        }

        function deleteItem(id) {
            $.ajax({
                url: '@Url.Action("Delete", "PermissionManagement")',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (response.success) {
                        alert('刪除成功');
                        location.reload();
                    } else {
                        alert('刪除失敗：' + response.message);
                    }
                },
                error: function() {
                    alert('刪除失敗，請稍後再試');
                }
            });
        }

    </script>
}

<!-- Modal 容器 -->
<div id="roleModal"></div>