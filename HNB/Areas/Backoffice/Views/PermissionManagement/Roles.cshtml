@{
    ViewData["Title"] = "角色管理 - 權限管理系統";
    ViewData["PageTitle"] = "角色管理";
    ViewData["PageDescription"] = "管理系統角色與權限設定";
    ViewData["PageIcon"] = "shield";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@model IEnumerable<Models.HnbHnbBackoffice.vw_permission_role>

@await Html.PartialAsync("../Settings/_HelpDetail")

<section class="space-y-6">

    <!-- 控制面板 -->
    <div class="bg-white border rounded-xl p-6">
        <div class="flex flex-col lg:flex-row gap-4">
            <div class="flex-1">
                <div class="relative">
                    <input type="text" id="searchInput" placeholder="搜尋角色名稱..." 
                           class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3 top-3 text-slate-400"></i>
                </div>
            </div>
            <div class="flex gap-4">
                <select id="organizationFilter" class="px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有組織</option>
                    <!-- 組織選項將由 JavaScript 動態載入 -->
                </select>
                <select id="statusFilter" class="px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有狀態</option>
                    <option value="true">啟用</option>
                    <option value="false">停用</option>
                </select>
                <button onclick="showRoleAdd()" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 flex items-center gap-2">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    新增角色
                </button>
            </div>
        </div>
    </div>

    <!-- 角色列表 -->
    <div class="bg-white border rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">角色</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">組織</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">等級</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">狀態</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">人員數量</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">建立時間</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">操作</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    @foreach (var role in Model)
                    {
                        <tr class="role-row hover:bg-slate-50 cursor-pointer" onclick="showRoleDetails(@role.id)">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10">
                                        <div class="h-10 w-10 rounded-full bg-purple-100 flex items-center justify-center">
                                            <i data-lucide="shield" class="w-5 h-5 text-purple-600"></i>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-slate-900">@role.name</div>
                                        <div class="text-sm text-slate-500">@role.name</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                @(role.organization_name ?? "未分配")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                1
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @(role.is_active == true ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                    @(role.is_active == true ? "啟用" : "停用")
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                @(role.user_count ?? 0)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                @(role.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button class="text-red-600 hover:text-red-900 delete-role-btn" data-role-id="@role.id" onclick="event.stopPropagation();">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- 引入所有彈出視窗模板 -->
<!-- 角色模態框容器 -->
<div id="roleModal" class="hidden"></div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // 初始化圖標
            lucide.createIcons();

            // 搜尋功能
            $('#searchInput').on('input', filterRoles);
            $('#organizationFilter, #statusFilter').on('change', filterRoles);

            // 新增角色按鈕
            $('#btnAddRole').on('click', function() {
                showRoleAdd();
            });

            // 刪除按鈕事件
            $('.delete-role-btn').on('click', function() {
                const roleId = $(this).data('role-id');
                if (confirm('確定要刪除這個角色嗎？')) {
                    deleteRole(roleId);
                }
            });
        });

        function filterRoles() {
            const searchTerm = $('#searchInput').val().toLowerCase();
            const organizationFilter = $('#organizationFilter').val();
            const statusFilter = $('#statusFilter').val();

            $('.role-row').each(function() {
                const $row = $(this);
                const roleName = $row.find('td:first .text-sm.font-medium').text().toLowerCase();
                const organization = $row.find('td:nth-child(2)').text();
                const status = $row.find('td:nth-child(4) .rounded-full').text();

                const matchesSearch = roleName.includes(searchTerm);
                const matchesOrganization = !organizationFilter || organization === organizationFilter;
                const matchesStatus = !statusFilter || 
                    (statusFilter === 'true' && status === '啟用') ||
                    (statusFilter === 'false' && status === '停用');

                if (matchesSearch && matchesOrganization && matchesStatus) {
                    $row.show();
                } else {
                    $row.hide();
                }
            });
        }

        function showRoleDetails(roleId) {
            showRoleDetail(roleId);
        }

        function showRoleAdd() {
            $.ajax({
                url: '@Url.Action("LoadForm", "PermissionManagement")',
                type: 'GET',
                data: { type: 'role', formAction: 'add' },
                success: function(response) {
                    $('#roleModal').html(response);
                    lucide.createIcons();
                    $('#roleModal').removeClass('hidden');
                },
                error: function() {
                    $('#roleModal').html(`
                        <div class="text-center py-4">
                            <i data-lucide="alert-circle" class="w-12 h-12 text-red-500 mx-auto mb-3"></i>
                            <p class="text-red-600">載入失敗，請稍後再試</p>
                        </div>
                    `);
                    lucide.createIcons();
                    $('#roleModal').removeClass('hidden');
                }
            });
        }

        function showRoleDetail(roleId) {
            $.ajax({
                url: '@Url.Action("LoadRoleDetails", "PermissionManagement")',
                type: 'GET',
                data: { id: roleId },
                success: function(response) {
                    $('#roleModal').html(response);
                    lucide.createIcons();
                    $('#roleModal').removeClass('hidden');
                    $('#roleModal').data('role-id', roleId);
                },
                error: function() {
                    $('#roleModal').html(`
                        <div class="text-center py-4">
                            <i data-lucide="alert-circle" class="w-12 h-12 text-red-500 mx-auto mb-3"></i>
                            <p class="text-red-600">載入失敗，請稍後再試</p>
                        </div>
                    `);
                    lucide.createIcons();
                    $('#roleModal').removeClass('hidden');
                }
            });
        }

        function showRoleEdit(roleId) {
            $.ajax({
                url: '@Url.Action("LoadForm", "PermissionManagement")',
                type: 'GET',
                data: { type: 'role', formAction: 'edit', id: roleId },
                success: function(response) {
                    $('#roleModal').html(response);
                    lucide.createIcons();
                    $('#roleModal').removeClass('hidden');
                },
                error: function() {
                    $('#roleModal').html(`
                        <div class="text-center py-4">
                            <i data-lucide="alert-circle" class="w-12 h-12 text-red-500 mx-auto mb-3"></i>
                            <p class="text-red-600">載入失敗，請稍後再試</p>
                        </div>
                    `);
                    lucide.createIcons();
                    $('#roleModal').removeClass('hidden');
                }
            });
        }

        function deleteRole(roleId) {
            $.ajax({
                url: '@Url.Action("DeleteRole", "PermissionManagement")',
                type: 'POST',
                data: { id: roleId },
                success: function(response) {
                    if (response.success) {
                        alert('角色刪除成功');
                        location.reload();
                    } else {
                        alert('刪除失敗：' + response.message);
                    }
                },
                error: function() {
                    alert('刪除失敗，請稍後再試');
                }
            });
        }

        // 模態框關閉事件（動態綁定）
        $(document).on('click', '[data-modal-close]', function() {
            $('#roleModal').addClass('hidden');
        });
    </script>
}