@model Models.HnbHnbBackoffice.vw_permission_organization

<!-- 組織表單模態框 -->
<div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[95vh] overflow-hidden">
        <!-- 標題區域 -->
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-8 py-6 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="p-2 bg-white bg-opacity-20 rounded-lg">
                        <i data-lucide="building" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">@(Model?.id > 0 ? "編輯組織" : "新增組織")</h3>
                        <p class="text-purple-100 text-sm">@(Model?.id > 0 ? "修改組織結構設定" : "建立新的組織單位")</p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button onclick="showHelpModal('organization-form-help')" class="text-white hover:text-purple-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="操作說明">
                        <i data-lucide="help-circle" class="w-5 h-5"></i>
                    </button>
                    <button data-modal-close class="text-white hover:text-purple-200 transition-colors p-2 rounded-lg hover:bg-white hover:bg-opacity-10" title="關閉">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 表單內容 -->
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-180px)]">
            <form id="FormData">
                <input type="hidden" name="id" value="@(Model?.id ?? 0)" />
                
                <div class="space-y-8">
                    <!-- 基本資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="building" class="w-5 h-5 text-purple-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">組織基本資訊</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="building" class="w-4 h-4 inline mr-1"></i>組織名稱 <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" value="@(Model?.name ?? "")" 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入組織名稱" required>
                            </div>
                            <div>
                                <label for="level" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="layers" class="w-4 h-4 inline mr-1"></i>組織層級 <span class="text-red-500">*</span>
                                </label>
                                <input type="number" id="level" name="level" value="@(Model?.level ?? 1)" min="1" max="10"
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all" 
                                       placeholder="請輸入組織層級" required>
                            </div>
                        </div>
                    </div>

                    <!-- 描述資訊區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="file-text" class="w-5 h-5 text-blue-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">組織描述</h4>
                        </div>
                        <div class="space-y-6">
                            <div>
                                <label for="description" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="align-left" class="w-4 h-4 inline mr-1"></i>組織描述
                                </label>
                                <textarea id="description" name="description" rows="4" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入組織描述和職責說明">@(Model?.description ?? "")</textarea>
                            </div>
                            <div>
                                <label for="notes" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i data-lucide="sticky-note" class="w-4 h-4 inline mr-1"></i>備註
                                </label>
                                <textarea id="notes" name="notes" rows="3" 
                                          class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all resize-none" 
                                          placeholder="請輸入相關備註或特殊說明">@(Model?.notes ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 角色管理區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="users" class="w-5 h-5 text-green-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">角色管理</h4>
                        </div>
                        <div>
                            <label for="assigned_roles" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="shield" class="w-4 h-4 inline mr-1"></i>分配角色
                            </label>
                            <div id="available_roles_container" class="space-y-2 max-h-48 overflow-y-auto border border-slate-300 rounded-lg p-3 bg-white">
                                <!-- 可用角色選項將由 JavaScript 動態載入 -->
                            </div>
                            <input type="hidden" id="assigned_roles" name="assigned_roles" value="">
                            <p class="text-xs text-slate-500 mt-1">選擇要分配給此組織的角色（只能選擇未分配的角色）</p>
                        </div>
                    </div>

                    <!-- 狀態設定區塊 -->
                    <div class="bg-slate-50 rounded-xl p-6">
                        <div class="flex items-center space-x-2 mb-4">
                            <i data-lucide="settings" class="w-5 h-5 text-orange-600"></i>
                            <h4 class="text-lg font-semibold text-slate-800">狀態設定</h4>
                        </div>
                        <div>
                            <label for="is_active" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i data-lucide="toggle-right" class="w-4 h-4 inline mr-1"></i>組織狀態
                            </label>
                            <select id="is_active" name="is_active" 
                                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all">
                                <option value="true" @(Model?.is_active == true ? "selected" : "")>✓ 啟用</option>
                                <option value="false" @(Model?.is_active == false ? "selected" : "")>✗ 停用</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- 底部按鈕區域 -->
        <div class="flex justify-end gap-4 px-8 py-6 border-t bg-slate-50">
            <button data-modal-close class="px-6 py-3 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors font-medium">
                <i data-lucide="x" class="w-4 h-4 inline mr-2"></i>取消
            </button>
            <button type="button" class="px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors font-medium" onclick="submitOrganizationForm()">
                <i data-lucide="@(Model?.id > 0 ? "save" : "plus")" class="w-4 h-4 inline mr-2"></i>@(Model?.id > 0 ? "儲存變更" : "新增組織")
            </button>
        </div>
    </div>
</div>

<script>
function showOrganizationFormHelp() {
    if (document.querySelector('.z-\\[9999\\]')) {
        return;
    }
    
    $.ajax({
        url: '@Url.Action("LoadHelp", "PermissionManagement")',
        type: 'GET',
        data: { type: 'organizationform' },
        success: function(response) {
            document.body.insertAdjacentHTML('beforeend', response);
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        },
        error: function() {
            alert('載入說明失敗，請稍後再試');
        }
    });
}

function closeHelp() {
    const helpModal = document.querySelector('.z-\\[9999\\]');
    if (helpModal) {
        helpModal.remove();
    }
}

// 載入可用角色
function loadAvailableRoles() {
    $.ajax({
        url: '@Url.Action("GetAvailableRoles", "PermissionManagement")',
        type: 'GET',
        data: { organizationId: @(Model?.id ?? 0) },
        success: function(response) {
            if (response.success) {
                const container = document.getElementById('available_roles_container');
                if (container) {
                    container.innerHTML = '';
                    
                    // 取得當前組織已分配的角色
                    const currentRoles = [];
                    
                    response.roles.forEach(function(role) {
                        const isChecked = currentRoles.includes(role.name);
                        
                        const checkboxDiv = document.createElement('div');
                        checkboxDiv.className = 'flex items-center space-x-2';
                        
                        checkboxDiv.innerHTML = `
                            <input type="checkbox" 
                                   id="role_${role.id}" 
                                   value="${role.id}" 
                                   class="role-checkbox rounded border-slate-300 text-green-600 focus:ring-green-500"
                                   ${isChecked ? 'checked' : ''}>
                            <label for="role_${role.id}" class="text-sm text-slate-700 flex items-center">
                                <i data-lucide="shield" class="w-4 h-4 mr-2"></i>
                                ${role.name}
                                ${role.description ? `<span class="text-slate-500 ml-2">(${role.description})</span>` : ''}
                            </label>
                        `;
                        
                        container.appendChild(checkboxDiv);
                    });
                    
                    // 初始化圖標
                    lucide.createIcons();
                    
                    // 更新隱藏欄位
                    updateAssignedRoles();
                }
            }
        },
        error: function() {
            console.error('載入可用角色失敗');
        }
    });
}

// 更新分配角色隱藏欄位
function updateAssignedRoles() {
    const checkboxes = document.querySelectorAll('.role-checkbox:checked');
    const roleIds = Array.from(checkboxes).map(cb => cb.value);
    document.getElementById('assigned_roles').value = JSON.stringify(roleIds);
}

// 提交組織表單
function submitOrganizationForm() {
    // 更新分配角色
    updateAssignedRoles();
    
    const formData = $("#FormData").serialize() + "&type=organization";
    
    $.ajax({
        url: '@Url.Action("SaveData", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                $('#organizationModal').addClass('hidden');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}

// 頁面載入時執行
$(document).ready(function() {
    loadAvailableRoles();
    
    // 監聽角色選擇變更
    $(document).on('change', '.role-checkbox', function() {
        updateAssignedRoles();
    });
});
</script>
