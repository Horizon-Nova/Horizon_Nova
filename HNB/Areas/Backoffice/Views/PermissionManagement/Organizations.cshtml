@model List<Models.HnbHnbBackoffice.vw_permission_organization>
@{
    ViewData["Title"] = "組織管理 - 權限管理系統";
    ViewData["PageTitle"] = "組織管理";
    ViewData["PageDescription"] = "管理系統組織架構與層級";
    ViewData["PageIcon"] = "building";
    ViewData["HelpModalId"] = "organizationHelpModal";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="mb-3 mb-lg-4">
    @await Html.PartialAsync("Partials/Organizations/_Control")
    @await Html.PartialAsync("Partials/Organizations/_SearchResults", Model)
</section>

@await Html.PartialAsync("Partials/Organizations/Modal/_FormData")
@await Html.PartialAsync("Partials/Organizations/Modal/_Help")
@await Html.PartialAsync("Partials/Organizations/Modal/_Detail")

@section Scripts {
    @await Html.PartialAsync("Partials/Organizations/_Scripts")
}
