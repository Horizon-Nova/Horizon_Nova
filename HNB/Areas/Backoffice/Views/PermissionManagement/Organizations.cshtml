@model List<Models.HnbHnbBackoffice.vw_permission_organization>
@{
    ViewData["Title"] = "組織管理 - 權限管理系統";
    ViewData["PageTitle"] = "組織管理";
    ViewData["PageDescription"] = "管理系統組織架構與層級";
    ViewData["PageIcon"] = "building";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="mb-3 mb-lg-4">
    <!-- 控制面板 -->
    <div class="bg-white border rounded-3 p-3 p-lg-4 mb-3 mb-lg-4">
        <div class="d-flex flex-column gap-3">
            <div class="w-100">
                <div class="position-relative">
                    <input type="text" id="searchInput" placeholder="搜尋組織名稱..."
                           class="form-control form-control-sm ps-5">
                    <i data-lucide="search" class="position-absolute top-50 translate-middle-y text-muted" style="left: 0.75rem; width: 1rem; height: 1rem;"></i>
                </div>
            </div>
            <div class="row g-2 g-lg-3">
                <div class="col-6 col-lg-4">
                    <select id="levelFilter" class="form-select form-select-sm">
                        <option value="">所有層級</option>
                        <option value="1">第1層</option>
                        <option value="2">第2層</option>
                        <option value="3">第3層</option>
                        <option value="4">第4層</option>
                        <option value="5">第5層</option>
                    </select>
                </div>
                <div class="col-6 col-lg-4">
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="">所有狀態</option>
                        <option value="true">啟用</option>
                        <option value="false">停用</option>
                    </select>
                </div>
                <div class="col-12 col-lg-4">
                    <button onclick="showModal('organizationFormModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: null, type: 'organization'}, container: 'organizationModal'})" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2">
                        <i data-lucide="plus" style="width: 1rem; height: 1rem;"></i>
                        新增組織
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 組織列表 -->
    <table id="organizationsTable" class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>組織</th>
                <th>上級組織</th>
                <th class="d-none d-lg-table-cell">層級</th>
                <th>狀態</th>
                <th class="d-none d-lg-table-cell">人員數</th>
                <th class="d-none d-lg-table-cell">角色數</th>
                <th class="d-none d-lg-table-cell">建立時間</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var org in Model ?? new List<Models.HnbHnbBackoffice.vw_permission_organization>())
            {
                <tr style="cursor: pointer;" onclick="showModal('organizationDetailModal', {url: '@Url.Action("LoadDetail", "PermissionManagement")', method: 'GET', data: {id: @org.id, type: 'organization'}, container: 'organizationModal'})">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="flex-shrink-0" style="width: 2.5rem; height: 2.5rem;">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 2.5rem; height: 2.5rem;">
                                    <i data-lucide="building" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                                </div>
                            </div>
                            <div class="overflow-hidden">
                                <div class="fw-medium text-truncate">@org.organization_name</div>
                                <div class="small text-muted text-truncate">@org.organization_description</div>
                            </div>
                        </div>
                    </td>
                    <td>@(org.parent_organization_name ?? "根組織")</td>
                    <td class="d-none d-lg-table-cell">@(org.organization_level ?? 1)</td>
                    <td>
                        <span class="badge rounded-pill @(org.is_active == true ? "bg-success" : "bg-danger")">
                            @(org.is_active == true ? "啟用" : "停用")
                        </span>
                    </td>
                    <td class="d-none d-lg-table-cell">@(org.total_users_count ?? 0)</td>
                    <td class="d-none d-lg-table-cell">@(org.total_roles_count ?? 0)</td>
                    <td class="small text-muted d-none d-lg-table-cell">@(org.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); if(confirm('確定要刪除這個組織嗎？')) deleteItem(@org.id);">
                            <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@section Scripts {
    <script>
        let organizationsTable;

        $(document).ready(function() {
            window.lucide?.createIcons?.();

            initializeDataTable();

            $('#searchInput').on('input', function() {
                organizationsTable.search(this.value).draw();
            });

            $('#levelFilter, #statusFilter').on('change', function() {
                applyFilters();
            });
        });

        function initializeDataTable() {
            organizationsTable = HNBDataTable.init('#organizationsTable', {
                order: [[6, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [7] }
                ],
                initComplete: function() {
                    $('.dataTables_filter').hide();
                    $('.dataTables_length').hide();
                }
            });
        }

        function applyFilters() {
            const levelFilter = $('#levelFilter').val();
            const statusFilter = $('#statusFilter').val();

            $.fn.dataTable.ext.search.pop();

            if (levelFilter || statusFilter) {
                $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                    const level = data[2];
                    const status = data[3];

                    const matchesLevel = !levelFilter || level.includes(levelFilter);
                    const matchesStatus = !statusFilter ||
                        (statusFilter === 'true' && status.includes('啟用')) ||
                        (statusFilter === 'false' && status.includes('停用'));

                    return matchesLevel && matchesStatus;
                });
            }

            organizationsTable.draw();
        }

        function deleteItem(id) {
            $.ajax({
                url: '@Url.Action("Delete", "PermissionManagement")',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (response.success) {
                        alert('刪除成功');
                        location.reload();
                    } else {
                        alert('刪除失敗：' + response.message);
                    }
                },
                error: () => alert('刪除失敗，請稍後再試')
            });
        }
    </script>
}

<!-- Modal 容器 -->
<div id="organizationModal"></div>
