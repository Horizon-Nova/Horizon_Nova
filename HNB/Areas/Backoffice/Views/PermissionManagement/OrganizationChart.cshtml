@model List<Models.HnbHnbBackoffice.vw_permission_organization>
@{
    ViewData["Title"] = "組織圖 - 權限管理系統";
    ViewData["PageTitle"] = "組織圖";
    ViewData["PageDescription"] = "視覺化查看組織架構與層級關係";
    ViewData["PageIcon"] = "building-2";
    ViewData["HelpModalId"] = "organizationChartHelpModal";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("Partials/OrganizationChart/_Control")
@await Html.PartialAsync("Partials/OrganizationChart/_Canvas")
@await Html.PartialAsync("Partials/OrganizationChart/_Legend")
@await Html.PartialAsync("Partials/OrganizationChart/Modal/_Help")
@await Html.PartialAsync("Partials/Organizations/Modal/_FormData")
@await Html.PartialAsync("Partials/Organizations/Modal/_Detail")

@section Scripts {
    @await Html.PartialAsync("Partials/OrganizationChart/_Scripts", Model)
}
