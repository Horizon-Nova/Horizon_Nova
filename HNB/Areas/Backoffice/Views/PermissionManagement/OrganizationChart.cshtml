@model List<Models.HnbHnbBackoffice.vw_permission_organization>
@{
    ViewData["Title"] = "組織圖 - 權限管理系統";
    ViewData["PageTitle"] = "組織圖";
    ViewData["PageDescription"] = "視覺化查看組織架構與層級關係";
    ViewData["PageIcon"] = "building-2";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="mb-3 mb-lg-4">
    <!-- 控制面板 -->
    <div class="bg-white border rounded-3 p-3 p-lg-4 mb-3 mb-lg-4">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3">
            <div class="d-flex gap-2">
                <button id="btnResetView" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                    <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;"></i>
                    重置視圖
                </button>
                <button id="btnFitToScreen" class="btn btn-success btn-sm d-flex align-items-center gap-2">
                    <i data-lucide="maximize" style="width: 1rem; height: 1rem;"></i>
                    適應螢幕
                </button>
            </div>
            <div class="d-flex gap-3">
                <div class="form-check">
                    <input type="checkbox" id="showUserCount" checked class="form-check-input">
                    <label class="form-check-label small" for="showUserCount">顯示人員數量</label>
                </div>
                <div class="form-check">
                    <input type="checkbox" id="showRoleCount" checked class="form-check-input">
                    <label class="form-check-label small" for="showRoleCount">顯示角色數量</label>
                </div>
            </div>
        </div>
    </div>

    <!-- 組織圖容器 -->
    <div class="bg-white border rounded-3 p-3 p-lg-4 mb-3 mb-lg-4">
        <div id="organizationChart" class="w-100 border rounded-3 bg-light position-relative overflow-hidden" style="height: 600px;">
            <!-- 組織圖將由 JavaScript 動態生成 -->
        </div>
    </div>

    <!-- 圖例 -->
    <div class="bg-white border rounded-3 p-3 p-lg-4">
        <h3 class="fs-6 fw-semibold mb-3">圖例說明</h3>
        <div class="row g-3 g-lg-4">
            <div class="col-12 col-lg-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 border border-2 border-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                        <i data-lucide="building" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                    </div>
                    <div>
                        <p class="fw-medium mb-0">組織單位</p>
                        <p class="small text-muted mb-0">公司部門或團隊</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 border border-2 border-success rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                        <i data-lucide="users" class="text-success" style="width: 1.25rem; height: 1.25rem;"></i>
                    </div>
                    <div>
                        <p class="fw-medium mb-0">人員數量</p>
                        <p class="small text-muted mb-0">該組織下的人員數</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 border border-2 border-info rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                        <i data-lucide="shield" class="text-info" style="width: 1.25rem; height: 1.25rem;"></i>
                    </div>
                    <div>
                        <p class="fw-medium mb-0">角色數量</p>
                        <p class="small text-muted mb-0">該組織下的角色數</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <script>
        let chartData = @Html.Raw(Json.Serialize(Model ?? new List<Models.HnbHnbBackoffice.vw_permission_organization>()));
        let svg, g, zoom;

        $(document).ready(function() {
            window.lucide?.createIcons?.();
            initOrganizationChart();

            $('#btnResetView').on('click', resetView);
            $('#btnFitToScreen').on('click', fitToScreen);
            $('#showUserCount, #showRoleCount').on('change', updateChart);

            let resizeTimer;
            $(window).on('resize', function() {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(initOrganizationChart, 250);
            });
        });

        function initOrganizationChart() {
            const container = d3.select('#organizationChart');
            container.selectAll('svg').remove();
            
            const width = $('#organizationChart').width();
            const height = $('#organizationChart').height();

            svg = container.append('svg')
                .attr('width', '100%')
                .attr('height', '100%')
                .attr('viewBox', `0 0 ${width} ${height}`)
                .attr('preserveAspectRatio', 'xMidYMid meet');

            g = svg.append('g');

            zoom = d3.zoom()
                .scaleExtent([0.1, 3])
                .on('zoom', (event) => g.attr('transform', event.transform));

            svg.call(zoom);

            updateChart();
        }

        function buildTreeStructure(data) {
            const map = new Map();
            const roots = [];

            data.forEach(d => map.set(d.id, { ...d, children: [] }));
            data.forEach(d => {
                const node = map.get(d.id);
                if (d.parent_id && map.has(d.parent_id)) {
                    map.get(d.parent_id).children.push(node);
                } else {
                    roots.push(node);
                }
            });

            return roots.length > 0 ? roots[0] : null;
        }

        function updateChart() {
            g.selectAll('*').remove();

            const root = buildTreeStructure(chartData);
            if (!root) return;

            const width = $('#organizationChart').width();
            const height = $('#organizationChart').height();
            const nodeWidth = 200;
            const nodeHeight = 80;
            const levelHeight = 120;
            const nodes = [];
            const links = [];

            function positionNodes(node, x, y, level = 0) {
                node.x = x;
                node.y = y;
                node.level = level;
                nodes.push(node);

                if (node.children && node.children.length > 0) {
                    const childWidth = nodeWidth * node.children.length;
                    const startX = x - childWidth / 2 + nodeWidth / 2;

                    node.children.forEach((child, index) => {
                        const childX = startX + index * nodeWidth;
                        const childY = y + levelHeight;
                        links.push({
                            source: { x: x, y: y + nodeHeight / 2 },
                            target: { x: childX, y: childY }
                        });
                        positionNodes(child, childX, childY, level + 1);
                    });
                }
            }

            positionNodes(root, width / 2, 50);

            // 繪製連接線
            g.selectAll('.link')
                .data(links)
                .enter()
                .append('path')
                .attr('class', 'link')
                .attr('d', d => {
                    const midY = d.source.y + (d.target.y - d.source.y) / 2;
                    return `M${d.source.x},${d.source.y} L${d.source.x},${midY} L${d.target.x},${midY} L${d.target.x},${d.target.y}`;
                })
                .attr('stroke', '#94a3b8')
                .attr('stroke-width', 2)
                .attr('fill', 'none');

            // 繪製節點
            const nodeGroups = g.selectAll('.node')
                .data(nodes)
                .enter()
                .append('g')
                .attr('class', 'node')
                .attr('transform', d => `translate(${d.x - nodeWidth/2}, ${d.y})`)
                .style('cursor', 'pointer');

            // 節點背景
            nodeGroups.append('rect')
                .attr('width', nodeWidth)
                .attr('height', nodeHeight)
                .attr('rx', 8)
                .attr('ry', 8)
                .attr('fill', '#ffffff')
                .attr('stroke', '#3b82f6')
                .attr('stroke-width', 2)
                .attr('filter', 'drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1))');

            // 組織圖標
            nodeGroups.append('circle')
                .attr('cx', 20)
                .attr('cy', 20)
                .attr('r', 12)
                .attr('fill', '#3b82f6')
                .attr('stroke', '#ffffff')
                .attr('stroke-width', 2);

            // 組織名稱
            nodeGroups.append('text')
                .attr('x', 40)
                .attr('y', 25)
                .attr('font-family', 'system-ui, -apple-system, sans-serif')
                .attr('font-size', '14px')
                .attr('font-weight', '600')
                .attr('fill', '#1e293b')
                .text(d => d.organization_name.length > 15 ? d.organization_name.substring(0, 15) + '...' : d.organization_name);

            // 人員數量
            if ($('#showUserCount').is(':checked')) {
                nodeGroups.append('text')
                    .attr('x', 40)
                    .attr('y', 45)
                    .attr('font-family', 'system-ui, -apple-system, sans-serif')
                    .attr('font-size', '12px')
                    .attr('fill', '#059669')
                    .text(d => `人員: ${d.total_users_count || 0}`);
            }

            // 角色數量
            if ($('#showRoleCount').is(':checked')) {
                nodeGroups.append('text')
                    .attr('x', 40)
                    .attr('y', 60)
                    .attr('font-family', 'system-ui, -apple-system, sans-serif')
                    .attr('font-size', '12px')
                    .attr('fill', '#7c3aed')
                    .text(d => `角色: ${d.total_roles_count || 0}`);
            }

            // 點擊事件
            nodeGroups.on('click', function(event, d) {
                showModal('organizationDetailModal', {
                    url: '@Url.Action("LoadDetail", "PermissionManagement")',
                    method: 'GET',
                    data: { id: d.id, type: 'organization' },
                    container: 'organizationModal'
                });
            });
        }

        function resetView() {
            svg.transition().duration(750).call(zoom.transform, d3.zoomIdentity);
        }

        function fitToScreen() {
            const width = $('#organizationChart').width();
            const height = $('#organizationChart').height();
            const bounds = g.node().getBBox();
            const fullWidth = bounds.width;
            const fullHeight = bounds.height;
            const midX = bounds.x + fullWidth / 2;
            const midY = bounds.y + fullHeight / 2;
            const scale = 0.9 / Math.max(fullWidth / width, fullHeight / height);
            const translate = [width / 2 - scale * midX, height / 2 - scale * midY];
            
            svg.transition().duration(750).call(
                zoom.transform,
                d3.zoomIdentity.translate(translate[0], translate[1]).scale(scale)
            );
        }
    </script>
}

<!-- Modal 容器 -->
<div id="organizationModal"></div>
