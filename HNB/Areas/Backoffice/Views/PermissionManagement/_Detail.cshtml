                                        @{
                                            var parentName = "根組織";
                                            var organization = ViewBag.Organization as Models.HnbHnbBackoffice.vw_permission_organization;
                                            if (organization != null && organization.parent_id.HasValue && ViewBag.Organizations != null)
                                            {
                                                var parentId = organization.parent_id.Value;
                                                foreach (var org in ViewBag.Organizations)
                                                {
                                                    if (org?.id == parentId)
                                                    {
                                                        parentName = org?.name ?? "根組織";
                                                        break;
                                                    }
                                                }
                                            }
                                        }
                                        @parentName
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">建立時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Organization?.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                        
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">統計資訊</h5>
                            <dl class="space-y-2">
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">使用者數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.user_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">角色數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.role_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">子組織數量</dt>
                                    <dd class="text-sm text-slate-900">@ViewBag.Organization?.child_count</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-sm text-slate-500">更新時間</dt>
                                    <dd class="text-sm text-slate-900">@(ViewBag.Organization?.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                    
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Organization?.notes))
                    {
                        <div>
                            <h5 class="font-medium text-slate-900 mb-2">備註</h5>
                            <p class="text-sm text-slate-600">@ViewBag.Organization?.notes</p>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="flex justify-end gap-3 p-6 border-t bg-slate-50">
            <button onclick="closeModal('organizationDetailModal')" class="px-4 py-2 bg-slate-300 text-slate-700 rounded-md hover:bg-slate-400">
                關閉
            </button>
            @if (ViewBag.Organization != null)
            {
                <button onclick="showOrganizationEdit(@ViewBag.Organization.id)" class="px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700 flex items-center gap-2">
                    <i data-lucide="edit" class="w-4 h-4"></i>
                    編輯
                </button>
            }
        </div>
    </div>
</div>

