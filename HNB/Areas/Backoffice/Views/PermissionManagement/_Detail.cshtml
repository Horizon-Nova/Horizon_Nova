// 提交使用者表單
function submitUserForm() {
    const formData = $("#FormDataUser").serialize();
    
    $.ajax({
        url: '@Url.Action("SubmitUser", "PermissionManagement")',
        type: 'POST',
        data: formData,
        success: function(response) {
            if (response.success) {
                alert(response.message);
                closeModal('userFormModal');
                location.reload();
            } else {
                alert('操作失敗：' + response.message);
            }
        },
        error: function() {
            alert('提交失敗，請稍後再試');
        }
    });
}

