@{
    ViewData["Title"] = "字體";
    ViewData["PageTitle"] = "字體";
    ViewData["PageDescription"] = "瀏覽和搜尋字體，查看字體名稱和 CSS 變數";
    ViewData["PageIcon"] = "type";
    ViewData["HelpModalId"] = "fontPaletteHelpModal";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="mb-4">
        <div class="input-group">
            <span class="input-group-text">
                <i data-lucide="search" style="width: 1rem; height: 1rem;"></i>
            </span>
            <input type="text" 
                   id="fontSearchInput" 
                   class="form-control" 
                   placeholder="搜尋字體名稱或 CSS 變數（例如：primary、font-primary）"
                   autocomplete="off">
            <button class="btn btn-outline-secondary" type="button" id="clearSearchBtn" style="display: none;">
                清除
            </button>
        </div>
    </div>

    <div id="fontList">
    </div>

    <div id="noResults" class="text-center text-muted py-5" style="display: none;">
        <i data-lucide="search-x" style="width: 3rem; height: 3rem; opacity: 0.5;"></i>
        <p class="mt-3 mb-0">找不到符合的字體</p>
    </div>
</div>

@await Html.PartialAsync("Partials/Modal/_Help")

@section Scripts {
    <script src="~/lib/font-palette/FontPalette.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof lucide !== 'undefined' && typeof lucide.createIcons === 'function') {
                lucide.createIcons();
            }
            
            if (typeof FontPalette !== 'undefined') {
                FontPalette.init();
            }
        });
    </script>
}

