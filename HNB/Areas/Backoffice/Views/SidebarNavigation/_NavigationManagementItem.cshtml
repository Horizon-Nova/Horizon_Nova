@model HNB.Areas.Backoffice.Services.NavigationItem

<div class="border border-slate-200 rounded-lg p-4 @(Model.IsActive ? "" : "opacity-60 bg-slate-50")">
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.Icon))
                {
                    <i data-lucide="@Model.Icon" class="h-4 w-4 text-slate-600"></i>
                }
                else
                {
                    <i data-lucide="circle" class="h-4 w-4 text-slate-400"></i>
                }
                <span class="font-medium text-slate-900">@Model.Title</span>
            </div>
            
            @if (!Model.IsActive)
            {
                <span class="px-2 py-1 text-xs bg-red-100 text-red-700 rounded">已停用</span>
            }
            
            @if (Model.HasChildren)
            {
                <span class="px-2 py-1 text-xs bg-blue-100 text-blue-700 rounded">@Model.Children.Count 個子項目</span>
            }
        </div>
        
        <div class="flex items-center gap-2">
            <span class="text-sm text-slate-500">排序: @Model.SortOrder</span>
            
            @if (!string.IsNullOrEmpty(Model.Url))
            {
                <a href="@Model.Url" target="_blank" 
                   class="text-blue-600 hover:text-blue-700 text-sm"
                   title="開啟連結">
                    <i data-lucide="external-link" class="h-4 w-4"></i>
                </a>
            }
            
            <a href="@Url.Action("Create", new { parentId = Model.Id })" 
               class="text-green-600 hover:text-green-700"
               title="新增子項目">
                <i data-lucide="plus" class="h-4 w-4"></i>
            </a>
            
            <a href="@Url.Action("Edit", new { id = Model.Id })" 
               class="text-blue-600 hover:text-blue-700"
               title="編輯">
                <i data-lucide="edit" class="h-4 w-4"></i>
            </a>
            
            <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" class="inline">
                @Html.AntiForgeryToken()
                <button type="button" 
                        class="text-red-600 hover:text-red-700 delete-btn"
                        data-title="@Model.Title"
                        title="刪除">
                    <i data-lucide="trash-2" class="h-4 w-4"></i>
                </button>
            </form>
        </div>
    </div>
    
    @if (!string.IsNullOrEmpty(Model.Url))
    {
        <div class="mt-2 text-sm text-slate-600">
            <i data-lucide="link" class="h-3 w-3 inline mr-1"></i>
            @Model.Url
        </div>
    }
    
    @if (Model.HasChildren)
    {
        <div class="mt-4 ml-6 space-y-2 border-l-2 border-slate-200 pl-4">
            @foreach (var child in Model.Children.OrderBy(c => c.SortOrder))
            {
                @await Html.PartialAsync("_NavigationManagementItem", child)
            }
        </div>
    }
</div>
