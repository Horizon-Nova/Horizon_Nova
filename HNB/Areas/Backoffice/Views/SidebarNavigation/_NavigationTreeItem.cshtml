@model Models.HnbHnbBackoffice.vw_sidebar_navigation
@{
    var getChildren = ViewData["GetChildren"] as Func<string, List<Models.HnbHnbBackoffice.vw_sidebar_navigation>>;
    var children = getChildren?.Invoke(Model.code ?? "");
    var hasChildren = children?.Any() == true;
    var isExternalLink = !string.IsNullOrEmpty(Model.url) &&
        (Model.url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
         Model.url.StartsWith("https://", StringComparison.OrdinalIgnoreCase));
}

<div class="nav-tree-item" draggable="true" data-nav-id="@Model.id" data-sort-order="@(Model.sort_order ?? 0)" data-parent-code="@(Model.parent_code ?? "")">
    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded border nav-item-card gap-3">
        <div class="d-flex align-items-start align-items-lg-center gap-2 gap-lg-3 flex-grow-1" style="min-width: 0;">
            <!-- 拖曳手柄 -->
            <div class="drag-handle text-muted flex-shrink-0" style="cursor: move;" title="拖曳以調整順序">
                <i data-lucide="grip-vertical" style="width: 1rem; height: 1rem;"></i>
            </div>
            
            @if (hasChildren)
            {
                <button type="button" class="btn btn-link btn-sm p-0 text-muted flex-shrink-0 js-nav-toggle-children">
                    <i data-lucide="chevron-down" class="nav-chevron-tree" style="width: 1rem; height: 1rem; transition: transform 0.2s;"></i>
                </button>
            }
            else
            {
                <div style="width: 1rem;" class="flex-shrink-0"></div>
            }

            <div class="d-flex align-items-center justify-content-center rounded flex-shrink-0"
                 style="width: 2.5rem; height: 2.5rem; background-color: #dbeafe;">
                <i data-lucide="@(Model.icon ?? "folder")" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
            </div>

            <div class="flex-grow-1" style="min-width: 0;">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                    <h6 class="mb-0 fw-semibold text-truncate">@Model.title</h6>
                    <span class="badge bg-secondary small">排序: @(Model.sort_order ?? 0)</span>
                    <span class="badge @(Model.is_active == true ? "bg-success" : "bg-danger") small">
                        @(Model.is_active == true ? "啟用" : "停用")
                    </span>
                    @if (isExternalLink)
                    {
                        <span class="badge bg-warning text-dark small d-flex align-items-center gap-1">
                            <i data-lucide="external-link" style="width: 0.75rem; height: 0.75rem;"></i>外部
                        </span>
                    }
                </div>
                <div class="d-flex flex-column flex-lg-row gap-1 gap-lg-3 small text-muted">
                    <span class="d-flex align-items-center gap-1 flex-shrink-0">
                        <i data-lucide="hash" style="width: 0.75rem; height: 0.75rem;"></i>@Model.code
                    </span>
                    @if (!string.IsNullOrEmpty(Model.url))
                    {
                        <span class="d-flex align-items-center gap-1 text-truncate" style="min-width: 0;">
                            <i data-lucide="@(isExternalLink ? "external-link" : "link")" class="flex-shrink-0" style="width: 0.75rem; height: 0.75rem;"></i>
                            <span class="text-truncate">@Model.url</span>
                        </span>
                    }
                    else
                    {
                        <span class="text-muted fst-italic">無連結（分類項目）</span>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex align-items-center gap-1 gap-lg-2 flex-shrink-0 nav-item-actions">
            <button type="button" class="btn btn-sm p-2 js-nav-show-detail" data-id="@Model.id"
                    class="btn btn-sm p-2" style="color: #6366f1;" title="查看詳情">
                <i data-lucide="eye" style="width: 1rem; height: 1rem;"></i>
            </button>
            <button type="button" class="btn btn-sm p-2 text-primary js-nav-show-edit" data-id="@Model.id" title="編輯">
                <i data-lucide="edit" style="width: 1rem; height: 1rem;"></i>
            </button>
            <button type="button" class="btn btn-sm p-2 text-danger js-nav-show-delete" data-id="@Model.id" title="刪除">
                <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
            </button>
        </div>
    </div>

    @if (hasChildren && children != null)
    {
                <div class="ms-3 ms-lg-4 mt-2 d-flex flex-column gap-2 border-start border-2 ps-2 ps-lg-3 hidden nav-children" data-parent-code="@Model.code">
            @foreach (var child in children)
            {
                @await Html.PartialAsync("Partials/_NavigationTreeItem", child, ViewData)
            }
        </div>
    }
</div>

