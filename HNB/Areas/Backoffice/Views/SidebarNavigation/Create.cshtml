@model HNB.Areas.Backoffice.Services.CreateNavigationRequest
@{
    ViewData["Title"] = "新增導航項目";
    var parentNavigations = ViewBag.ParentNavigations as List<HNB.Areas.Backoffice.Services.NavigationItem> ?? new List<HNB.Areas.Backoffice.Services.NavigationItem>();
    var parentId = ViewBag.ParentId as int?;
}

<div class="p-6">
    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-slate-600 mb-2">
            <a href="@Url.Action("Index")" class="hover:text-blue-600">側欄導航管理</a>
            <i data-lucide="chevron-right" class="h-4 w-4"></i>
            <span>新增導航項目</span>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">新增導航項目</h1>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-6">
        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- 標題 -->
                <div>
                    <label for="Title" class="block text-sm font-medium text-slate-700 mb-2">
                        標題 <span class="text-red-500">*</span>
                    </label>
                    <input type="text" 
                           id="Title" 
                           name="Title" 
                           value="@Model?.Title"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           placeholder="請輸入導航項目標題"
                           required>
                    <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
                </div>

                <!-- 圖示 -->
                <div>
                    <label for="Icon" class="block text-sm font-medium text-slate-700 mb-2">
                        圖示 (Lucide Icons)
                    </label>
                    <input type="text" 
                           id="Icon" 
                           name="Icon" 
                           value="@Model?.Icon"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           placeholder="例如: home, users, settings">
                    <span asp-validation-for="Icon" class="text-red-500 text-sm"></span>
                    <p class="text-xs text-slate-500 mt-1">
                        參考 <a href="https://lucide.dev/icons/" target="_blank" class="text-blue-600 hover:text-blue-700">Lucide Icons</a>
                    </p>
                </div>
            </div>

            <!-- URL -->
            <div>
                <label for="Url" class="block text-sm font-medium text-slate-700 mb-2">
                    連結網址
                </label>
                <input type="url" 
                       id="Url" 
                       name="Url" 
                       value="@Model?.Url"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                       placeholder="例如: /Backoffice/Dashboard 或 https://example.com">
                <span asp-validation-for="Url" class="text-red-500 text-sm"></span>
                <p class="text-xs text-slate-500 mt-1">
                    支援完整網址或相對路徑，留空表示僅作為分類標題
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- 父級項目 -->
                <div>
                    <label for="ParentId" class="block text-sm font-medium text-slate-700 mb-2">
                        父級項目
                    </label>
                    <select id="ParentId" 
                            name="ParentCode" 
                            class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                        <option value="">-- 頂層項目 --</option>
                        @foreach (var nav in GetAllNavigationItems(parentNavigations))
                        {
                            var selected = (Model?.ParentCode == nav.Code) ? "selected" : "";
                            var indent = new string('　', nav.Level);
                            <option value="@nav.Code" @selected>@indent@nav.Title</option>
                        }
                    </select>
                    <span asp-validation-for="ParentCode" class="text-red-500 text-sm"></span>
                </div>

                <!-- 排序 -->
                <div>
                    <label for="SortOrder" class="block text-sm font-medium text-slate-700 mb-2">
                        排序順序
                    </label>
                    <input type="number" 
                           id="SortOrder" 
                           name="SortOrder" 
                           value="@(Model?.SortOrder ?? 0)"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           min="0">
                    <span asp-validation-for="SortOrder" class="text-red-500 text-sm"></span>
                    <p class="text-xs text-slate-500 mt-1">數字越小排序越前面</p>
                </div>
            </div>

            <!-- 按鈕 -->
            <div class="flex items-center justify-between pt-6 border-t border-slate-200">
                <a href="@Url.Action("Index")" 
                   class="px-4 py-2 text-slate-600 hover:text-slate-800 transition-colors">
                    取消
                </a>
                <button type="submit" 
                        class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                    新增導航項目
                </button>
            </div>
        </form>
    </div>
</div>

@functions {
    private List<(int Id, string Code, string Title, int Level)> GetAllNavigationItems(List<HNB.Areas.Backoffice.Services.NavigationItem> items, int level = 0)
    {
        var result = new List<(int Id, string Code, string Title, int Level)>();
        foreach (var item in items.OrderBy(i => i.SortOrder))
        {
            result.Add((item.Id, item.Code, item.Title, level));
            if (item.HasChildren)
            {
                result.AddRange(GetAllNavigationItems(item.Children, level + 1));
            }
        }
        return result;
    }
}

<script>
document.addEventListener('DOMContentLoaded', () => {
    if (window.lucide) window.lucide.createIcons();
});
</script>
