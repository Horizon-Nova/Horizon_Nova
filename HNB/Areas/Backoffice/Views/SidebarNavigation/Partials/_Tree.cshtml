@{
    Layout = null;
    var allNavigations = ViewBag.Navigations as List<Models.HnbHnbBackoffice.vw_sidebar_navigation> ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
    var rootItems = allNavigations.Where(n => string.IsNullOrEmpty(n.parent_code)).OrderBy(n => n.sort_order).ToList();
    Func<string, List<Models.HnbHnbBackoffice.vw_sidebar_navigation>> getChildren = (parentCode) =>
        allNavigations.Where(n => n.parent_code == parentCode).OrderBy(n => n.sort_order).ToList();
}

<!-- 目錄樹狀結構 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom p-3">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="folder-tree" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
            <h5 class="mb-0 fw-semibold">目錄結構</h5>
        </div>
    </div>

    <div id="navigationTreeContent" class="card-body p-3">
            <div class="d-flex flex-column gap-2">
                @foreach (var item in rootItems)
                {
                var itemChildren = getChildren(item.code ?? "");
                <div class="nav-tree-item" data-nav-id="@(item.id ?? 0)" data-parent-code="@(item.parent_code ?? "")" draggable="true">
                    <div class="nav-item-card card border shadow-sm mb-2">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center gap-2">
                                <i data-lucide="grip-vertical" class="text-muted drag-handle" style="width: 1rem; height: 1rem; cursor: move;"></i>
                                
                                @(itemChildren.Any() ? Html.Raw($@"<button type=""button"" class=""btn btn-link btn-sm p-0"" onclick=""toggleChildren(this)"" title=""展開/收合"">
                                    <i data-lucide=""chevron-right"" class=""nav-chevron-tree text-muted""></i>
                                </button>") : Html.Raw(@"<span style=""width: 1rem;""></span>"))
                                
                                @(!string.IsNullOrWhiteSpace(item.icon) ? Html.Raw($@"<i data-lucide=""{item.icon}"" style=""width: 1.25rem; height: 1.25rem;""></i>") : Html.Raw(""))
                                
                                <h6 class="mb-0 flex-grow-1">@(item.title ?? "")</h6>
                                
                                <span class="text-muted small">
                                    <i data-lucide="hash" style="width: 0.875rem; height: 0.875rem;"></i>
                                    @(item.code ?? "")
                                </span>
                                
                                <span class="badge @((item.is_active ?? false) ? "bg-success" : "bg-secondary")">
                                    @((item.is_active ?? false) ? "啟用" : "停用")
                                </span>
                                
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDetail', method: 'GET', data: { id: @(item.id ?? 0) }, container: 'navDetailModalContent' })" title="查看詳情">
                                        <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem;"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadEdit', method: 'GET', data: { id: @(item.id ?? 0) }, container: 'navEditModalContent' })" title="編輯">
                                        <i data-lucide="edit" style="width: 0.875rem; height: 0.875rem;"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDelete', method: 'GET', data: { id: @(item.id ?? 0) }, container: 'navDeleteModalContent' })" title="刪除">
                                        <i data-lucide="trash-2" style="width: 0.875rem; height: 0.875rem;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="nav-children hidden ms-4">
                        @foreach (var child in itemChildren)
                        {
                                var childChildren = getChildren(child.code ?? "");
                                <div class="nav-tree-item" data-nav-id="@(child.id ?? 0)" data-parent-code="@(child.parent_code ?? "")" draggable="true">
                                    <div class="nav-item-card card border shadow-sm mb-2">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <i data-lucide="grip-vertical" class="text-muted drag-handle" style="width: 1rem; height: 1rem; cursor: move;"></i>
                                                
                                                @(childChildren.Any() ? Html.Raw($@"<button type=""button"" class=""btn btn-link btn-sm p-0"" onclick=""toggleChildren(this)"" title=""展開/收合"">
                                                    <i data-lucide=""chevron-right"" class=""nav-chevron-tree text-muted""></i>
                                                </button>") : Html.Raw(@"<span style=""width: 1rem;""></span>"))
                                                
                                                @(!string.IsNullOrWhiteSpace(child.icon) ? Html.Raw($@"<i data-lucide=""{child.icon}"" style=""width: 1.25rem; height: 1.25rem;""></i>") : Html.Raw(""))
                                                
                                                <h6 class="mb-0 flex-grow-1">@(child.title ?? "")</h6>
                                                
                                                <span class="text-muted small">
                                                    <i data-lucide="hash" style="width: 0.875rem; height: 0.875rem;"></i>
                                                    @(child.code ?? "")
                                                </span>
                                                
                                                <span class="badge @((child.is_active ?? false) ? "bg-success" : "bg-secondary")">
                                                    @((child.is_active ?? false) ? "啟用" : "停用")
                                                </span>
                                                
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-primary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDetail', method: 'GET', data: { id: @(child.id ?? 0) }, container: 'navDetailModalContent' })" title="查看詳情">
                                                        <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem;"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-outline-secondary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadEdit', method: 'GET', data: { id: @(child.id ?? 0) }, container: 'navEditModalContent' })" title="編輯">
                                                        <i data-lucide="edit" style="width: 0.875rem; height: 0.875rem;"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDelete', method: 'GET', data: { id: @(child.id ?? 0) }, container: 'navDeleteModalContent' })" title="刪除">
                                                        <i data-lucide="trash-2" style="width: 0.875rem; height: 0.875rem;"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="nav-children hidden ms-4">
                                        @foreach (var grandchild in childChildren)
                                        {
                                                <div class="nav-tree-item" data-nav-id="@(grandchild.id ?? 0)" data-parent-code="@(grandchild.parent_code ?? "")" draggable="true">
                                                    <div class="nav-item-card card border shadow-sm mb-2">
                                                        <div class="card-body p-3">
                                                            <div class="d-flex align-items-center gap-2">
                                                                <i data-lucide="grip-vertical" class="text-muted drag-handle" style="width: 1rem; height: 1rem; cursor: move;"></i>
                                                                
                                                                <span style="width: 1rem;"></span>
                                                                
                                                                @(!string.IsNullOrWhiteSpace(grandchild.icon) ? Html.Raw($@"<i data-lucide=""{grandchild.icon}"" style=""width: 1.25rem; height: 1.25rem;""></i>") : Html.Raw(""))
                                                                
                                                                <h6 class="mb-0 flex-grow-1">@(grandchild.title ?? "")</h6>
                                                                
                                                                <span class="text-muted small">
                                                                    <i data-lucide="hash" style="width: 0.875rem; height: 0.875rem;"></i>
                                                                    @(grandchild.code ?? "")
                                                                </span>
                                                                
                                                                <span class="badge @((grandchild.is_active ?? false) ? "bg-success" : "bg-secondary")">
                                                                    @((grandchild.is_active ?? false) ? "啟用" : "停用")
                                                                </span>
                                                                
                                                                <div class="btn-group btn-group-sm">
                                                                    <button type="button" class="btn btn-outline-primary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDetail', method: 'GET', data: { id: @(grandchild.id ?? 0) }, container: 'navDetailModalContent' })" title="查看詳情">
                                                                        <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem;"></i>
                                                                    </button>
                                                                    <button type="button" class="btn btn-outline-secondary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadEdit', method: 'GET', data: { id: @(grandchild.id ?? 0) }, container: 'navEditModalContent' })" title="編輯">
                                                                        <i data-lucide="edit" style="width: 0.875rem; height: 0.875rem;"></i>
                                                                    </button>
                                                                    <button type="button" class="btn btn-outline-danger" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDelete', method: 'GET', data: { id: @(grandchild.id ?? 0) }, container: 'navDeleteModalContent' })" title="刪除">
                                                                        <i data-lucide="trash-2" style="width: 0.875rem; height: 0.875rem;"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                        }
                                    </div>
                                </div>
                        }
                    </div>
            </div>
        }
        </div>
        @if (!rootItems.Any())
        {
            <div class="text-center py-5 text-muted">
                <i data-lucide="folder-x" class="mx-auto mb-2 text-muted" style="width: 3rem; height: 3rem;"></i>
                <p class="mb-0">尚未建立任何導航項目</p>
            </div>
        }
    </div>
</div>
