@model List<Models.HnbHnbBackoffice.vw_sidebar_navigation>
@{
    Layout = null;
    var allNavigations = Model ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
    var sortedNavigations = allNavigations.OrderBy(n => n.sort_order).ToList();
}

<!-- 目錄列表 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom p-3">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="folder-tree" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
            <h5 class="mb-0 fw-semibold">目錄結構</h5>
        </div>
    </div>

    <div id="navigationTreeContent" class="card-body p-3">
        <div class="d-flex flex-column gap-2">
            @foreach (var item in sortedNavigations)
            {
                <div class="nav-tree-item" data-nav-id="@(item.id ?? 0)" data-parent-code="@(item.parent_code ?? "")" draggable="true">
                    <div class="nav-item-card card border shadow-sm mb-2">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center gap-2">
                                <i data-lucide="grip-vertical" class="text-muted drag-handle" style="width: 1rem; height: 1rem; cursor: move;"></i>
                                
                                @if (!string.IsNullOrWhiteSpace(item.icon))
                                {
                                    <i data-lucide="@item.icon" style="width: 1.25rem; height: 1.25rem;"></i>
                                }
                                
                                <h6 class="mb-0 flex-grow-1">@(item.title ?? "")</h6>
                                
                                <span class="text-muted small">
                                    <i data-lucide="hash" style="width: 0.875rem; height: 0.875rem;"></i>
                                    @(item.code ?? "")
                                </span>
                                
                                <span class="badge @((item.is_active ?? false) ? "bg-success" : "bg-secondary")">
                                    @((item.is_active ?? false) ? "啟用" : "停用")
                                </span>
                                
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDetail', method: 'GET', data: { id: @(item.id ?? 0) }, container: 'navDetailModalContent' })" title="查看詳情">
                                        <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem;"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadEdit', method: 'GET', data: { id: @(item.id ?? 0) }, container: 'navEditModalContent' })" title="編輯">
                                        <i data-lucide="edit" style="width: 0.875rem; height: 0.875rem;"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger" onclick="showModal('NavModal', { url: '/Backoffice/SidebarNavigation/LoadDelete', method: 'GET', data: { id: @(item.id ?? 0) }, container: 'navDeleteModalContent' })" title="刪除">
                                        <i data-lucide="trash-2" style="width: 0.875rem; height: 0.875rem;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        @if (!sortedNavigations.Any())
        {
            <div class="text-center py-5 text-muted">
                <i data-lucide="folder-x" class="mx-auto mb-2 text-muted" style="width: 3rem; height: 3rem;"></i>
                <p class="mb-0">尚未建立任何導航項目</p>
            </div>
        }
    </div>
</div>
