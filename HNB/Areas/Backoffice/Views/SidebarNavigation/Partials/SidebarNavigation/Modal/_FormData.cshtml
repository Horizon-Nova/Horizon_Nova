@model Models.HnbHnbBackoffice.vw_sidebar_navigation?
@{
    Layout = null;
    var isEdit = Model?.id > 0;
    var modalId = isEdit ? "nav-edit-modal" : "nav-add-modal";
    var formId = isEdit ? "navEditForm" : "navAddForm";
    var action = isEdit ? "edit" : "add";
}

<!-- 動態 Modal 容器 -->
<div id="navigationModals">
    <!-- 新增 Modal -->
    <div id="nav-add-modal" class="modal fade" tabindex="-1" aria-labelledby="navAddModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="navAddModalLabel">新增目錄</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="navAddForm" autocomplete="off">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="0" />
                        
                        <div class="vstack gap-3">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label for="navAddTitle" class="col-form-label col-form-label-sm mb-0">目錄名稱<span class="text-danger">*</span></label></div>
                                <div class="col"><input type="text" id="navAddTitle" name="title" class="form-control form-control-sm" placeholder="請輸入目錄名稱" required></div>
                            </div>
                            
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label for="navAddCode" class="col-form-label col-form-label-sm mb-0">目錄代碼<span class="text-danger">*</span></label></div>
                                <div class="col"><input type="text" id="navAddCode" name="code" class="form-control form-control-sm" placeholder="請輸入目錄代碼（英文小寫、數字、底線）" required pattern="[a-z0-9_]+"></div>
                            </div>
                            
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label for="navAddIcon" class="col-form-label col-form-label-sm mb-0">圖標</label></div>
                                <div class="col">
                                    <div class="input-group input-group-sm">
                                        <input type="text" id="navAddIcon" name="icon" class="form-control" placeholder="請選擇圖標">
                                        <button type="button" class="btn btn-outline-secondary js-open-icon-picker" data-target="#navAddIcon">
                                            <i data-lucide="search" style="width: 1rem; height: 1rem;"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label for="navAddParent" class="col-form-label col-form-label-sm mb-0">上層目錄</label></div>
                                <div class="col">
                                    <select id="navAddParent" name="parent_code" class="form-select form-select-sm">
                                        <option value="">根目錄（第一層）</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label for="navAddSortOrder" class="col-form-label col-form-label-sm mb-0">排序順序</label></div>
                                <div class="col"><input type="number" id="navAddSortOrder" name="sort_order" value="0" class="form-control form-control-sm" min="0"></div>
                            </div>
                            
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label for="navAddUrl" class="col-form-label col-form-label-sm mb-0">路徑 URL</label></div>
                                <div class="col"><input type="text" id="navAddUrl" name="url" class="form-control form-control-sm" placeholder="/Backoffice/Controller/Action 或 https://..."></div>
                            </div>
                            
                            <div class="row g-2 align-items-center">
                                <div class="col-auto" style="width: 100px;"><label class="col-form-label col-form-label-sm mb-0">啟用狀態</label></div>
                                <div class="col">
                                    <div class="form-check">
                                        <input type="checkbox" id="navAddIsActive" name="is_active" class="form-check-input" checked>
                                        <label class="form-check-label" for="navAddIsActive">啟用此目錄</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                    <button type="button" class="btn btn-primary btn-sm js-save-navigation" data-action="add">儲存</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 編輯 Modal（動態載入） -->
    <div id="nav-edit-modal" class="modal fade" tabindex="-1" aria-labelledby="navEditModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
            <div class="modal-content" id="navEditModalContent">
                <!-- 內容將通過 AJAX 動態載入 -->
            </div>
        </div>
    </div>
    
    <!-- 詳情 Modal（動態載入） -->
    <div id="nav-detail-modal" class="modal fade" tabindex="-1" aria-labelledby="navDetailModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
            <div class="modal-content" id="navDetailModalContent">
                <!-- 內容將通過 AJAX 動態載入 -->
            </div>
        </div>
    </div>
    
    <!-- 刪除確認 Modal（動態載入） -->
    <div id="nav-delete-modal" class="modal fade" tabindex="-1" aria-labelledby="navDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" id="navDeleteModalContent">
                <!-- 內容將通過 AJAX 動態載入 -->
            </div>
        </div>
    </div>
</div>

