@model Models.HnbHnbBackoffice.vw_sidebar_navigation
@{
    Layout = null;
    var getChildren = ViewData["GetChildren"] as Func<string, List<Models.HnbHnbBackoffice.vw_sidebar_navigation>>;
    var children = getChildren?.Invoke(Model.code ?? "") ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
    var hasChildren = children.Any();
}

<div class="nav-tree-item" data-nav-id="@(Model.id ?? 0)" data-parent-code="@(Model.parent_code ?? "")" draggable="true">
    <div class="nav-item-card card border shadow-sm mb-2">
        <div class="card-body p-3">
            <div class="d-flex align-items-center gap-2">
                <!-- 拖曳手柄 -->
                <i data-lucide="grip-vertical" class="text-muted drag-handle" style="width: 1rem; height: 1rem; cursor: move;"></i>
                
                <!-- 展開/收合按鈕 -->
                @if (hasChildren)
                {
                    <button type="button" class="btn btn-link btn-sm p-0 js-nav-toggle-children" title="展開/收合">
                        <i data-lucide="chevron-right" class="nav-chevron-tree text-muted" style="width: 1rem; height: 1rem;"></i>
                    </button>
                }
                else
                {
                    <span style="width: 1rem;"></span>
                }
                
                <!-- 圖標 -->
                @if (!string.IsNullOrWhiteSpace(Model.icon))
                {
                    <i data-lucide="@Model.icon" style="width: 1.25rem; height: 1.25rem;"></i>
                }
                
                <!-- 標題 -->
                <h6 class="mb-0 flex-grow-1">@(Model.title ?? "")</h6>
                
                <!-- 目錄代碼 -->
                <span class="text-muted small">
                    <i data-lucide="hash" style="width: 0.875rem; height: 0.875rem;"></i>
                    @(Model.code ?? "")
                </span>
                
                <!-- 狀態標籤 -->
                <span class="badge @((Model.is_active ?? false) ? "bg-success" : "bg-secondary")">
                    @((Model.is_active ?? false) ? "啟用" : "停用")
                </span>
                
                <!-- 操作按鈕 -->
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-outline-primary js-nav-show-detail" data-id="@(Model.id ?? 0)" title="查看詳情">
                        <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem;"></i>
                    </button>
                    <button type="button" class="btn btn-outline-secondary js-nav-show-edit" data-id="@(Model.id ?? 0)" title="編輯">
                        <i data-lucide="edit" style="width: 0.875rem; height: 0.875rem;"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger js-nav-show-delete" data-id="@(Model.id ?? 0)" title="刪除">
                        <i data-lucide="trash-2" style="width: 0.875rem; height: 0.875rem;"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 子項目 -->
    @if (hasChildren)
    {
        <div class="nav-children hidden ms-4">
            @foreach (var child in children)
            {
                @await Html.PartialAsync("Partials/SidebarNavigation/_TreeItem", child, ViewData)
            }
        </div>
    }
</div>

