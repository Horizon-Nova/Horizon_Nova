@{
    Layout = null;
}

<style>
.hidden {
    display: none;
}

.nav-item-card {
    transition: all 0.2s ease-in-out;
}

.nav-item-card:hover {
    border-color: var(--Blue-400) !important;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
}

.nav-item-actions {
    opacity: 1;
}

@@media (min-width: 992px) {
    .nav-item-actions {
        opacity: 0;
    }
    
    .nav-item-card:hover .nav-item-actions {
        opacity: 1;
    }
}

.nav-chevron-tree {
    transition: transform 0.2s ease-in-out;
}

.nav-chevron-tree.rotated {
    transform: rotate(180deg);
}

.nav-tree-item {
    transition: all 0.2s ease-in-out;
}

.nav-tree-item.dragging {
    opacity: 0.5;
}

.nav-tree-item.drag-over {
    border-top: 3px solid var(--Blue-500);
    padding-top: 0.5rem;
}

.drag-handle {
    opacity: 0.3;
    transition: opacity 0.2s;
}

.nav-item-card:hover .drag-handle {
    opacity: 1;
}
</style>

