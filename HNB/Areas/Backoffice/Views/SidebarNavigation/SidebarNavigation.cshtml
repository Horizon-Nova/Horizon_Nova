@model List<HNB.Areas.Backoffice.Services.NavigationItem>
@{
    ViewData["Title"] = "側欄導航管理";
}

<div class="p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">側欄導航管理</h1>
            <p class="text-slate-600 mt-1">管理系統側欄導航項目和階層結構</p>
        </div>
        <div class="flex gap-3">
            <a href="@Url.Action("RolePermissions")" 
               class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                <i data-lucide="shield" class="h-4 w-4"></i>
                角色權限管理
            </a>
            <a href="@Url.Action("Create")" 
               class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                <i data-lucide="plus" class="h-4 w-4"></i>
                新增導航項目
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg">
            <div class="flex items-center gap-2 text-green-800">
                <i data-lucide="check-circle" class="h-4 w-4"></i>
                @TempData["SuccessMessage"]
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
            <div class="flex items-center gap-2 text-red-800">
                <i data-lucide="alert-circle" class="h-4 w-4"></i>
                @TempData["ErrorMessage"]
            </div>
        </div>
    }

    <div class="bg-white rounded-lg border border-slate-200">
        <div class="p-4 border-b border-slate-200">
            <h2 class="text-lg font-semibold text-slate-900">導航結構</h2>
        </div>
        
        <div class="p-4">
            @if (Model.Any())
            {
                <div class="space-y-2">
                    @foreach (var item in Model)
                    {
                        @await Html.PartialAsync("_NavigationManagementItem", item)
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8 text-slate-500">
                    <i data-lucide="folder-x" class="h-12 w-12 mx-auto mb-3 text-slate-400"></i>
                    <p>尚未建立任何導航項目</p>
                    <a href="@Url.Action("Create")" class="text-blue-600 hover:text-blue-700 mt-2 inline-block">
                        立即新增第一個導航項目
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    if (window.lucide) window.lucide.createIcons();
    
    // 刪除確認
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const title = btn.getAttribute('data-title');
            if (confirm(`確定要刪除導航項目「${title}」嗎？\n\n注意：這將同時刪除所有子項目！`)) {
                btn.closest('form').submit();
            }
        });
    });
});
</script>
