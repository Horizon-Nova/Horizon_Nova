@{
    ViewData["Title"] = "目錄管理";
    ViewData["PageTitle"] = "目錄管理";
    ViewData["PageDescription"] = "管理系統導航選單結構與權限";
    ViewData["PageIcon"] = "folder-tree";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";

    var allNavigations = ViewBag.Navigations as List<Models.HnbHnbBackoffice.vw_sidebar_navigation> ?? new List<Models.HnbHnbBackoffice.vw_sidebar_navigation>();
    var rootItems = allNavigations.Where(n => string.IsNullOrEmpty(n.parent_code)).OrderBy(n => n.sort_order).ToList();
    Func<string, List<Models.HnbHnbBackoffice.vw_sidebar_navigation>> getChildren = (parentCode) =>
        allNavigations.Where(n => n.parent_code == parentCode).OrderBy(n => n.sort_order).ToList();
    ViewData["GetChildren"] = getChildren;
}

<link rel="stylesheet" href="~/Backoffice/css/NavigationManagement.css" />

<!-- 動態 Modal 容器 -->
<div id="navigationModals">
    @await Html.PartialAsync("_NavigationManagementModal", new Models.HnbHnbBackoffice.vw_sidebar_navigation())
</div>

<!-- 靜態 Modal：圖標選擇器（不會被 AJAX 重新載入）-->
<div id="icon-picker-modal" class="modal fade" tabindex="-1" aria-labelledby="iconPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">選擇圖標</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            
            <div class="modal-body p-4">
                <!-- 搜尋框 -->
                <div class="mb-4">
                    <div class="position-relative">
                        <input type="text" id="iconSearchInput" class="form-control ps-5" 
                               placeholder="搜尋圖標名稱或標籤（例如：home, arrow, user）...">
                        <i data-lucide="search" class="position-absolute text-muted" 
                           style="width: 1rem; height: 1rem; left: 0.75rem; top: 50%; transform: translateY(-50%);"></i>
                    </div>
                    <div class="text-muted small mt-2">
                        已載入 <span id="iconCount">0</span> 個圖標
                    </div>
                </div>
                
                <!-- 圖標網格 -->
                <div class="row g-3" id="iconGrid" style="max-height: 60vh; overflow-y: auto;">
                    <!-- 圖標將通過 JavaScript 動態載入 -->
                </div>
                
                <!-- 無結果提示 -->
                <div id="iconNoResults" class="text-center py-5 text-muted" style="display: none;">
                    <i data-lucide="search-x" style="width: 3rem; height: 3rem;" class="mb-3"></i>
                    <p class="mb-0">找不到符合的圖標</p>
                    <p class="small">請嘗試其他關鍵字</p>
                </div>
            </div>
            
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="selectIcon()">選擇</button>
            </div>
        </div>
    </div>
</div>

<!-- 靜態 Modal：操作說明 -->
<div id="navigation-help" class="modal fade" tabindex="-1" aria-labelledby="navigationHelpLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">操作說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            
            <div class="modal-body p-4">
                <div class="mb-4">
                    <h6 class="fw-semibold mb-3">基本操作</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i data-lucide="plus-circle" style="width: 1rem; height: 1rem;" class="text-primary mt-1"></i>
                            <span><strong>新增目錄：</strong>點擊「新增目錄」按鈕，填寫表單後儲存</span>
                        </li>
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i data-lucide="edit" style="width: 1rem; height: 1rem;" class="text-purple mt-1"></i>
                            <span><strong>編輯目錄：</strong>點擊目錄卡片上的編輯按鈕</span>
                        </li>
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i data-lucide="eye" style="width: 1rem; height: 1rem;" class="text-success mt-1"></i>
                            <span><strong>查看詳情：</strong>點擊目錄卡片上的查看按鈕</span>
                        </li>
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i data-lucide="trash-2" style="width: 1rem; height: 1rem;" class="text-danger mt-1"></i>
                            <span><strong>刪除目錄：</strong>點擊刪除按鈕，輸入目錄代碼確認</span>
                        </li>
                    </ul>
                </div>
                
                <div class="mb-4">
                    <h6 class="fw-semibold mb-3">進階功能</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i data-lucide="chevron-down" style="width: 1rem; height: 1rem;" class="text-muted mt-1"></i>
                            <span><strong>展開/收合：</strong>點擊子項目旁的箭頭圖標</span>
                        </li>
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i data-lucide="search" style="width: 1rem; height: 1rem;" class="text-muted mt-1"></i>
                            <span><strong>搜尋篩選：</strong>使用搜尋框或下拉選單篩選目錄</span>
                        </li>
                    </ul>
                </div>
            </div>
            
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

<!-- 頂部操作欄 -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="mb-0 fw-semibold">操作面板</h5>
            <button type="button" onclick="event.stopPropagation(); showModal('navigation-help')"
                    class="btn btn-link btn-sm p-0 text-muted" title="操作說明">
                <i data-lucide="help-circle" style="width: 1.25rem; height: 1.25rem;"></i>
            </button>
        </div>

        <!-- 搜尋區 -->
        <div class="mb-3">
            <div class="position-relative">
                <input type="text" id="searchInput" placeholder="搜尋目錄名稱、路徑..."
                       class="form-control form-control-sm ps-5">
                <i data-lucide="search" class="position-absolute text-muted" style="width: 1rem; height: 1rem; left: 0.75rem; top: 50%; transform: translateY(-50%);"></i>
            </div>
        </div>

        <!-- 篩選與操作按鈕 -->
        <div class="row g-2">
            <div class="col-6 col-lg-3">
                <select id="statusFilter" class="form-select form-select-sm">
                    <option value="">所有狀態</option>
                    <option value="active">啟用</option>
                    <option value="inactive">停用</option>
                </select>
            </div>

            <div class="col-6 col-lg-3">
                <select id="levelFilter" class="form-select form-select-sm">
                    <option value="">所有層級</option>
                    <option value="0">第一層</option>
                    <option value="1">第二層</option>
                    <option value="2">第三層</option>
                </select>
            </div>

            <div class="col-12 col-lg-6">
                <button onclick="showModal('nav-add-modal')" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2">
                    <i data-lucide="plus" style="width: 1rem; height: 1rem;"></i>
                    新增目錄
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 目錄樹狀結構 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom p-3">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="folder-tree" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
            <h5 class="mb-0 fw-semibold">目錄結構</h5>
        </div>
    </div>

    <div id="navigationTreeContent" class="card-body p-3">
        @if (rootItems?.Any() == true)
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var item in rootItems)
                {
                    @await Html.PartialAsync("_NavigationTreeItem", item, ViewData)
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i data-lucide="folder-x" class="mx-auto mb-2 text-muted" style="width: 3rem; height: 3rem;"></i>
                <p class="mb-0">尚未建立任何導航項目</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/Backoffice/js/NavigationManagement.js"></script>
}
