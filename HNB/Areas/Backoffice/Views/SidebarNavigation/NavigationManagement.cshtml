@{
    ViewData["Title"] = "目錄管理 - 後台管理系統";
    ViewData["PageTitle"] = "目錄管理";
    ViewData["PageDescription"] = "管理系統導航選單結構與權限";
    ViewData["PageIcon"] = "folder-tree";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";

    var allNavigations = ViewBag.NavigationTree as List<HNB.Areas.Backoffice.Services.NavigationItem> ?? new List<HNB.Areas.Backoffice.Services.NavigationItem>();
}

@await Html.PartialAsync("_NavigationModal")


<div class="space-y-6">
    <!-- 頂部操作欄 -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <div class="flex flex-col lg:flex-row gap-4 items-start lg:items-center justify-between">
            <!-- 搜尋區 -->
            <div class="flex-1 w-full lg:w-auto">
                <div class="relative">
                    <input type="text" id="searchInput" placeholder="搜尋目錄名稱、路徑..."
                           class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3 top-3 text-slate-400"></i>
                </div>
            </div>

            <!-- 篩選與操作按鈕 -->
            <div class="flex gap-3 w-full lg:w-auto">
                <select id="statusFilter" class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有狀態</option>
                    <option value="active">啟用</option>
                    <option value="inactive">停用</option>
                </select>

                <select id="levelFilter" class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">所有層級</option>
                    <option value="0">第一層</option>
                    <option value="1">第二層</option>
                    <option value="2">第三層</option>
                </select>

                <button onclick="showNavModal('nav-edit-modal')" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2 transition-colors whitespace-nowrap">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    新增目錄
                </button>
            </div>
        </div>
    </div>

    <!-- 目錄樹狀結構 -->
    <div id="navigationTreeContainer" class="bg-white rounded-xl shadow-sm border border-slate-200">
        <div class="p-6 border-b border-slate-200">
            <div class="flex items-center gap-3">
                <i data-lucide="folder-tree" class="w-5 h-5 text-blue-600"></i>
                <h2 class="text-lg font-semibold text-slate-900">目錄結構</h2>
            </div>
        </div>
        
        <div id="navigationTreeContent" class="p-6">
            @if (allNavigations != null && allNavigations.Any())
            {
                <div class="space-y-2">
                    @foreach (var item in allNavigations)
                    {
                        var hasChildren = item.HasChildren;
                        var isExternalLink = !string.IsNullOrEmpty(item.Url) && (item.Url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || item.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase));

                        <div class="nav-tree-item">
                            <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg border border-slate-200 hover:border-blue-300 hover:shadow-sm transition-all group">
                                <div class="flex items-center gap-4 flex-1">
                                    @(hasChildren? Html.Raw("<button type=\"button\" onclick=\"toggleChildren(this)\" class=\"text-slate-400 hover:text-slate-600 transition-colors\"><i data-lucide=\"chevron-down\" class=\"w-4 h-4 transform transition-transform\"></i></button>") : Html.Raw("<div class=\"w-4\"></div>"))

                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                        <i data-lucide="@(item.Icon ?? "folder")" class="w-5 h-5 text-blue-600"></i>
                                    </div>

                                    <div class="flex-1">
                                        <div class="flex items-center gap-3">
                                            <h3 class="font-semibold text-slate-900">@item.Title</h3>
                                            <span class="px-2 py-1 text-xs font-semibold rounded-full @(item.IsActive ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@(item.IsActive ? "啟用" : "停用")</span>
                                            @(isExternalLink? Html.Raw("<span class=\"px-2 py-1 text-xs font-medium bg-orange-100 text-orange-700 rounded flex items-center gap-1\"><i data-lucide=\"external-link\" class=\"w-3 h-3\"></i>外部連結</span>") : Html.Raw(""))
                                        </div>
                                        <div class="flex items-center gap-4 mt-1 text-sm text-slate-500">
                                            <span class="flex items-center gap-1"><i data-lucide="hash" class="w-3 h-3"></i>@item.Code</span>
                                            @(!string.IsNullOrEmpty(item.Url) ? Html.Raw($"<span class=\"flex items-center gap-1\"><i data-lucide=\"{(isExternalLink ? "external-link" : "link")}\" class=\"w-3 h-3\"></i>{System.Web.HttpUtility.HtmlEncode(item.Url)}</span>") : Html.Raw("<span class=\"text-slate-400\">無連結（分類項目）</span>"))
                                        </div>
                                    </div>
                                </div>

                                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button type="button" onclick="showNavModal('nav-detail-modal', @item.Id)" class="p-2 text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="查看詳情"><i data-lucide="eye" class="w-4 h-4"></i></button>
                                    <button type="button" onclick="showNavModal('nav-edit-modal', @item.Id)" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="編輯"><i data-lucide="edit" class="w-4 h-4"></i></button>
                                    <button type="button" onclick="if(confirm('確定要刪除「@item.Title」嗎？')) console.log('刪除ID:@item.Id')" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="刪除"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </div>
                            </div>

                            @if (hasChildren)
                            {
                                <div class="ml-8 mt-2 space-y-2 border-l-2 border-slate-200 pl-4 hidden nav-children">
                                    @foreach (var child in item.Children.OrderBy(c => c.SortOrder))
                                    {
                                        var childHasChildren = child.HasChildren;
                                        var childIsExternalLink = !string.IsNullOrEmpty(child.Url) && (child.Url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || child.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase));

                                        <div class="nav-tree-item">
                                            <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg border border-slate-200 hover:border-blue-300 hover:shadow-sm transition-all group">
                                                <div class="flex items-center gap-4 flex-1">
                                                    @(childHasChildren? Html.Raw("<button type=\"button\" onclick=\"toggleChildren(this)\" class=\"text-slate-400 hover:text-slate-600 transition-colors\"><i data-lucide=\"chevron-down\" class=\"w-4 h-4 transform transition-transform\"></i></button>") : Html.Raw("<div class=\"w-4\"></div>"))

                                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                                        <i data-lucide="@(child.Icon ?? "folder")" class="w-5 h-5 text-blue-600"></i>
                                                    </div>

                                                    <div class="flex-1">
                                                        <div class="flex items-center gap-3">
                                                            <h3 class="font-semibold text-slate-900">@child.Title</h3>
                                                            <span class="px-2 py-1 text-xs font-semibold rounded-full @(child.IsActive ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@(child.IsActive ? "啟用" : "停用")</span>
                                                            @(childIsExternalLink? Html.Raw("<span class=\"px-2 py-1 text-xs font-medium bg-orange-100 text-orange-700 rounded flex items-center gap-1\"><i data-lucide=\"external-link\" class=\"w-3 h-3\"></i>外部連結</span>") : Html.Raw(""))
                                                        </div>
                                                        <div class="flex items-center gap-4 mt-1 text-sm text-slate-500">
                                                            <span class="flex items-center gap-1"><i data-lucide="hash" class="w-3 h-3"></i>@child.Code</span>
                                                            @(!string.IsNullOrEmpty(child.Url) ? Html.Raw($"<span class=\"flex items-center gap-1\"><i data-lucide=\"{(childIsExternalLink ? "external-link" : "link")}\" class=\"w-3 h-3\"></i>{System.Web.HttpUtility.HtmlEncode(child.Url)}</span>") : Html.Raw("<span class=\"text-slate-400\">無連結（分類項目）</span>"))
                                                        </div>
                                                    </div>
                                                </div>

                                               <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                   <button type="button" onclick="showNavModal('nav-detail-modal', @child.Id)" class="p-2 text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="查看詳情"><i data-lucide="eye" class="w-4 h-4"></i></button>
                                                   <button type="button" onclick="showNavModal('nav-edit-modal', @child.Id)" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="編輯"><i data-lucide="edit" class="w-4 h-4"></i></button>
                                                   <button type="button" onclick="if(confirm('確定要刪除「@child.Title」嗎？')) console.log('刪除ID:@child.Id')" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="刪除"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                               </div>
                                            </div>

                                            @if (childHasChildren)
                                            {
                                                <div class="ml-8 mt-2 space-y-2 border-l-2 border-slate-200 pl-4 hidden nav-children">
                                                    @foreach (var grandChild in child.Children.OrderBy(c => c.SortOrder))
                                                    {
                                                        var grandChildIsExternalLink = !string.IsNullOrEmpty(grandChild.Url) && (grandChild.Url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || grandChild.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase));

                                                        <div class="nav-tree-item">
                                                            <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg border border-slate-200 hover:border-blue-300 hover:shadow-sm transition-all group">
                                                                <div class="flex items-center gap-4 flex-1">
                                                                    <div class="w-4"></div>
                                                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                                                        <i data-lucide="@(grandChild.Icon ?? "folder")" class="w-5 h-5 text-blue-600"></i>
                                                                    </div>

                                                                    <div class="flex-1">
                                                                        <div class="flex items-center gap-3">
                                                                            <h3 class="font-semibold text-slate-900">@grandChild.Title</h3>
                                                                            <span class="px-2 py-1 text-xs font-semibold rounded-full @(grandChild.IsActive ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@(grandChild.IsActive ? "啟用" : "停用")</span>
                                                                            @(grandChildIsExternalLink? Html.Raw("<span class=\"px-2 py-1 text-xs font-medium bg-orange-100 text-orange-700 rounded flex items-center gap-1\"><i data-lucide=\"external-link\" class=\"w-3 h-3\"></i>外部連結</span>") : Html.Raw(""))
                                                                        </div>
                                                                        <div class="flex items-center gap-4 mt-1 text-sm text-slate-500">
                                                                            <span class="flex items-center gap-1"><i data-lucide="hash" class="w-3 h-3"></i>@grandChild.Code</span>
                                                                            @(!string.IsNullOrEmpty(grandChild.Url) ? Html.Raw($"<span class=\"flex items-center gap-1\"><i data-lucide=\"{(grandChildIsExternalLink ? "external-link" : "link")}\" class=\"w-3 h-3\"></i>{System.Web.HttpUtility.HtmlEncode(grandChild.Url)}</span>") : Html.Raw("<span class=\"text-slate-400\">無連結（分類項目）</span>"))
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                               <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                                   <button type="button" onclick="showNavModal('nav-detail-modal', @grandChild.Id)" class="p-2 text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="查看詳情"><i data-lucide="eye" class="w-4 h-4"></i></button>
                                                                   <button type="button" onclick="showNavModal('nav-edit-modal', @grandChild.Id)" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="編輯"><i data-lucide="edit" class="w-4 h-4"></i></button>
                                                                   <button type="button" onclick="if(confirm('確定要刪除「@grandChild.Title」嗎？')) console.log('刪除ID:@grandChild.Id')" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="刪除"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                                               </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12 text-slate-500">
                    <i data-lucide="folder-x" class="h-12 w-12 mx-auto mb-3 text-slate-400"></i>
                    <p>尚未建立任何導航項目</p>
                </div>
            }

        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('searchInput')?.addEventListener('input', applyFilters);
            document.getElementById('statusFilter')?.addEventListener('change', applyFilters);
            document.getElementById('levelFilter')?.addEventListener('change', applyFilters);
        });

        function applyFilters() {
            const searchKeyword = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const statusFilter = document.getElementById('statusFilter')?.value || '';
            const levelFilter = document.getElementById('levelFilter')?.value || '';
                        const treeContainer = document.getElementById('navigationTreeContent');
            if (!treeContainer) return;
            
            const allItems = treeContainer.querySelectorAll('.nav-tree-item');
            let visibleCount = 0;
            
            allItems.forEach(item => {
                const card = item.querySelector('.flex.items-center.justify-between');
                if (!card) return;
                
                const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
                const code = card.querySelector('[data-lucide="hash"]')?.parentElement?.textContent.toLowerCase() || '';
                const url = card.querySelector('[data-lucide="link"], [data-lucide="external-link"]')?.parentElement?.textContent.toLowerCase() || '';
                const statusBadge = card.querySelector('.rounded-full')?.textContent || '';
                const isActive = statusBadge.includes('啟用');
                
                let level = 0;
                let parent = item.parentElement;
                while (parent) {
                    if (parent.classList.contains('nav-children')) {
                        level++;
                    }
                    parent = parent.parentElement;
                }
                
                const matchesSearch = !searchKeyword || 
                    title.includes(searchKeyword) || 
                    code.includes(searchKeyword) || 
                    url.includes(searchKeyword);
                
                const matchesStatus = !statusFilter || 
                    (statusFilter === 'active' && isActive) || 
                    (statusFilter === 'inactive' && !isActive);
                
                const matchesLevel = !levelFilter || level.toString() === levelFilter;
                
                if (matchesSearch && matchesStatus && matchesLevel) {
                    item.style.display = '';
                    visibleCount++;
                    
                    if (searchKeyword) {
                        let parentContainer = item.parentElement;
                        while (parentContainer) {
                            if (parentContainer.classList.contains('nav-children')) {
                                parentContainer.classList.remove('hidden');
                                const parentItem = parentContainer.previousElementSibling;
                                if (parentItem) {
                                    const chevron = parentItem.querySelector('[data-lucide="chevron-down"]');
                                    if (chevron) {
                                        chevron.classList.add('rotate-180');
                                    }
                                }
                            }
                            parentContainer = parentContainer.parentElement;
                        }
                    }
                } else {
                    item.style.display = 'none';
                }
            });
            
            const emptyState = treeContainer.querySelector('.text-center.py-12');
            const itemsContainer = treeContainer.querySelector('.space-y-2');
            
            if (visibleCount === 0 && itemsContainer) {
                if (!emptyState) {
                    const emptyDiv = document.createElement('div');
                    emptyDiv.className = 'text-center py-12 text-slate-500 filter-empty-state';
                    emptyDiv.innerHTML = `
                        <i data-lucide="search-x" class="h-12 w-12 mx-auto mb-3 text-slate-400"></i>
                        <p>找不到符合條件的導航項目</p>
                        <p class="text-sm text-slate-400 mt-2">請嘗試調整搜尋或篩選條件</p>
                    `;
                    itemsContainer.parentElement.appendChild(emptyDiv);
                    lucide.createIcons();
                }
                itemsContainer.style.display = 'none';
            } else {
                const filterEmptyState = treeContainer.querySelector('.filter-empty-state');
                if (filterEmptyState) {
                    filterEmptyState.remove();
                }
                if (itemsContainer) {
                    itemsContainer.style.display = '';
                }
            }
        }

        // 展開/收起子項目
        function toggleChildren(btn) {
            const item = btn.closest('.nav-tree-item');
            const children = item.querySelector('.nav-children');
            const icon = btn.querySelector('i');
            
            if (children) {
                children.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
            }
        }

    </script>
}
