@model Models.HnbHnbBackoffice.vw_sidebar_navigation
@{
    Layout = null;
    var model = Model ?? new Models.HnbHnbBackoffice.vw_sidebar_navigation();
}

<!-- 新增目錄模態框 -->
<div id="nav-add-modal" class="modal fade" tabindex="-1" aria-labelledby="navAddModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">新增目錄</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <form id="navAddForm">
                    <input type="hidden" id="navAddId" name="id" value="">

                    <div class="vstack gap-4">
                    <!-- 基本資訊 -->
                        <div>
                            <h6 class="fw-semibold pb-2 border-bottom mb-3">基本資訊</h6>
                            <div class="vstack gap-2">
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navAddTitle" class="col-form-label col-form-label-sm mb-0">目錄名稱<span class="text-danger">*</span></label></div>
                                    <div class="col"><input type="text" id="navAddTitle" name="title" class="form-control form-control-sm" placeholder="請輸入目錄名稱" required></div>
                                    <div class="col-auto" style="width: 90px;"><label for="navAddCode" class="col-form-label col-form-label-sm mb-0">目錄代碼<span class="text-danger">*</span></label></div>
                                    <div class="col"><input type="text" id="navAddCode" name="code" class="form-control form-control-sm" placeholder="例如: dashboard" required></div>
                            </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navAddIcon" class="col-form-label col-form-label-sm mb-0">圖標</label></div>
                                    <div class="col">
                                <div class="position-relative">
                                            <div id="navAddIconPreview" class="position-absolute top-50 start-0 translate-middle-y ms-2 text-muted">
                                        <i data-lucide="image" style="width: 1rem; height: 1rem;"></i>
                                    </div>
                                            <input type="text" id="navAddIcon" name="icon" class="form-control form-control-sm ps-5 pe-5" placeholder="例如: home" readonly style="background-color: #f8f9fa; cursor: pointer;" onclick="openIconPicker()">
                                            <button type="button" class="btn btn-link position-absolute top-50 end-0 translate-middle-y me-1 p-0" onclick="openIconPicker()">
                                                <i data-lucide="search" style="width: 1rem; height: 1rem;"></i>
                                    </button>
                                </div>
                            </div>
                                    <div class="col-auto" style="width: 90px;"><label for="navAddParent" class="col-form-label col-form-label-sm mb-0">上層目錄</label></div>
                                    <div class="col">
                                        <select id="navAddParent" name="parent_code" class="form-select form-select-sm">
                                            <option value="">無（第一層）</option>
                                </select>
                            </div>
                            </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navAddSort" class="col-form-label col-form-label-sm mb-0">排序順序</label></div>
                                    <div class="col"><input type="number" id="navAddSort" name="sort_order" class="form-control form-control-sm" value="0" placeholder="數字越小越前面"></div>
                                    <div class="col-auto" style="width: 90px;"><label for="navAddIsActive" class="col-form-label col-form-label-sm mb-0">啟用狀態</label></div>
                                    <div class="col">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="navAddIsActive" name="is_active" checked>
                                            <label class="form-check-label small" for="navAddIsActive">啟用</label>
                                </div>
                            </div>
                        </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navAddUrl" class="col-form-label col-form-label-sm mb-0">路徑 URL</label></div>
                                    <div class="col"><input type="text" id="navAddUrl" name="url" class="form-control form-control-sm" placeholder="/Backoffice/Dashboard 或 https://example.com"></div>
                            </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveNavigation('add')">儲存</button>
            </div>
        </div>
    </div>
</div>

<!-- 編輯目錄模態框 -->
<div id="nav-edit-modal" class="modal fade" tabindex="-1" aria-labelledby="navEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">編輯目錄</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <form id="navEditForm">
                    <input type="hidden" id="navEditId" name="id" value="@(model.id?.ToString() ?? "")">

                    <div class="vstack gap-4">
                    <!-- 基本資訊 -->
                        <div>
                            <h6 class="fw-semibold pb-2 border-bottom mb-3">基本資訊</h6>
                            <div class="vstack gap-2">
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navEditTitle" class="col-form-label col-form-label-sm mb-0">目錄名稱<span class="text-danger">*</span></label></div>
                                    <div class="col"><input type="text" id="navEditTitle" name="title" class="form-control form-control-sm" placeholder="請輸入目錄名稱" value="@(model.title ?? "")" required></div>
                                    <div class="col-auto" style="width: 90px;"><label for="navEditCode" class="col-form-label col-form-label-sm mb-0">目錄代碼<span class="text-danger">*</span></label></div>
                                    <div class="col"><input type="text" id="navEditCode" name="code" class="form-control form-control-sm" placeholder="例如: dashboard" value="@(model.code ?? "")" required></div>
                            </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navEditIcon" class="col-form-label col-form-label-sm mb-0">圖標</label></div>
                                    <div class="col">
                                <div class="position-relative">
                                            <div id="navEditIconPreview" class="position-absolute top-50 start-0 translate-middle-y ms-2 text-muted">
                                        @if (!string.IsNullOrEmpty(model.icon))
                                        {
                                                    <i data-lucide="@(model.icon ?? "")" style="width: 1rem; height: 1rem;"></i>
                                        }
                                        else
                                        {
                                            <i data-lucide="image" style="width: 1rem; height: 1rem;"></i>
                                        }
                                    </div>
                                            <input type="text" id="navEditIcon" name="icon" class="form-control form-control-sm ps-5 pe-5" placeholder="例如: home" value="@(model.icon ?? "")" readonly style="background-color: #f8f9fa; cursor: pointer;" onclick="openIconPicker()">
                                            <button type="button" class="btn btn-link position-absolute top-50 end-0 translate-middle-y me-1 p-0" onclick="openIconPicker()">
                                                <i data-lucide="search" style="width: 1rem; height: 1rem;"></i>
                                    </button>
                                </div>
                            </div>
                                    <div class="col-auto" style="width: 90px;"><label for="navEditParent" class="col-form-label col-form-label-sm mb-0">上層目錄</label></div>
                                    <div class="col">
                                        <select id="navEditParent" name="parent_code" class="form-select form-select-sm">
                                            <option value="">無（第一層）</option>
                                </select>
                            </div>
                            </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navEditSort" class="col-form-label col-form-label-sm mb-0">排序順序</label></div>
                                    <div class="col"><input type="number" id="navEditSort" name="sort_order" class="form-control form-control-sm" value="@(model.sort_order ?? 0)" placeholder="數字越小越前面"></div>
                                    <div class="col-auto" style="width: 90px;"><label for="navEditIsActive" class="col-form-label col-form-label-sm mb-0">啟用狀態</label></div>
                                    <div class="col">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="navEditIsActive" name="is_active" @(model.is_active == true ? "checked" : "")>
                                            <label class="form-check-label small" for="navEditIsActive">啟用</label>
                                </div>
                            </div>
                        </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto" style="width: 90px;"><label for="navEditUrl" class="col-form-label col-form-label-sm mb-0">路徑 URL</label></div>
                                    <div class="col"><input type="text" id="navEditUrl" name="url" class="form-control form-control-sm" placeholder="/Backoffice/Dashboard 或 https://example.com" value="@(model.url ?? "")"></div>
                            </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveNavigation('edit')">儲存</button>
            </div>
        </div>
    </div>
</div>

<!-- 查看詳情模態框 -->
<div id="nav-detail-modal" class="modal fade" tabindex="-1" aria-labelledby="navDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">目錄詳情</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="vstack gap-3">
                    <!-- 基本資訊 -->
                    <div>
                        <h6 class="fw-semibold mb-2">基本資訊</h6>
                        <table class="table table-sm table-borderless small">
                            <tr><td class="text-muted" style="width: 100px;">目錄名稱</td><td>@(model.title ?? "-")</td></tr>
                            <tr><td class="text-muted">目錄代碼</td><td><code>@(model.code ?? "-")</code></td></tr>
                            <tr><td class="text-muted">圖標</td><td>
                                        @if (!string.IsNullOrEmpty(model.icon))
                                        {
                                    <i data-lucide="@(model.icon)" style="width: 1rem; height: 1rem;"></i>
                                    <span>@(model.icon)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">未設定</span>
                                        }
                            </td></tr>
                            <tr><td class="text-muted">狀態</td><td><span class="badge rounded-pill @(model.is_active == true ? "bg-success" : "bg-danger")">@(model.is_active == true ? "啟用" : "停用")</span></td></tr>
                            <tr><td class="text-muted">上層目錄</td><td>@(model.parent_code ?? "無（第一層）")</td></tr>
                            <tr><td class="text-muted">排序順序</td><td>@(model.sort_order ?? 0)</td></tr>
                        </table>
                    </div>

                    <!-- 路徑資訊 -->
                            <div>
                        <h6 class="fw-semibold mb-2">路徑資訊</h6>
                        <table class="table table-sm table-borderless small">
                            <tr><td class="text-muted" style="width: 100px;">路徑 URL</td><td>
                                @if (!string.IsNullOrEmpty(model.url))
                                {
                                    var url = model.url ?? "";
                                    <span>@url</span>
                                    @if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-warning text-dark ms-2">外部連結</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">無（分類項目）</span>
                                }
                            </td></tr>
                        </table>
                    </div>

                    <!-- 系統資訊 -->
                    <div>
                        <h6 class="fw-semibold mb-2">系統資訊</h6>
                        <table class="table table-sm table-borderless small">
                            <tr><td class="text-muted" style="width: 100px;">建立時間</td><td>@(model.created_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td></tr>
                            <tr><td class="text-muted">更新時間</td><td>@(model.updated_at?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td></tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

<!-- 刪除確認模態框 -->
<div id="nav-delete-modal" class="modal fade" tabindex="-1" aria-labelledby="navDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">刪除目錄</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="deleteNavId" value="@(model.id?.ToString() ?? "")">

                <div class="alert alert-danger mb-3">
                        <h6 class="fw-semibold mb-2">警告：此操作無法復原</h6>
                        <p class="mb-0 small">刪除此目錄後，所有相關數據將永久移除且無法恢復。</p>
                </div>

                <div class="mb-3">
                    <h6 class="fw-semibold mb-2">即將刪除的目錄</h6>
                    <table class="table table-sm table-borderless small">
                        <tr><td class="text-muted" style="width: 100px;">目錄名稱</td><td>@(model.title ?? "-")</td></tr>
                        <tr><td class="text-muted">目錄代碼</td><td><code>@(model.code ?? "-")</code></td></tr>
                    </table>
                </div>

                <div>
                    <h6 class="fw-semibold mb-2">確認刪除</h6>
                    <p class="small text-muted mb-2">請輸入目錄代碼 <code class="text-danger fw-semibold">@(model.code ?? "")</code> 以確認刪除：</p>
                    <input type="text" id="deleteConfirmInput" class="form-control form-control-sm" placeholder="請輸入目錄代碼" oninput="validateDeleteInput()">
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" id="btnConfirmDelete" class="btn btn-danger btn-sm" onclick="confirmDelete()" disabled>確認刪除</button>
            </div>
        </div>
    </div>
</div>