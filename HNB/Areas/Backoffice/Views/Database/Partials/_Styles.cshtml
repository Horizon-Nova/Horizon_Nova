@{
    Layout = null;
}

<style>
/* 基於Bootstrap的Autocomplete樣式 */
.autocomplete-container {
    position: relative;
    width: 100%;
}

.autocomplete-input {
    width: 100%;
    padding: 6px 8px;
    border: 1px solid var(--Gray-300);
    border-radius: 0.375rem;
    font-size: 14px;
    background-color: var(--White);
    transition: all 0.2s;
}

    .autocomplete-input:focus {
        outline: none;
        border-color: var(--Emerald-500);
        box-shadow: 0 0 0 1px var(--Emerald-500);
    }

/* 簡化的下拉選單樣式 - 位置由 JavaScript 動態控制 */
.SearchResults {
    max-height: 200px;
    overflow-x: hidden;
    border: 1px solid var(--Gray-DDD);
    border-radius: 4px;
    background-color: var(--White);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

/* 資料庫管理頁面特定樣式 */
.database-management-container {
    max-width: 1200px;
    margin: 0 auto;
}

.connection-card {
    background: var(--White);
    border-radius: 12px;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    border: 1px solid var(--Gray-200);
}

.table-management-card {
    background: var(--White);
    border-radius: 12px;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    border: 1px solid var(--Gray-200);
}

.operation-result {
    margin-top: 1rem;
    min-height: 50px;
}

/* 表格樣式 */
.table-fields-table {
    width: 100%;
    border-collapse: collapse;
}

    .table-fields-table th {
        background-color: var(--Slate-50);
        font-weight: 600;
        text-align: left;
        padding: 12px;
        border-bottom: 2px solid var(--Gray-200);
    }

    .table-fields-table td {
        padding: 12px;
        border-bottom: 1px solid var(--Gray-200);
    }

.field-row:hover {
    background-color: var(--Slate-50);
}

/* 按鈕樣式 */
.btn-database {
    background: linear-gradient(135deg, var(--Emerald-500) 0%, var(--Emerald-600) 100%);
    border: none;
    color: var(--White);
    font-weight: 500;
    transition: all 0.2s;
}

    .btn-database:hover {
        background: linear-gradient(135deg, var(--Emerald-600) 0%, var(--Emerald-700) 100%);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

.btn-secondary-custom {
    background: var(--Gray-500);
    border: none;
    color: var(--White);
    font-weight: 500;
    transition: all 0.2s;
}

    .btn-secondary-custom:hover {
        background: var(--Gray-600);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(107, 114, 128, 0.3);
    }

/* 模態視窗樣式 */
.modal-content {
    border-radius: 12px;
    border: none;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

.modal-header {
    border-bottom: 1px solid var(--Gray-200);
    padding: 1.5rem;
}

.modal-body {
    padding: 1.5rem;
}

.modal-footer {
    border-top: 1px solid var(--Gray-200);
    padding: 1.5rem;
}

/* 表單樣式 */
.form-control:focus {
    border-color: var(--Emerald-500);
    box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
}

.form-select:focus {
    border-color: var(--Emerald-500);
    box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
}

/* 狀態指示器 */
.status-indicator {
    display: inline-flex;
    align-items: center;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
}

.status-success {
    background-color: var(--Emerald-100);
    color: var(--Emerald-800);
}

.status-warning {
    background-color: var(--Yellow-100);
    color: var(--Yellow-800);
}

.status-error {
    background-color: var(--Red-100);
    color: var(--Red-800);
}

.status-info {
    background-color: var(--Blue-100);
    color: var(--Blue-800);
}

/* 動畫效果 */
.fade-in {
    animation: fadeIn 0.3s ease-in-out;
}

@@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.slide-in {
    animation: slideIn 0.3s ease-in-out;
}

@@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }

    to {
        opacity: 1;
        transform: translateX(0);
    }
}
</style>

