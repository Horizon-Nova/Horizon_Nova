@using HNB.Areas.Backoffice.Dtos
@{
    Layout = null;
    var tableName = ViewBag.TableName as string;
    var tableColumns = ViewBag.TableColumns as List<TableColumnDto> ?? new();
}

<div id="tableDetailsModal" class="modal fade" tabindex="-1" aria-labelledby="tableDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tableDetailsModalLabel">
                    資料表詳情 @(string.IsNullOrWhiteSpace(tableName) ? string.Empty : $"- {tableName}")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body">
                <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <i data-lucide="columns" class="text-primary" style="width: 2rem; height: 2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <p class="text-muted small mb-0">總欄位數</p>
                                            <h5 class="mb-0">@((tableColumns.Count > 0 ? tableColumns.Count.ToString() : null) ?? "")</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <i data-lucide="key" class="text-success" style="width: 2rem; height: 2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <p class="text-muted small mb-0">主鍵欄位</p>
                                            <h5 class="mb-0">@((tableColumns.Count(c => c.IsPrimaryKey) > 0 ? tableColumns.Count(c => c.IsPrimaryKey).ToString() : null) ?? "")</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <i data-lucide="shield-check" class="text-warning" style="width: 2rem; height: 2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <p class="text-muted small mb-0">必填欄位</p>
                                            <h5 class="mb-0">@((tableColumns.Count(c => !c.IsNullable) > 0 ? tableColumns.Count(c => !c.IsNullable).ToString() : null) ?? "")</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>欄位名稱</th>
                                <th>資料型別</th>
                                <th>長度</th>
                                <th>允許空值</th>
                                <th>預設值</th>
                                <th>主鍵</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var column in tableColumns)
                            {
                                <tr>
                                    <td><strong>@(column.ColumnName ?? "")</strong></td>
                                    <td><span class="badge bg-primary">@(column.DataType ?? "")</span></td>
                                    <td>
                                        @(column.Length ?? "")
                                    </td>
                                    <td>
                                        <span class="badge @(column.IsNullable ? "bg-success" : "bg-danger")">
                                            @(column.IsNullable ? "允許" : "必填")
                                        </span>
                                    </td>
                                    <td>
                                        @(column.DefaultValue ?? "")
                                    </td>
                                    <td>
                                        <span class="badge @(column.IsPrimaryKey ? "bg-warning text-dark" : "bg-light text-muted border")">
                                            @(column.IsPrimaryKey ? "主鍵" : "-")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <div class="text-muted small me-auto">
                    共 @((tableColumns.Count > 0 ? tableColumns.Count.ToString() : null) ?? "") 個欄位
                </div>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

