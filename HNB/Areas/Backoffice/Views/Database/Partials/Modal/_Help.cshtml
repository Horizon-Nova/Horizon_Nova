@{
    Layout = null;
}

<div id="helpModal" class="modal fade" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="helpModalLabel">資料庫管理說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <section>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">什麼是資料庫管理？</h6>
                                <p class="small mb-0">
                                    這個工具可協助連線至既有資料庫，並備份資料表結構與資料，
                                    方便管理與遷移，類似使用資料庫客戶端（如 DBeaver）的流程。
                                </p>
                            </section>

                            <section>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">操作步驟</h6>
                                <ol class="small mb-0">
                                    <li>選擇資料庫類型（SQL Server、PostgreSQL）。</li>
                                    <li>填入連線字串與輸出位置。</li>
                                    <li>點擊「測試連線」確認連接是否成功。</li>
                                    <li>測試成功後，即可執行「備份資料表」。</li>
                                    <li>待備份完成後，可透過資料表管理操作或匯出結果。</li>
                                </ol>
                            </section>

                            <section>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">連線字串範例</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>SQL Server:</strong></p>
                                    <code class="d-block bg-light p-2 rounded mb-3">Server=localhost;Database=MyDB;User Id=sa;Password=123456;</code>
                                    <p class="mb-2"><strong>PostgreSQL:</strong></p>
                                    <code class="d-block bg-light p-2 rounded">Host=localhost;Database=MyDB;Username=postgres;Password=123456;</code>
                                </div>
                            </section>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <section>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">備份說明</h6>
                                <div class="alert alert-warning small mb-0">
                                    <strong>重要提醒：</strong>
                                    <ul class="mb-0 mt-2">
                                        <li>每次備份會建立帶時間戳記的資料夾。</li>
                                        <li>備份包含資料表結構與資料，請確保磁碟空間足夠。</li>
                                        <li>備份前務必確認連線資訊正確，以免造成失敗。</li>
                                    </ul>
                                </div>
                            </section>

                            <section>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>Q1：連線測試失敗怎麼辦？</strong></p>
                                    <p class="ms-3 mb-3">A：請檢查 IP、防火牆、帳密與資料庫是否對外開放。</p>

                                    <p class="mb-2"><strong>Q2：可以備份哪些資料庫？</strong></p>
                                    <p class="ms-3 mb-3">A：目前支援 SQL Server 與 PostgreSQL。</p>

                                    <p class="mb-2"><strong>Q3：備份檔案存在哪裡？</strong></p>
                                    <p class="ms-3 mb-0">A：依照「輸出位置」欄位指定路徑建立資料夾。</p>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">我知道了</button>
            </div>
        </div>
    </div>
</div>

