@model List<HNB.Areas.Backoffice.Dtos.TableColumnDto>

<div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
            @if (Model != null && Model.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full border-collapse border border-slate-300">
                        <thead>
                            <tr class="bg-slate-50">
                                <th class="border border-slate-300 px-4 py-3 text-left text-sm font-medium text-slate-700">欄位名稱</th>
                                <th class="border border-slate-300 px-4 py-3 text-left text-sm font-medium text-slate-700">資料型別</th>
                                <th class="border border-slate-300 px-4 py-3 text-left text-sm font-medium text-slate-700">最大長度</th>
                                <th class="border border-slate-300 px-4 py-3 text-left text-sm font-medium text-slate-700">允許空值</th>
                                <th class="border border-slate-300 px-4 py-3 text-left text-sm font-medium text-slate-700">預設值</th>
                                <th class="border border-slate-300 px-4 py-3 text-left text-sm font-medium text-slate-700">主鍵</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var column in Model)
                            {
                                <tr class="hover:bg-slate-50">
                                    <td class="border border-slate-300 px-4 py-3 text-sm text-slate-800 font-medium">@column.ColumnName</td>
                                    <td class="border border-slate-300 px-4 py-3 text-sm text-slate-600">@column.DataType</td>
                                    <td class="border border-slate-300 px-4 py-3 text-sm text-slate-600">
                                        @if (!string.IsNullOrEmpty(column.Length))
                                        {
                                            @column.Length
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">-</span>
                                        }
                                    </td>
                                    <td class="border border-slate-300 px-4 py-3 text-sm">
                                        @if (column.IsNullable)
                                        {
                                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                <i data-lucide="check" class="w-3 h-3 mr-1"></i>
                                                允許
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                <i data-lucide="x" class="w-3 h-3 mr-1"></i>
                                                不允許
                                            </span>
                                        }
                                    </td>
                                    <td class="border border-slate-300 px-4 py-3 text-sm text-slate-600">
                                        @if (!string.IsNullOrEmpty(column.DefaultValue))
                                        {
                                            <code class="bg-slate-100 px-2 py-1 rounded text-xs">@column.DefaultValue</code>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">-</span>
                                        }
                                    </td>
                                    <td class="border border-slate-300 px-4 py-3 text-sm">
                                        @if (column.IsPrimaryKey)
                                        {
                                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                <i data-lucide="key" class="w-3 h-3 mr-1"></i>
                                                是
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-8">
                    <i data-lucide="database" class="w-16 h-16 mx-auto text-slate-300 mb-4"></i>
                    <p class="text-slate-500">沒有找到資料表欄位資訊</p>
                </div>
            }
</div>
