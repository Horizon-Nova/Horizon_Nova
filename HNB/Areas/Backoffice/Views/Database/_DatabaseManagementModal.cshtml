@using HNB.Areas.Backoffice.Dtos
@{
    Layout = null;
    var tableName = ViewBag.TableName as string;
    var tableColumns = ViewBag.TableColumns as List<TableColumnDto> ?? new List<TableColumnDto>();
}

<!-- 資料表詳情視窗 -->
<div id="tableDetailsModal" class="modal fade" tabindex="-1" aria-labelledby="tableDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="tableDetailsModalLabel">
                    資料表詳情 @(!string.IsNullOrEmpty(tableName) ? $"- {tableName}" : "")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                @if (tableColumns != null && tableColumns.Any())
                {
                    <!-- 統計資訊 -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <i data-lucide="columns" class="text-primary" style="width: 2rem; height: 2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <p class="text-muted small mb-0">總欄位數</p>
                                            <h5 class="mb-0">@tableColumns.Count</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <i data-lucide="key" class="text-success" style="width: 2rem; height: 2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <p class="text-muted small mb-0">主鍵欄位</p>
                                            <h5 class="mb-0">@tableColumns.Count(c => c.IsPrimaryKey)</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <i data-lucide="shield-check" class="text-warning" style="width: 2rem; height: 2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <p class="text-muted small mb-0">必填欄位</p>
                                            <h5 class="mb-0">@tableColumns.Count(c => !c.IsNullable)</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 表格 -->
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>欄位名稱</th>
                                    <th>資料型別</th>
                                    <th>長度</th>
                                    <th>允許空值</th>
                                    <th>預設值</th>
                                    <th>主鍵</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var column in tableColumns)
                                {
                                    <tr>
                                        <td>
                                            <strong>@column.ColumnName</strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary">@column.DataType</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(column.Length))
                                            {
                                                <code>@column.Length</code>
                                            }
                                            else
                                            {
                                                <span class="text-muted">無限制</span>
                                            }
                                        </td>
                                        <td>
                                            @if (column.IsNullable)
                                            {
                                                <span class="badge bg-success">允許</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">必填</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(column.DefaultValue))
                                            {
                                                <code>@column.DefaultValue</code>
                                            }
                                            else
                                            {
                                                <span class="text-muted">無</span>
                                            }
                                        </td>
                                        <td>
                                            @if (column.IsPrimaryKey)
                                            {
                                                <span class="badge bg-warning text-dark">主鍵</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i data-lucide="database-x" class="text-muted" style="width: 3rem; height: 3rem;"></i>
                        <h5 class="mt-3">沒有找到資料表欄位資訊</h5>
                        <p class="text-muted">請檢查資料表名稱是否正確，或資料表是否包含任何欄位。</p>
                    </div>
                }
            </div>

            <!-- Modal Footer -->
            <div class="modal-footer">
                <div class="text-muted small me-auto">
                    共 @tableColumns.Count 個欄位
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>
