@{
    Layout = null;
}

<!-- 系統狀態圖表 -->
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-4">
                    <i data-lucide="activity" class="text-success" style="width: 1.25rem; height: 1.25rem;"></i>
                    系統資源使用率
                </h5>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-center">
                            <canvas id="cpuChart" style="max-height: 200px;"></canvas>
                            <div class="mt-2">
                                <div class="fw-semibold">CPU 使用率</div>
                                <div class="h4 mb-0" id="cpuPercent">0%</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <canvas id="memoryChart" style="max-height: 200px;"></canvas>
                            <div class="mt-2">
                                <div class="fw-semibold">記憶體使用率</div>
                                <div class="h4 mb-0" id="memoryPercent">0%</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">伺服器狀態</span>
                        <span class="badge @(ViewBag.ServerStatus == "正常運行" ? "bg-success" : "bg-danger")">@(ViewBag.ServerStatus ?? "未知")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-4">
                    <i data-lucide="trending-up" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                    系統資源趨勢
                </h5>
                <div>
                    <canvas id="resourceTrendChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        // 確保 Chart.js 已載入
        if (typeof Chart === 'undefined') {
            console.error('Chart.js 未載入');
            return;
        }
        
        // 獲取 CSS 變數值
        const root = getComputedStyle(document.documentElement);
        const bootstrapDanger = root.getPropertyValue('--Bootstrap-Danger').trim();
        const bootstrapWarning = root.getPropertyValue('--Bootstrap-Warning').trim();
        const bootstrapInfo = root.getPropertyValue('--Bootstrap-Info').trim();
        const bootstrapLight = root.getPropertyValue('--Bootstrap-Light').trim();
        const bootstrapPrimary = root.getPropertyValue('--Bootstrap-Primary').trim();
        
        // 系統資源數據
        const cpuUsage = @(ViewBag.CpuUsage ?? 0);
        const memoryUsage = @(ViewBag.MemoryUsage ?? 0);
        
        // CPU 圓形圖
        const cpuCtx = document.getElementById('cpuChart');
        const cpuChart = new Chart(cpuCtx, {
        type: 'doughnut',
        data: {
            labels: ['已使用', '未使用'],
            datasets: [{
                data: [cpuUsage, 100 - cpuUsage],
                backgroundColor: [
                    cpuUsage > 90 ? bootstrapDanger : cpuUsage > 70 ? bootstrapWarning : bootstrapInfo,
                    bootstrapLight
                ],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.label + ': ' + context.parsed + '%';
                        }
                    }
                }
            },
            cutout: '75%'
        }
    });
    
    // 記憶體圓形圖
    const memoryCtx = document.getElementById('memoryChart');
    const memoryChart = new Chart(memoryCtx, {
        type: 'doughnut',
        data: {
            labels: ['已使用', '未使用'],
            datasets: [{
                data: [memoryUsage, 100 - memoryUsage],
                backgroundColor: [
                    memoryUsage > 90 ? bootstrapDanger : memoryUsage > 70 ? bootstrapWarning : bootstrapPrimary,
                    bootstrapLight
                ],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.label + ': ' + context.parsed + '%';
                        }
                    }
                }
            },
            cutout: '75%'
        }
    });
    
    // 更新百分比顯示
    document.getElementById('cpuPercent').textContent = cpuUsage.toFixed(1) + '%';
    document.getElementById('memoryPercent').textContent = memoryUsage.toFixed(1) + '%';
    
    // 資源趨勢折線圖
    const trendCtx = document.getElementById('resourceTrendChart');
    const trendChart = new Chart(trendCtx, {
        type: 'line',
        data: {
            labels: ['現在'],
            datasets: [
                {
                    label: 'CPU 使用率',
                    data: [cpuUsage],
                    borderColor: bootstrapInfo,
                    backgroundColor: 'rgba(13, 202, 240, 0.1)',
                    tension: 0.4,
                    fill: true
                },
                {
                    label: '記憶體使用率',
                    data: [memoryUsage],
                    borderColor: bootstrapPrimary,
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    tension: 0.4,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true,
                        padding: 15
                    }
                },
                tooltip: {
                    mode: 'index',
                    intersect: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100,
                    ticks: {
                        callback: function(value) {
                            return value + '%';
                        }
                    }
                }
            }
        }
    });
    });
</script>

