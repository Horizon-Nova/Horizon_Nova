@{
    Layout = null;
    var fullName = User.FindFirst("FullName")?.Value;
    var currentUserName = User.Identity?.Name ?? "未知用戶";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "未設定";
    var lastLogin = User.FindFirst("LastLogin")?.Value ?? "未記錄";
    var displayName = !string.IsNullOrEmpty(fullName) ? fullName : currentUserName;
}

<!-- 歡迎區域 -->
<div class="card border-0 shadow-sm mb-3" style="background: linear-gradient(to right, rgb(99, 102, 241), rgb(139, 92, 246));">
    <div class="card-body p-3">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="text-white fw-bold mb-2" style="font-size: 1.5rem;">歡迎回來，@displayName!</h2>
                <p class="text-white mb-1" style="opacity: 0.75;">@userEmail</p>
                <p class="text-white small mb-0" style="opacity: 0.65;">最後登入：@lastLogin</p>
            </div>
            <div class="col-md-4 text-md-end text-white">
                <div class="fw-bold mb-1" style="font-size: 2.5rem;">@DateTime.Now.ToString("HH:mm")</div>
                <div class="small mb-0" style="opacity: 0.75;">@DateTime.Now.ToString("yyyy年MM月dd日 dddd")</div>
            </div>
        </div>
    </div>
</div>

