@{
    Layout = null;
}

<!-- 系統狀態與統計 -->
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-3">
                    <i data-lucide="activity" class="text-success" style="width: 1.25rem; height: 1.25rem;"></i>
                    系統狀態
                </h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">伺服器狀態</span>
                        <span class="badge bg-success">正常運行</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">記憶體使用率</span>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress" style="width: 100px; height: 8px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: 45%"></div>
                            </div>
                            <span class="fw-semibold">45%</span>
                        </div>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">CPU 使用率</span>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress" style="width: 100px; height: 8px;">
                                <div class="progress-bar bg-info" role="progressbar" style="width: 23%"></div>
                            </div>
                            <span class="fw-semibold">23%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-3">
                    <i data-lucide="bar-chart" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                    統計資訊
                </h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">總用戶數</span>
                        <span class="fs-5 fw-bold">1,234</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">活躍用戶</span>
                        <span class="fs-5 fw-bold text-success">856</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">今日登入</span>
                        <span class="fs-5 fw-bold text-primary">42</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

