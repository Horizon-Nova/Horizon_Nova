@{
    ViewData["Title"] = "儀表板";
    ViewData["PageTitle"] = "儀表板";
    ViewData["PageDescription"] = "歡迎使用 Horizon Nova 後台管理系統";
    ViewData["PageIcon"] = "home";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@{
    var fullName = User.FindFirst("FullName")?.Value;
    var currentUserName = User.Identity?.Name ?? "未知用戶";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "未設定";
    var lastLogin = User.FindFirst("LastLogin")?.Value ?? "未記錄";
    var displayName = !string.IsNullOrEmpty(fullName) ? fullName : currentUserName;
}

<!-- 歡迎區域 -->
<div class="card border-0 shadow-sm mb-3" style="background: linear-gradient(to right, rgb(99, 102, 241), rgb(139, 92, 246));">
    <div class="card-body p-3">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="text-white fw-bold mb-2" style="font-size: 1.5rem;">歡迎回來，@displayName!</h2>
                <p class="text-white mb-1" style="opacity: 0.75;">@userEmail</p>
                <p class="text-white small mb-0" style="opacity: 0.65;">最後登入：@lastLogin</p>
            </div>
            <div class="col-md-4 text-md-end text-white">
                <div class="fw-bold mb-1" style="font-size: 2.5rem;">@DateTime.Now.ToString("HH:mm")</div>
                <div class="small mb-0" style="opacity: 0.75;">@DateTime.Now.ToString("yyyy年MM月dd日 dddd")</div>
            </div>
        </div>
    </div>
</div>

<!-- 快速操作 -->
<div class="row g-3 mb-3">
    <div class="col-12">
        <h5 class="fw-bold mb-3">
            <i data-lucide="zap" style="width: 1.25rem; height: 1.25rem;"></i>
            快速操作
        </h5>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <a href="@Url.Action("Settings", "Settings", new { area = "Backoffice" })" 
           class="card border-0 shadow-sm text-decoration-none h-100 hover-lift">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-primary bg-opacity-10 rounded">
                        <i data-lucide="settings" class="text-primary" style="width: 1.5rem; height: 1.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">系統設定</h6>
                        <p class="small text-muted mb-0">管理系統配置</p>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
        <a href="@Url.Action("Users", "PermissionManagement", new { area = "Backoffice" })" 
           class="card border-0 shadow-sm text-decoration-none h-100 hover-lift">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-success bg-opacity-10 rounded">
                        <i data-lucide="users" class="text-success" style="width: 1.5rem; height: 1.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">人員管理</h6>
                        <p class="small text-muted mb-0">管理用戶帳號</p>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
        <a href="@Url.Action("Roles", "PermissionManagement", new { area = "Backoffice" })" 
           class="card border-0 shadow-sm text-decoration-none h-100 hover-lift">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-danger bg-opacity-10 rounded">
                        <i data-lucide="shield" class="text-danger" style="width: 1.5rem; height: 1.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">角色管理</h6>
                        <p class="small text-muted mb-0">管理權限角色</p>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
        <a href="@Url.Action("Organizations", "PermissionManagement", new { area = "Backoffice" })" 
           class="card border-0 shadow-sm text-decoration-none h-100 hover-lift">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-warning bg-opacity-10 rounded">
                        <i data-lucide="building" class="text-warning" style="width: 1.5rem; height: 1.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">組織管理</h6>
                        <p class="small text-muted mb-0">管理組織架構</p>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- 系統狀態與統計 -->
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-3">
                    <i data-lucide="activity" class="text-success" style="width: 1.25rem; height: 1.25rem;"></i>
                    系統狀態
                </h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">伺服器狀態</span>
                        <span class="badge bg-success">正常運行</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">記憶體使用率</span>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress" style="width: 100px; height: 8px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: 45%"></div>
                            </div>
                            <span class="fw-semibold">45%</span>
                        </div>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">CPU 使用率</span>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress" style="width: 100px; height: 8px;">
                                <div class="progress-bar bg-info" role="progressbar" style="width: 23%"></div>
                            </div>
                            <span class="fw-semibold">23%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-3">
                    <i data-lucide="bar-chart" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                    統計資訊
                </h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">總用戶數</span>
                        <span class="fs-5 fw-bold">1,234</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">活躍用戶</span>
                        <span class="fs-5 fw-bold text-success">856</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">今日登入</span>
                        <span class="fs-5 fw-bold text-primary">42</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 最近活動 -->
<div class="row g-3">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title fw-bold d-flex align-items-center gap-2 mb-3">
                    <i data-lucide="clock" class="text-info" style="width: 1.25rem; height: 1.25rem;"></i>
                    最近活動
                </h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item px-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0 p-2 bg-success bg-opacity-10 rounded">
                                <i data-lucide="user-plus" class="text-success" style="width: 1.25rem; height: 1.25rem;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">新用戶註冊</div>
                                <div class="small text-muted">張三 註冊了新帳號</div>
                            </div>
                            <span class="small text-muted">2 分鐘前</span>
                        </div>
                    </div>
                    <div class="list-group-item px-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0 p-2 bg-primary bg-opacity-10 rounded">
                                <i data-lucide="settings" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">系統設定更新</div>
                                <div class="small text-muted">管理員更新了系統配置</div>
                            </div>
                            <span class="small text-muted">15 分鐘前</span>
                        </div>
                    </div>
                    <div class="list-group-item px-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0 p-2 bg-danger bg-opacity-10 rounded">
                                <i data-lucide="shield" class="text-danger" style="width: 1.25rem; height: 1.25rem;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">權限變更</div>
                                <div class="small text-muted">李四 的角色權限已更新</div>
                            </div>
                            <span class="small text-muted">1 小時前</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.hover-lift {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}

.hover-lift:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
}
</style>

@section Scripts {
    <script>
        // 初始化 Lucide 圖示
        document.addEventListener('DOMContentLoaded', function() {
            if (window.lucide && lucide.createIcons) {
                lucide.createIcons();
            }
        });
    </script>
}
