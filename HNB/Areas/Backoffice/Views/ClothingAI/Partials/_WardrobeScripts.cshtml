<script>
$(document).ready(function() {
    window.lucide?.createIcons?.();
    
    const uploadZone = $('#uploadZone');
    const fileInput = $('#fileInput');
    const processingState = $('#processingState');
    const previewContainer = $('#previewContainer');
    const previewItemsGrid = $('#previewItemsGrid');
    const previewCount = $('#previewCount');
    const confirmBtn = $('#confirmBtn');
    const cancelBtn = $('#cancelBtn');
    const closePreviewBtn = $('#closePreviewBtn');
    
    let detectedItems = [];
    
    uploadZone.on('click', function() {
        fileInput.click();
    });
    
    uploadZone.on('dragover', function(e) {
        e.preventDefault();
        e.stopPropagation();
        $(this).addClass('border-primary');
    });
    
    uploadZone.on('dragleave', function(e) {
        e.preventDefault();
        e.stopPropagation();
        $(this).removeClass('border-primary');
    });
    
    uploadZone.on('drop', function(e) {
        e.preventDefault();
        e.stopPropagation();
        $(this).removeClass('border-primary');
        handleFiles(e.originalEvent.dataTransfer.files);
    });
    
    fileInput.on('change', function(e) {
        handleFiles(e.target.files);
    });
    
    confirmBtn.on('click', saveDetectedItems);
    cancelBtn.on('click', resetUpload);
    closePreviewBtn.on('click', resetUpload);
    
    $('#categoryFilter').on('change', filterWardrobe);
    $('#searchInput').on('input', filterWardrobe);
    
    $('.wardrobe-item-card').hover(
        function() { $(this).find('.opacity-0').removeClass('opacity-0').addClass('opacity-100'); },
        function() { $(this).find('.opacity-100').removeClass('opacity-100').addClass('opacity-0'); }
    );
    
    const batchActionsBar = $('#batchActionsBar');
    const selectAllCheckbox = $('#selectAllCheckbox');
    const selectedCount = $('#selectedCount');
    const batchDeleteBtn = $('#batchDeleteBtn');
    
    $('.item-checkbox').on('change', function() {
        updateBatchActions();
    });
    
    selectAllCheckbox.on('change', function() {
        const isChecked = $(this).is(':checked');
        $('.item-checkbox:visible').prop('checked', isChecked);
        updateBatchActions();
    });
    
    batchDeleteBtn.on('click', function() {
        batchDelete();
    });
    
    function updateBatchActions() {
        const checkedBoxes = $('.item-checkbox:checked:visible');
        const count = checkedBoxes.length;
        
        if (count > 0) {
            batchActionsBar.removeClass('d-none');
            selectedCount.text(count);
            
            const visibleBoxes = $('.item-checkbox:visible');
            const checkedVisibleBoxes = $('.item-checkbox:checked:visible');
            selectAllCheckbox.prop('checked', visibleBoxes.length === checkedVisibleBoxes.length && visibleBoxes.length > 0);
        } else {
            batchActionsBar.addClass('d-none');
            selectAllCheckbox.prop('checked', false);
        }
    }
    
    function batchDelete() {
        const checkedBoxes = $('.item-checkbox:checked:visible');
        if (checkedBoxes.length === 0) return;
        
        if (!confirm(`確定要刪除選中的 ${checkedBoxes.length} 件服裝嗎？`)) return;
        
        const itemsToDelete = [];
        checkedBoxes.each(function() {
            itemsToDelete.push({
                fileName: $(this).data('filename'),
                category: $(this).data('category')
            });
        });
        
        batchDeleteBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>刪除中...');
        
        const requestData = {
            items: itemsToDelete
        };
        
        $.ajax({
            type: 'POST',
            url: '@Url.Action("BatchDelete", "ClothingAI")',
            contentType: 'application/json',
            data: JSON.stringify(requestData),
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
                if (response && response.success) {
                    location.reload();
                } else {
                    const message = response.failureCount > 0 
                        ? `刪除完成：${response.successCount} 成功，${response.failureCount} 失敗`
                        : (response.error || '刪除失敗');
                    alert(message);
                    location.reload();
                }
            },
            error: function() {
                alert('刪除失敗');
                batchDeleteBtn.prop('disabled', false).html('<i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i><span>批量刪除</span>');
                window.lucide?.createIcons?.();
            }
        });
    }
    
    function handleFiles(files) {
        if (files.length === 0) return;
        
        uploadZone.addClass('d-none');
        processingState.removeClass('d-none');
        
        const imagePromises = Array.from(files).map(file => {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    resolve(e.target.result);
                };
                reader.readAsDataURL(file);
            });
        });
        
        Promise.all(imagePromises).then(base64Images => {
            detectClothing(base64Images);
        });
    }
    
    function detectClothing(base64Images) {
        const detectionRequest = {
            imagesBase64: base64Images,
            textPrompt: 'clothes, jacket, pants, shirt, dress, shoes'
        };
        
        $.ajax({
            type: 'POST',
            url: '/api/ObjectDetectionApi/DetectBase64',
            contentType: 'application/json',
            data: JSON.stringify(detectionRequest),
            success: function(detectionResponse) {
                if (!detectionResponse || !detectionResponse.success || !detectionResponse.images) {
                    alert('物件偵測失敗');
                    processingState.addClass('d-none');
                    resetUpload();
                    return;
                }
                
                const detectedClothes = [];
                detectionResponse.images.forEach(image => {
                    if (image.success && image.detections) {
                        image.detections.forEach(detection => {
                            if (detection.croppedImageBase64) {
                                const base64Data = detection.croppedImageBase64;
                                let base64String = base64Data;
                                if (base64Data.startsWith('data:')) {
                                    base64String = base64Data.split(',')[1];
                                }
                                detectedClothes.push({
                                    base64: base64String,
                                    label: detection.label || '服裝',
                                    score: detection.score || 0
                                });
                            }
                        });
                    }
                });
                
                if (detectedClothes.length === 0) {
                    alert('未檢測到服裝');
                    processingState.addClass('d-none');
                    resetUpload();
                    return;
                }
                
                function buildPrompt(clothingLabel) {
                    const labelMap = {
                        'shirt': '上衣/襯衫',
                        'jacket': '外套',
                        'pants': '褲子',
                        'dress': '洋裝',
                        'shoes': '鞋子',
                        'clothes': '服裝'
                    };
                    
                    const labelText = labelMap[clothingLabel.toLowerCase()] || clothingLabel || '服裝';
                    
                    return `這是一張已裁剪的${labelText}圖片。請將圖片中的${labelText}轉換為商品展示圖：只保留這件${labelText}本身，不要處理圖片中的其他服裝（如外套、內搭等）。完全移除人物、臉部、手部、腳部、身體部位、背景、其他物品、配飾和裝飾。只保留這件${labelText}的細節、材質、顏色和紋理。背景改為純白色，無陰影、無反光、乾淨專業的商品展示風格。`;
                }
                
                const dallePromises = detectedClothes.map((clothing) => {
                    return new Promise((resolve) => {
                        const prompt = buildPrompt(clothing.label);
                        const dalleRequest = {
                            prompt: prompt,
                            imagesBase64: [clothing.base64],
                            model: 'gpt-image-1'
                        };
                        
                        $.ajax({
                            type: 'POST',
                            url: '/api/DallE3Api/EditBase64',
                            contentType: 'application/json',
                            data: JSON.stringify(dalleRequest),
                            success: function(dalleResponse) {
                                if (dalleResponse && dalleResponse.success && dalleResponse.images && dalleResponse.images.length > 0) {
                                    const successImages = dalleResponse.images.filter(img => img.success && img.imageBase64);
                                    if (successImages.length > 0) {
                                        resolve({
                                            success: true,
                                            images: successImages.map(img => ({
                                                imageBase64: img.imageBase64,
                                                label: clothing.label,
                                                score: clothing.score,
                                                prompt: prompt
                                            }))
                                        });
                                    } else {
                                        resolve({
                                            success: false,
                                            error: dalleResponse.images[0]?.error || '圖片生成失敗',
                                            label: clothing.label
                                        });
                                    }
                                } else {
                                    resolve({
                                        success: false,
                                        error: dalleResponse?.errors?.[0] || '圖片生成失敗',
                                        label: clothing.label
                                    });
                                }
                            },
                            error: function(xhr) {
                                resolve({
                                    success: false,
                                    error: xhr.responseJSON?.error || '圖片生成失敗',
                                    label: clothing.label
                                });
                            }
                        });
                    });
                });
                
                Promise.all(dallePromises).then(results => {
                    processingState.addClass('d-none');
                    
                    detectedItems = [];
                    const failedItems = [];
                    
                    results.forEach(result => {
                        if (result.success && result.images) {
                            result.images.forEach(img => {
                                detectedItems.push(img);
                            });
                        } else {
                            failedItems.push(result);
                        }
                    });
                    
                    if (detectedItems.length === 0) {
                        const errorMsg = failedItems[0]?.error || '未知錯誤';
                        let displayMsg = '所有圖片生成失敗';
                        
                        if (errorMsg.includes('計費上限') || errorMsg.includes('billing_hard_limit_reached')) {
                            displayMsg = '無法生成圖片：已達到計費上限。請檢查您的 OpenAI 帳戶計費設定。';
                        } else if (errorMsg.includes('rate_limit')) {
                            displayMsg = '無法生成圖片：請求頻率過高，請稍後再試。';
                        } else if (errorMsg) {
                            displayMsg = `所有圖片生成失敗：${errorMsg}`;
                        }
                        
                        alert(displayMsg);
                        resetUpload();
                        return;
                    }
                    
                    if (failedItems.length > 0) {
                        const errorMsg = `成功生成 ${detectedItems.length} 張，失敗 ${failedItems.length} 張`;
                        const hasBillingError = failedItems.some(item => 
                            item.error && (item.error.includes('計費上限') || item.error.includes('billing_hard_limit_reached'))
                        );
                        
                        if (hasBillingError) {
                            alert(`${errorMsg}\n\n部分失敗原因：已達到計費上限。請檢查您的 OpenAI 帳戶計費設定。`);
                        } else {
                            console.warn(errorMsg, failedItems);
                        }
                    }
                    
                    displayPreview();
                });
            },
            error: function(xhr) {
                processingState.addClass('d-none');
                const errorMsg = xhr.responseJSON?.error || '物件偵測失敗';
                alert(errorMsg);
                resetUpload();
            }
        });
    }
    
    function displayPreview() {
        previewItemsGrid.empty();
        previewCount.text(`${detectedItems.length} 件服裝`);
        
        detectedItems.forEach((item, index) => {
            const previewCard = $(`
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm">
                        <div class="position-relative" style="aspect-ratio: 1; overflow: hidden;">
                            <img src="${item.imageBase64}" alt="${item.label || 'AI 組合服裝'}" class="card-img-top h-100 w-100 object-fit-cover">
                        </div>
                        <div class="card-body p-2">
                            <div class="small text-muted">${item.label || 'AI 組合服裝'}</div>
                        </div>
                    </div>
                </div>
            `);
            previewItemsGrid.append(previewCard);
        });
        
        previewContainer.removeClass('d-none');
        window.lucide?.createIcons?.();
    }
    
    function saveDetectedItems() {
        if (detectedItems.length === 0) return;
        
        confirmBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>處理中...');
        
        const formData = new FormData();
        formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());
        
        detectedItems.forEach((item, index) => {
            const blob = base64ToBlob(item.imageBase64);
            formData.append('files', blob, `dalle3_${item.label}_${index}.png`);
        });
        
        $.ajax({
            type: 'POST',
            url: '@Url.Action("SubmitUpload", "ClothingAI")',
            data: formData,
            processData: false,
            contentType: false,
            success: function(response) {
                if (response && response.success) {
                    location.reload();
                } else {
                    alert(response?.error || '上傳失敗');
                    confirmBtn.prop('disabled', false).html('<i data-lucide="check" style="width: 1rem; height: 1rem;"></i><span>確認提取</span>');
                    window.lucide?.createIcons?.();
                }
            },
            error: function() {
                alert('上傳失敗');
                confirmBtn.prop('disabled', false).html('<i data-lucide="check" style="width: 1rem; height: 1rem;"></i><span>確認提取</span>');
                window.lucide?.createIcons?.();
            }
        });
    }
    
    function resetUpload() {
        uploadZone.removeClass('d-none');
        processingState.addClass('d-none');
        previewContainer.addClass('d-none');
        previewItemsGrid.empty();
        fileInput.val('');
        detectedItems = [];
    }
    
    function filterWardrobe() {
        const category = $('#categoryFilter').val();
        const search = $('#searchInput').val().toLowerCase();
        
        $('.category-section').each(function() {
            const $section = $(this);
            const sectionCategory = $section.data('category');
            
            if (category && sectionCategory !== category) {
                $section.addClass('d-none');
                return;
            }
            
            $section.removeClass('d-none');
            
            let hasVisibleItems = false;
            $section.find('.wardrobe-item-card').each(function() {
                const $card = $(this);
                const cardFilename = $card.data('filename')?.toLowerCase() || '';
                const cardCategory = $card.data('category')?.toLowerCase() || '';
                
                const matchSearch = !search || cardCategory.includes(search) || cardFilename.includes(search);
                
                if (matchSearch) {
                    $card.removeClass('d-none');
                    hasVisibleItems = true;
                } else {
                    $card.addClass('d-none');
                }
            });
            
            if (!hasVisibleItems && search) {
                $section.addClass('d-none');
            }
        });
        
        updateBatchActions();
    }
    
    function base64ToBlob(base64) {
        const parts = base64.split(',');
        const contentType = parts[0].match(/:(.*?);/)[1];
        const raw = window.atob(parts[1]);
        const rawLength = raw.length;
        const uInt8Array = new Uint8Array(rawLength);
        
        for (let i = 0; i < rawLength; ++i) {
            uInt8Array[i] = raw.charCodeAt(i);
        }
        
        return new Blob([uInt8Array], { type: contentType });
    }
});

function viewClothing(webPath) {
    const modal = new bootstrap.Modal(document.getElementById('imageModal'));
    $('#modalImage').attr('src', webPath);
    modal.show();
}

function closeImageModal() {
    const modal = bootstrap.Modal.getInstance(document.getElementById('imageModal'));
    if (modal) modal.hide();
}

function deleteClothing(fileName, category) {
    if (!confirm('確定要刪除此服裝嗎？')) return;
    
    $.ajax({
        type: 'DELETE',
        url: '@Url.Action("Delete", "ClothingAI")' + `?fileName=${encodeURIComponent(fileName)}&category=${encodeURIComponent(category)}`,
        success: function(response) {
            if (response && response.success) {
                location.reload();
            } else {
                alert(response?.error || '刪除失敗');
            }
        },
        error: function() {
            alert('刪除失敗');
        }
    });
}
</script>

