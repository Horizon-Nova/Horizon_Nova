@{
    ViewData["Title"] = "衣櫃管理 - 服裝 AI";
    ViewData["PageTitle"] = "我的衣櫃";
    ViewData["PageDescription"] = "管理和查看您已上傳的服裝收藏";
    ViewData["PageIcon"] = "tshirt";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

<section class="space-y-6">
    <!-- 衣櫃統計卡片 -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">總服裝數</p>
                    <p class="text-2xl font-bold text-blue-600">4</p>
                </div>
                <i data-lucide="tshirt" class="h-8 w-8 text-blue-500"></i>
            </div>
        </div>
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">外套</p>
                    <p class="text-2xl font-bold text-green-600">1</p>
                </div>
                <i data-lucide="coat-hanger" class="h-8 w-8 text-green-500"></i>
            </div>
        </div>
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">衣服</p>
                    <p class="text-2xl font-bold text-purple-600">1</p>
                </div>
                <i data-lucide="shirt" class="h-8 w-8 text-purple-500"></i>
            </div>
        </div>
        <div class="bg-white border rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600">其他</p>
                    <p class="text-2xl font-bold text-orange-600">2</p>
                </div>
                <i data-lucide="more-horizontal" class="h-8 w-8 text-orange-500"></i>
            </div>
        </div>
    </div>

    <!-- AI 服裝提取管理 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- 圖片上傳與 AI 處理 -->
        <div class="bg-white border rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold flex items-center gap-2">
                    <i data-lucide="upload" class="h-5 w-5"></i>
                    AI 服裝提取
                </h3>
                <button type="button" class="text-sm text-blue-600 hover:text-blue-800" onclick="refreshUploadStatus()">
                    <i data-lucide="refresh-cw" class="h-4 w-4 inline mr-1"></i>刷新
                </button>
            </div>
            <div class="space-y-4">
                <!-- 上傳區域 -->
                <div id="uploadArea" class="border-2 border-dashed border-blue-300 rounded-xl p-8 text-center hover:border-blue-400 hover:bg-blue-50 transition-all cursor-pointer">
                    <i data-lucide="image-plus" class="h-12 w-12 text-blue-400 mx-auto mb-4"></i>
                    <h4 class="text-lg font-medium text-gray-700 mb-2">拖曳圖片到這裡</h4>
                    <p class="text-sm text-gray-500 mb-4">AI 將自動識別並提取服裝</p>
                    <input type="file" id="fileInput" multiple accept="image/*" class="hidden">
                    <button type="button" class="bg-blue-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-600 transition-colors" onclick="document.getElementById('fileInput').click()">
                        <i data-lucide="plus" class="h-4 w-4 inline mr-2"></i> 選擇檔案
                    </button>
                </div>
                
                <!-- 處理狀態 -->
                <div id="processingStatus" class="hidden">
                    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                        <div class="flex items-center">
                            <i data-lucide="loader" class="h-5 w-5 text-yellow-600 animate-spin mr-3"></i>
                            <div>
                                <p class="font-medium text-yellow-800">AI 正在處理中...</p>
                                <p class="text-sm text-yellow-600">請稍候，正在識別和提取服裝</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 預覽區域 -->
                <div id="previewArea" class="hidden">
                    <h4 class="font-semibold text-gray-800 mb-3">AI 識別結果</h4>
                    <div id="imagePreview" class="grid grid-cols-2 gap-4"></div>
                    <div class="mt-4 flex space-x-3">
                        <button type="button" class="flex-1 bg-green-500 text-white px-4 py-3 rounded-lg font-medium hover:bg-green-600 transition-colors" id="processBtn">
                            <i data-lucide="scissors" class="h-4 w-4 inline mr-2"></i> 確認提取
                        </button>
                        <button type="button" class="flex-1 bg-gray-500 text-white px-4 py-3 rounded-lg font-medium hover:bg-gray-600 transition-colors" id="clearBtn">
                            <i data-lucide="trash-2" class="h-4 w-4 inline mr-2"></i> 重新選擇
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 衣櫃管理工具 -->
        <div class="bg-white border rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold flex items-center gap-2">
                    <i data-lucide="settings" class="h-5 w-5"></i>
                    衣櫃管理
                </h3>
                <button type="button" class="text-sm text-blue-600 hover:text-blue-800" onclick="refreshWardrobeStats()">
                    <i data-lucide="refresh-cw" class="h-4 w-4 inline mr-1"></i>刷新
                </button>
            </div>
            <div class="space-y-3">
                <!-- 批量操作 -->
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <p class="font-medium">批量管理</p>
                            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showHelpModal('batch-help')">
                                <i data-lucide="help-circle" class="h-4 w-4"></i>
                            </button>
                        </div>
                        <p class="text-sm text-gray-500">批量編輯、刪除或分類服裝</p>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" class="px-3 py-1 bg-blue-100 text-blue-700 rounded text-sm hover:bg-blue-200" onclick="batchEdit()">
                            批量編輯
                        </button>
                        <button type="button" class="px-3 py-1 bg-red-100 text-red-700 rounded text-sm hover:bg-red-200" onclick="batchDelete()">
                            批量刪除
                        </button>
                    </div>
                </div>

                <!-- 分類管理 -->
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <p class="font-medium">分類管理</p>
                            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showHelpModal('category-help')">
                                <i data-lucide="help-circle" class="h-4 w-4"></i>
                            </button>
                        </div>
                        <p class="text-sm text-gray-500">管理服裝分類和標籤</p>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" class="px-3 py-1 bg-green-100 text-green-700 rounded text-sm hover:bg-green-200" onclick="manageCategories()">
                            管理分類
                        </button>
                        <button type="button" class="px-3 py-1 bg-purple-100 text-purple-700 rounded text-sm hover:bg-purple-200" onclick="manageTags()">
                            管理標籤
                        </button>
                    </div>
                </div>

                <!-- 數據管理 -->
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <p class="font-medium">數據管理</p>
                            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="showHelpModal('data-help')">
                                <i data-lucide="help-circle" class="h-4 w-4"></i>
                            </button>
                        </div>
                        <p class="text-sm text-gray-500">匯出、備份或清理衣櫃數據</p>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded text-sm hover:bg-indigo-200" onclick="exportWardrobe()">
                            匯出數據
                        </button>
                        <button type="button" class="px-3 py-1 bg-amber-100 text-amber-700 rounded text-sm hover:bg-amber-200" onclick="cleanupWardrobe()">
                            清理數據
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 服裝展示與管理 -->
    <div class="bg-white border rounded-xl p-6">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold flex items-center gap-2">
                <i data-lucide="grid-3x3" class="h-5 w-5"></i>
                我的服裝
            </h3>
            <div class="flex items-center space-x-3">
                <select class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" id="categoryFilter">
                    <option value="">全部類型</option>
                    <option value="外套">外套</option>
                    <option value="衣服">衣服</option>
                    <option value="褲子">褲子</option>
                    <option value="鞋子">鞋子</option>
                </select>
                <select class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" id="styleFilter">
                    <option value="">全部風格</option>
                    <option value="商務正裝">商務正裝</option>
                    <option value="商務休閒">商務休閒</option>
                    <option value="休閒">休閒</option>
                    <option value="運動">運動</option>
                </select>
                <div class="relative">
                    <input type="text" class="w-64 px-3 py-2 pr-10 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" id="searchInput" placeholder="搜尋服裝...">
                    <button class="absolute right-3 top-2.5 text-gray-400 hover:text-gray-600" type="button" id="searchBtn">
                        <i data-lucide="search" class="h-4 w-4"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- 服裝網格 -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
            <!-- 外套 -->
            <div class="bg-white border rounded-lg overflow-hidden hover:shadow-md transition-shadow wardrobe-item" 
                 data-category="外套" 
                 data-style="商務正裝" 
                 data-season="四季"
                 data-description="深藍色西裝外套">
                <div class="relative">
                    <img src="/storage/image/TempFiles/wardrobe1.jpg" class="w-full h-32 object-cover" alt="深藍色西裝外套">
                    <div class="absolute top-2 right-2">
                        <span class="bg-blue-500 text-white px-2 py-1 rounded text-xs font-medium">外套</span>
                    </div>
                    <div class="absolute top-2 left-2">
                        <input type="checkbox" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500" onchange="toggleSelection(this)">
                    </div>
                </div>
                <div class="p-3">
                    <h4 class="text-sm font-medium text-gray-800 truncate">深藍色西裝外套</h4>
                    <p class="text-xs text-gray-500 mb-2">商務正裝 • 四季</p>
                    <div class="flex space-x-1">
                        <button type="button" class="flex-1 bg-blue-500 text-white px-2 py-1 rounded text-xs hover:bg-blue-600" onclick="viewDetails(1)">
                            <i data-lucide="eye" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-green-500 text-white px-2 py-1 rounded text-xs hover:bg-green-600" onclick="editItem(1)">
                            <i data-lucide="edit" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-red-500 text-white px-2 py-1 rounded text-xs hover:bg-red-600" onclick="removeItem(1)">
                            <i data-lucide="trash-2" class="h-3 w-3 inline"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 衣服 -->
            <div class="bg-white border rounded-lg overflow-hidden hover:shadow-md transition-shadow wardrobe-item" 
                 data-category="衣服" 
                 data-style="商務休閒" 
                 data-season="四季"
                 data-description="白色棉質襯衫">
                <div class="relative">
                    <img src="/storage/image/TempFiles/wardrobe2.jpg" class="w-full h-32 object-cover" alt="白色棉質襯衫">
                    <div class="absolute top-2 right-2">
                        <span class="bg-purple-500 text-white px-2 py-1 rounded text-xs font-medium">衣服</span>
                    </div>
                    <div class="absolute top-2 left-2">
                        <input type="checkbox" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500" onchange="toggleSelection(this)">
                    </div>
                </div>
                <div class="p-3">
                    <h4 class="text-sm font-medium text-gray-800 truncate">白色棉質襯衫</h4>
                    <p class="text-xs text-gray-500 mb-2">商務休閒 • 四季</p>
                    <div class="flex space-x-1">
                        <button type="button" class="flex-1 bg-blue-500 text-white px-2 py-1 rounded text-xs hover:bg-blue-600" onclick="viewDetails(2)">
                            <i data-lucide="eye" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-green-500 text-white px-2 py-1 rounded text-xs hover:bg-green-600" onclick="editItem(2)">
                            <i data-lucide="edit" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-red-500 text-white px-2 py-1 rounded text-xs hover:bg-red-600" onclick="removeItem(2)">
                            <i data-lucide="trash-2" class="h-3 w-3 inline"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 褲子 -->
            <div class="bg-white border rounded-lg overflow-hidden hover:shadow-md transition-shadow wardrobe-item" 
                 data-category="褲子" 
                 data-style="商務正裝" 
                 data-season="四季"
                 data-description="深色西裝褲">
                <div class="relative">
                    <img src="/storage/image/TempFiles/wardrobe3.jpg" class="w-full h-32 object-cover" alt="深色西裝褲">
                    <div class="absolute top-2 right-2">
                        <span class="bg-orange-500 text-white px-2 py-1 rounded text-xs font-medium">褲子</span>
                    </div>
                    <div class="absolute top-2 left-2">
                        <input type="checkbox" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500" onchange="toggleSelection(this)">
                    </div>
                </div>
                <div class="p-3">
                    <h4 class="text-sm font-medium text-gray-800 truncate">深色西裝褲</h4>
                    <p class="text-xs text-gray-500 mb-2">商務正裝 • 四季</p>
                    <div class="flex space-x-1">
                        <button type="button" class="flex-1 bg-blue-500 text-white px-2 py-1 rounded text-xs hover:bg-blue-600" onclick="viewDetails(3)">
                            <i data-lucide="eye" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-green-500 text-white px-2 py-1 rounded text-xs hover:bg-green-600" onclick="editItem(3)">
                            <i data-lucide="edit" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-red-500 text-white px-2 py-1 rounded text-xs hover:bg-red-600" onclick="removeItem(3)">
                            <i data-lucide="trash-2" class="h-3 w-3 inline"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 鞋子 -->
            <div class="bg-white border rounded-lg overflow-hidden hover:shadow-md transition-shadow wardrobe-item" 
                 data-category="鞋子" 
                 data-style="商務正裝" 
                 data-season="四季"
                 data-description="黑色真皮皮鞋">
                <div class="relative">
                    <img src="/storage/image/TempFiles/wardrobe4.jpg" class="w-full h-32 object-cover" alt="黑色真皮皮鞋">
                    <div class="absolute top-2 right-2">
                        <span class="bg-green-500 text-white px-2 py-1 rounded text-xs font-medium">鞋子</span>
                    </div>
                    <div class="absolute top-2 left-2">
                        <input type="checkbox" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500" onchange="toggleSelection(this)">
                    </div>
                </div>
                <div class="p-3">
                    <h4 class="text-sm font-medium text-gray-800 truncate">黑色真皮皮鞋</h4>
                    <p class="text-xs text-gray-500 mb-2">商務正裝 • 四季</p>
                    <div class="flex space-x-1">
                        <button type="button" class="flex-1 bg-blue-500 text-white px-2 py-1 rounded text-xs hover:bg-blue-600" onclick="viewDetails(4)">
                            <i data-lucide="eye" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-green-500 text-white px-2 py-1 rounded text-xs hover:bg-green-600" onclick="editItem(4)">
                            <i data-lucide="edit" class="h-3 w-3 inline"></i>
                        </button>
                        <button type="button" class="flex-1 bg-red-500 text-white px-2 py-1 rounded text-xs hover:bg-red-600" onclick="removeItem(4)">
                            <i data-lucide="trash-2" class="h-3 w-3 inline"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 空狀態 -->
        <div id="emptyState" class="text-center py-12 hidden">
            <i data-lucide="tshirt" class="h-16 w-16 text-gray-300 mx-auto mb-4"></i>
            <h3 class="text-lg font-medium text-gray-600 mb-2">還沒有服裝</h3>
            <p class="text-gray-500 mb-4">開始上傳您的第一件服裝，讓 AI 幫您管理！</p>
            <button class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition-colors" onclick="document.getElementById('fileInput').click()">
                <i data-lucide="plus" class="h-4 w-4 inline mr-1"></i> 上傳服裝
            </button>
        </div>
    </div>

    <!-- GitHub 風格日曆 -->
    <div class="lg:col-span-2 bg-white border rounded-lg p-4">
        <div class="flex items-center justify-between mb-3">
            <h4 class="font-semibold text-gray-800">上傳活動日曆</h4>
        </div>
        <div class="w-full">
            <div class="github-calendar">
                <!-- 日曆將由 JavaScript 完全生成 -->
            </div>
        </div>
        <div class="mt-3 text-sm text-gray-500">
            <span id="calendarSummary">過去 365 天共上傳了 4 件服裝</span>
        </div>
    </div>

</section>

<!-- 裁切預覽 Modal -->
<div id="cropModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 hidden">
    <div class="bg-white rounded-lg max-w-4xl w-full max-h-[90vh] overflow-hidden">
        <div class="border-b p-4 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-800">AI 裁切預覽</h3>
            <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600">
                <i data-lucide="x" class="h-6 w-6"></i>
            </button>
        </div>
        <div class="p-6">
            <div id="cropPreview" class="grid grid-cols-2 gap-4 mb-6">
                <!-- 裁切預覽將在這裡顯示 -->
            </div>
            <div class="flex justify-end space-x-2">
                <button onclick="closeCropModal()" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors">
                    取消
                </button>
                <button onclick="submitCrop()" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition-colors">
                    <i data-lucide="check" class="h-4 w-4 inline mr-2"></i> 確認提交
                </button>
            </div>
        </div>
    </div>
</div>
