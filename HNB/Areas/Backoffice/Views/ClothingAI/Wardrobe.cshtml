@model List<HNB.Areas.Backoffice.Dtos.WardrobeItem>
@{
    ViewData["Title"] = "服裝 AI 提取";
    ViewData["PageTitle"] = "AI 服裝提取";
    ViewData["PageDescription"] = "上傳圖片，AI 自動識別並提取服裝";
    ViewData["PageIcon"] = "sparkles";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
    
    ViewBag.WardrobeItems = Model ?? new List<HNB.Areas.Backoffice.Dtos.WardrobeItem>();
}

@Html.AntiForgeryToken()

<link rel="stylesheet" href="~/Backoffice/css/Wardrobe.css" />

<section class="mb-3 mb-lg-4">
    @await Html.PartialAsync("Partials/Wardrobe/_ExtractSection")
    @await Html.PartialAsync("Partials/Wardrobe/_WardrobeSection")
</section>

@await Html.PartialAsync("Partials/Wardrobe/Modal/_ImageModal")

@section Scripts {
    @await Html.PartialAsync("Partials/Wardrobe/_Scripts")
}
