@model List<HNB.Areas.Backoffice.Dtos.WardrobeItem>
@{
    ViewData["Title"] = "衣櫃管理 - 服裝 AI";
    ViewData["PageTitle"] = "我的衣櫃";
    ViewData["PageDescription"] = "管理和查看您已上傳的服裝收藏";
    ViewData["PageIcon"] = "shirt";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
    
    var wardrobeItems = Model ?? new List<HNB.Areas.Backoffice.Dtos.WardrobeItem>();
}

@Html.AntiForgeryToken()

@functions {
    string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<link rel="stylesheet" href="~/Backoffice/css/Wardrobe.css" />

<section class="mb-3 mb-lg-4">

    <!-- 統計卡片 -->
    <div class="row g-3 mb-3 mb-lg-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small mb-1">總服裝數</div>
                            <div class="h4 mb-0 fw-bold text-primary">@wardrobeItems.Count</div>
                        </div>
                        <div class="p-2 bg-primary bg-opacity-10 rounded">
                            <i data-lucide="shirt" style="width: 1.5rem; height: 1.5rem; color: #0d6efd;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small mb-1">本月上傳</div>
                            <div class="h4 mb-0 fw-bold text-success">@wardrobeItems.Count(i => i.UploadDate.Month == DateTime.Now.Month)</div>
                        </div>
                        <div class="p-2 bg-success bg-opacity-10 rounded">
                            <i data-lucide="upload" style="width: 1.5rem; height: 1.5rem; color: #198754;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small mb-1">總大小</div>
                            <div class="h4 mb-0 fw-bold text-info">@FormatBytes(wardrobeItems.Sum(i => i.FileSize))</div>
                        </div>
                        <div class="p-2 bg-info bg-opacity-10 rounded">
                            <i data-lucide="hard-drive" style="width: 1.5rem; height: 1.5rem; color: #0dcaf0;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small mb-1">最近更新</div>
                            <div class="h4 mb-0 fw-bold text-warning">@(wardrobeItems.Count(i => i.ModifiedDate > DateTime.Now.AddDays(-7)))</div>
                        </div>
                        <div class="p-2 bg-warning bg-opacity-10 rounded">
                            <i data-lucide="clock" style="width: 1.5rem; height: 1.5rem; color: #ffc107;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- AI 服裝提取區域 -->
    <div class="row g-3 g-lg-4 mb-3 mb-lg-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <div class="d-flex align-items-center justify-content-between">
                        <h5 class="mb-0 fw-semibold d-flex align-items-center gap-2">
                            <i data-lucide="upload" style="width: 1.25rem; height: 1.25rem;"></i>
                    AI 服裝提取
                        </h5>
                        <button type="button" class="btn btn-sm btn-link p-0" onclick="refreshUploadStatus()">
                            <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;"></i>
                </button>
            </div>
                </div>
                <div class="card-body">
                <!-- 上傳區域 -->
                    <div id="uploadArea" class="border-2 border-dashed rounded-3 p-5 text-center" style="cursor: pointer; border-color: #dee2e6; transition: all 0.2s;">
                        <i data-lucide="image-plus" style="width: 3rem; height: 3rem; color: #0d6efd; opacity: 0.5;"></i>
                        <h6 class="fw-semibold mt-3 mb-2">拖曳圖片到這裡</h6>
                        <p class="text-muted small mb-3">AI 將自動識別並提取服裝</p>
                        <input type="file" id="fileInput" multiple accept="image/*" class="d-none">
                        <button type="button" class="btn btn-primary btn-sm" onclick="$('#fileInput').click()">
                            <i data-lucide="plus" style="width: 1rem; height: 1rem;"></i>
                            選擇檔案
                    </button>
                </div>
                
                <!-- 處理狀態 -->
                    <div id="processingStatus" class="d-none mt-3">
                        <div class="alert alert-warning mb-0 d-flex align-items-center gap-2">
                            <div class="spinner-border spinner-border-sm text-warning" role="status"></div>
                            <div>
                                <div class="fw-semibold">AI 正在處理中...</div>
                                <div class="small">請稍候，正在識別和提取服裝</div>
                        </div>
                    </div>
                </div>

                <!-- 預覽區域 -->
                    <div id="previewArea" class="d-none mt-3">
                        <h6 class="fw-semibold mb-3">AI 識別結果</h6>
                        <div id="imagePreview" class="row g-3 mb-3"></div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-success btn-sm flex-grow-1" id="processBtn">
                                <i data-lucide="check" style="width: 1rem; height: 1rem;"></i>
                                確認提取
                        </button>
                            <button type="button" class="btn btn-secondary btn-sm flex-grow-1" id="clearBtn">
                                <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
                                重新選擇
                        </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- 服裝展示與管理 -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom">
            <div class="d-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-semibold d-flex align-items-center gap-2">
                    <i data-lucide="grid-3x3" style="width: 1.25rem; height: 1.25rem;"></i>
                    我的服裝
                </h5>
                <div class="d-flex align-items-center gap-2">
                    <select class="form-select form-select-sm" style="width: auto;" id="categoryFilter">
                    <option value="">全部類型</option>
                    <option value="外套">外套</option>
                    <option value="衣服">衣服</option>
                    <option value="褲子">褲子</option>
                    <option value="鞋子">鞋子</option>
                </select>
                    <div class="position-relative">
                        <input type="text" class="form-control form-control-sm" style="width: 200px;" id="searchInput" placeholder="搜尋服裝...">
                        <i data-lucide="search" class="position-absolute top-50 translate-middle-y text-muted" style="right: 0.5rem; width: 0.875rem; height: 0.875rem; pointer-events: none;"></i>
                    </div>
                </div>
            </div>
                    </div>
        <div class="card-body">
            <!-- 服裝網格 -->
            <div class="row g-3" id="wardrobeGrid">
                @foreach (var item in wardrobeItems)
                {
                    <div class="col-6 col-md-4 col-lg-3 col-xl-2 wardrobe-item" 
                         data-filename="@item.FileName"
                         data-category="@item.Category"
                         data-date="@item.UploadDate.ToString("yyyy-MM-dd")">
                        <div class="card border">
                            <div class="position-relative">
                                <img src="@item.WebPath" class="card-img-top" style="height: 150px; object-fit: cover;" alt="@item.FileName">
                            </div>
                            <div class="card-body p-2">
                                <h6 class="card-title small fw-medium mb-1 text-truncate" title="@item.FileName">@item.Category</h6>
                                <p class="card-text small text-muted mb-2">@FormatBytes(item.FileSize) • @item.UploadDate.ToString("yyyy/MM/dd")</p>
                                <div class="d-flex gap-1">
                                    <button type="button" class="btn btn-sm btn-outline-primary flex-grow-1" onclick="viewImage('@item.WebPath'); event.stopPropagation();">
                                        <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem;"></i>
                        </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger flex-grow-1" onclick="removeClothing(this); event.stopPropagation();">
                                        <i data-lucide="trash-2" style="width: 0.875rem; height: 0.875rem;"></i>
                        </button>
                    </div>
                </div>
            </div>
                    </div>
                }
            </div>

            <!-- 空狀態 -->
            @if (!wardrobeItems.Any())
            {
                <div class="text-center py-5">
                    <i data-lucide="shirt" style="width: 4rem; height: 4rem; color: #dee2e6;"></i>
                    <h6 class="fw-semibold mt-3 mb-2">還沒有服裝</h6>
                    <p class="text-muted mb-3">開始上傳您的第一件服裝，讓 AI 幫您管理！</p>
                    <button class="btn btn-primary btn-sm" onclick="$('#fileInput').click()">
                        <i data-lucide="plus" style="width: 1rem; height: 1rem;"></i>
                        上傳服裝
                        </button>
                </div>
            }
        </div>
    </div>

</section>

@section Scripts {
<script>
$(document).ready(function() {
    window.lucide?.createIcons?.();
    
    // 檔案上傳事件
    $('#fileInput').on('change', function(e) {
        handleFileSelect(e.target.files);
    });
    
    // 拖曳上傳
    $('#uploadArea').on('dragover', function(e) {
        e.preventDefault();
        $(this).css({'border-color': '#0d6efd', 'background-color': '#f0f8ff'});
    }).on('dragleave', function(e) {
        e.preventDefault();
        $(this).css({'border-color': '#dee2e6', 'background-color': 'transparent'});
    }).on('drop', function(e) {
        e.preventDefault();
        $(this).css({'border-color': '#dee2e6', 'background-color': 'transparent'});
        handleFileSelect(e.originalEvent.dataTransfer.files);
    });

    // 搜尋功能
    $('#searchInput').on('input', function() {
        const searchTerm = $(this).val().toLowerCase();
        $('.wardrobe-item').each(function() {
            const text = $(this).text().toLowerCase();
            const filename = $(this).data('filename') || '';
            $(this).toggle(text.includes(searchTerm) || filename.toLowerCase().includes(searchTerm));
        });
        checkEmptyState();
    });

    function checkEmptyState() {
        const visibleItems = $('.wardrobe-item:visible').length;
        if (visibleItems === 0 && @(Model?.Count ?? 0) > 0) {
            $('#wardrobeGrid').after('<div class="text-center py-3"><span class="text-muted">找不到符合條件的服裝</span></div>');
        }
    }
});

function handleFileSelect(files) {
    if (files.length === 0) return;
    
    $('#uploadArea').addClass('d-none');
    $('#processingStatus').removeClass('d-none');
    
    const formData = new FormData();
    Array.from(files).forEach(function(file) {
        formData.append('files', file);
    });
    formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());
    
    $.ajax({
        type: 'POST',
        url: '@Url.Action("SubmitUpload", "ClothingAI")',
        data: formData,
        processData: false,
        contentType: false,
        success: function(response) {
            $('#processingStatus').addClass('d-none');
            $('#uploadArea').removeClass('d-none');
            if (response && response.success) {
                alert('上傳成功！');
                location.reload();
            } else {
                alert(response && response.error ? response.error : '上傳失敗');
            }
        },
        error: function() {
            $('#processingStatus').addClass('d-none');
            $('#uploadArea').removeClass('d-none');
            alert('上傳失敗');
        }
    });
}

function refreshUploadStatus() {
    alert('刷新狀態');
}


function viewImage(webPath) {
    window.open(webPath, '_blank');
}

function removeClothing(button) {
    if (confirm('確定要刪除此服裝嗎？')) {
        const item = $(button).closest('.wardrobe-item');
        const fileName = item.data('filename');
        const category = item.data('category');
        $.ajax({
            type: 'DELETE',
            url: '@Url.Action("Delete", "ClothingAI")' + '?fileName=' + encodeURIComponent(fileName) + '&category=' + encodeURIComponent(category),
            success: function(response) {
                if (response && response.success) {
                    alert('刪除成功！');
                    location.reload();
                } else {
                    alert(response && response.error ? response.error : '刪除失敗');
                }
            },
            error: function() {
                alert('刪除失敗');
            }
        });
    }
}

function showHelpModal(topic) {
    alert('顯示說明：' + topic);
}
</script>
}
