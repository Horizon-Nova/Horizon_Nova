@{
    ViewData["Title"] = "AI 穿搭助理 - 服裝 AI";
    ViewData["PageTitle"] = "AI 穿搭助理";
    ViewData["PageDescription"] = "告訴我您的需求，AI 將為您推薦最適合的穿搭";
    ViewData["PageIcon"] = "bot";
    Layout = "~/Areas/Backoffice/Views/Shared/_Layout.cshtml";
}

@Html.AntiForgeryToken()

<link rel="stylesheet" href="~/Backoffice/css/Wardrobe.css" />

<section class="mb-3 mb-lg-4">

    <div class="row g-3 g-lg-4">
        <!-- 對話區域 -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-3">
                            <div class="p-2 bg-primary bg-opacity-10 rounded">
                                <i data-lucide="bot" style="width: 1.25rem; height: 1.25rem; color: #0d6efd;"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">AI 穿搭助理</div>
                                <div class="small text-muted">Moondream2 AI</div>
                            </div>
                        </div>
                        <span class="badge bg-success">
                            <i data-lucide="circle" style="width: 0.5rem; height: 0.5rem;"></i>
                            線上
                        </span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <!-- 對話記錄 -->
                    <div id="chatContainer" class="border-bottom p-4" style="height: 400px; overflow-y: auto; background-color: #f8f9fa;">
                        <div class="d-flex align-items-start gap-2 mb-3">
                            <div class="p-2 bg-primary rounded-circle flex-shrink-0">
                                <i data-lucide="bot" style="width: 1rem; height: 1rem; color: white;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body p-3">
                                        <p class="mb-0">您好！我是您的 AI 穿搭助理。請告訴我您今天需要什麼樣的穿搭建議？例如：</p>
                                        <ul class="small mb-0 mt-2">
                                            <li>「我今天要參加一場重要的資訊會議」</li>
                                            <li>「週末和朋友聚餐，想要休閒一點的風格」</li>
                                            <li>「運動健身，需要舒適的運動裝」</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="small text-muted mt-1">剛剛</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 輸入區域 -->
                    <div class="p-3">
                        <div class="input-group">
                            <input type="text" id="userInput" class="form-control form-control-sm" placeholder="請描述您的穿搭需求..." maxlength="500">
                            <button class="btn btn-primary btn-sm" type="button" id="sendBtn">
                                <i data-lucide="send" style="width: 1rem; height: 1rem;"></i>
                            </button>
                        </div>
                        <div class="small text-muted mt-2">按 Enter 發送訊息</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 設定與快速建議 -->
        <div class="col-lg-4">
            <div class="vstack gap-3">
                <!-- 環境設定 -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-semibold">環境設定</h6>
                    </div>
                    <div class="card-body">
                        <div class="vstack gap-3">
                            <div>
                                <label for="location" class="form-label small fw-medium mb-2">地點</label>
                                <select class="form-select form-select-sm" id="location">
                                    <option value="台北市">台北市</option>
                                    <option value="新北市">新北市</option>
                                    <option value="桃園市">桃園市</option>
                                    <option value="台中市">台中市</option>
                                    <option value="台南市">台南市</option>
                                    <option value="高雄市">高雄市</option>
                                </select>
                            </div>

                            <div>
                                <label for="weather" class="form-label small fw-medium mb-2">天氣</label>
                                <select class="form-select form-select-sm" id="weather">
                                    <option value="晴天">晴天</option>
                                    <option value="多雲">多雲</option>
                                    <option value="陰天">陰天</option>
                                    <option value="雨天">雨天</option>
                                    <option value="雪天">雪天</option>
                                </select>
                            </div>

                            <div>
                                <label for="temperature" class="form-label small fw-medium mb-2">溫度 (°C)</label>
                                <input type="number" class="form-control form-control-sm" id="temperature" value="25" min="-10" max="40">
                            </div>

                            <div>
                                <label for="timeOfDay" class="form-label small fw-medium mb-2">時段</label>
                                <select class="form-select form-select-sm" id="timeOfDay">
                                    <option value="早上">早上 (6:00-12:00)</option>
                                    <option value="下午">下午 (12:00-18:00)</option>
                                    <option value="晚上">晚上 (18:00-24:00)</option>
                                    <option value="深夜">深夜 (0:00-6:00)</option>
                                </select>
                            </div>

                            <button class="btn btn-primary btn-sm w-100" id="updateWeatherBtn">
                                <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;"></i>
                                更新天氣資訊
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 快速建議 -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-semibold">快速建議</h6>
                    </div>
                    <div class="card-body">
                        <div class="vstack gap-2">
                            <button class="btn btn-outline-primary btn-sm w-100 text-start quick-suggestion" data-query="我今天要參加一場重要的資訊會議">
                                <i data-lucide="briefcase" style="width: 1rem; height: 1rem;"></i>
                                重要會議
                            </button>
                            <button class="btn btn-outline-success btn-sm w-100 text-start quick-suggestion" data-query="週末和朋友聚餐，想要休閒一點的風格">
                                <i data-lucide="utensils" style="width: 1rem; height: 1rem;"></i>
                                朋友聚餐
                            </button>
                            <button class="btn btn-outline-warning btn-sm w-100 text-start quick-suggestion" data-query="運動健身，需要舒適的運動裝">
                                <i data-lucide="dumbbell" style="width: 1rem; height: 1rem;"></i>
                                運動健身
                            </button>
                            <button class="btn btn-outline-danger btn-sm w-100 text-start quick-suggestion" data-query="約會晚餐，想要優雅一點的打扮">
                                <i data-lucide="heart" style="width: 1rem; height: 1rem;"></i>
                                約會晚餐
                            </button>
                            <button class="btn btn-outline-info btn-sm w-100 text-start quick-suggestion" data-query="購物逛街，想要舒適又時尚的穿搭">
                                <i data-lucide="shopping-bag" style="width: 1rem; height: 1rem;"></i>
                                購物逛街
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 推薦記錄 -->
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-header bg-white border-bottom">
            <h6 class="mb-0 fw-semibold">推薦記錄</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- 會議推薦 -->
                <div class="col-md-6">
                    <div class="card border border-success">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between mb-3">
                                <h6 class="mb-0 fw-medium flex-grow-1">我今天要參加一場重要的資訊會議</h6>
                                <span class="badge bg-success">95%</span>
                            </div>
                            
                            <div class="row g-2 mb-3 small text-muted">
                                <div class="col-6">
                                    <i data-lucide="map-pin" style="width: 0.875rem; height: 0.875rem;"></i>
                                    台北市
                                </div>
                                <div class="col-6">
                                    <i data-lucide="thermometer" style="width: 0.875rem; height: 0.875rem;"></i>
                                    25°C
                                </div>
                            </div>
                            
                            <div class="mb-3 small text-muted">
                                <i data-lucide="cloud" style="width: 0.875rem; height: 0.875rem;"></i>
                                晴天
                            </div>
                            
                            <div class="mb-3">
                                <h6 class="fw-medium text-primary mb-2 small">推薦穿搭</h6>
                                <div class="row g-2 small">
                                    <div class="col-6">
                                        <i data-lucide="shirt" style="width: 0.875rem; height: 0.875rem; color: #0d6efd;"></i>
                                        白色襯衫
                                    </div>
                                    <div class="col-6">
                                        <i data-lucide="circle" style="width: 0.875rem; height: 0.875rem; color: #0dcaf0;"></i>
                                        深藍色西裝褲
                                    </div>
                                    <div class="col-6">
                                        <i data-lucide="circle-dot" style="width: 0.875rem; height: 0.875rem; color: #ffc107;"></i>
                                        黑色皮鞋
                                    </div>
                                    <div class="col-6">
                                        <i data-lucide="watch" style="width: 0.875rem; height: 0.875rem; color: #198754;"></i>
                                        簡約手錶
                                    </div>
                                </div>
                            </div>
                            
                            <div class="small text-muted">
                                <i data-lucide="clock" style="width: 0.75rem; height: 0.75rem;"></i>
                                2 小時前
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 聚餐推薦 -->
                <div class="col-md-6">
                    <div class="card border border-warning">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between mb-3">
                                <h6 class="mb-0 fw-medium flex-grow-1">週末和朋友聚餐</h6>
                                <span class="badge bg-warning text-dark">88%</span>
                            </div>
                            
                            <div class="row g-2 mb-3 small text-muted">
                                <div class="col-6">
                                    <i data-lucide="map-pin" style="width: 0.875rem; height: 0.875rem;"></i>
                                    信義區
                                </div>
                                <div class="col-6">
                                    <i data-lucide="thermometer" style="width: 0.875rem; height: 0.875rem;"></i>
                                    22°C
                                </div>
                            </div>
                            
                            <div class="mb-3 small text-muted">
                                <i data-lucide="cloud" style="width: 0.875rem; height: 0.875rem;"></i>
                                多雲
                            </div>
                            
                            <div class="mb-3">
                                <h6 class="fw-medium text-primary mb-2 small">推薦穿搭</h6>
                                <div class="row g-2 small">
                                    <div class="col-6">
                                        <i data-lucide="shirt" style="width: 0.875rem; height: 0.875rem; color: #0d6efd;"></i>
                                        條紋針織衫
                                    </div>
                                    <div class="col-6">
                                        <i data-lucide="circle" style="width: 0.875rem; height: 0.875rem; color: #0dcaf0;"></i>
                                        牛仔褲
                                    </div>
                                    <div class="col-6">
                                        <i data-lucide="circle-dot" style="width: 0.875rem; height: 0.875rem; color: #ffc107;"></i>
                                        白色運動鞋
                                    </div>
                                    <div class="col-6">
                                        <i data-lucide="shopping-bag" style="width: 0.875rem; height: 0.875rem; color: #198754;"></i>
                                        帆布包
                                    </div>
                                </div>
                            </div>
                            
                            <div class="small text-muted">
                                <i data-lucide="clock" style="width: 0.75rem; height: 0.75rem;"></i>
                                1 天前
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</section>

@section Scripts {
<script>
let isTyping = false;

$(document).ready(function() {
    window.lucide?.createIcons?.();
    
    // 發送訊息
    $('#sendBtn').on('click', sendMessage);
    $('#userInput').on('keypress', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // 快速建議
    $('.quick-suggestion').on('click', function() {
        const query = $(this).data('query');
        $('#userInput').val(query);
        sendMessage();
    });

    // 更新天氣資訊
    $('#updateWeatherBtn').on('click', function() {
        alert('天氣資訊已更新！');
    });
});

function sendMessage() {
    const userInput = $('#userInput');
    const message = userInput.val().trim();
    
    if (!message || isTyping) return;
    
    // 添加用戶訊息到聊天記錄
    addMessage(message, 'user');
    userInput.val('');
    
    // 顯示 AI 正在輸入
    showTypingIndicator();
    
    // 獲取環境設定
    const location = $('#location').val();
    const weather = $('#weather').val();
    const temperature = parseInt($('#temperature').val());
    
    // 模擬 AI 回應
    setTimeout(function() {
        hideTypingIndicator();
        
        let responseText = '';
        if (message.includes('會議') || message.includes('工作') || message.includes('商務')) {
            responseText = `根據您的需求「${message}」，我為您推薦以下穿搭：\n\n` +
                `📍 地點：${location}\n` +
                `🌤️ 天氣：${weather} (${temperature}°C)\n\n` +
                `👔 推薦穿搭：\n` +
                `• 上衣：白色商務襯衫\n` +
                `• 下裝：深藍色西裝褲\n` +
                `• 鞋子：黑色皮鞋\n` +
                `• 配件：簡約手錶、深色皮帶\n\n` +
                `💡 推薦理由：\n根據您的工作場合需求，推薦商務正裝風格。白色襯衫搭配深藍色西裝褲展現專業形象，黑色皮鞋增加正式感。\n\n` +
                `🎯 信心度：92%`;
        } else if (message.includes('聚餐') || message.includes('朋友') || message.includes('休閒')) {
            responseText = `根據您的需求「${message}」，我為您推薦以下穿搭：\n\n` +
                `📍 地點：${location}\n` +
                `🌤️ 天氣：${weather} (${temperature}°C)\n\n` +
                `👔 推薦穿搭：\n` +
                `• 上衣：條紋針織衫\n` +
                `• 下裝：牛仔褲\n` +
                `• 鞋子：白色運動鞋\n` +
                `• 配件：帆布包\n\n` +
                `💡 推薦理由：\n休閒聚餐場合適合輕鬆舒適的風格，條紋針織衫搭配牛仔褲既時尚又舒適，白色運動鞋增加活力感。\n\n` +
                `🎯 信心度：88%`;
        } else if (message.includes('運動') || message.includes('健身')) {
            responseText = `根據您的需求「${message}」，我為您推薦以下穿搭：\n\n` +
                `📍 地點：${location}\n` +
                `🌤️ 天氣：${weather} (${temperature}°C)\n\n` +
                `👔 推薦穿搭：\n` +
                `• 上衣：運動排汗衣\n` +
                `• 下裝：運動短褲\n` +
                `• 鞋子：專業運動鞋\n` +
                `• 配件：運動毛巾、水壺\n\n` +
                `💡 推薦理由：\n運動時需要透氣舒適的服裝，排汗衣能保持乾爽，運動短褲提供活動自由度，專業運動鞋保護腳部。\n\n` +
                `🎯 信心度：95%`;
        } else {
            responseText = `根據您的需求「${message}」，我為您推薦以下穿搭：\n\n` +
                `📍 地點：${location}\n` +
                `🌤️ 天氣：${weather} (${temperature}°C)\n\n` +
                `👔 推薦穿搭：\n` +
                `• 上衣：基本款T恤\n` +
                `• 下裝：休閒褲\n` +
                `• 鞋子：休閒鞋\n` +
                `• 配件：簡約包包\n\n` +
                `💡 推薦理由：\n這是一套百搭的休閒穿搭，適合日常各種場合，既舒適又得體。\n\n` +
                `🎯 信心度：85%`;
        }
        
        addMessage(responseText, 'bot');
    }, 2000);
}

function addMessage(text, sender) {
    const chatContainer = $('#chatContainer');
    const messageDiv = $('<div>').addClass('d-flex align-items-start gap-2 mb-3');
    if (sender === 'user') messageDiv.addClass('flex-row-reverse');
    
    const now = new Date();
    const timeString = now.toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' });
    
    const icon = $('<div>').addClass('p-2 rounded-circle flex-shrink-0');
    if (sender === 'user') {
        icon.addClass('bg-success');
    } else {
        icon.addClass('bg-primary');
    }
    const iconElement = $('<i>').attr('data-lucide', sender === 'user' ? 'user' : 'bot');
    iconElement.css({'width': '1rem', 'height': '1rem', 'color': 'white'});
    icon.append(iconElement);
    
    const contentDiv = $('<div>').addClass('flex-grow-1');
    const card = $('<div>').addClass('card shadow-sm border-0');
    const cardBody = $('<div>').addClass('card-body p-3');
    const textP = $('<p>').addClass('mb-0').text(text).css('white-space', 'pre-line');
    cardBody.append(textP);
    card.append(cardBody);
    const timeP = $('<div>').addClass('small text-muted mt-1').text(timeString);
    contentDiv.append(card).append(timeP);
    
    messageDiv.append(icon).append(contentDiv);
    chatContainer.append(messageDiv);
    chatContainer.scrollTop(chatContainer[0].scrollHeight);
    
    window.lucide?.createIcons?.();
}

function showTypingIndicator() {
    isTyping = true;
    const chatContainer = $('#chatContainer');
    const typingDiv = $('<div>').addClass('d-flex align-items-start gap-2 mb-3').attr('id', 'typingIndicator');
    
    const icon = $('<div>').addClass('p-2 bg-primary rounded-circle flex-shrink-0');
    const iconElement = $('<i>').attr('data-lucide', 'bot');
    iconElement.css({'width': '1rem', 'height': '1rem', 'color': 'white'});
    icon.append(iconElement);
    
    const contentDiv = $('<div>').addClass('flex-grow-1');
    const card = $('<div>').addClass('card shadow-sm border-0');
    const cardBody = $('<div>').addClass('card-body p-3');
    const spinner = $('<div>').addClass('d-flex gap-1');
    for (let i = 0; i < 3; i++) {
        const dot = $('<div>').css({
            'width': '0.5rem',
            'height': '0.5rem',
            'background-color': '#6c757d',
            'border-radius': '50%',
            'animation': 'bounce 1.4s infinite ease-in-out both'
        });
        if (i > 0) dot.css('animation-delay', (i * 0.16) + 's');
        spinner.append(dot);
    }
    cardBody.append(spinner);
    card.append(cardBody);
    contentDiv.append(card);
    
    typingDiv.append(icon).append(contentDiv);
    chatContainer.append(typingDiv);
    chatContainer.scrollTop(chatContainer[0].scrollHeight);
}

function hideTypingIndicator() {
    isTyping = false;
    $('#typingIndicator').remove();
}
</script>
<style>
@@keyframes bounce {
    0%, 80%, 100% {
        transform: scale(0);
    }
    40% {
        transform: scale(1);
    }
}
</style>
}
