@{
    Layout = null;
}

<!-- AI 服裝提取說明 -->
<div id="ai-extraction-help" class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-purple-500 p-2 rounded-lg">
                        <i data-lucide="brain" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">AI 服裝提取說明</h3>
                        <p class="text-sm text-purple-100 mt-1">了解 AI 智能識別功能</p>
                    </div>
                </div>
                <button onclick="closeHelpModal('ai-extraction-help')" class="text-white hover:text-purple-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-purple-600"></i>AI 功能
                    </h4>
                    <p class="text-sm text-slate-600 mb-4">AI 會自動分析上傳的圖片，識別並提取其中的服裝項目。</p>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>智能識別</strong>：支援多種服裝類型識別</li>
                        <li>• <strong>自動分類</strong>：自動分類和標籤化</li>
                        <li>• <strong>裁剪功能</strong>：提供裁剪和調整功能</li>
                        <li>• <strong>圖片建議</strong>：建議上傳清晰、單一服裝的圖片</li>
                    </ul>
                </div>
                
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-4">
                    <h4 class="font-semibold text-purple-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-purple-700">
                        為了獲得最佳的 AI 識別效果，建議上傳光線充足、背景簡潔的服裝圖片，避免多人或複雜場景。
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeHelpModal('ai-extraction-help')" class="modal-close px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 上傳功能說明 -->
<div id="upload-help" class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[95vh] overflow-hidden transform transition-all duration-300 ease-out">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="bg-blue-500 p-2 rounded-lg">
                        <i data-lucide="upload" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">上傳功能說明</h3>
                        <p class="text-sm text-blue-100 mt-1">了解如何上傳服裝圖片</p>
                    </div>
                </div>
                <button onclick="closeHelpModal('upload-help')" class="text-white hover:text-blue-200 hover:bg-white hover:bg-opacity-10 p-2 rounded-lg transition-all duration-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
        <div class="p-8 overflow-y-auto max-h-[calc(95vh-160px)] bg-slate-50">
            <div class="space-y-6">
                <div>
                    <h4 class="font-semibold text-slate-800 mb-3 flex items-center">
                        <i data-lucide="info" class="w-4 h-4 mr-2 text-blue-600"></i>上傳方式
                    </h4>
                    <p class="text-sm text-slate-600 mb-4">支援多種方式上傳服裝圖片到您的衣櫃。</p>
                    <ul class="space-y-2 text-sm text-slate-600">
                        <li>• <strong>拖曳上傳</strong>：直接拖曳圖片到上傳區域</li>
                        <li>• <strong>點擊上傳</strong>：點擊選擇檔案按鈕</li>
                        <li>• <strong>格式支援</strong>：支援 JPG、PNG、WEBP 格式</li>
                        <li>• <strong>批量上傳</strong>：單次最多上傳 10 張圖片</li>
                    </ul>
                </div>
                
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                    <h4 class="font-semibold text-blue-800 mb-2 flex items-center">
                        <i data-lucide="lightbulb" class="w-4 h-4 mr-2"></i>小提示
                    </h4>
                    <p class="text-sm text-blue-700">
                        建議一次上傳 3-5 張圖片，這樣 AI 處理會更快速，也便於您逐一確認識別結果。
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-200">
            <div class="flex items-center justify-end">
                <button type="button" onclick="closeHelpModal('upload-help')" class="modal-close px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all duration-200">
                    我知道了
                </button>
            </div>
        </div>
    </div>
</div>

