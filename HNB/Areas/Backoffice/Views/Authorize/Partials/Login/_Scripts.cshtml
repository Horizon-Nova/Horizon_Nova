@{
    Layout = null;
}

<script>
    // 頁面載入完成後的初始化
    $(function () {
        // 密碼顯示/隱藏切換（jQuery）
        $('#togglePwdBtn').on('click', function () {
            const $passwordInput = $('#Password');
            const $eyeIcon = $('#eyeIcon');

            if ($passwordInput.attr('type') === 'password') {
                $passwordInput.attr('type', 'text');
                $eyeIcon.attr('data-lucide', 'eye-off');
            } else {
                $passwordInput.attr('type', 'password');
                $eyeIcon.attr('data-lucide', 'eye');
            }

            if (window.lucide?.createIcons) {
                window.lucide.createIcons();
            }
        });

        $('#btnSubmit').on('click', SubmitForm);

        // 自動聚焦到用戶名輸入框
        const $usernameInput = $('#Username');
        if ($usernameInput.length) {
            $usernameInput.trigger('focus');
        }

        // 處理 Enter 鍵提交
        $(document).on('keypress', function (e) {
            if (e.key === 'Enter') {
                const $active = $(document.activeElement);
                if ($active && ($active.attr('id') === 'Username' || $active.attr('id') === 'Password')) {
                    e.preventDefault();
                    SubmitForm();
                }
            }
        });
    });

    // 表單提交
    function SubmitForm() {
        const $form = $('#FormData');
        const $submitBtn = $('#btnSubmit');
        const $spinner = $('#btnSpinner');
        const $submitText = $submitBtn.find('span');
        const $submitIcon = $submitBtn.find('i[data-lucide="log-in"]');

        // 驗證表單
        const username = $('#Username').val().trim();
        const password = $('#Password').val().trim();

        if (!username || !password) {
            showNotification('請輸入帳號和密碼', 'error');
            return;
        }

        // 顯示載入狀態
        $submitBtn.prop('disabled', true);
        $submitText.text('登入中...');
        if ($submitIcon.length) {
            $submitIcon.hide();
        }
        $spinner.removeClass('hidden');

        // 提交表單
        $form.trigger('submit');
    }

    // 顯示通知（使用 Razor 預先產生的容器，不動態組裝 HTML）
    function showNotification(message, type = 'info') {
        const $notification = $('#loginNotification');
        if ($notification.length === 0) return;

        $notification
            .removeClass('hidden bg-red-500 bg-green-500 bg-yellow-500 bg-blue-500')
            .addClass(
                type === 'error' ? 'bg-red-500' :
                type === 'success' ? 'bg-green-500' :
                type === 'warning' ? 'bg-yellow-500' : 'bg-blue-500'
            )
            .text(message)
            .fadeIn(150);

        setTimeout(() => {
            $notification.fadeOut(200);
        }, 3000);
    }
</script>

