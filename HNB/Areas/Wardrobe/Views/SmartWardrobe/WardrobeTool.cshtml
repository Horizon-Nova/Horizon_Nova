@{
    Layout = "~/Views/Shared/_LayoutQAS.cshtml";
}

<h3 class="mb-3">WW 圖片裁切工具</h3>

<div class="row">
    <!-- 左側：操作 -->
    <div class="col-md-4">
        <div class="form-group mb-3">
            <label class="form-label">選擇圖片</label>
            <input type="file" id="imageInput" accept="image/*" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label class="form-label">輸入提示詞</label>
            <input type="text" id="promptInput" class="form-control" placeholder="例如：dog、pants、jacket" />
        </div>

        <!-- 信心門檻 -->
        <div class="form-group mb-3">
            <label class="form-label d-flex justify-content-between">
                <span>信心門檻</span>
                <span class="text-secondary small">≥ <span id="thVal">0.30</span></span>
            </label>
            <input type="range" id="thSlider" class="form-range" min="0" max="1" step="0.05" value="0.30" />
        </div>

        <button class="btn btn-primary w-100" id="detectBtn">
            <i class="fa fa-search me-1"></i> 辨識並裁切
        </button>

        <div class="mt-4">
            <h5>輸出結果 (JSON)</h5>
            <pre id="jsonOutput" class="bg-light p-2 rounded small overflow-auto" style="max-height: 300px;"></pre>
        </div>
    </div>

    <!-- 右側：顯示區 -->
    <div class="col-md-5">
        <div class="mb-4" id="originalView">
            <h5>原圖（含邊框）</h5>
            <div id="originalImageBox" class="position-relative border rounded overflow-hidden" style="max-width:200px;"></div>
        </div>

        <div id="cropView">
            <h5>裁切後圖片</h5>
            <div id="cropResults" class="d-flex flex-wrap gap-2"></div>
        </div>
    </div>
</div>

    <script>
        // ---- UI helpers --------------------------------------------------------
        const $btn   = $('#detectBtn');
        const $json  = $('#jsonOutput');
        const $crops = $('#cropResults');
        const $orig  = $('#originalImageBox');

        // 更新 slider label
        $('#thSlider').on('input', function () {
            $('#thVal').text(parseFloat(this.value).toFixed(2));
        });

        // 選圖片時同步預覽並清空舊結果
        $('#imageInput').on('change', function () {
            clearResults();

            const file = this.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = e => {
                $orig.html(`
                    <img src="${e.target.result}"
                         id="originalImage"
                         class="img-fluid border"
                         style="max-width:100%; max-height:500px; object-fit:contain;" />
                `);
            };
            reader.readAsDataURL(file);
        });

        // 按钮事件
        $btn.on('click', function () {
            const prompt = $('#promptInput').val().trim();
            const file   = $('#imageInput')[0].files[0];
            const thVal  = $('#thSlider').val();

            if (!file)   { alert('請選擇圖片！'); return; }
            if (!prompt) { alert('請輸入提示詞！'); return; }

            // UI: loading 狀態
            setLoading(true);

            const fd = new FormData();
            fd.append('prompt', prompt);
            fd.append('image',  file);
            fd.append('threshold', thVal);

            $.ajax({
                url: '@Url.Action("DetectAndCrop", "SmartWardrobe")',
                type: 'POST',
                data: fd,
                processData: false,
                contentType: false
            })
            .done(res => {
                clearResults();

                if (res.error) {
                    $json.text(res.error);
                    return;
                }

                // JSON 區塊
                $json.text(JSON.stringify(res, null, 2));

                // 右側原圖（含框） — 後端直接給 Boxed Image 最省事
                $orig.html(`<img src="${res.result.base64BoxedImage}" class="img-fluid border rounded" style="max-width:100%;" />`);

                // 裁切結果
                res.result.base64Crops.forEach((src, idx) => {
                    $crops.append(`
                        <div class="text-center">
                            <img src="${src}" class="border rounded mb-1" style="max-width:150px;" />
                            <div class="small text-muted">#${idx + 1}</div>
                        </div>
                    `);
                });
            })
            .fail(err => {
                console.error(err);
                $json.text('伺服器錯誤');
            })
            .always(() => setLoading(false));
        });

        // ---- utils -------------------------------------------------------------
        function setLoading(isLoading) {
            if (isLoading) {
                $btn.prop('disabled', true)
                    .html('<span class="spinner-border spinner-border-sm me-2"></span>辨識中…');
            } else {
                $btn.prop('disabled', false)
                    .html('<i class="fa fa-search me-1"></i> 辨識並裁切');
            }
        }

        function clearResults() {
            $json.empty();
            $crops.empty();
            // 若要保留原先預覽可省略下一行
            // $orig.empty();
        }
    </script>

