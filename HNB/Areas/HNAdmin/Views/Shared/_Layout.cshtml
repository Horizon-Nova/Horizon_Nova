@{
    Layout = null;

    var title           = ViewData["Title"] as string ?? "HN Admin";
    var pageTitle       = ViewData["PageTitle"] as string ?? title;
    var pageDescription = ViewData["PageDescription"] as string ?? "";
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title — HN Admin</title>

    <link rel="icon" type="image/svg+xml" href="@Url.Content("~/HNB_WEB/image/horizon-nova.svg")">

    <!-- Bootstrap 5 (utilities only) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- HNAdmin 專屬設計系統 -->
    <link rel="stylesheet" href="@Url.Content("~/HNAdmin/css/Layout.css")" />
    <script src="@Url.Content("~/HNAdmin/js/Layout.js")"></script>

    <!-- Pre-apply sidebar state (prevent layout shift) -->
    <script>
        (function () {
            try {
                var v = sessionStorage.getItem('hna_sidebar_collapsed');
                var collapsed = v === '1';
                document.addEventListener('DOMContentLoaded', function () {
                    var s = document.getElementById('hna-sidebar');
                    if (s) s.setAttribute('data-collapsed', collapsed ? 'true' : 'false');
                });
            } catch (e) {}
        })();
    </script>
</head>
<body>

<div id="hna-toasts" class="hna-toasts"></div>
<div id="hna-overlay" class="hna-overlay" onclick="hna_CloseMobileSidebar()"></div>

<div class="hna-shell">

    <!-- ── Sidebar ─────────────────────────────────────── -->
    <aside id="hna-sidebar" data-collapsed="false">

        <!-- Brand -->
        <div class="hna-brand">
            <div class="hna-brand-icon">
                <i data-lucide="layout-dashboard"></i>
            </div>
            <span class="hna-brand-name">HN Admin</span>
        </div>

        <!-- Nav -->
        <nav class="hna-nav" aria-label="主導覽">

            <a href="@Url.Action("Index", "Dashboard", new { area = "HNAdmin" })" class="hna-nav-item">
                <span class="hna-nav-icon"><i data-lucide="home"></i></span>
                <span class="hna-nav-label-text">儀表板</span>
            </a>

            <div class="hna-nav-divider"></div>
            <div class="hna-nav-label">管理模組</div>

            <a href="#" class="hna-nav-item">
                <span class="hna-nav-icon"><i data-lucide="banknote"></i></span>
                <span class="hna-nav-label-text">財務</span>
            </a>
            <a href="#" class="hna-nav-item">
                <span class="hna-nav-icon"><i data-lucide="users"></i></span>
                <span class="hna-nav-label-text">人員管理</span>
            </a>
            <a href="#" class="hna-nav-item">
                <span class="hna-nav-icon"><i data-lucide="cloud"></i></span>
                <span class="hna-nav-label-text">雲端資料夾</span>
            </a>
            <a href="#" class="hna-nav-item">
                <span class="hna-nav-icon"><i data-lucide="globe"></i></span>
                <span class="hna-nav-label-text">網頁管理</span>
            </a>
            <a href="#" class="hna-nav-item">
                <span class="hna-nav-icon"><i data-lucide="building-2"></i></span>
                <span class="hna-nav-label-text">組織管理</span>
            </a>

        </nav>

        <!-- Toggle (desktop) -->
        <button class="hna-toggle-btn" onclick="hna_ToggleSidebar()" title="收合側欄">
            <i data-lucide="chevron-left" style="width:14px;height:14px;"></i>
        </button>

        <!-- User -->
        <div class="hna-sidebar-user">
            <button class="hna-sidebar-user-btn" onclick="hna_ToggleUserMenu()">
                <div class="hna-user-avatar">A</div>
                <div class="hna-user-info">
                    <div class="hna-user-name">Admin</div>
                    <div class="hna-user-role">管理員</div>
                </div>
            </button>
        </div>
    </aside>

    <!-- ── Main ─────────────────────────────────────────── -->
    <div class="hna-main">

        <!-- Header -->
        <header class="hna-header">
            <button class="hna-mobile-toggle" onclick="hna_OpenMobileSidebar()" aria-label="開啟選單">
                <i data-lucide="menu"></i>
            </button>

            <div class="hna-header-title">
                <p class="hna-page-title">@(string.IsNullOrEmpty(pageTitle) ? "HN Admin" : pageTitle)</p>
                @if (!string.IsNullOrEmpty(pageDescription))
                {
                    <p class="hna-page-desc">@pageDescription</p>
                }
            </div>

            <div class="hna-header-actions">
                <button class="hna-icon-btn" title="通知">
                    <i data-lucide="bell"></i>
                </button>

                <div class="hna-header-divider"></div>

                <div class="position-relative">
                    <button id="hna-user-btn"
                            class="hna-header-user"
                            onclick="hna_ToggleUserMenu()"
                            aria-haspopup="true"
                            aria-expanded="false">
                        <div class="hna-user-avatar" style="width:28px;height:28px;font-size:12px;">A</div>
                        <span class="hna-header-user-name d-none d-md-block">Admin</span>
                        <i data-lucide="chevron-down"></i>
                    </button>

                    <div id="hna-user-menu" class="hna-dropdown" role="menu">
                        <div class="hna-dropdown-header">
                            <div class="hna-dd-name">Admin</div>
                            <div class="hna-dd-email">admin@example.com</div>
                            <span class="hna-dd-badge">
                                <i data-lucide="shield"></i> 管理員
                            </span>
                        </div>
                        <div class="hna-dropdown-divider"></div>
                        <a class="hna-dd-item danger" href="#">
                            <i data-lucide="log-out"></i> 登出
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="hna-content">
            @RenderBody()
        </main>

    </div><!-- /hna-main -->
</div><!-- /hna-shell -->

@RenderSection("Scripts", required: false)

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>

</body>
</html>
