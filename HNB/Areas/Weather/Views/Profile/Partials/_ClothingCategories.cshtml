@{
    Layout = null;
}

<!-- Top 區塊 -->
<div class="clothing-section-card mb-3">
    <div class="category-card">
        <div class="category-header mb-2">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="h6 fw-bold mb-0">Top</h3>
                </div>
                <div class="col-auto">
                    <div class="category-actions">
                        <button class="add-btn btn border-0 bg-transparent me-2">+</button>
                        <button class="heart-btn btn border-0 bg-transparent">♡</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="clothing-grid row g-2 mb-2">
            <div class="col-4 col-md-2">
                <div class="clothing-item position-relative">
                    <button class="clothing-delete-btn position-absolute top-0 end-0">×</button>
                    <button class="clothing-favorite-btn position-absolute bottom-0 end-0">♡</button>
                </div>
            </div>
            <div class="col-4 col-md-2">
                <div class="clothing-item position-relative">
                    <button class="clothing-delete-btn position-absolute top-0 end-0">×</button>
                    <button class="clothing-favorite-btn position-absolute bottom-0 end-0">♡</button>
                </div>
            </div>
            <div class="col-4 col-md-2">
