@{
    Layout = null;
}

<div class="entry-page-container">
    <div class="container p-5 min-vh-100 w-100">
        <div class="row g-4">
            <!-- 左側區塊 -->
            <div class="col-12 col-md-6">
                <h2 class="fw-bold mb-3 display-3">
                    Drag your photo to your walk-in
                    <em class="brand-italic fw-normal">closet</em>
                </h2>
                <p class="text-secondary mb-4 fs-5">5 photos only , we will coordinate for you</p>
                
                <div class="upload-button-bg p-3 w-100 rounded-3">
                    <button type="button" class="upload-button rounded-2 w-100 text-center py-4" id="uploadButton">
                        <span class="upload-icon fs-1 fw-light d-block">+</span>
                        <span class="upload-text fw-bold text-dark small d-block mt-2">Upload<br>Here</span>
                    </button>
                </div>
            </div>
            
            <!-- 右側區塊 -->
            <div class="col-12 col-md-6">
                <div class="h-100 text-center">
                    <div class="row h-100 align-items-center justify-content-center">
                        <div class="col-12">
                            <i data-lucide="map-pin" style="width: 60px; height: 60px;"></i>
                            <p class="mb-1 fw-semibold fs-5">Location:</p>
                            <div class="row justify-content-center align-items-center mb-4">
                                <div class="col-auto">
                                    <p class="mb-0 fs-5" id="locationText">Winona, MN 88987</p>
                                </div>
                                <div class="col-auto">
                                    <button type="button" class="btn p-0 border-0 bg-transparent" id="refreshLocationBtn">
                                        <i data-lucide="refresh-cw" style="width: 16px; height: 16px;"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <div class="w-100 mx-auto" style="max-width: 300px;">
                                <input type="text" id="weatherField" placeholder="Today I want to ......" class="form-control rounded-pill fs-5 mb-3">
                                <button type="button" class="btn generate-btn rounded-pill text-black fw-semibold fs-5" id="generateBtn">Generate</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
