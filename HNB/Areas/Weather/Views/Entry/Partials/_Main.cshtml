@{
    Layout = null;
}

<div class="vh-100 d-flex align-items-center position-relative" style="background-color: var(--color-beige); background-image: url('/Weather/image/section-c-bg.png'); background-position: center; background-size: cover; background-repeat: no-repeat; margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); width: 100vw;">
    <div class="container">
        <div class="row g-4">
        <!-- 左側區塊 -->
        <div class="col-12 col-md-6">
            <h2 class="fw-bold mb-3 fs-b">
                Drag your photo to your walk-in
                <em class="brand-italic fw-normal">closet</em>
            </h2>
            <p class="text-secondary mb-4 fs-s">5 photos only , we will coordinate for you</p>
            
            <div class="upload-button-bg p-3 w-100 rounded-3">
                <button type="button" class="upload-button rounded-2 w-100 text-center py-4" id="uploadButton">
                    <span class="upload-icon fs-b fw-light d-block">+</span>
                    <span class="upload-text fw-bold text-dark fs-l d-block mt-2">Upload<br>Here</span>
                </button>
            </div>
        </div>
        
        <!-- 右側區塊 -->
        <div class="col-12 col-md-6">
            <div class="text-center">
                <i data-lucide="map-pin" style="width: 60px; height: 60px;"></i>
                <p class="mb-1 fw-semibold fs-s">Location:</p>
                <div class="d-flex justify-content-center align-items-center gap-2 mb-4">
                    <p class="mb-0 fs-s" id="locationText">Winona, MN 88987</p>
                    <button type="button" class="btn p-0 border-0 bg-transparent" id="refreshLocationBtn">
                        <i data-lucide="refresh-cw" style="width: 16px; height: 16px;"></i>
                    </button>
                </div>
                
                <div class="w-100 mx-auto" style="max-width: 300px;">
                    <input type="text" id="weatherField" placeholder="Today I want to ......" class="form-control rounded-pill fs-s mb-3">
                    <button type="button" class="btn generate-btn rounded-pill text-black fw-semibold fs-s" id="generateBtn">Generate</button>
                </div>
            </div>
        </div>
        </div>
    </div>
</div>

<!-- 衣櫃區域 -->
<div class="vh-100 d-flex align-items-center position-relative">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="position-relative">
                    <button class="btn btn-sm position-absolute top-0 end-0" style="z-index: 10; background-color: var(--color-orange); color: var(--White);">View photo/item</button>
                    <div class="clothing-grid row g-2">
                        @for (int i = 0; i < 16; i++)
                        {
                            <div class="col-3">
                                <div class="clothing-item position-relative"></div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
