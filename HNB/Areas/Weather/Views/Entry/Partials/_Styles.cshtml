.entry-page-container {
    background-color: #d9d4c0;
    background-image: url('/Weather/image/section-c-bg.png');
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
}

/* 外層背景顏色 */
.upload-button-bg {
