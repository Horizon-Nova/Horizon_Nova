@{
    Layout = null;
}

<style>
/* 外層背景顏色 */
.upload-button-bg {
    background-color: var(--color-cream);
}

/* 內層邊框顏色 */
.upload-button {
    border: 2px dashed var(--color-orange);
    background-color: transparent;
}

/* 加號顏色 */
.upload-icon {
    color: var(--color-orange);
}

/* 定位圖示顏色 */
[data-lucide="map-pin"] {
    color: var(--color-orange);
}

/* 刷新圖示顏色 */
[data-lucide="refresh-cw"] {
    color: var(--color-orange);
}

/* Generate 按鈕背景顏色 */
.generate-btn {
    background-color: var(--color-orange);
}

.generate-btn:hover {
    background-color: var(--color-orange);
}

/* 衣櫃區域 */
.clothing-grid {
    margin-top: 2rem;
}

.clothing-item {
    aspect-ratio: 1;
    background-color: var(--color-cream);
    border-radius: 4px;
}
</style>
