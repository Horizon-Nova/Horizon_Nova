@{
    ViewData["Title"] = "Whatever the wheather.";
    Layout = "~/Areas/Weather/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/Weather/css/outfit.css" />
}

<div id="section-a">
    <!-- A 區塊：區塊1（vh-100）-->
    <div class="vh-100 d-flex flex-column align-items-center justify-content-center">
        <div class="d-flex align-items-center gap-3">
            <div>
                <h1 class="fw-bold mb-0 text-dark" style="font-size: 8rem; line-height: 1;">What ever</h1>
                <h1 class="mb-0 text-dark fw-normal" style="font-size: 8rem; line-height: 1;">the <em class="brand-italic fw-normal">wheather</em></h1>
            </div>
            <div>
                <h3 class="mb-0 text-dark">Smart closet.Smarter You.</h3>
            </div>
        </div>
        <div class="text-center mt-5">
            <button class="btn btn-brand rounded-pill px-4 py-2 text-dark">Try it for Free</button>
        </div>
    </div>

    <!-- A 區塊：區塊2（vh-100）-->
    <div class="vh-100 d-flex align-items-center justify-content-center px-5">
        <div class="d-flex align-items-center gap-3">
            <div>
                <h2 class="display-3 fw-bold text-dark">
                    Manage your Closet with <em class="brand-italic fw-normal">AI-power.</em>
                </h2>
            </div>
            <div class="h-60 w-60">
                    <div class="bg-white rounded-3 shadow p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0 fw-bold small">Top</h6>
                            <div class="d-flex gap-2">
                                <i data-lucide="plus" style="width:1rem;height:1rem;"></i>
                                <i data-lucide="heart" style="width:1rem;height:1rem;"></i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-3 shadow p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0 fw-bold small">Bottom</h6>
                            <div class="d-flex gap-2">
                                <i data-lucide="x" style="width:1rem;height:1rem;"></i>
                                <i data-lucide="heart" style="width:1rem;height:1rem;"></i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-3 shadow p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0 fw-bold small">Outwear</h6>
                            <div class="d-flex gap-2">
                                <i data-lucide="plus" style="width:1rem;height:1rem;"></i>
                                <i data-lucide="heart" style="width:1rem;height:1rem;"></i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                        </div>
                    </div>
            </div>
        </div>
    </div>

    <!-- A 區塊：區塊3（vh-100，標題靠右） -->
    <div class="vh-100 d-flex align-items-center justify-content-end p-5">
        <div class="text-start" style="max-width: 450px;">
            <h1 class="display-1 fw-bold mb-0 text-dark">Create Your</h1>
            <h1 class="display-1 mb-3 text-dark fw-normal"><em class="brand-italic">Outfit Log</em></h1>
            <h2 class="display-6 fw-bold mb-0 text-dark">smart, stylish, and always ready for you.</h2>
        </div>
    </div>
</div>
<div id="section-b">
    <div class="text-center py-5 mt-5 vh-100">
        <h1 class="display-1 fw-bold mb-0 text-dark">What to <em class="brand-italic fw-normal">wear?</em></h1>
    </div>
</div>

<div id="section-c" class="vh-100 d-flex flex-column align-items-center justify-content-center">
    <h2 class="display-2 text-white mb-4">Ready to create your <em class="brand-italic">AI Closet?</em></h2>
    <button class="btn btn-brand rounded-pill px-5 py-3 text-white fs-4">Get Started</button>
</div>