@{
    Layout = null;
}

<div id="section-a">
    <!-- Hero Section -->
    <div class="vh-100 px-3">
        <div class="container h-100">
            <div class="row h-100 justify-content-center pt-5">
                <div class="col-6 text-center align-self-center">
                    <h1 class="fw-bold mb-0 text-dark display-1" style="line-height: 1;">What ever</h1>
                    <h1 class="mb-0 text-dark fw-normal display-1" style="line-height: 1;">the <em class="brand-italic fw-normal">wheather</em></h1>
                </div>
                <div class="col-6 text-center align-self-center">
                    <h3 class="mb-0 text-dark fs-4">Smart closet.Smarter You.</h3>
                </div>
                <div class="col-12 text-center">
                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Entry", new { area = "Weather" })" class="btn btn-brand rounded-pill px-4 py-2 text-dark text-decoration-none">Try it for Free</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="vh-100 px-5">
            <div class="container h-100">
                <div class="row h-100 g-4">
                    <div class="col-12 col-md-6 text-center">
                        <h2 class="display-3 fw-bold text-dark">
                            Manage your Closet with <em class="brand-italic fw-normal">AI-power.</em>
                        </h2>
                    </div>
                    <div class="col-12 col-md-6">
                    <div class="bg-white rounded-3 shadow p-3 mb-3">
                        <div class="row align-items-center mb-2">
                            <div class="col">
                                <h6 class="mb-0 fw-bold small">Top</h6>
                            </div>
                            <div class="col-auto">
                                <i data-lucide="plus" style="width:1rem;height:1rem;"></i>
                                <i data-lucide="heart" style="width:1rem;height:1rem;"></i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-3 shadow p-3 mb-3">
                        <div class="row align-items-center mb-2">
                            <div class="col">
                                <h6 class="mb-0 fw-bold small">Bottom</h6>
                            </div>
                            <div class="col-auto">
                                <i data-lucide="x" style="width:1rem;height:1rem;"></i>
                                <i data-lucide="heart" style="width:1rem;height:1rem;"></i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-3 shadow p-3">
                        <div class="row align-items-center mb-2">
                            <div class="col">
                                <h6 class="mb-0 fw-bold small">Outwear</h6>
                            </div>
                            <div class="col-auto">
                                <i data-lucide="plus" style="width:1rem;height:1rem;"></i>
                                <i data-lucide="heart" style="width:1rem;height:1rem;"></i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                            <div class="col-3">
                                <div class="ratio ratio-1x1 bg-light rounded-2"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Your Outfit Log Section -->
    <div class="vh-100 px-5">
        <div class="container h-100">
            <div class="row h-100 justify-content-end">
                <div class="col-12 col-md-6 text-center">
                    <h1 class="display-1 fw-bold mb-0 text-dark">Create Your</h1>
                    <h1 class="display-1 mb-3 text-dark fw-normal"><em class="brand-italic">Outfit Log</em></h1>
                    <h2 class="display-6 fw-bold mb-0 text-dark">smart, stylish, and always ready for you.</h2>
                </div>
            </div>
        </div>
    </div>
</div>


