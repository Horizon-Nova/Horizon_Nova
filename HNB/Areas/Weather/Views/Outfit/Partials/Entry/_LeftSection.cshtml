@{
    Layout = null;
}

<section class="d-flex flex-column justify-content-center h-100">
    <div>
        <h2 class="display-2 fw-bold mb-3">
            Drag your photo<br>
            to your walk-in<br>
            <em class="fst-italic fw-normal">closet</em>
        </h2>
        <p class="fs-5 entry-subtitle mb-4">5 photos only, we will coordinate for you</p>

        <div class="entry-upload-zone border border-2 rounded-3 d-flex align-items-center justify-content-center ratio" style="aspect-ratio: 6/5; max-width: 150px;">
            <div class="entry-upload-text text-center fw-semibold small">
                <strong>Upload<br>Here</strong>
            </div>
        </div>
    </div>
</section>
