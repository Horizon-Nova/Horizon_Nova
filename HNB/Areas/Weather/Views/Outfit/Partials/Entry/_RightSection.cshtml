@{
    Layout = null;
}

<section class="d-flex flex-column justify-content-center gap-4 h-100">
    <div class="card shadow-sm rounded-4 p-4" style="background-color: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
        <div class="mb-3">
            <div class="entry-location-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
            </div>
        </div>
        <div class="d-flex align-items-start justify-content-between">
            <div>
                <p class="fw-semibold mb-1">Location:</p>
                <p class="fs-5 fw-medium mb-0 entry-location-text">Winona, MN 55987</p>
            </div>
            <button type="button" class="btn entry-edit-location rounded-circle p-2 flex-shrink-0" style="border: none; background: none;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M11.013 1.427a1.75 1.75 0 0 1 2.474 0l1.086 1.086a1.75 1.75 0 0 1 0 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 0 1-.927-.928l.929-3.25c.081-.286.235-.547.445-.758l8.61-8.61Z"/>
                </svg>
            </button>
        </div>
    </div>

    <div class="d-flex gap-2">
        <input type="text" placeholder="Today I want to ..." class="form-control rounded-pill border-0 shadow-sm entry-weather-field py-3 px-4" style="background-color: rgba(255, 255, 255, 0.9);">
        <button type="button" class="btn entry-generate-btn rounded-pill px-4 py-3 text-white fw-semibold flex-shrink-0" style="border: none;">Generate</button>
    </div>
</section>
