<!DOCTYPE html>
<html lang="zh-TW" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Whatever the wheather</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        html, body {
            font-size: .875rem;
            line-height: 1.25rem;
        }

        .hidden-important {
            display: none !important;
        }
    </style>
</head>
<body class="h-full bg-gradient-to-br from-slate-50 to-slate-100">

    <!-- 背景裝飾 -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-16 -left-16 w-56 h-56 rounded-full bg-orange-200/40 blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-20 -right-20 w-72 h-72 rounded-full bg-amber-200/40 blur-3xl animate-pulse"></div>
    </div>

    <!-- 主要內容 -->
    <div class="relative z-10 h-full">
        @RenderBody()
    </div>

    <!-- 全域 JavaScript -->
    <script>
        $(function() {
            if (window.lucide?.createIcons) {
                window.lucide.createIcons();
            }

            const $main = $('main');
            if ($main.length) {
                $main.addClass('fade-in-up');
            }
        });

        $(window).on('error', function(e) {
            console.error('JavaScript 錯誤:', e.error);
        });

        $(window).on('unhandledrejection', function(e) {
            console.error('未處理的 Promise 拒絕:', e.reason);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

