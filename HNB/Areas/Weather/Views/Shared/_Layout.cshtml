@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Whatever the wheather";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserName = User.Identity?.Name ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? currentUserName;
    var displayName = !string.IsNullOrEmpty(fullName) ? fullName : currentUserName;
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Flatpickr Calendar -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Bodoni+Moda:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/Weather/css/layout.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="min-height: 100vh; width: 100vw; display: flex; flex-direction: column;">
    <!-- Header -->
    <header class="bg-true-black text-white py-2 position-relative">
        <div class="container">
            <div class="d-flex justify-content-end align-items-center gap-3">
                @if (isAuthenticated)
                {
                    <!-- 使用者選單 -->
                    <div class="dropdown position-relative">
                        <button id="btnUserMenu"
                                type="button"
                                class="btn btn-link text-white text-decoration-none p-0 d-flex align-items-center gap-2"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            <span class="small">Hello, @displayName</span>
                            <i id="userMenuIcon" data-lucide="chevron-down" style="width: 1rem; height: 1rem;"></i>
                        </button>
                        <!-- Dropdown Menu -->
                        <ul id="userMenu"
                            class="dropdown-menu dropdown-menu-end position-absolute end-0 mt-2 bg-dark"
                            style="min-width: auto; width: auto; z-index: 1050;"
                            aria-labelledby="btnUserMenu">
                            <li>
                                <div class="px-3 py-2">
                                    <h6 class="mb-0 fw-bold">
                                        <span class="brand-italic">W</span>w
                                    </h6>
                                </div>
                            </li>
                            <li>
                                <a class="dropdown-item text-white text-orange" 
                                   href="@Url.Action("Index", "Profile", new { area = "Weather" })">
                                    My Closet
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item text-white" href="@Url.Action("Index", "Profile", new { area = "Weather" })">
                                    Calendar
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item text-white" href="@Url.Action("Index", "Profile", new { area = "Weather" })">
                                    Account Status
                                </a>
                            </li>
                            <li>
                                <div class="dropdown-item text-white d-flex justify-content-center align-items-center" style="cursor: default; padding: 0.5rem 1rem;">
                                    <span class="d-flex align-items-center justify-content-center gap-2">
                                        <!-- 1. 洗衣機 -->
                                        <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="4" width="18" height="16" rx="2"/>
                                            <circle cx="12" cy="12" r="4"/>
                                            <path d="M8 4V2M16 4V2"/>
                                        </svg>
                                        <!-- 2. 三角形 -->
                                        <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M12 2L22 20H2L12 2Z"/>
                                        </svg>
                                        <!-- 3. 正方形 -->
                                        <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="3" width="18" height="18"/>
                                        </svg>
                                        <!-- 4. 正方形中有圓形 -->
                                        <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="3" width="18" height="18"/>
                                            <circle cx="12" cy="12" r="5"/>
                                        </svg>
                                        <!-- 5. 熨斗 -->
                                        <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M6 8L18 8L16 20H8L6 8Z"/>
                                            <path d="M6 8L4 6L6 4L8 6L6 8Z"/>
                                            <path d="M18 8L20 6L18 4L16 6L18 8Z"/>
                                            <circle cx="12" cy="14" r="2"/>
                                        </svg>
                                        <!-- 6. 圓形 -->
                                        <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                        </svg>
                                    </span>
                                </div>
                            </li>
                            <li>
                                <form method="post" action="@Url.Action("Logout", "Login", new { area = "Weather" })">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="dropdown-item text-white w-100 text-start border-0 bg-transparent"
                                            style="border-top: 1px dashed rgba(255, 255, 255, 0.3) !important; margin-top: 0.5rem;">
                                        Log out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Index", "Login", new { area = "Weather" })" class="text-white text-decoration-none small">Login</a>
                    <a href="@Url.Action("Index", "Profile", new { area = "Weather" })" class="btn btn-brand btn-sm px-3 rounded-pill text-decoration-none">Try it for free</a>
                }
            </div>
            <div class="position-absolute top-50 start-50 translate-middle text-center">
                <div class="fw-bold medium">Whatever the <em class="brand-italic">wheather</em>.</div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-true-black text-white py-5">
        <div class="container">
            <div class="row align-items-center mb-4">
                <div class="col-12 col-md-6">
                    <nav class="d-flex justify-content-start gap-3">
                        <a href="#" class="text-white text-decoration-none small">Company</a>
                        <a href="#" class="text-white text-decoration-none small">Pricing</a>
                        <a href="#" class="text-white text-decoration-none small">Legal</a>
                    </nav>
                </div>
                <div class="col-12 col-md-6">
                    <div class="d-flex justify-content-md-end justify-content-start gap-3">
                        <a href="#" class="text-white text-decoration-none" aria-label="Instagram">
                            <i data-lucide="instagram" style="width:20px;height:20px;"></i>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="Twitter">
                            <i data-lucide="twitter" style="width:20px;height:20px;"></i>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="YouTube">
                            <i data-lucide="youtube" style="width:20px;height:20px;"></i>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="GitHub">
                            <i data-lucide="github" style="width:20px;height:20px;"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="text-center">
                <h2 class="mb-1 fw-bold display-5">Whatever the <em class="brand-italic">wheather</em>.</h2>
                <div class="text-white-50 small">&copy; 2025 WW. All rights reserved.</div>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide && typeof lucide.createIcons === 'function') {
                lucide.createIcons();
            }

            // 監聽 Bootstrap dropdown 事件來更新圖標
            const btnUserMenu = document.getElementById('btnUserMenu');
            const userMenuIcon = document.getElementById('userMenuIcon');
            
            if (btnUserMenu && userMenuIcon) {
                btnUserMenu.addEventListener('show.bs.dropdown', function () {
                    userMenuIcon.setAttribute('data-lucide', 'chevron-up');
                    if (window.lucide && typeof lucide.createIcons === 'function') {
                        lucide.createIcons();
                    }
                });

                btnUserMenu.addEventListener('hide.bs.dropdown', function () {
                    userMenuIcon.setAttribute('data-lucide', 'chevron-down');
                    if (window.lucide && typeof lucide.createIcons === 'function') {
                        lucide.createIcons();
                    }
                });
            }
        });
    </script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

