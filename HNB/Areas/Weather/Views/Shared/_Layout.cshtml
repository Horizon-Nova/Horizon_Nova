@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Whatever the wheather";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserName = User.Identity?.Name ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? currentUserName;
    var displayName = !string.IsNullOrEmpty(fullName) ? fullName : currentUserName;
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/Weather/image/logo.png">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Flatpickr Calendar -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Bodoni+Moda:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Color Palette -->
    <link rel="stylesheet" href="~/lib/color-palette/color-palette.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/Weather/css/layout.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="min-height: 100vh; width: 100vw; display: flex; flex-direction: column;">
    <!-- Header -->
    <header class="bg-true-black text-white py-2 position-relative">
        <div class="container">
            <div class="d-flex justify-content-end align-items-center gap-3">
                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <button id="btnUserMenu" type="button" class="btn btn-link text-white text-decoration-none p-0 d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                            <span class="fs-l">Hello, @displayName</span>
                            <i id="userMenuIcon" data-lucide="chevron-down" style="width: 1rem; height: 1rem;"></i>
                        </button>
                        <ul id="userMenu" class="dropdown-menu dropdown-menu-end mt-2 bg-dark" aria-labelledby="btnUserMenu">
                            <li><div class="px-3 py-2"><img src="~/Weather/image/logo.png" alt="Ww." class="img-fluid" style="max-height: 2rem;"></div></li>
                            <li><a class="dropdown-item text-white text-orange" href="@Url.Action("Index", "Profile", new { area = "Weather" })">My Closet</a></li>
                            <li><a class="dropdown-item text-white" href="@Url.Action("Index", "Profile", new { area = "Weather" })">Calendar</a></li>
                            <li><a class="dropdown-item text-white" href="@Url.Action("Index", "Profile", new { area = "Weather" })">Account Status</a></li>
                            <li>
                                <div class="dropdown-item text-white d-flex justify-content-center gap-2" style="cursor: default; padding: 0.5rem 1rem;">
                                    <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="12" cy="12" r="4"/><path d="M8 4V2M16 4V2"/></svg>
                                    <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L22 20H2L12 2Z"/></svg>
                                    <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18"/></svg>
                                    <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18"/><circle cx="12" cy="12" r="5"/></svg>
                                    <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8L18 8L16 20H8L6 8Z"/><path d="M6 8L4 6L6 4L8 6L6 8Z"/><path d="M18 8L20 6L18 4L16 6L18 8Z"/><circle cx="12" cy="14" r="2"/></svg>
                                    <svg style="width: 1rem; height: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
                                </div>
                            </li>
                            <li>
                                <form method="post" action="@Url.Action("Logout", "Login", new { area = "Weather" })">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-white w-100 text-start border-0 bg-transparent" style="border-top: 1px dashed rgba(255, 255, 255, 0.3) !important; margin-top: 0.5rem;">Log out</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Index", "Login", new { area = "Weather" })" class="text-white text-decoration-none fs-l">Login</a>
                    <a href="@Url.Action("Index", "Profile", new { area = "Weather" })" class="btn btn-brand btn-sm px-3 rounded-pill text-decoration-none">Try it for free</a>
                }
            </div>
            <div class="position-absolute top-50 start-50 translate-middle text-center">
                <div class="fw-bold fs-n">Whatever the <em class="brand-italic">wheather</em>.</div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow-1">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-true-black text-white py-3">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                <nav class="d-flex gap-3">
                    <a href="#" class="text-white text-decoration-none fs-l">Company</a>
                    <a href="#" class="text-white text-decoration-none fs-l">Pricing</a>
                    <a href="#" class="text-white text-decoration-none fs-l">Legal</a>
                </nav>
                <div class="d-flex gap-3">
                    <a href="#" class="text-white text-decoration-none" aria-label="Instagram"><i data-lucide="instagram" style="width:20px;height:20px;"></i></a>
                    <a href="#" class="text-white text-decoration-none" aria-label="Twitter"><i data-lucide="twitter" style="width:20px;height:20px;"></i></a>
                    <a href="#" class="text-white text-decoration-none" aria-label="YouTube"><i data-lucide="youtube" style="width:20px;height:20px;"></i></a>
                    <a href="#" class="text-white text-decoration-none" aria-label="GitHub"><i data-lucide="github" style="width:20px;height:20px;"></i></a>
                </div>
            </div>
            <div class="text-center">
                <h2 class="mb-1 fw-bold fs-n">Whatever the <em class="brand-italic">wheather</em>.</h2>
                <div class="text-white-50 fs-l">&copy; 2025 WW. All rights reserved.</div>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            lucide?.createIcons();
            
            const btnUserMenu = document.getElementById('btnUserMenu');
            const userMenuIcon = document.getElementById('userMenuIcon');
            
            if (btnUserMenu && userMenuIcon) {
                btnUserMenu.addEventListener('show.bs.dropdown', () => {
                    userMenuIcon.setAttribute('data-lucide', 'chevron-up');
                    lucide?.createIcons();
                });
                btnUserMenu.addEventListener('hide.bs.dropdown', () => {
                    userMenuIcon.setAttribute('data-lucide', 'chevron-down');
                    lucide?.createIcons();
                });
            }
        });
    </script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

