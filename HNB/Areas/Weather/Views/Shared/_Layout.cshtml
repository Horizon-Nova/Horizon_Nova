@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Whatever the wheather";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Bodoni+Moda:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/Weather/css/layout.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body  style="min-height: 100vh; width: 100vw;">
    <!-- Header -->
    <header class="bg-true-black text-white py-2 position-relative">
        <div class="container">
            <div class="d-flex justify-content-end align-items-center gap-3">
                <a href="#" class="text-white text-decoration-none small">Login</a>
                <a href="@Url.Action("Index", "Entry", new { area = "Weather" })" class="btn btn-brand btn-sm px-3 rounded-pill text-decoration-none">Try it for free</a>
            </div>
            <div class="position-absolute top-50 start-50 translate-middle text-center">
                <div class="fw-bold medium">Whatever the <em class="brand-italic">wheather</em>.</div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="bg-white">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-true-black text-white py-5">
        <div class="container">
            <div class="row align-items-center mb-4">
                <div class="col-12 col-md-6">
                    <nav class="d-flex justify-content-start gap-3">
                        <a href="#" class="text-white text-decoration-none small">Company</a>
                        <a href="#" class="text-white text-decoration-none small">Pricing</a>
                        <a href="#" class="text-white text-decoration-none small">Legal</a>
                    </nav>
                </div>
                <div class="col-12 col-md-6">
                    <div class="d-flex justify-content-md-end justify-content-start gap-3">
                        <a href="#" class="text-white text-decoration-none" aria-label="Instagram">
                            <i data-lucide="instagram" style="width:20px;height:20px;"></i>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="Twitter">
                            <i data-lucide="twitter" style="width:20px;height:20px;"></i>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="YouTube">
                            <i data-lucide="youtube" style="width:20px;height:20px;"></i>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="GitHub">
                            <i data-lucide="github" style="width:20px;height:20px;"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="text-center">
                <h2 class="mb-1 fw-bold display-5">Whatever the <em class="brand-italic">wheather</em>.</h2>
                <div class="text-white-50 small">&copy; 2025 WW. All rights reserved.</div>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide && typeof lucide.createIcons === 'function') {
                lucide.createIcons();
            }
        });
    </script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
