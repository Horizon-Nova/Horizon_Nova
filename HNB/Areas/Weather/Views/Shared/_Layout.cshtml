@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Whatever the wheather";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Bodoni+Moda:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <style>
        :root {
            --primary-orange: #d7673;
            --bg-color: #d4ceb9;
        }

        body {
            font-family: 'Lato', sans-serif;
            background-color: var(--bg-color);
        }

        .header-title {
            font-family: 'Lato', sans-serif;
            font-weight: 700;
            font-size: 24pt;
        }

        .header-title .italic {
            font-family: 'Bodoni Moda', serif;
            font-weight: 500;
            font-style: italic;
        }

        .header-nav a {
            font-family: 'Lato', sans-serif;
            font-weight: 400;
            font-size: 18pt;
        }

        .cta-button {
            font-family: 'Lato', sans-serif;
            font-weight: 400;
            font-size: 18pt;
            background-color: var(--primary-orange);
            border: none;
            border-radius: 25px;
        }

        .cta-button:hover {
            background-color: #c55a2a;
        }

        .footer-title {
            font-family: 'Lato', sans-serif;
            font-weight: 700;
            font-size: 80pt;
            line-height: 1;
        }

        .footer-title .italic {
            font-family: 'Bodoni Moda', serif;
            font-weight: 500;
            font-style: italic;
        }

    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Header -->
    <header class="d-flex flex-column flex-md-row align-items-center justify-content-between bg-dark text-white px-4 py-2" style="min-height: 60px;">
        <h1 class="header-title mb-0 mb-md-0">Whatever the <span class="italic">wheather</span>.</h1>
        <div class="d-flex align-items-center gap-3">
            <a href="#" class="header-nav text-white text-decoration-none">Login</a>
            <button class="btn cta-button text-white px-3 py-2">Try it for free</button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="min-vh-100">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-5">
        <h2 class="footer-title mb-0">Whatever the <span class="italic">wheather</span>.</h2>
    </footer>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
