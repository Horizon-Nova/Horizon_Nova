@{
    ViewData["Title"] = "頁面編輯 - Test";
    Layout = "~/Areas/Weather/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/color-palette/color-palette.css" />
    <style>
        .page-editor-container {
            display: flex;
            height: calc(100vh - 200px);
            gap: 1rem;
        }
        
        .partials-list {
            width: 200px;
            background-color: var(--color-white);
            border-radius: 8px;
            padding: 1rem;
            border: 1px solid #dee2e6;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        
        .partial-item {
            aspect-ratio: 16 / 9;
            background-color: var(--color-cream);
            border-radius: 4px;
            border: 2px solid transparent;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
            color: var(--color-black);
            position: relative;
            overflow: hidden;
            min-height: 100px;
        }
        
        .partial-item:hover {
            background-color: #e9ecef;
        }
        
        .partial-item.active {
            border-color: var(--color-orange);
            background-color: #fff3e0;
        }
        
        .partial-item-preview {
            width: 100%;
            height: 100%;
            pointer-events: none;
            position: absolute;
            top: 0;
            left: 0;
            overflow: hidden;
        }
        
        .partial-item-preview > * {
            width: 100% !important;
            height: 100% !important;
            max-width: 100% !important;
            max-height: 100% !important;
            object-fit: contain;
        }
        
        .partial-item-preview .container,
        .partial-item-preview .row,
        .partial-item-preview [class*="col-"] {
            width: 100% !important;
            max-width: 100% !important;
            padding: 0.25rem !important;
        }
        
        .partial-item-preview .vh-100 {
            height: 100% !important;
            min-height: 100% !important;
        }
        
        .partial-item-preview h1,
        .partial-item-preview h2,
        .partial-item-preview h3 {
            font-size: 0.75rem !important;
            line-height: 1.2 !important;
            margin: 0.1rem 0 !important;
        }
        
        .partial-item-preview .display-1 {
            font-size: 0.75rem !important;
        }
        
        .partial-item-preview .display-3 {
            font-size: 0.75rem !important;
        }
        
        .partial-item-preview .display-6 {
            font-size: 0.75rem !important;
        }
        
        .partial-item-preview .fs-4,
        .partial-item-preview .fs-5 {
            font-size: 0.75rem !important;
        }
        
        .partial-item-preview .btn {
            padding: 0.1rem 0.3rem !important;
            font-size: 0.75rem !important;
        }
        
        .partial-item-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
            text-align: center;
            z-index: 1;
        }
        
        .preview-panel {
            flex: 1;
            overflow: auto;
            background-color: var(--color-white);
            border-radius: 8px;
            padding: 1rem;
            border: 1px solid #dee2e6;
        }
        
        .preview-panel.empty {
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
        }
        
        .control-panel {
            width: 400px;
            background-color: var(--color-white);
            border-radius: 8px;
            padding: 1.5rem;
            overflow-y: auto;
            border: 1px solid #dee2e6;
            font-size: 0.75rem;
        }
        
        .control-title {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--color-black);
            margin-bottom: 1.5rem;
        }
        
        .control-panel .col-form-label {
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--color-black);
            margin-bottom: 0.5rem;
        }
        
        .control-panel .form-control,
        .control-panel .form-select,
        .control-panel .btn,
        .control-panel .text-muted,
        .control-panel .small {
            font-size: 0.75rem;
        }
        
        .element-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .element-item {
            padding: 0.75rem 1rem;
            margin-bottom: 0.5rem;
            background-color: var(--color-cream);
            border-radius: 4px;
            border: 1px solid #dee2e6;
            cursor: pointer;
        }
        
        .element-item:hover {
            background-color: #e9ecef;
        }
        
        .element-name {
            font-weight: 500;
            color: var(--color-black);
            margin-bottom: 0.25rem;
        }
        
        .element-type {
            font-size: 0.75rem;
            color: #6c757d;
        }
        
        .empty-message {
            text-align: center;
            color: #6c757d;
            padding: 2rem;
            font-size: 0.75rem;
        }
        
        .editable-element {
            position: relative;
            transition: all 0.2s;
        }
        
        .editable-element:hover {
            outline: 2px dashed var(--color-orange);
            outline-offset: 2px;
        }
        
        .editable-element.selected {
            outline: 2px solid var(--color-orange);
            outline-offset: 2px;
        }
        
        .background-editable:hover .background-edit-hint {
            display: block !important;
        }
        
        .background-editable.selected .background-edit-hint {
            display: block !important;
            background: rgba(255, 152, 0, 0.2) !important;
            border: 2px solid var(--color-orange) !important;
        }
        
        .editor-form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        
        .editor-form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .editor-form-label {
            font-weight: 500;
            color: var(--color-black);
            font-size: 0.75rem;
        }
        
        .editor-form-input {
            padding: 0.5rem;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            font-size: 0.75rem;
        }
        
        .editor-form .text-muted {
            font-size: 0.75rem;
        }
        
        .editor-form .btn {
            font-size: 0.75rem;
            padding: 0.5rem 1rem;
        }
    </style>
}

<div class="container-fluid p-4">
    <div class="page-editor-container">
        <!-- 左側：Partials 列表（像 PPT 幻燈片縮圖） -->
        <div class="partials-list">
            @if (ViewBag.Sections != null)
            {
                @foreach (var item in ViewBag.Sections)
                {
                    <div class="partial-item" data-partial="@item.name" onclick="selectPartial('@item.name')">
                        <div class="partial-item-label">@item.displayName</div>
                    </div>
                }
            }
        </div>
        
        <!-- 中間：選中 Partial 的預覽 -->
        <div class="preview-panel" id="previewPanel">
            <div class="empty-message">請選擇一個 Partial 進行編輯</div>
        </div>
        
        <!-- 右側：元素格式工具 -->
        <div class="control-panel">
            <h2 class="control-title">格式工具</h2>
            <div id="elementEditor">
                <div class="empty-message">請點選左側或中間預覽中的元素進行編輯</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/Backoffice/js/ColorPalette.js"></script>
    <script src="~/lib/font-palette/FontPalette.js"></script>
    <script>
        let currentPartial = null;
        let stylesHtml = '';
        
        $(document).ready(function() {
            // 先載入 Styles
            loadStyles();
            
            // 載入所有 Partials 的縮圖
            @if (ViewBag.Sections != null)
            {
                @foreach (var item in ViewBag.Sections)
                {
                    <text>
                    loadPartialThumbnail('@item.name');
                    </text>
                }
            }
        });
        
        function loadStyles() {
            $.ajax({
                type: 'GET',
                url: '/Weather/PageEditor/LoadPartialPreview',
                data: { pageName: 'Test', sectionName: 'Styles' },
                success: function(html) {
                    stylesHtml = html;
                }
            });
        }
        
        function loadPartialThumbnail(partialName) {
            const partialItem = $(`.partial-item[data-partial="${partialName}"]`);
            
            // 載入縮圖預覽
            $.ajax({
                type: 'GET',
                url: '/Weather/PageEditor/LoadPartialPreview',
                data: { pageName: 'Test', sectionName: partialName },
                success: function(html) {
                    const previewDiv = $('<div class="partial-item-preview"></div>');
                    if (partialName !== 'Styles') {
                        previewDiv.html(stylesHtml + html);
                    } else {
                        previewDiv.html(html);
                    }
                    partialItem.append(previewDiv);
                }
            });
        }
        
        function selectPartial(partialName) {
            // 更新選中狀態
            $('.partial-item').removeClass('active');
            $(`.partial-item[data-partial="${partialName}"]`).addClass('active');
            
            currentPartial = partialName;
            
            // 載入 Partial 預覽
            loadPartialPreview(partialName);
            
            // 載入可編輯元素列表
            loadEditableElements(partialName);
        }
        
        function loadPartialPreview(partialName) {
            const previewPanel = $('#previewPanel');
            previewPanel.removeClass('empty');
            previewPanel.html('<div class="text-center p-4">載入中...</div>');
            
            // 先載入 Styles（如果不是 Styles 本身）
            let stylesHtml = '';
            if (partialName !== 'Styles') {
                $.ajax({
                    type: 'GET',
                    url: '/Weather/PageEditor/LoadPartialPreview',
                    data: { pageName: 'Test', sectionName: 'Styles' },
                    async: false,
                    success: function(html) {
                        stylesHtml = html;
                    }
                });
            }
            
            // 載入 Partial 內容
            $.ajax({
                type: 'GET',
                url: '/Weather/PageEditor/LoadPartialPreview',
                data: { pageName: 'Test', sectionName: partialName },
                success: function(html) {
                    previewPanel.html(stylesHtml + html);
                    // 載入後標記可編輯元素（包括當前 partial 和 Styles 中的背景元素）
                    loadEditableElements(partialName);
                },
                error: function() {
                    previewPanel.html('<div class="text-danger text-center p-4">載入失敗</div>');
                }
            });
        }
        
        function loadEditableElements(partialName) {
            const allElements = [];
            
            // 載入當前 partial 的可編輯元素
            $.ajax({
                type: 'GET',
                url: '/Weather/PageEditor/GetEditableElements',
                data: { pageName: 'Test', sectionName: partialName },
                success: function(res) {
                    if (res.success && res.elements && res.elements.length > 0) {
                        res.elements.forEach(function(el) {
                            el.sectionName = partialName; // 記錄來源 section
                            allElements.push(el);
                        });
                        
                        // 如果不是 Styles，也要載入 Styles 中的背景圖片元素
                        if (partialName !== 'Styles') {
                            $.ajax({
                                type: 'GET',
                                url: '/Weather/PageEditor/GetEditableElements',
                                data: { pageName: 'Test', sectionName: 'Styles' },
                                success: function(stylesRes) {
                                    if (stylesRes.success && stylesRes.elements && stylesRes.elements.length > 0) {
                                        stylesRes.elements.forEach(function(el) {
                                            if (el.type === 'background') {
                                                el.sectionName = 'Styles'; // 記錄來源 section
                                                allElements.push(el);
                                            }
                                        });
                                    }
                                    // 標記所有元素
                                    markEditableElements(allElements);
                                }
                            });
                        } else {
                            // 如果是 Styles，直接標記
                            markEditableElements(allElements);
                        }
                    } else {
                        // 即使當前 partial 沒有元素，也要載入 Styles 中的背景元素
                        if (partialName !== 'Styles') {
                            $.ajax({
                                type: 'GET',
                                url: '/Weather/PageEditor/GetEditableElements',
                                data: { pageName: 'Test', sectionName: 'Styles' },
                                success: function(stylesRes) {
                                    if (stylesRes.success && stylesRes.elements && stylesRes.elements.length > 0) {
                                        stylesRes.elements.forEach(function(el) {
                                            if (el.type === 'background') {
                                                el.sectionName = 'Styles';
                                                allElements.push(el);
                                            }
                                        });
                                    }
                                    markEditableElements(allElements);
                                }
                            });
                        } else {
                            markEditableElements(allElements);
                        }
                    }
                }
            });
        }
        
        function markEditableElements(elements) {
            // 清除之前的標記
            $('#previewPanel [data-editable]').removeAttr('data-editable').removeClass('editable-element');
            $('#previewPanel .background-editable').removeClass('background-editable');
            
            elements.forEach(function(element) {
                if (element.type === 'background') {
                    // 背景圖片元素：在預覽中找到對應的元素並加上標記
                    if (element.selector) {
                        const $element = $(element.selector, '#previewPanel');
                        if ($element.length > 0) {
                            $element.attr('data-editable', element.id);
                            $element.attr('data-element-type', element.type);
                            $element.attr('data-section-name', element.sectionName || 'Styles'); // 記錄來源 section
                            $element.addClass('editable-element background-editable');
                            $element.css('cursor', 'pointer');
                            $element.css('position', 'relative');
                            
                            // 添加視覺提示
                            if (!$element.find('.background-edit-hint').length) {
                                $element.append('<div class="background-edit-hint" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255, 152, 0, 0.1); border: 2px dashed var(--color-orange); display: none; pointer-events: none; z-index: 9999;"></div>');
                            }
                        } else {
                            // 如果找不到元素，輸出調試信息
                            console.log('背景元素未找到:', element.selector, element.name);
                        }
                    } else {
                        console.log('背景元素缺少選擇器:', element.name);
                    }
                } else {
                    // 根據 selector 找到元素並加上標記
                    const $element = $(element.selector, '#previewPanel');
                    if ($element.length > 0) {
                        $element.attr('data-editable', element.id);
                        $element.attr('data-element-type', element.type);
                        $element.addClass('editable-element');
                        $element.css('cursor', 'pointer');
                        
                        // 如果是超連結，移除 href 或改為 javascript:void(0)
                        if (element.type === 'link' && $element.is('a')) {
                            $element.attr('data-original-href', $element.attr('href'));
                            $element.attr('href', 'javascript:void(0)');
                        }
                        // 如果是按鈕，移除 onclick 或暫時禁用
                        if (element.type === 'button' && $element.is('button')) {
                            $element.attr('data-original-onclick', $element.attr('onclick'));
                            $element.removeAttr('onclick');
                        }
                    }
                }
            });
        }
        
        // 點擊預覽中的元素
        $(document).on('click', '#previewPanel .editable-element', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const elementId = $(this).attr('data-editable');
            const elementType = $(this).attr('data-element-type');
            if (elementId && currentPartial) {
                selectElement(elementId, elementType);
            }
            return false;
        });
        
        function selectElement(elementId, elementType) {
            // 從元素屬性中取得 sectionName（背景元素來自 Styles）
            const $element = $(`[data-editable="${elementId}"]`, '#previewPanel');
            const sectionName = $element.attr('data-section-name') || currentPartial;
            
            // 載入元素編輯器
            $.ajax({
                type: 'GET',
                url: '/Weather/PageEditor/LoadElementEditor',
                data: { 
                    pageName: 'Test', 
                    sectionName: sectionName, 
                    elementId: elementId 
                },
                success: function(html) {
                    $('#elementEditor').html(html);
                },
                error: function() {
                    $('#elementEditor').html('<div class="text-danger text-center p-4">載入失敗</div>');
                }
            });
        }
    </script>
}
