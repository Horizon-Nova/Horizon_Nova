@{
    Layout = null;
    var element = ViewBag.Element as HNB.Areas.Weather.Services.EditableElement;
    var pageName = ViewBag.PageName as string ?? "";
    var sectionName = ViewBag.SectionName as string ?? "";
}

@if (element != null)
{
    <form id="elementEditorForm" autocomplete="off">
        <div class="form-group row mt-2">
            <label class="col-lg-3 col-form-label">元素名稱</label>
            <div class="col-lg-9">
                <div class="text-muted small">@element.Name</div>
            </div>
        </div>
        
        @if (element.Type == "text")
        {
            <!-- 文字內容 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="elementValue">文字內容</label>
                <div class="col-lg-9">
                    <textarea 
                        class="form-control" 
                        id="elementValue" 
                        rows="3"
                        data-element-id="@element.Id"
                        data-element-type="@element.Type"
                        data-selector="@element.Selector">@element.Value</textarea>
                </div>
            </div>
            
            <!-- 字體大小 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="fontSize">字體大小</label>
                <div class="col-lg-9">
                    <select class="form-select" id="fontSize" data-property="font-size">
                        <option value="">保持原樣</option>
                        <option value="0.75rem">0.75rem (12px)</option>
                        <option value="0.875rem">0.875rem (14px)</option>
                        <option value="1rem">1rem (16px)</option>
                        <option value="1.125rem">1.125rem (18px)</option>
                        <option value="1.25rem">1.25rem (20px)</option>
                        <option value="1.5rem">1.5rem (24px)</option>
                        <option value="2rem">2rem (32px)</option>
                        <option value="2.5rem">2.5rem (40px)</option>
                        <option value="3rem">3rem (48px)</option>
                    </select>
                </div>
            </div>
            
            <!-- 字體樣式 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label">字體樣式</label>
                <div class="col-lg-9">
                    <div id="fontPaletteContainer" class="border rounded p-2" style="max-height: 150px; overflow-y: auto; display: none;">
                        <div class="row g-2" id="fontList"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mt-2" onclick="toggleFontPalette()">選擇字體</button>
                    <input type="hidden" id="fontFamily" data-property="font-family" />
                </div>
            </div>
            
            <!-- 文字顏色 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label">文字顏色</label>
                <div class="col-lg-9">
                    <div id="colorPaletteContainer" class="border rounded p-2" style="max-height: 200px; overflow-y: auto; display: none;">
                        <div class="row g-2" id="colorList"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mt-2" onclick="toggleColorPalette('text')">選擇顏色</button>
                    <input type="hidden" id="textColor" data-property="color" />
                </div>
            </div>
            
            <!-- 字體粗細 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="fontWeight">字體粗細</label>
                <div class="col-lg-9">
                    <select class="form-select" id="fontWeight" data-property="font-weight">
                        <option value="">保持原樣</option>
                        <option value="100">100 (Thin)</option>
                        <option value="300">300 (Light)</option>
                        <option value="400">400 (Normal)</option>
                        <option value="500">500 (Medium)</option>
                        <option value="600">600 (Semi Bold)</option>
                        <option value="700">700 (Bold)</option>
                        <option value="900">900 (Black)</option>
                    </select>
                </div>
            </div>
        }
        else if (element.Type == "link")
        {
            <!-- 連結文字 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="elementValue">連結文字</label>
                <div class="col-lg-9">
                    <input 
                        type="text" 
                        class="form-control" 
                        id="elementValue" 
                        value="@element.Value"
                        data-element-id="@element.Id"
                        data-element-type="@element.Type"
                        data-selector="@element.Selector" />
                </div>
            </div>
            
            <!-- 連結網址 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="elementExtraData">連結網址</label>
                <div class="col-lg-9">
                    <input 
                        type="text" 
                        class="form-control" 
                        id="elementExtraData" 
                        value="@element.ExtraData"
                        data-element-id="@element.Id"
                        data-element-type="@element.Type" />
                </div>
            </div>
            
            <!-- 文字顏色 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label">文字顏色</label>
                <div class="col-lg-9">
                    <div id="colorPaletteContainer" class="border rounded p-2" style="max-height: 200px; overflow-y: auto; display: none;">
                        <div class="row g-2" id="colorList"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mt-2" onclick="toggleColorPalette('text')">選擇顏色</button>
                    <input type="hidden" id="textColor" data-property="color" />
                </div>
            </div>
            
            <!-- 導角 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="borderRadius">導角</label>
                <div class="col-lg-9">
                    <select class="form-select" id="borderRadius" data-property="border-radius">
                        <option value="">保持原樣</option>
                        <option value="0">0 (無導角)</option>
                        <option value="0.25rem">0.25rem (4px)</option>
                        <option value="0.5rem">0.5rem (8px)</option>
                        <option value="1rem">1rem (16px)</option>
                        <option value="1.5rem">1.5rem (24px)</option>
                        <option value="2rem">2rem (32px)</option>
                        <option value="50%">50% (圓形)</option>
                    </select>
                </div>
            </div>
        }
        else if (element.Type == "button")
        {
            <!-- 按鈕文字 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="elementValue">按鈕文字</label>
                <div class="col-lg-9">
                    <input 
                        type="text" 
                        class="form-control" 
                        id="elementValue" 
                        value="@element.Value"
                        data-element-id="@element.Id"
                        data-element-type="@element.Type"
                        data-selector="@element.Selector" />
                </div>
            </div>
            
            <!-- onclick 事件 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="elementExtraData">onclick 事件</label>
                <div class="col-lg-9">
                    <input 
                        type="text" 
                        class="form-control" 
                        id="elementExtraData" 
                        value="@element.ExtraData"
                        data-element-id="@element.Id"
                        data-element-type="@element.Type" />
                </div>
            </div>
            
            <!-- 背景顏色 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label">背景顏色</label>
                <div class="col-lg-9">
                    <div id="colorPaletteContainer" class="border rounded p-2" style="max-height: 200px; overflow-y: auto; display: none;">
                        <div class="row g-2" id="colorList"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mt-2" onclick="toggleColorPalette('background')">選擇顏色</button>
                    <input type="hidden" id="backgroundColor" data-property="background-color" />
                </div>
            </div>
            
            <!-- 文字顏色 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label">文字顏色</label>
                <div class="col-lg-9">
                    <div id="buttonTextColorPaletteContainer" class="border rounded p-2" style="max-height: 200px; overflow-y: auto; display: none;">
                        <div class="row g-2" id="buttonTextColorList"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mt-2" onclick="toggleColorPalette('text', 'buttonTextColorList', 'buttonTextColorPaletteContainer')">選擇顏色</button>
                    <input type="hidden" id="buttonTextColor" data-property="color" />
                </div>
            </div>
            
            <!-- 導角 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="borderRadius">導角</label>
                <div class="col-lg-9">
                    <select class="form-select" id="borderRadius" data-property="border-radius">
                        <option value="">保持原樣</option>
                        <option value="0">0 (無導角)</option>
                        <option value="0.25rem">0.25rem (4px)</option>
                        <option value="0.5rem">0.5rem (8px)</option>
                        <option value="1rem">1rem (16px)</option>
                        <option value="1.5rem">1.5rem (24px)</option>
                        <option value="2rem">2rem (32px)</option>
                        <option value="50%">50% (圓形)</option>
                    </select>
                </div>
            </div>
        }
        else if (element.Type == "background")
        {
            <!-- 背景圖片路徑 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label" for="elementValue">背景圖片路徑</label>
                <div class="col-lg-9">
                    <input 
                        type="text" 
                        class="form-control" 
                        id="elementValue" 
                        value="@element.Value"
                        data-element-id="@element.Id"
                        data-element-type="@element.Type"
                        data-selector="@element.Selector" />
                </div>
            </div>
            
            <!-- 背景顏色 -->
            <div class="form-group row mt-2">
                <label class="col-lg-3 col-form-label">背景顏色</label>
                <div class="col-lg-9">
                    <div id="colorPaletteContainer" class="border rounded p-2" style="max-height: 200px; overflow-y: auto; display: none;">
                        <div class="row g-2" id="colorList"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mt-2" onclick="toggleColorPalette('background')">選擇顏色</button>
                    <input type="hidden" id="backgroundColor" data-property="background-color" />
                </div>
            </div>
        }
        
        <div class="form-group row mt-3">
            <div class="col-lg-12">
                <button type="button" class="btn btn-primary btn-sm w-100" onclick="saveElement()">儲存</button>
            </div>
        </div>
    </form>
}
else
{
    <div class="empty-message">元素不存在</div>
}

<script>
    let currentElementSelector = '';
    let currentElementType = '';
    
    function toggleColorPalette(type, containerId = 'colorList', containerSelector = 'colorPaletteContainer') {
        const container = $('#' + containerSelector);
        if (container.is(':visible')) {
            container.hide();
            return;
        }
        
        // 隱藏其他顏色選擇器
        $('[id$="PaletteContainer"]').not('#' + containerSelector).hide();
        
        container.show();
        const list = $('#' + containerId);
        
        if (list.children().length === 0) {
            // 載入顏色表
            if (typeof ColorPalette !== 'undefined') {
                ColorPalette.loadColorsFromCSS();
                const colors = ColorPalette.colors;
                let html = '';
                colors.forEach(color => {
                    html += '<div class="col-6 col-sm-4 col-md-3">';
                    html += '<div class="border rounded overflow-hidden" style="background-color: var(' + color.varName + '); width: 100%; aspect-ratio: 1; cursor: pointer;" onclick="selectColor(\'' + type + '\', \'var(' + color.varName + ')\', \'' + containerSelector + '\')" title="' + color.name + '"></div>';
                    html += '</div>';
                });
                list.html(html);
            }
        }
    }
    
    function toggleFontPalette() {
        const container = $('#fontPaletteContainer');
        if (container.is(':visible')) {
            container.hide();
            return;
        }
        
        container.show();
        const list = $('#fontList');
        
        if (list.children().length === 0) {
            // 載入字體表
            if (typeof FontPalette !== 'undefined') {
                FontPalette.loadFontsFromCSS();
                const fonts = FontPalette.fonts;
                let html = '';
                fonts.forEach(font => {
                    html += '<div class="col-6 col-sm-4 col-md-3">';
                    html += '<div class="border rounded p-2 text-center" style="cursor: pointer; background-color: var(--color-cream);" onclick="selectFont(\'var(' + font.varName + ')\')" title="' + font.name + '">';
                    html += '<div style="font-family: var(' + font.varName + '); font-size: 0.75rem;">' + font.name + '</div>';
                    html += '</div>';
                    html += '</div>';
                });
                list.html(html);
            }
        }
    }
    
    function selectColor(type, colorValue, containerSelector = 'colorPaletteContainer') {
        if (type === 'text') {
            const textColorInput = $('#textColor, #buttonTextColor');
            textColorInput.val(colorValue);
            applyStyle('color', colorValue);
        } else if (type === 'background') {
            $('#backgroundColor').val(colorValue);
            applyStyle('background-color', colorValue);
        }
        $('#' + containerSelector).hide();
    }
    
    function selectFont(fontValue) {
        $('#fontFamily').val(fontValue);
        applyStyle('font-family', fontValue);
        $('#fontPaletteContainer').hide();
    }
    
    function applyStyle(property, value) {
        if (!currentElementSelector) {
            const selector = $('#elementValue').attr('data-selector');
            if (selector) {
                currentElementSelector = selector;
                currentElementType = $('#elementValue').attr('data-element-type');
            }
        }
        
        if (currentElementSelector) {
            const $element = $(currentElementSelector, '#previewPanel');
            if ($element.length > 0) {
                $element.css(property, value);
            }
        }
    }
    
    function saveElement() {
        const elementId = $('#elementValue').attr('data-element-id');
        const elementType = $('#elementValue').attr('data-element-type');
        const selector = $('#elementValue').attr('data-selector');
        const value = $('#elementValue').val();
        const extraData = $('#elementExtraData') ? $('#elementExtraData').val() : '';
        
        // 收集所有樣式變更
        const styles = {};
        $('[data-property]').each(function() {
            const prop = $(this).attr('data-property');
            const val = $(this).val();
            if (val) {
                styles[prop] = val;
            }
        });
        
        // TODO: 儲存元素修改
        console.log('儲存元素:', {
            elementId: elementId,
            elementType: elementType,
            selector: selector,
            value: value,
            extraData: extraData,
            styles: styles
        });
        
        alert('儲存功能待實作');
    }
    
    // 初始化
    $(document).ready(function() {
        const selector = $('#elementValue').attr('data-selector');
        if (selector) {
            currentElementSelector = selector;
            currentElementType = $('#elementValue').attr('data-element-type');
        }
    });
</script>
