@{
    Layout = null;
}
<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        position: relative;
    }

    .login-image-section {
        flex: 1;
        background-color: var(--color-black);
        position: relative;
        clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);
        overflow: hidden;
    }

    #particles-js {
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
    }

    .login-form-section {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background-color: var(--color-white);
        position: relative;
        clip-path: polygon(15% 0, 100% 0, 100% 100%, 0 100%);
    }

    .login-form {
        width: 100%;
        max-width: 400px;
    }

    .login-title {
        font-size: 2rem;
        font-weight: bold;
        color: var(--color-black);
        margin-bottom: 2rem;
        text-align: center;
    }

    .login-form-group {
        margin-bottom: 1.5rem;
    }

    .login-form-label {
        display: block;
        color: var(--color-black);
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .login-form-input {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--color-black);
        border-radius: 4px;
        background-color: var(--color-white);
        color: var(--color-black);
    }

    .login-form-input:focus {
        outline: none;
        border-color: var(--color-orange);
    }

    .login-btn {
        width: 100%;
        padding: 0.75rem;
        background-color: var(--color-orange);
        color: var(--color-white);
        border: none;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
    }

    .login-btn:hover {
        background-color: red; /* TODO: 需要 hover 橘色變數 */
        color: var(--color-white);
    }

    .alert {
        padding: 0.75rem;
        border-radius: 4px;
        color: var(--color-black);
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
    }

    .alert:empty {
        display: none;
    }
</style>

