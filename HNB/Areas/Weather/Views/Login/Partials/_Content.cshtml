@{
    Layout = null;
}

<div class="login-container">
    <div class="login-image-section" data-aos="fade-right" data-aos-duration="1000">
        <div id="particles-js"></div>
    </div>
    
    <div class="login-form-section">
        <div class="login-form">
            <h1 class="login-title">Login</h1>
            
            <form id="login-form">
                @Html.AntiForgeryToken()
                
                <div id="login-error-message" class="alert mb-3" role="alert" style="display: none;"></div>
                
                <div class="login-form-group">
                    <label class="login-form-label" for="email">Email\帳號</label>
                    <input type="text" id="email" name="email" class="login-form-input" placeholder="Enter your email or account" required />
                </div>
                
                <div class="login-form-group">
                    <label class="login-form-label" for="password">Password</label>
                    <input type="password" id="password" name="password" class="login-form-input" placeholder="Enter your password" required />
                </div>
                
                <button type="submit" class="login-btn" id="login-submit-btn">Login</button>
            </form>
        </div>
    </div>
</div>

