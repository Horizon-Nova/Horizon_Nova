@{
    Layout = null;
}
<style>
    .declaration-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .declaration-title {
        font-size: 2.5rem;
        font-weight: bold;
        color: var(--color-black);
        margin-bottom: 2rem;
        text-align: left;
    }

    .declaration-section-title {
        font-size: 1.5rem;
        font-weight: bold;
        color: var(--color-black);
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .declaration-content {
        color: var(--color-black);
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    .declaration-content a {
        color: var(--color-black);
        text-decoration: none;
    }

    .declaration-content a:hover {
        color: var(--color-black);
        text-decoration: underline;
    }

    .declaration-content strong {
        font-weight: bold;
    }

</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (window.lucide && typeof lucide.createIcons === 'function') {
        lucide.createIcons();
    }
});
</script>

