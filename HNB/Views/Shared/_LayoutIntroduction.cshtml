<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- jQuery -->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollToPlugin.min.js"></script>

    <!-- Three.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <!-- Vanta.js 模組 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanta/0.5.24/vanta.net.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanta/0.5.24/vanta.fog.min.js"></script>

    <!-- Particles.js -->
    <script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Caveat&family=Source+Code+Pro&display=swap" rel="stylesheet">

    <!-- 自訂樣式 -->
    <link rel="stylesheet" href="~/css/LayoutIntroduction.css" />
    <script src="~/js/LayoutIntroduction.js"></script>
</head>
<body>
    <!-- 導覽列 -->
    <nav class="navbar navbar-expand-lg navbar-light shadow ">
        <div class="container-fluid">
            <a class="navbar-brand px-5" href="@Url.Action("Team_introduction", "Overview")">
                <img src="/image/Horizon Nova Logo1.png" alt="Logo" style="height: 60px;" />
            </a>
            <div class="d-flex">
                <div class="dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-user-circle"></i> 使用者
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#">帳號設定</a></li>
                        <li><a class="dropdown-item" href="@Url.Action("HNBAccess", "GitHubAccess")">登入</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Team Header -->
    <section class="team-header d-flex flex-column justify-content-center align-items-center text-center py-5 min-vh-100 position-relative">
        <div id="team-particles-bg" class="position-absolute w-100 h-100 top-0 start-0"></div>

        <div class="container position-relative">
            <h1 class="mb-3">Horizon Nova 團隊</h1>
            <p class="mb-4">開發只是開始，未來由我們領航</p>
            <div class="team-logos d-flex justify-content-center align-items-center gap-3">
                <img src="/image/Team_introduction/Horizon Nova Logo.png" style="max-width: 30%;" class="img-fluid" />
                <img src="/image/MISSA_Logo3.png" alt="MISSA Logo" class="img-fluid bg-white p-2 rounded shadow" style="max-width: 20%;" />
            </div>
        </div>
    </section>

    <section class="white-section text-center">
        <div class="container min-vw-100 min-vh-100">
            @RenderBody()
        </div>
    </section>

    <!-- Footer 區塊 -->
    <footer class="py-4 text-white">
        <div>
            <div class="row align-items-center">
                <!-- 左側：聯絡方式 -->
                <div class="col-md-6 text-start">
                    <div class="d-flex align-items-center gap-4">
                        <div>
                            <i class="fas fa-envelope"></i>
                            <a href="mailto:hiaconde@gmail.com" class="text-white text-decoration-underline">
                                hiaconde@gmail.com
                            </a>
                        </div>
                        <div>
                            <i class="fab fa-line"></i>
                            a0920220334
                        </div>
                    </div>
                </div>

                <!-- 右側：版權聲明 -->
                <div class="col-md-6 text-end">
                    <small>© 2025 Horizon Nova. All rights reserved. | Horizon Nova 團隊</small>
                </div>
            </div>
        </div>
    </footer>

    @RenderSection("js_section", required: false)
</body>
</html>