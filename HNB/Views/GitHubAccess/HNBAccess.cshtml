@{
    ViewBag.Title = "GitHub 組織登入";
    Layout = "~/Views/Shared/_LayoutHNBAccess.cshtml";
}
@section js_section {

}

<div class="container min-vh-100 d-flex align-items-center justify-content-center">
    <div class="row w-100">
        <div class="col-12 col-md-6 col-lg-4 mx-auto">
            <div class="card shadow-lg rounded-4 p-4 bg-white border-0">
                <h2 class="mb-4 fw-bold text-dark">
                    <i class="fab fa-github fa-lg me-2"></i>
                    Horizon Nova 組織登入
                </h2>
                <div class="mb-3 text-secondary small">
                    請使用 GitHub 帳號登入以驗證組織成員身份
                </div>
                <a href="@Url.Action("RedirectGitHub", "GitHubAccess")"
                   class="btn btn-dark w-100 py-2 fs-5">
                    <i class="fab fa-github"></i> 使用 GitHub 登入
                </a>
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }


                <div class="mt-3 text-center small">
                    <span class="text-info-emphasis">僅組織成員可進入系統</span>
                </div>
            </div>
        </div>
    </div>
</div>
