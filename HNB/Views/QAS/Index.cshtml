@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<div class="container mt-4">
    <h3>圖片裁切工具</h3>
    <input type="file" class="form-control mb-3" id="upload" accept="image/*">

    <div class="row flex-column flex-md-row">
        <div class="col-md-6 mb-3">
            <div class="border mb-2">
                <img id="image" src="/image/Horizon Nova Logo1.png" class="img-fluid">
            </div>
            <div class="mb-2">
                <button id="confirm" class="btn btn-primary btn-sm">確認裁切</button>
                <button id="cancel" class="btn btn-secondary btn-sm">取消</button>
            </div>
        </div>

        <div class="col-md-6">
            <h5>
                <span style="font-size: 1.2rem;">▼</span> 裁切結果
            </h5>


            <img id="result" class="img-fluid border">
        </div>
    </div>
</div>

<script>
    let cropper;
    const upload = document.getElementById('upload');
    const image = document.getElementById('image');
    const result = document.getElementById('result');
    const confirmBtn = document.getElementById('confirm');
    const cancelBtn = document.getElementById('cancel');

    // 預設初始化 cropper
    window.addEventListener('load', () => {
        cropper = new Cropper(image, {
            aspectRatio: NaN,
            viewMode: 1
        });
    });

    // 上傳新圖片
    upload.addEventListener('change', e => {
        const file = e.target.files[0];
        if (!file) return;
        const url = URL.createObjectURL(file);
        image.src = url;

        if (cropper) cropper.destroy();

        image.onload = () => {
            cropper = new Cropper(image, {
                aspectRatio: NaN,
                viewMode: 1
            });
        };
    });

    confirmBtn.addEventListener('click', () => {
        if (!cropper) return;
        const canvas = cropper.getCroppedCanvas();
        result.src = canvas.toDataURL('image/png');
    });

    cancelBtn.addEventListener('click', () => {
        if (cropper) {
            cropper.destroy();
            cropper = null;
        }
        image.src = '/image/Horizon Nova Logo1.png';
        result.src = '';
        upload.value = '';

        image.onload = () => {
            cropper = new Cropper(image, {
                aspectRatio: NaN,
                viewMode: 1
            });
        };
    });
</script>
