@{
    Layout = "~/Views/Shared/_LayoutQAS.cshtml";
}

<h3>Grounding DINO – Prompt 測試</h3>

<div class="mb-3">
    <input type="text" id="promptInput" class="form-control" placeholder="Enter prompt..." />
</div>

<div class="mb-3">
    <input type="file" id="imageInput" class="form-control" accept="image/*" />
</div>

<button id="sendPrompt" class="btn btn-primary">送出</button>

<hr />

<div id="result" class="mt-4"></div>

<script>
    $('#sendPrompt').click(function () {
        const prompt = $('#promptInput').val();
        const fileInput = $('#imageInput')[0];

        if (!fileInput.files.length) {
            alert("請選擇圖片！");
            return;
        }
        if (!prompt) {
            alert("請輸入 prompt！");
            return;
        }

        const formData = new FormData();
        formData.append("prompt", prompt);
        formData.append("image", fileInput.files[0]);

        $.ajax({
            url: '@Url.Action("Detect", "QAS")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                const now = new Date().toLocaleString();

                // 包裝為 JSON 字串
                const debugJson = JSON.stringify(res, null, 2);

                let html = `<h5>推論結果 (${now})</h5>`;
                html += `<pre>${debugJson}</pre>`;

                $('#result').html(html);
            },
            error: function (err) {
                const now = new Date().toLocaleString();
                console.error(err);

                const errText = JSON.stringify(err.responseJSON || { error: "無法取得錯誤內容" }, null, 2);
                let html = `<h5 class="text-danger">伺服器錯誤 (${now})</h5>`;
                html += `<pre class="text-danger">${errText}</pre>`;

                $('#result').html(html);
            }
        });
    });

</script>

