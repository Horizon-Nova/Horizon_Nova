@{
    Layout = "~/Views/Shared/_FormGray.cshtml";
}

@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
@section header{
    <link href="@Url.Content("~/lib/summernote/0.8.15/summernote.min.css")" rel="stylesheet" type="text/css">
    <script src='@Url.Content("~/lib/summernote/0.8.15/summernote.js")' type="text/javascript"></script>
    <script src='@Url.Content("~/lib/summernote/0.8.15/lang/summernote-zh-CN.min.js")' type="text/javascript"></script>
}

<div class="wrapper wrapper-content">
    <div class="row">
        <div class="col-sm-12">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <h2>Summernote</h2>
                    <p>
                        <a href="https://github.com/summernote/summernote" target="_blank">Summernote</a> 是一個簡單的基於Bootstrap的WYSIWYG富文本編輯器
                    </p>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-sm-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Summernote 富文本編輯器</h5>
                </div>
                <div class="ibox-content no-padding">
                    <div class="summernote">
                        <h2>一Horizon Nova後台</h2>
                        <p>
                            NovaAdmin 是一個開源的後台管理系统快速開發框架，基於.NET Core Web技術（ASP.NET Core Web，ASP.NET Core Web Api），主要目的讓開發者專注業務，
                            降低技術難度，從而節省人力成本，縮短項目周期，提高軟體安全質量。
                        </p>
                        <p>
                            <span class="label label-warning">免費開源</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-sm-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>編輯/保存為html代碼範例</h5>
                    <button id="edit" class="btn btn-primary btn-xs m-l-sm" onclick="edit()" type="button">編輯</button>
                    <button id="save" class="btn btn-primary  btn-xs" onclick="save()" type="button">保存</button>
                </div>
                <div class="ibox-content" id="eg">

                    <div class="click2edit wrapper">
                        <h3>你好，一沙 </h3>
                        <p>
                            YiShaAdmin 是一個開源的後台管理系统快速開發框架，基於.NET Core Web技術（ASP.NET Core Web，ASP.NET Core Web Api），主要目的讓開發者專注業務，
                            降低技術難度，從而節省人力成本，縮短項目周期，提高軟體安全質量。
                        </p>
                        <p>
                            <span class="label label-warning">開源免費</span>
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('.summernote').summernote({
            lang: 'zh-CN'
        });
    });

    var edit = function () {
        $("#eg").addClass("no-padding");
        $('.click2edit').summernote({
            lang: 'zh-CN',
            focus: true
        });
    };

    var save = function () {
        $("#eg").removeClass("no-padding");
        var html = $('.click2edit').summernote('code');
        $('.click2edit').summernote('destroy');
    };
</script>