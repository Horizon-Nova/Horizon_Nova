@model ManagementSystem.Areas.Backoffice.Dtos.FileListVm
@using System.Text.Json

@{
    var listUrl = Url.Action("FileManager", "Backoffice", new { area = "Backoffice" });
    var dlUrl = Url.Action("Download", "Backoffice", new { area = "Backoffice" });
    var zipUrl = Url.Action("DownloadFolderZip", "Backoffice", new { area = "Backoffice" });

    string FmtSize(long? s) => s is null ? "" :
        s < 1024 ? $"{s} B" :
        s < 1_048_576 ? $"{s / 1024.0:0.##} KB" :
        s < 1_073_741_824 ? $"{s / 1_048_576.0:0.##} MB" : $"{s / 1_073_741_824.0:0.##} GB";
    string FmtTs(DateTime? u) => u?.ToLocalTime().ToString("yyyy/MM/dd HH:mm") ?? "";

    var path = string.IsNullOrWhiteSpace(Model.Path) ? "/" : Model.Path;
    if (!path.StartsWith("/")) path = "/" + path;

    var parts = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var crumbs = new List<(string name, string vpath)>();
    crumbs.Add(("/", "/"));
    var acc = "";
    foreach (var p in parts)
    {
        acc = string.IsNullOrEmpty(acc) || acc == "/" ? "/" + p : acc + "/" + p;
        crumbs.Add((p, acc));
    }
}

<!-- 麵包屑 -->
<div class="flex items-center justify-between mb-2">
    <div class="text-sm text-slate-600 flex items-center gap-1 flex-wrap">
        位置：
        <nav id="breadcrumb" class="flex items-center gap-1 flex-wrap">
            @for (int i = 0; i < crumbs.Count; i++)
            {
                var c = crumbs[i];
                if (i < crumbs.Count - 1)
                {
                    <a class="text-blue-600 hover:underline" href="@($"{listUrl}?path={Uri.EscapeDataString(c.vpath)}")">@c.name</a>
                    <span class="text-slate-400">/</span>
                }
                else
                {
                    <span class="text-slate-700">@c.name</span>
                }
            }
        </nav>
    </div>
</div>

<!-- 檔案清單 -->
<div class="overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="border-b text-left text-gray-600">
            <tr>
                <th class="py-2">名稱</th>
                <th class="py-2">大小</th>
                <th class="py-2">修改時間</th>
                <th class="py-2 text-right">操作</th>
            </tr>
        </thead>
        <tbody id="fileTableBody">
            @foreach (var it in Model.Items)
            {
                if (it.Kind == ManagementSystem.Areas.Backoffice.Dtos.EntryKind.Folder)
                {
                    var next = path == "/" ? "/" + it.Name : path + "/" + it.Name;
                    <tr class="border-b hover:bg-slate-50" data-type="folder" data-name="@it.Name">
                        <td class="py-2">
                            <a class="flex items-center gap-2 hover:underline" href="@listUrl?path=@(Uri.EscapeDataString(next))">
                                <i data-lucide="folder" class="w-4 h-4 text-amber-500"></i>
                                <span class="item-name">@it.Name</span>
                            </a>
                        </td>
                        <td class="py-2 text-slate-400">—</td>
                        <td class="py-2">@FmtTs(it.LastWriteUtc)</td>
                        <td class="py-2 text-right space-x-2">
                            <form method="post" action="@zipUrl" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="path" value="@path" />
                                <input type="hidden" name="name" value="@it.Name" />
                                <button type="submit"
                                        class="inline-flex items-center gap-1 px-2 py-1 bg-emerald-100 text-emerald-700 rounded-md hover:bg-emerald-200 text-xs">
                                    下載 ZIP
                                </button>
                            </form>
                            <button class="px-2 py-1 bg-slate-100 text-slate-700 rounded-md text-xs"
                                    onclick='return fmAskRename(@Html.Raw(JsonSerializer.Serialize(it.Name)),"folder");'>
                                重新命名
                            </button>
                            <button class="px-2 py-1 bg-red-100 text-red-700 rounded-md text-xs"
                                    onclick='return fmAskDelete(@Html.Raw(JsonSerializer.Serialize(it.Name)), "folder");'>
                                刪除
                            </button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr class="border-b hover:bg-slate-50" data-type="file" data-name="@it.Name">
                        <td class="py-2 flex items-center gap-2">
                            <i data-lucide="file" class="w-4 h-4 text-slate-500"></i>
                            <span class="item-name">@it.Name</span>
                        </td>
                        <td class="py-2">@FmtSize(it.Size)</td>
                        <td class="py-2">@FmtTs(it.LastWriteUtc)</td>
                        <td class="py-2 text-right space-x-2">
                            <button class="px-2 py-1 bg-purple-100 text-purple-700 rounded-md text-xs"
                                    onclick='return fmPreview(@Html.Raw(JsonSerializer.Serialize(it.Name)));'>
                                預覽
                            </button>

                            <button class="px-2 py-1 bg-amber-100 text-amber-700 rounded-md text-xs"
                                    onclick='return fmEdit(@Html.Raw(JsonSerializer.Serialize(it.Name)));'>
                                編輯
                            </button>
                            <form method="post" action="@dlUrl" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="path" value="@path" />
                                <input type="hidden" name="name" value="@it.Name" />
                                <button type="submit"
                                        class="inline-flex items-center gap-1 px-2 py-1 bg-blue-100 text-blue-700 rounded-md hover:bg-blue-200 text-xs">
                                    下載
                                </button>
                            </form>
                            <button class="px-2 py-1 bg-slate-100 text-slate-700 rounded-md text-xs"
                                    onclick='return fmAskRename(@Html.Raw(JsonSerializer.Serialize(it.Name)),"file");'>
                                重新命名
                            </button>
                            <button class="px-2 py-1 bg-red-100 text-red-700 rounded-md text-xs"
                                    onclick='return fmAskDelete(@Html.Raw(JsonSerializer.Serialize(it.Name)), "file");'>
                                刪除
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- 刪除確認 Modal -->
<div class="modal fade" id="delModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ghdel">
            <div class="modal-header border-0 px-4 pt-4 border-bottom">
                <h2 class="modal-title fw-semibold ">
                    Delete <span id="delTitleShort"></span>
                </h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body px-4 border-bottom">
                <div class="flex items-center justify-center mb-3 ">
                    <i data-lucide="lock-keyhole" class="w-10 h-10 text-secondary opacity-75"></i>
                </div>
                <div class="text-center mb-1 fs-4 fw-bold " id="delDisplayName"></div>

            </div>

            <!-- Modal Footer -->
            <div class="modal-footer flex-column align-items-stretch border-0 px-4 pb-4 w-100">
                <div class="text-muted small mb-2 text-start">
                    To confirm, type <span class="text-body fw-semibold">"<span id="delConfirmLabel"></span>"</span> in the box below
                </div>
                <input id="delConfirmInput" type="text"
                       class="form-control is-invalid mb-3"
                       placeholder="請輸入完全相同的名稱"
                       autocomplete="off" oninput="fmDelOnInput();">
                <input id="delHiddenName" type="hidden">
                <input id="delHiddenType" type="hidden">
                <div class="grid grid-cols-2 gap-2 w-100">
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">取消</button>
                    <button type="button" id="btnDelConfirm" class="btn btn-danger w-100" disabled
                            onclick="return fmDoDelete();">
                        刪除
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- 重新命名 Modal -->
<div class="modal fade" id="renModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ghdel">
            <div class="modal-header border-bottom px-4 pt-4">
                <h5 class="modal-title fw-semibold">重新命名 <span id="renTitleShort"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body px-4">
                <div class="flex items-center justify-center mb-3">
                    <i data-lucide="edit-3" class="w-10 h-10 text-secondary opacity-75"></i>
                </div>
                <div class="text-muted small mb-2 text-start">
                    請輸入新名稱（不允許 \\ / : * ? " &lt; &gt; |）
                </div>
                <input id="renInput" type="text" class="form-control mb-3" autocomplete="off" oninput="fmRenOnInput();">
                <input id="renHiddenOld" type="hidden">
                <input id="renHiddenType" type="hidden">
            </div>
            <div class="modal-footer border-0 px-4 pb-4 w-100">
                <div class="grid grid-cols-2 gap-2 w-100">
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">取消</button>
                    <button type="button" id="btnRenConfirm" class="btn btn-primary w-100" disabled
                            onclick="return fmDoRename();">
                        確定
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const CURRENT_PATH = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(path));
    const URL_DEL_FILE = '@Url.Action("DeleteFile", "Backoffice", new { area = "Backoffice" })';
    const URL_DEL_DIR  = '@Url.Action("DeleteFolder", "Backoffice", new { area = "Backoffice" })';
    const URL_REN_FILE = '@Url.Action("RenameFile", "Backoffice", new { area = "Backoffice" })';
    const URL_REN_DIR  = '@Url.Action("RenameFolder", "Backoffice", new { area = "Backoffice" })';
    function fmInvalidName(s){ return /[\\/:*?"<>|]/.test(s); }

    function fmGetToken() {
        const el = document.querySelector('#fmTokens input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    function fmAskDelete(name, type){
      document.getElementById('delHiddenName').value = name;
      document.getElementById('delHiddenType').value = type; // 'file' | 'folder'
      document.getElementById('delTitleShort').textContent = name;
      document.getElementById('delDisplayName').textContent = name;
      document.getElementById('delConfirmLabel').textContent = name;
      document.getElementById('delConfirmInput').value = '';
      document.getElementById('delConfirmInput').classList.add('is-invalid');
      document.getElementById('btnDelConfirm').disabled = true;
      new bootstrap.Modal(document.getElementById('delModal')).show();
      return false;
    }

    function fmDelOnInput(){
      const expected = document.getElementById('delHiddenName').value || '';
      const val = (document.getElementById('delConfirmInput').value || '').trim();
      const ok = (val === expected);
      document.getElementById('btnDelConfirm').disabled = !ok;
      document.getElementById('delConfirmInput').classList.toggle('is-invalid', !ok);
    }

    function fmDoDelete(){
      const name = document.getElementById('delHiddenName').value || '';
      const type = document.getElementById('delHiddenType').value || 'file';
      const url  = (type === 'folder') ? URL_DEL_DIR : URL_DEL_FILE;

      $.ajax({
        type:'POST', url:url,
        data:{ path: CURRENT_PATH, name: name },
        headers:{ 'RequestVerificationToken': fmGetToken() },
        success:function(res){
          if(res?.ok){
            bootstrap.Modal.getInstance(document.getElementById('delModal')).hide();
            loadList(); if(type==='folder'){ loadTree(CURRENT_PATH); }
          }else{ alert(res?.message || '刪除失敗'); }
        },
        error:function(xhr){ alert('刪除失敗：' + xhr.status); }
      });
      return false;
    }

    function fmAskRename(oldName, type){
      document.getElementById('renHiddenOld').value = oldName;
      document.getElementById('renHiddenType').value = type; // 'file' | 'folder'
      document.getElementById('renTitleShort').textContent = oldName;
      const ipt = document.getElementById('renInput');
      ipt.value = oldName;
      document.getElementById('btnRenConfirm').disabled = true;
      const m = new bootstrap.Modal(document.getElementById('renModal')); m.show();
      setTimeout(()=> ipt.select(), 100);
      return false;
    }

    function fmRenOnInput(){
      const oldName = document.getElementById('renHiddenOld').value || '';
      const val = (document.getElementById('renInput').value || '').trim();
      const ok = !!val && !fmInvalidName(val) && val !== oldName;
      document.getElementById('btnRenConfirm').disabled = !ok;
    }

    function fmDoRename(){
      const oldName = document.getElementById('renHiddenOld').value || '';
      const type = document.getElementById('renHiddenType').value || 'file';
      const newName = (document.getElementById('renInput').value || '').trim();
      if (!newName || fmInvalidName(newName)){ alert('名稱不合法'); return false; }
      const url = (type === 'folder') ? URL_REN_DIR : URL_REN_FILE;

      $.ajax({
        type:'POST', url:url,
        data:{ path: CURRENT_PATH, oldName: oldName, newName: newName },
        headers:{ 'RequestVerificationToken': fmGetToken() },
        success:function(res){
          if (res?.ok){
            bootstrap.Modal.getInstance(document.getElementById('renModal')).hide();
            loadList(); if (type === 'folder') loadTree(CURRENT_PATH);
          } else { alert(res?.message || '重新命名失敗'); }
        },
        error:function(xhr){ alert('重新命名失敗：' + xhr.status); }
      });
      return false;
    }


</script>
