@{
    var title = ViewData["Title"] as string ?? "";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - HNB.IIS 管理系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0a0a0a;
            background-image: 
                linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
            background-size: 50px 50px;
        }
        .cyber-border {
            position: relative;
            box-shadow: 0 0 20px rgba(255,255,255,0.05);
        }
        .cyber-border::after {
            content: '';
            position: absolute;
            top: -1px;
            left: -1px;
            right: -1px;
            bottom: -1px;
            background: linear-gradient(45deg, rgba(255,255,255,0.1), transparent);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .cyber-border:hover::after {
            opacity: 1;
        }
        .status-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .3; }
        }
        /* 網路掃描線效果 */
        .scan-line {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
            animation: scan 4s linear infinite;
            z-index: -10;
            pointer-events: none;
        }
        @@keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(100vh); }
        }
    </style>
</head>
<body>
    <!-- 網路掃描線效果 -->
    <div class="scan-line"></div>
    
    <div class="flex h-screen overflow-hidden">
        <!-- 側邊欄 - 精簡設計 -->
        <aside class="w-56 bg-black border-r border-white border-opacity-5 flex-shrink-0 flex flex-col">
            <!-- Logo -->
            <div class="p-5 border-b border-white border-opacity-5">
                <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 border border-white border-opacity-40 flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-base font-bold text-white tracking-widest">HNB.IIS</h1>
                        <p class="text-[10px] text-gray-600 tracking-widest">CORE</p>
                    </div>
                </div>
            </div>

            <!-- 導航 -->
            <nav class="flex-1 p-3 space-y-0.5">
                <a href="/SiteManagement" class="flex items-center gap-2.5 px-3 py-2.5 border-l-2 border-white text-white bg-white bg-opacity-5 transition group">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <span class="text-xs tracking-wide">站台管理</span>
                </a>
                
                <a href="#" class="flex items-center gap-2.5 px-3 py-2.5 border-l-2 border-transparent text-gray-500 hover:text-white hover:border-white hover:border-opacity-30 transition group">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span class="text-xs tracking-wide">安全管理</span>
                </a>

                <a href="#" class="flex items-center gap-2.5 px-3 py-2.5 border-l-2 border-transparent text-gray-500 hover:text-white hover:border-white hover:border-opacity-30 transition group">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <span class="text-xs tracking-wide">日誌記錄</span>
                </a>
            </nav>

            <!-- 用戶區 - 底部 -->
            <div class="p-3 border-t border-white border-opacity-5">
                <div class="flex items-center justify-between px-3 py-2.5 hover:bg-white hover:bg-opacity-5 transition">
                    <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 border border-white border-opacity-40 flex items-center justify-center">
                            <span class="text-xs font-bold text-white">@(User.Identity?.Name?.Substring(0, 1) ?? "U")</span>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-white">@User.Identity?.Name</p>
                            <p class="text-[10px] text-gray-600 tracking-wider">ADMIN</p>
                        </div>
                    </div>
                    <form method="post" action="/Account/Logout" class="inline">
                        <button type="submit" class="p-1.5 hover:bg-white hover:bg-opacity-10 transition" title="登出">
                            <svg class="w-3.5 h-3.5 text-gray-500 hover:text-white transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- 主內容區 -->
        <div class="flex-1 flex flex-col overflow-hidden bg-black">
            <!-- 頂部標題區 - 簡化 -->
            <header class="border-b border-white border-opacity-5 px-8 py-5">
                <div class="flex items-center justify-between">
                    <div class="flex items-baseline gap-4">
                        <h2 class="text-xl font-bold text-white tracking-wide">@ViewData["Title"]</h2>
                        <div class="flex items-center gap-2 text-green-500">
                            <div class="w-1.5 h-1.5 bg-green-500 rounded-full status-pulse"></div>
                            <span class="text-xs tracking-wider">ONLINE</span>
                        </div>
                    </div>
                    <div class="text-xs text-gray-600 font-mono">
                        @DateTime.Now.ToString("yyyy.MM.dd HH:mm:ss")
                    </div>
                </div>
            </header>

            <!-- 內容區域 -->
            <main class="flex-1 overflow-y-auto px-8 py-6">
                @RenderBody()
            </main>
        </div>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>