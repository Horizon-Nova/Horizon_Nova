@{
    var title = ViewData["Title"] as string ?? "";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - HNB.IIS 管理系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        body {
            background-color: #0a0a0a;
            background-image: 
                linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
            background-size: 50px 50px;
        }
        .cyber-border {
            position: relative;
            box-shadow: 0 0 20px rgba(255,255,255,0.05);
        }
        .cyber-border::after {
            content: '';
            position: absolute;
            top: -1px;
            left: -1px;
            right: -1px;
            bottom: -1px;
            background: linear-gradient(45deg, rgba(255,255,255,0.1), transparent);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .cyber-border:hover::after {
            opacity: 1;
        }
        .status-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .3; }
        }
        /* 網路掃描線效果 */
        .scan-line {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
            animation: scan 4s linear infinite;
            z-index: -10;
            pointer-events: none;
        }
        @@keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(100vh); }
        }
    </style>
</head>
<body>
    <!-- 網路掃描線效果 -->
    <div class="scan-line"></div>
    
    <!-- 引入可折疊側邊欄 -->
    @await Html.PartialAsync("Partials/_Sidebar")
    
    <!-- 主內容區 -->
    <div class="flex flex-col h-screen overflow-hidden w-full">
        <!-- 頂部標題區 - 簡化 -->
        <header class="border-b border-white border-opacity-5 px-8 py-5 bg-black">
            <div class="flex items-center justify-between">
                <div class="flex items-baseline gap-4">
                    <h2 class="text-xl font-bold text-white tracking-wide">@ViewData["Title"]</h2>
                    <div class="flex items-center gap-2 text-green-500">
                        <div class="w-1.5 h-1.5 bg-green-500 rounded-full status-pulse"></div>
                        <span class="text-xs tracking-wider">ONLINE</span>
                    </div>
                </div>
                <div class="text-xs text-gray-600 font-mono">
                    @DateTime.Now.ToString("yyyy.MM.dd HH:mm:ss")
                </div>
            </div>
        </header>

        <!-- 內容區域 -->
        <main class="flex-1 overflow-y-auto px-8 py-6 bg-black">
            @Html.AntiForgeryToken()
            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>