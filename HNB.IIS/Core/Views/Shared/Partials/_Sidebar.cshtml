@* 可折疊側邊欄 - 滑鼠停留左側2秒自動展開 *@
<!-- 側邊欄面板 -->
<aside id="sidebar" class="fixed left-0 top-0 h-full w-56 bg-black border-r border-white border-opacity-5 z-40 -translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
    <!-- Logo -->
    <div class="p-5 border-b border-white border-opacity-5">
        <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 border border-white border-opacity-40 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                </svg>
            </div>
            <div>
                <h1 class="text-base font-bold text-white tracking-widest">HNB.IIS</h1>
                <p class="text-[10px] text-gray-600 tracking-widest">CORE</p>
            </div>
        </div>
    </div>

    <!-- 導航 -->
    <nav class="flex-1 p-3 space-y-0.5">
        <a href="/SiteManagement" class="flex items-center gap-2.5 px-3 py-2.5 border-l-2 border-white text-white bg-white bg-opacity-5 transition group">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <span class="text-xs tracking-wide">站台管理</span>
        </a>
        
        <a href="#" class="flex items-center gap-2.5 px-3 py-2.5 border-l-2 border-transparent text-gray-500 hover:text-white hover:border-white hover:border-opacity-30 transition group">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span class="text-xs tracking-wide">安全管理</span>
        </a>

        <a href="#" class="flex items-center gap-2.5 px-3 py-2.5 border-l-2 border-transparent text-gray-500 hover:text-white hover:border-white hover:border-opacity-30 transition group">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="text-xs tracking-wide">日誌記錄</span>
        </a>
    </nav>

    <!-- 用戶區 - 底部 -->
    <div class="p-3 border-t border-white border-opacity-5">
        <div class="flex items-center justify-between px-3 py-2.5 hover:bg-white hover:bg-opacity-5 transition">
            <div class="flex items-center gap-2.5">
                <div class="w-7 h-7 border border-white border-opacity-40 flex items-center justify-center">
                    <span class="text-xs font-bold text-white">@(User.Identity?.Name?.Substring(0, 1) ?? "U")</span>
                </div>
                <div>
                    <p class="text-xs font-semibold text-white">@User.Identity?.Name</p>
                    <p class="text-[10px] text-gray-600 tracking-wider">ADMIN</p>
                </div>
            </div>
            <form method="post" action="/Account/Logout" class="inline">
                <button type="submit" class="p-1.5 hover:bg-white hover:bg-opacity-10 transition" title="登出">
                    <svg class="w-3.5 h-3.5 text-gray-500 hover:text-white transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</aside>

<!-- 遮罩層（側欄開啟時顯示） -->
<div id="sidebarOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden pointer-events-none"></div>

<script>
    $(function() {
        const $sidebar = $('#sidebar');
        const $overlay = $('#sidebarOverlay');
        let autoOpenTimer = null;
        const HOVER_ZONE_WIDTH = 50; // 左側感應區域寬度（px）
        const AUTO_OPEN_DELAY = 1000; // 自動展開延遲時間（毫秒）
        
        function openSidebar() {
            $sidebar.removeClass('-translate-x-full');
            $overlay.removeClass('hidden pointer-events-none');
        }
        
        function closeSidebar() {
            $sidebar.addClass('-translate-x-full');
            $overlay.addClass('hidden pointer-events-none');
        }
        
        // 清除所有計時器
        function clearAllTimers() {
            if (autoOpenTimer) {
                clearTimeout(autoOpenTimer);
                autoOpenTimer = null;
            }
        }
        
        // 滑鼠移動檢測
        $(document).on('mousemove', function(e) {
            // 清除舊計時器
            clearAllTimers();
            
            // 如果滑鼠在左側感應區域
            if (e.pageX <= HOVER_ZONE_WIDTH && $sidebar.hasClass('-translate-x-full')) {
                // 開始計時，2秒後自動展開
                autoOpenTimer = setTimeout(function() {
                    openSidebar();
                }, AUTO_OPEN_DELAY);
            }
        });
        
        // 滑鼠離開頁面時關閉側欄
        $(document).on('mouseleave', function() {
            closeSidebar();
        });
        
        // 遮罩層點擊關閉
        $overlay.on('click', closeSidebar);
    });
</script>
