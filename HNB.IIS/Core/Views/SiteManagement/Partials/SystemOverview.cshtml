@* 系統總覽區塊 *@
@{
    var sites = (List<SiteInfo>)ViewBag.Sites;
    var totalSites = sites.Count;
    var activeSites = sites.Count(s => s.Status == "運行中");
    var stoppedSites = sites.Count(s => s.Status == "已停止");
    var totalStorageMB = (sites.Sum(s => s.FileSize) / 1024.0 / 1024.0);
    var activePercentage = totalSites > 0 ? (activeSites * 100.0 / totalSites) : 0;
}

<div class="mb-6">
    <div class="flex items-center gap-4 mb-4">
        <h2 class="text-lg font-bold text-white tracking-wide font-mono">系統總覽</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white via-white to-transparent opacity-10"></div>
        <span class="text-xs text-gray-500 font-mono">@DateTime.Now.ToString("HH:mm:ss")</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <!-- 左側：關鍵指標清單 -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <h3 class="text-xs text-gray-500 font-mono tracking-wider mb-4">系統統計</h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-between py-2 border-b border-white border-opacity-5">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-white opacity-40"></div>
                            <span class="text-xs text-gray-500 font-mono tracking-wider">TOTAL</span>
                        </div>
                        <span class="text-lg font-bold text-white font-mono">@totalSites</span>
                    </div>

                    <div class="flex items-center justify-between py-2 border-b border-white border-opacity-5">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-green-500 rounded-full status-pulse"></div>
                            <span class="text-xs text-gray-500 font-mono tracking-wider">ACTIVE</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-16 h-1.5 bg-white bg-opacity-10 rounded-full overflow-hidden">
                                <div class="h-full bg-green-500" style="width: @($"{activePercentage:F0}")%"></div>
                            </div>
                            <span class="text-lg font-bold text-green-400 font-mono w-8 text-right">@activeSites</span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between py-2 border-b border-white border-opacity-5">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-gray-500"></div>
                            <span class="text-xs text-gray-500 font-mono tracking-wider">STOPPED</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-16 h-1.5 bg-white bg-opacity-10 rounded-full overflow-hidden">
                                <div class="h-full bg-gray-500" style="width: @($"{(totalSites > 0 ? (stoppedSites * 100.0 / totalSites) : 0):F0}")%"></div>
                            </div>
                            <span class="text-lg font-bold text-gray-400 font-mono w-8 text-right">@stoppedSites</span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between py-2">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-blue-500 opacity-60"></div>
                            <span class="text-xs text-gray-500 font-mono tracking-wider">STORAGE</span>
                        </div>
                        <div class="text-right">
                            <span class="text-lg font-bold text-white font-mono">@($"{totalStorageMB:F1}")<span class="text-xs text-gray-500 ml-1">MB</span></span>
                            <p class="text-xs text-gray-600 font-mono">@($"{totalStorageMB / 1024.0:F2} GB")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 中間：狀態分佈圖 -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <h3 class="text-xs text-gray-500 font-mono tracking-wider mb-4">狀態分佈</h3>
                <div class="relative" style="height: 200px;">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>

        <!-- 右側：資源統計 -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <h3 class="text-xs text-gray-500 font-mono tracking-wider mb-4">資源使用</h3>
                <div class="space-y-4">
                    <!-- CPU -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs text-gray-500 font-mono tracking-wider">CPU</span>
                            <span class="text-sm font-bold text-orange-400 font-mono">N/A</span>
                        </div>
                        <div class="relative h-2 bg-white bg-opacity-10 rounded-full overflow-hidden">
                            <div class="absolute inset-0 bg-orange-500 bg-opacity-20" style="width: 0%"></div>
                        </div>
                    </div>
                    
                    <!-- Memory -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs text-gray-500 font-mono tracking-wider">MEMORY</span>
                            <span class="text-sm font-bold text-blue-400 font-mono">N/A</span>
                        </div>
                        <div class="relative h-2 bg-white bg-opacity-10 rounded-full overflow-hidden">
                            <div class="absolute inset-0 bg-blue-500 bg-opacity-20" style="width: 0%"></div>
                        </div>
                    </div>
                    
                    <!-- Network -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs text-gray-500 font-mono tracking-wider">NETWORK</span>
                            <span class="text-sm font-bold text-green-400 font-mono">N/A</span>
                        </div>
                        <div class="relative h-2 bg-white bg-opacity-10 rounded-full overflow-hidden">
                            <div class="absolute inset-0 bg-green-500 bg-opacity-20" style="width: 0%"></div>
                        </div>
                    </div>
                    
                    <!-- Disk -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs text-gray-500 font-mono tracking-wider">DISK I/O</span>
                            <span class="text-sm font-bold text-purple-400 font-mono">N/A</span>
                        </div>
                        <div class="relative h-2 bg-white bg-opacity-10 rounded-full overflow-hidden">
                            <div class="absolute inset-0 bg-purple-500 bg-opacity-20" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
