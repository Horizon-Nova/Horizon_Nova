@* 資源監控圖表區塊 *@
<div class="mb-6">
    <div class="flex items-center gap-4 mb-4">
        <h2 class="text-lg font-bold text-white tracking-wide font-mono">資源監控</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white via-white to-transparent opacity-10"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- CPU 使用率 -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <span class="text-xs text-gray-500 font-mono tracking-wider">CPU USAGE</span>
                    </div>
                    <span class="text-lg font-bold text-orange-400 font-mono" id="cpuUsage">N/A</span>
                </div>
                <div class="relative h-32">
                    <canvas id="cpuChart"></canvas>
                </div>
            </div>
        </div>

        <!-- 記憶體使用率 -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                        </svg>
                        <span class="text-xs text-gray-500 font-mono tracking-wider">MEMORY</span>
                    </div>
                    <span class="text-lg font-bold text-blue-400 font-mono" id="memUsage">N/A</span>
                </div>
                <div class="relative h-32">
                    <canvas id="memoryChart"></canvas>
                </div>
            </div>
        </div>

        <!-- 網路流量 -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                        <span class="text-xs text-gray-500 font-mono tracking-wider">NETWORK</span>
                    </div>
                    <span class="text-lg font-bold text-green-400 font-mono" id="netUsage">N/A</span>
                </div>
                <div class="relative h-32">
                    <canvas id="networkChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Disk I/O -->
        <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
            <div class="p-4">
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                        <span class="text-xs text-gray-500 font-mono tracking-wider">DISK I/O</span>
                    </div>
                    <span class="text-lg font-bold text-purple-400 font-mono" id="diskUsage">N/A</span>
                </div>
                <div class="relative h-32">
                    <canvas id="diskChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

