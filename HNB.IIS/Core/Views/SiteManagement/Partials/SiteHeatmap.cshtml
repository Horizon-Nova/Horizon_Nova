@* 站台流量熱力圖區塊 *@
@{
    var sites = (List<SiteInfo>)ViewBag.Sites;
    var activeSites = sites.Where(s => s.Status == "運行中").ToList();
}

<div class="mb-6">
    <div class="flex items-center gap-4 mb-4">
        <h2 class="text-lg font-bold text-white tracking-wide font-mono">站台流量熱力圖</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white via-white to-transparent opacity-10"></div>
    </div>
    
    <div class="border border-white border-opacity-10 bg-black bg-opacity-50">
        <div class="p-4">
            @if (sites.Any())
            {
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
                    @foreach (var site in sites)
                    {
                        var isActive = site.Status == "運行中";
                        <div class="group relative cursor-pointer @(isActive ? "" : "opacity-40")">
                            <div class="border @(isActive ? "border-green-500" : "border-gray-600") border-opacity-50 bg-gradient-to-br from-green-500 to-transparent p-3 hover:border-opacity-100 transition-all duration-300 @(isActive ? "" : "bg-gray-900")"
                                 style="@(isActive ? "background: linear-gradient(135deg, rgba(34, 197, 94, 0.3) 0%, rgba(34, 197, 94, 0) 100%)" : "")">
                                <div class="flex flex-col items-center gap-2">
                                    <div class="w-full text-center">
                                        <p class="text-xs font-bold text-white font-mono truncate">@site.Name</p>
                                    </div>
                                    <div class="w-full h-2 bg-black bg-opacity-30 rounded-full overflow-hidden">
                                        <div class="h-full @(isActive ? "bg-green-400" : "bg-gray-600")" style="width: @(isActive ? "50" : "0")%"></div>
                                    </div>
                                    <p class="text-xs font-bold text-green-400 font-mono">@(isActive ? "Running" : "Stopped")</p>
                                </div>
                            </div>
                            <!-- 工具提示 -->
                            <div class="absolute z-10 hidden group-hover:block bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-2 bg-black border border-white border-opacity-30">
                                <p class="text-xs text-white font-mono whitespace-nowrap">
                                    @site.Name
                                </p>
                                <p class="text-xs text-gray-400 font-mono">
                                    狀態: @site.Status
                                </p>
                                <p class="text-xs text-gray-400 font-mono">
                                    Port: @site.Port
                                </p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12">
                    <p class="text-gray-400 tracking-wide text-sm font-mono">目前沒有任何站台</p>
                </div>
            }
        </div>
    </div>
</div>

