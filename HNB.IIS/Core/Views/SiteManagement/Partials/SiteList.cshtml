@* 站台列表區塊 *@
<div class="mb-4">
    <div class="flex items-center justify-between mb-4">
        <div class="flex items-baseline gap-4">
            <h3 class="text-base font-bold text-white tracking-wide font-mono">站台列表</h3>
            <span class="text-xs text-gray-500 font-mono"><span id="filteredCount">@ViewBag.Sites.Count</span> / @ViewBag.Sites.Count SITES</span>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="refreshStatus()"
                    class="px-4 py-2 border border-white border-opacity-20 text-white hover:border-opacity-40 hover:bg-white hover:bg-opacity-5 transition-all duration-300 text-xs font-mono tracking-wider flex items-center gap-2"
                    title="刷新狀態">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                刷新
            </button>
            <button onclick="openCreateSiteModal()"
                    class="px-4 py-2 border border-white border-opacity-20 text-white hover:border-opacity-40 hover:bg-white hover:bg-opacity-5 transition-all duration-300 text-xs font-mono tracking-wider flex items-center gap-2">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                新增站台
            </button>
        </div>
    </div>

    <!-- 篩選器 -->
    <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 border border-white border-opacity-20 bg-black bg-opacity-30 px-3 py-2">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text"
                   id="searchInput"
                   onkeyup="filterSites()"
                   placeholder="搜尋站台..."
                   class="bg-transparent border-0 outline-0 text-white placeholder-gray-600 text-sm font-mono focus:outline-none flex-1 w-48" />
        </div>
        <div class="flex items-center gap-2">
            <button onclick="filterByStatus('all')"
                    class="filter-status-btn px-3 py-2 border border-white border-opacity-30 text-white bg-white bg-opacity-10 text-xs font-mono tracking-wider transition-all duration-300"
                    data-status="all">
                全部
            </button>
            <button onclick="filterByStatus('運行中')"
                    class="filter-status-btn px-3 py-2 border border-green-500 border-opacity-20 text-green-400 hover:bg-green-500 hover:bg-opacity-10 text-xs font-mono tracking-wider transition-all duration-300"
                    data-status="運行中">
                運行中
            </button>
            <button onclick="filterByStatus('已停止')"
                    class="filter-status-btn px-3 py-2 border border-white border-opacity-20 text-gray-400 hover:bg-white hover:bg-opacity-5 text-xs font-mono tracking-wider transition-all duration-300"
                    data-status="已停止">
                已停止
            </button>
        </div>
    </div>
</div>

<!-- 站台列表 -->
<div class="grid grid-cols-1 xl:grid-cols-2 gap-4" id="sitesGrid">
    @foreach (var site in ViewBag.Sites)
    {
        <div class="site-card group relative border @(site.Status == "運行中" ? "border-green-500 border-opacity-20" : site.Status == "已停止" ? "border-white border-opacity-10" : "border-yellow-500 border-opacity-20") bg-black bg-opacity-50 hover:bg-opacity-70 transition-all duration-300"
             data-name="@site.Name"
             data-status="@site.Status"
             data-path="@site.Path">
            <!-- 左側狀態指示條 -->
            <div class="absolute left-0 top-0 bottom-0 w-1 @(site.Status == "運行中" ? "bg-green-500" : site.Status == "已停止" ? "bg-gray-500" : "bg-yellow-500")"></div>

            <div class="relative p-5">
                <!-- 頂部：站台名稱和狀態 -->
                <div class="flex items-start justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <div class="w-3 h-3 @(site.Status == "運行中" ? "bg-green-400" : site.Status == "已停止" ? "bg-gray-500" : "bg-yellow-500") rounded-full @(site.Status == "運行中" ? "status-pulse" : "")"></div>
                            @if (site.Status == "運行中")
                            {
                                <div class="absolute inset-0 w-3 h-3 bg-green-400 rounded-full animate-ping opacity-75"></div>
                            }
                        </div>
                        <div>
                            <h4 class="text-base font-bold text-white font-mono tracking-wide">@site.Name</h4>
                            <p class="text-xs text-gray-500 font-mono">@site.AppPool</p>
                        </div>
                    </div>
                    <span class="text-xs @(site.Status == "運行中" ? "text-green-400" : site.Status == "已停止" ? "text-gray-400" : "text-yellow-400") font-mono bg-black bg-opacity-50 px-2 py-1 border border-opacity-30">@site.Status</span>
                </div>

                <!-- 中間：關鍵資訊網格 -->
                <div class="grid grid-cols-3 gap-4 mb-4">
                    <div class="border-l border-white border-opacity-10 pl-3">
                        <p class="text-xs text-gray-500 mb-1 font-mono tracking-wider">PORT</p>
                        <p class="text-lg font-bold text-white font-mono">@site.Port</p>
                    </div>
                    <div class="border-l border-white border-opacity-10 pl-3">
                        <p class="text-xs text-gray-500 mb-1 font-mono tracking-wider">SIZE</p>
                        <p class="text-lg font-bold text-white font-mono">@((site.FileSize / 1024.0 / 1024.0).ToString("F2"))<span class="text-xs text-gray-500 ml-1">MB</span></p>
                    </div>
                    <div class="border-l border-white border-opacity-10 pl-3">
                        <p class="text-xs text-gray-500 mb-1 font-mono tracking-wider">UPDATED</p>
                        <p class="text-sm font-bold text-white font-mono">@(site.LastPublish?.ToString("MM/dd HH:mm") ?? "N/A")</p>
                    </div>
                </div>

                <!-- 連結按鈕 -->
                @if (site.Status == "運行中")
                {
                    <div class="mb-4">
                        <a href="http://localhost:@site.Port" 
                           target="_blank"
                           class="flex items-center justify-center gap-2 px-4 py-2 border border-blue-500 border-opacity-30 text-blue-400 hover:text-blue-300 hover:bg-blue-500 hover:bg-opacity-10 transition-all duration-300 text-xs font-mono">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                            查看站台 (localhost:@site.Port)
                        </a>
                    </div>
                }

                <!-- 底部：路徑和操作 -->
                <div class="flex items-center justify-between pt-3 border-t border-white border-opacity-10">
                    <p class="text-xs text-gray-600 font-mono truncate flex-1 mr-3">@site.Path</p>
                    <div class="flex items-center gap-2">
                        @if (site.Status == "已停止")
                        {
                            <button onclick="startSite('@site.Name')"
                                    class="px-3 py-1.5 text-green-400 hover:text-green-300 hover:bg-white hover:bg-opacity-5 transition-all duration-300 text-xs font-mono border border-green-500 border-opacity-30"
                                    title="啟動站台">
                                <div class="flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span>START</span>
                                </div>
                            </button>
                        }
                        else
                        {
                            <button onclick="stopSite('@site.Name')"
                                    class="px-3 py-1.5 text-orange-400 hover:text-orange-300 hover:bg-white hover:bg-opacity-5 transition-all duration-300 text-xs font-mono border border-orange-500 border-opacity-30"
                                    title="停止站台">
                                <div class="flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span>STOP</span>
                                </div>
                            </button>
                        }
                        <button onclick="deleteSite('@site.Name')"
                                class="px-3 py-1.5 text-red-400 hover:text-red-300 hover:bg-white hover:bg-opacity-5 transition-all duration-300 text-xs font-mono border border-red-500 border-opacity-30"
                                title="刪除站台">
                            <div class="flex items-center gap-1.5">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                <span>DELETE</span>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (ViewBag.Sites.Count == 0)
{
    <div class="text-center py-20">
        <div class="inline-block p-8 border border-white border-opacity-10 bg-black bg-opacity-30">
            <svg class="w-16 h-16 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <p class="text-gray-400 tracking-wide mb-1">目前沒有任何站台</p>
            <p class="text-xs text-gray-600">點擊上方「新增站台」開始部署</p>
        </div>
    </div>
}

<!-- 新增站台 Modal -->
<div id="createSiteModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20">
        <!-- 遮罩層 -->
        <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity" onclick="closeCreateSiteModal()"></div>
        
        <!-- Modal 內容 -->
        <div class="relative bg-black border border-white border-opacity-20 w-full max-w-lg">
            <div class="border-b border-white border-opacity-10 p-5">
                <div class="flex items-center justify-between">
                    <h3 class="text-lg font-bold text-white tracking-wide font-mono">新增站台</h3>
                    <button onclick="closeCreateSiteModal()" class="text-gray-400 hover:text-white transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            
             <div class="p-5">
                 <form id="createSiteForm" enctype="multipart/form-data">
                     <div class="mb-4">
                         <label class="block text-xs text-gray-400 font-mono tracking-wider mb-2">站台名稱</label>
                         <input type="text" id="siteNameInput" required
                                class="w-full bg-black border border-white border-opacity-20 text-white px-3 py-2 font-mono focus:border-white focus:outline-none transition"
                                placeholder="例如：MyNewSite">
                     </div>
                     <div class="mb-4">
                         <label class="block text-xs text-gray-400 font-mono tracking-wider mb-2">上傳已發布站台</label>
                         <input type="file" id="siteZipInput" accept=".zip" required
                                class="w-full bg-black border border-white border-opacity-20 text-white px-3 py-2 font-mono focus:border-white focus:outline-none transition"
                                title="選擇 ZIP 壓縮檔">
                         <p class="text-xs text-gray-500 mt-2">請上傳已發布站台的 ZIP 壓縮檔</p>
                     </div>
                 </form>
             </div>
            
            <div class="border-t border-white border-opacity-10 p-5 flex justify-end gap-2">
                <button onclick="closeCreateSiteModal()"
                        class="px-4 py-2 border border-white border-opacity-20 text-gray-400 hover:text-white hover:border-opacity-40 transition text-xs font-mono tracking-wider">
                    取消
                </button>
                <button onclick="submitCreateSite()"
                        class="px-4 py-2 border border-green-500 border-opacity-30 text-green-400 hover:text-green-300 hover:bg-green-500 hover:bg-opacity-10 transition text-xs font-mono tracking-wider">
                    建立
                </button>
            </div>
        </div>
    </div>
</div>
