@model List<HNB.IIS.Core.Models.Hnbdata.error_log>

@{
    ViewData["Title"] = "錯誤日誌管理";
    var totalCount = ViewBag.TotalCount ?? 0;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-gradient-danger text-white d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            錯誤日誌管理
                        </h4>
                        <small>監控系統錯誤，確保應用程式穩定運行</small>
                    </div>
                    <div>
                        <span class="badge bg-white text-danger fs-6">
                            總錯誤數: @totalCount
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <!-- 統計資訊 -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card border-start border-danger border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted mb-1">今日錯誤</h6>
                                            <h3 class="mb-0">@Model.Count(x => x.created_at?.Date == DateTime.Today)</h3>
                                        </div>
                                        <div class="text-danger">
                                            <i class="fas fa-bug fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-start border-warning border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted mb-1">Middleware</h6>
                                            <h3 class="mb-0">@Model.Count(x => x.stage == 0)</h3>
                                        </div>
                                        <div class="text-warning">
                                            <i class="fas fa-layer-group fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-start border-info border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted mb-1">Filter</h6>
                                            <h3 class="mb-0">@Model.Count(x => x.stage == 1)</h3>
                                        </div>
                                        <div class="text-info">
                                            <i class="fas fa-filter fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-start border-success border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted mb-1">最近一小時</h6>
                                            <h3 class="mb-0">@Model.Count(x => x.created_at >= DateTime.Now.AddHours(-1))</h3>
                                        </div>
                                        <div class="text-success">
                                            <i class="fas fa-clock fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 測試按鈕 -->
                    <div class="alert alert-warning d-flex justify-content-between align-items-center" role="alert">
                        <div>
                            <i class="fas fa-vial me-2"></i>
                            <strong>測試錯誤捕捉功能：</strong> 點擊以下按鈕來測試不同類型的錯誤捕捉
                        </div>
                        <div class="btn-group" role="group">
                            <a href="/ErrorLog/TestException" class="btn btn-sm btn-danger" target="_blank">
                                <i class="fas fa-bug me-1"></i>基本測試
                            </a>
                            <a href="/ErrorLog/TestErrorType?type=null" class="btn btn-sm btn-warning" target="_blank">
                                <i class="fas fa-exclamation-circle me-1"></i>Null 測試
                            </a>
                            <a href="/ErrorLog/TestErrorType?type=divide" class="btn btn-sm btn-info" target="_blank">
                                <i class="fas fa-divide me-1"></i>除零測試
                            </a>
                            <a href="/ErrorLog/TestErrorType?type=nested" class="btn btn-sm btn-secondary" target="_blank">
                                <i class="fas fa-sitemap me-1"></i>巢狀測試
                            </a>
                            <a href="/ErrorLog/TestNormal" class="btn btn-sm btn-success" target="_blank">
                                <i class="fas fa-check me-1"></i>正常測試
                            </a>
                        </div>
                    </div>

                    <!-- 錯誤日誌列表 -->
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="errorLogTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 80px;">ID</th>
                                    <th style="width: 100px;">層級</th>
                                    <th style="width: 200px;">功能</th>
                                    <th>錯誤訊息</th>
                                    <th style="width: 120px;">HTTP</th>
                                    <th style="width: 80px;">狀態碼</th>
                                    <th style="width: 180px;">時間</th>
                                    <th style="width: 100px;">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    @foreach (var log in Model)
                                    {
                                        var severityClass = log.stage switch
                                        {
                                            0 => "danger",
                                            1 => "warning",
                                            2 => "info",
                                            3 => "secondary",
                                            _ => "dark"
                                        };
                                        
                                        var statusClass = log.status_code switch
                                        {
                                            >= 500 => "bg-danger",
                                            >= 400 => "bg-warning",
                                            _ => "bg-secondary"
                                        };

                                        <tr>
                                            <td class="fw-bold">#@log.id</td>
                                            <td>
                                                <span class="badge bg-@severityClass">
                                                    @log.layer
                                                </span>
                                            </td>
                                            <td>
                                                <small class="text-muted d-block">@log.function</small>
                                                @if (!string.IsNullOrEmpty(log.user_id))
                                                {
                                                    <small class="text-info">
                                                        <i class="fas fa-user fa-xs"></i> @log.user_id
                                                    </small>
                                                }
                                            </td>
                                            <td>
                                                <div class="error-message-preview">
                                                    @{
                                                        var shortMessage = log.message.Length > 150 
                                                            ? log.message.Substring(0, 150) + "..." 
                                                            : log.message;
                                                    }
                                                    <span class="text-danger">@shortMessage</span>
                                                </div>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(log.http_method))
                                                {
                                                    <span class="badge bg-primary">@log.http_method</span>
                                                    <small class="d-block text-muted mt-1">@log.path</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td>
                                                @if (log.status_code.HasValue)
                                                {
                                                    <span class="badge @statusClass">@log.status_code</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td>
                                                <small>
                                                    @if (log.created_at.HasValue)
                                                    {
                                                        @log.created_at.Value.ToLocalTime().ToString("MM/dd HH:mm:ss")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Unknown</span>
                                                    }
                                                </small>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-primary" 
                                                        onclick="showErrorDetail(@log.id)">
                                                    <i class="fas fa-eye"></i> 詳情
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-5">
                                            <div class="text-muted">
                                                <i class="fas fa-check-circle fa-3x mb-3 text-success"></i>
                                                <h5>沒有錯誤記錄</h5>
                                                <p>系統目前運行正常，沒有捕捉到任何錯誤</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 錯誤詳情模態框 -->
<div class="modal fade" id="errorDetailModal" tabindex="-1" aria-labelledby="errorDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="errorDetailModalLabel">
                    <i class="fas fa-bug me-2"></i>錯誤詳細資訊
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="errorDetailContent">
                <!-- 詳細內容將通過 JavaScript 動態載入 -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 顯示錯誤詳情
        function showErrorDetail(logId) {
            const log = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
            const errorLog = log.find(l => l.id === logId);
            
            if (!errorLog) {
                alert('找不到錯誤記錄');
                return;
            }

            let extra = {};
            try {
                extra = errorLog.extra ? JSON.parse(errorLog.extra) : {};
            } catch (e) {
                console.error('Failed to parse extra data:', e);
            }

            const html = `
                <div class="row">
                    <div class="col-12">
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <strong>基本資訊</strong>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <strong>ID:</strong> #${errorLog.id}
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>層級:</strong> <span class="badge bg-danger">${errorLog.layer}</span>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>功能:</strong> ${errorLog.function || 'N/A'}
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>完整函數名稱:</strong> ${errorLog.function_full || 'N/A'}
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>時間:</strong> ${errorLog.created_at ? new Date(errorLog.created_at).toLocaleString('zh-TW') : 'N/A'}
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>追蹤 ID:</strong> ${errorLog.trace_id || 'N/A'}
                                    </div>
                                </div>
                            </div>
                        </div>

                        ${errorLog.http_method ? `
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <strong>HTTP 資訊</strong>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4 mb-2">
                                        <strong>方法:</strong> <span class="badge bg-primary">${errorLog.http_method}</span>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <strong>狀態碼:</strong> <span class="badge bg-danger">${errorLog.status_code || 'N/A'}</span>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <strong>使用者:</strong> ${errorLog.user_id || 'Anonymous'}
                                    </div>
                                    <div class="col-12 mb-2">
                                        <strong>路徑:</strong> ${errorLog.path || 'N/A'}
                                    </div>
                                </div>
                            </div>
                        </div>
                        ` : ''}

                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <strong>錯誤訊息</strong>
                            </div>
                            <div class="card-body">
                                <pre class="mb-0 bg-danger bg-opacity-10 p-3 rounded">${errorLog.message || 'N/A'}</pre>
                            </div>
                        </div>

                        ${errorLog.stack_trace ? `
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <strong>堆疊追蹤</strong>
                            </div>
                            <div class="card-body">
                                <pre class="mb-0 bg-dark text-light p-3 rounded" style="max-height: 400px; overflow-y: auto;">${errorLog.stack_trace}</pre>
                            </div>
                        </div>
                        ` : ''}

                        ${extra && Object.keys(extra).length > 0 ? `
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <strong>額外資訊</strong>
                            </div>
                            <div class="card-body">
                                <pre class="mb-0 bg-light p-3 rounded">${JSON.stringify(extra, null, 2)}</pre>
                            </div>
                        </div>
                        ` : ''}
                    </div>
                </div>
            `;

            document.getElementById('errorDetailContent').innerHTML = html;
            new bootstrap.Modal(document.getElementById('errorDetailModal')).show();
        }

        // 自動刷新（每30秒）
        let autoRefreshInterval = null;
        
        function toggleAutoRefresh() {
            if (autoRefreshInterval) {
                clearInterval(autoRefreshInterval);
                autoRefreshInterval = null;
            } else {
                autoRefreshInterval = setInterval(() => {
                    location.reload();
                }, 30000);
            }
        }
    </script>
}

<style>
    .error-message-preview {
        font-size: 0.9rem;
        line-height: 1.4;
    }
    
    .table td {
        vertical-align: middle;
    }
    
    pre {
        white-space: pre-wrap;
        word-wrap: break-word;
    }
</style>

