@{
    ViewData["Title"] = "站台管理";
}

<h2>HNB.IIS 站台管理</h2>

<div class="container mt-4">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>站台名稱</th>
                <th>路徑</th>
                <th>應用程式集區</th>
                <th>端口</th>
                <th>狀態</th>
                <th>最後發布</th>
                <th>大小</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var site in ViewBag.Sites)
            {
                <tr>
                    <td>@site.Name</td>
                    <td>@site.Path</td>
                    <td>@site.AppPool</td>
                    <td>@site.Port</td>
                    <td>@site.Status</td>
                    <td>@site.LastPublish</td>
                    <td>@((site.FileSize / 1024.0).ToString("F2")) KB</td>
                    <td>
                        <button class="btn btn-warning btn-sm" onclick="stopSite('@site.Name')">停止</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteSite('@site.Name')">刪除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function stopSite(siteName) {
        if (confirm('確定要停止站台 ' + siteName + '?')) {
            fetch('/SiteManagement/Stop', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ siteName: siteName })
            })
            .then(r => r.json())
            .then(data => {
                alert(data.message);
                location.reload();
            });
        }
    }

    function deleteSite(siteName) {
        if (confirm('確定要刪除站台 ' + siteName + '? 此操作無法復原！')) {
            fetch('/SiteManagement/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ siteName: siteName })
            })
            .then(r => r.json())
            .then(data => {
                alert(data.message);
                location.reload();
            });
        }
    }
</script>

