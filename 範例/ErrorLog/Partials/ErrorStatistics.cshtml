@{
    var statistics = ViewBag.Statistics as ErrorLogStatistics;
    var days = ViewBag.Days as int? ?? 7;
}

<div class="mb-4">
    <div class="d-flex align-items-center gap-md mb-3">
        <h2 class="fs-lg fw-bold text-primary-custom mb-0" style="letter-spacing: 0.05em;">錯誤統計</h2>
        <div class="flex-grow-1" style="height: 1px; background: linear-gradient(to right, var(--color-border), transparent); opacity: 0.1;"></div>
        <div class="d-flex align-items-center gap-sm">
            <select id="daysFilter" onchange="loadStatistics()" class="form-select form-select-sm bg-primary-custom border-custom text-primary-custom fs-sm px-2 py-1 font-monospace" style="background-color: var(--color-bg-primary) !important; border-color: var(--color-border) !important; color: var(--color-text-primary) !important; font-size: var(--font-size-sm);">
                @if (days == 1)
                {
                    <option value="1" selected>最近 1 天</option>
                }
                else
                {
                    <option value="1">最近 1 天</option>
                }
                @if (days == 7)
                {
                    <option value="7" selected>最近 7 天</option>
                }
                else
                {
                    <option value="7">最近 7 天</option>
                }
                @if (days == 30)
                {
                    <option value="30" selected>最近 30 天</option>
                }
                else
                {
                    <option value="30">最近 30 天</option>
                }
                @if (days == 90)
                {
                    <option value="90" selected>最近 90 天</option>
                }
                else
                {
                    <option value="90">最近 90 天</option>
                }
            </select>
            <button onclick="loadStatistics()" class="btn btn-sm border-custom text-primary-custom fs-sm px-2 py-1 font-monospace" style="border-color: var(--color-border); color: var(--color-text-primary); background-color: transparent; transition: all 0.3s;" onmouseover="this.style.borderColor='var(--color-border-hover)'; this.style.backgroundColor='var(--color-hover)';" onmouseout="this.style.borderColor='var(--color-border)'; this.style.backgroundColor='transparent';">
                <svg style="width: calc(14px * var(--scale-factor)); height: calc(14px * var(--scale-factor)); display: inline;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
            </button>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-3">
            <div class="border border-danger border-opacity-25 bg-danger bg-opacity-5 p-3" style="border-color: rgba(239, 68, 68, 0.2) !important; background-color: rgba(239, 68, 68, 0.05) !important;">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="fs-sm text-secondary-custom font-monospace" style="letter-spacing: 0.05em;">總錯誤數</span>
                    <svg style="width: calc(20px * var(--scale-factor)); height: calc(20px * var(--scale-factor)); color: #ef4444;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                </div>
                <div class="fs-3xl fw-bold text-primary-custom font-monospace" id="totalErrors">@statistics.TotalErrors</div>
            </div>
        </div>

        <div class="col-12 col-lg-3">
            <div class="border border-custom bg-secondary-custom p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="fs-sm text-secondary-custom font-monospace" style="letter-spacing: 0.05em;">層級類型</span>
                    <svg style="width: calc(20px * var(--scale-factor)); height: calc(20px * var(--scale-factor)); color: #3b82f6;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                </div>
                <div class="text-3xl fw-bold text-primary-custom font-monospace" id="layerCount">@statistics.ByLayer.Count</div>
            </div>
        </div>

        <div class="col-12 col-lg-3">
            <div class="border border-custom bg-secondary-custom p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="fs-sm text-secondary-custom font-monospace" style="letter-spacing: 0.05em;">狀態碼類型</span>
                    <svg style="width: calc(20px * var(--scale-factor)); height: calc(20px * var(--scale-factor)); color: #eab308;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                </div>
                <div class="text-3xl fw-bold text-primary-custom font-monospace" id="statusCodeCount">@statistics.ByStatusCode.Count</div>
            </div>
        </div>

        <div class="col-12 col-lg-3">
            <div class="border border-custom bg-secondary-custom p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="fs-sm text-secondary-custom font-monospace" style="letter-spacing: 0.05em;">最近 24 小時</span>
                    <svg style="width: calc(20px * var(--scale-factor)); height: calc(20px * var(--scale-factor)); color: #10b981;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div class="text-3xl fw-bold text-primary-custom font-monospace" id="last24Hours">@statistics.TimeSeries.Sum(t => t.Count)</div>
            </div>
        </div>
    </div>
</div>

