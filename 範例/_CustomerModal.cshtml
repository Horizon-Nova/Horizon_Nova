@{
    Layout = null;
}

<!-- 錯誤LOG Modal -->
<div id="errorLogModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <label class="col-form-label"><i class="fa fa-file-text-o"></i> 錯誤LOG</label>
                <button type="button" class="close" onclick="closeModal('errorLogModal')">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body" id="errorLogModalContent">
                <!-- AJAX 動態載入內容 -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-lg btn-dark" onclick="closeModal('errorLogModal')">關閉</button>
            </div>
        </div>
    </div>
</div>

<!-- 客戶主檔說明 Modal -->
<div class="modal fade" id="customer-help" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-question-circle"></i> 客戶主檔說明</h5>
                <button type="button" class="close" onclick="closeModal('customer-help')">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- 左側：說明內容 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 功能說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">功能說明</h6>
                                <p class="small mb-0">
                                    客戶主檔用於管理 PA/pPA 系統的客戶資料與 SAP 客戶對照關係。
                                    系統依據年度、類別（PA/PPA）、公司別等條件查詢客戶資料，並支援 Excel 匯入功能進行批次維護。
                                </p>
                            </div>

                            <!-- 基本操作流程 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">基本操作流程</h6>
                                <ol class="small mb-0">
                                    <li>選擇查詢條件後點擊「查詢」按鈕</li>
                                    <li>使用 SAP 客戶自動完成功能快速查找</li>
                                    <li>點擊「匯出Excel」匯出查詢結果</li>
                                    <li>使用範本進行批次匯入（功能開發中）</li>
                                    <li>點擊「錯誤LOG」查看匯入錯誤記錄</li>
                                </ol>
                            </div>

                            <!-- 查詢條件說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">查詢條件說明</h6>
                                <table class="table table-sm table-bordered small mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 90px;">欄位</th>
                                            <th>說明</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>年度</strong></td>
                                            <td>選擇客戶資料所屬年度（例：2024、2025）</td>
                                        </tr>
                                        <tr>
                                            <td><strong>類別</strong></td>
                                            <td>PA：公開發行公司客戶；PPA：非公開發行公司客戶</td>
                                        </tr>
                                        <tr>
                                            <td><strong>公司別</strong></td>
                                            <td>選擇所屬公司代碼（Comp-1~4）</td>
                                        </tr>
                                        <tr>
                                            <td><strong>SAP客戶</strong></td>
                                            <td>輸入 SAP 客戶代號或名稱，支援模糊搜尋與自動完成</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- 資料結構說明 -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">資料結構說明</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>資料來源：</strong></p>
                                    <ul class="mb-2">
                                        <li><strong>客戶主檔（PACustomer）：</strong>包含客戶基本資料（統編、名稱等）</li>
                                        <li><strong>客戶對照檔（PACustomerMapping）：</strong>維護客戶統編與 SAP 客戶代號的對照關係</li>
                                    </ul>
                                    <p class="mb-2"><strong>查詢結果欄位：</strong></p>
                                    <ul class="mb-0">
                                        <li><code>類別代號</code>：公司別代碼</li>
                                        <li><code>年份</code>：資料所屬年度</li>
                                        <li><code>類別</code>：PA 或 PPA</li>
                                        <li><code>客戶統編</code>：客戶統一編號</li>
                                        <li><code>客戶名稱</code>：客戶公司名稱</li>
                                        <li><code>SAP客戶代號</code>：對應的 SAP 系統客戶代碼</li>
                                        <li><code>SAP客戶名稱</code>：SAP 系統客戶名稱</li>
                                        <li><code>上傳使用者</code>：資料建立或更新人員</li>
                                        <li><code>上傳日期</code>：資料建立或更新日期時間</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 右側：常見問題 -->
                    <div class="col-md-6">
                        <div class="vstack gap-3">
                            <!-- 常見問題 Q&A -->
                            <div>
                                <h6 class="fw-bold mb-2 pb-2 border-bottom">常見問題 (Q&A)</h6>
                                <div class="small">
                                    <p class="mb-2"><strong>Q1：如何查詢特定客戶？</strong></p>
                                    <p class="ms-3 mb-3">A：在「SAP客戶」欄位輸入關鍵字，系統會自動顯示匹配的客戶清單供選擇，選擇後點擊「查詢」即可。</p>

                                    <p class="mb-2"><strong>Q2：客戶統編與 SAP 客戶代號的關係？</strong></p>
                                    <p class="ms-3 mb-3">A：一個客戶統編可能對應多個 SAP 客戶代號，這是為了處理同一客戶在不同公司別的交易情況。</p>

                                    <p class="mb-2"><strong>Q3：如何匯入客戶資料？</strong></p>
                                    <p class="ms-3 mb-3">A：（功能開發中）下載範本 → 依格式填寫 → 選擇檔案 → 點擊「匯入Excel」→ 若有錯誤可查看「錯誤LOG」。</p>

                                    <p class="mb-2"><strong>Q4：匯入失敗如何處理？</strong></p>
                                    <p class="ms-3 mb-3">A：點擊「錯誤LOG」按鈕查看詳細錯誤訊息，包含錯誤原因、發生時間、操作人員等資訊。</p>

                                    <p class="mb-2"><strong>Q5：為什麼有些欄位顯示為空？</strong></p>
                                    <p class="ms-3 mb-3">A：若客戶主檔與對照檔未完整建立關聯，部分欄位可能為空。請確認兩邊資料是否都已正確匯入。</p>

                                    <p class="mb-2"><strong>Q6：資料是否可以刪除？</strong></p>
                                    <p class="ms-3 mb-0">A：客戶資料採用覆蓋式管理，每次匯入會自動比對並更新。若需刪除，請在下次匯入時不包含該筆資料即可。</p>
                                </div>
                            </div>

                            <!-- 重要注意事項 -->
                            <div class="alert alert-warning small mb-0">
                                <h6 class="fw-bold mb-2">重要注意事項</h6>
                                <ul class="mb-0">
                                    <li>客戶資料依<strong>年度</strong>進行管理，不同年度獨立維護</li>
                                    <li>客戶統編與 SAP 客戶代號為<strong>對照關係</strong></li>
                                    <li>匯入 Excel 前請先下載範本，確實依格式填寫</li>
                                    <li>系統自動記錄上傳使用者與時間，便於稽核追蹤</li>
                                    <li>查詢結果支援 DataTables 功能（排序、分頁、匯出）</li>
                                    <li>SAP 客戶自動完成僅搜尋現有資料</li>
                                    <li>匯入錯誤資訊保存於 TB_PSIP_LOG 表</li>
                                    <li>資料更新採覆蓋式，請謹慎操作</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="closeModal('customer-help')">我知道了</button>
            </div>
        </div>
    </div>
</div>
