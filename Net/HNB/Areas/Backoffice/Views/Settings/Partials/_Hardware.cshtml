@using System.Globalization
@{
    Layout = null;
    var hardware = ViewBag.HardwareInfo;

    double? ToNullableDouble(object? value)
        => value is null ? null : Convert.ToDouble(value, CultureInfo.InvariantCulture);

    int? ToNullableInt(object? value)
        => value is null ? null : Convert.ToInt32(value, CultureInfo.InvariantCulture);

    string TemperatureClass(double? value)
    {
        if (!value.HasValue)
        {
            return string.Empty;
        }

        return value > 80 ? "text-danger" : value > 60 ? "text-warning" : "text-success";
    }

    string HealthClass(double? value)
    {
        if (!value.HasValue)
        {
            return string.Empty;
        }

        return value < 80 ? "text-danger" : value < 90 ? "text-warning" : "text-success";
    }

    string FormatTemperature(double? value)
        => value.HasValue ? $"{value.Value:F0}°C" : string.Empty;

    string FormatPercentage(double? value)
        => value.HasValue ? $"{value.Value:F0}%" : string.Empty;

    string FormatRange(double? min, double? max)
    {
        if (!min.HasValue && !max.HasValue)
        {
            return string.Empty;
        }

        var minText = min.HasValue ? $"{min.Value:F1}" : string.Empty;
        var maxText = max.HasValue ? $"{max.Value:F1}" : string.Empty;
        return string.IsNullOrEmpty(maxText) ? minText : $"{minText} - {maxText}";
    }

    var cpuHealth = ToNullableDouble(hardware?.cpu_health_percentage);
    var cpuBaseClock = ToNullableDouble(hardware?.cpu_base_clock);
    var cpuBoostClock = ToNullableDouble(hardware?.cpu_boost_clock);
    var cpuCores = ToNullableInt(hardware?.cpu_cores) ?? 0;
    var cpuThreads = ToNullableInt(hardware?.cpu_threads) ?? 0;

    var gpuTemperature = ToNullableDouble(hardware?.gpu_temperature);

    var memoryHealth = ToNullableDouble(hardware?.memory_health_percentage);
    var memoryUsed = ToNullableDouble(hardware?.memory_used_gb);
    var memoryTotal = ToNullableDouble(hardware?.memory_total_capacity_gb);
    var memoryChannelText = (ViewBag.MemoryChannel as string) ?? string.Empty;
}

<div id="hardwareInfoCard" class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h5 class="card-title fw-semibold d-flex align-items-center gap-2 mb-3">
            <i data-lucide="monitor" style="width: 1.25rem; height: 1.25rem;"></i>
            硬體資訊
        </h5>
        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="cpu" style="width: 1rem; height: 1rem;"></i>
                        CPU 資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">型號</span>
                            <span class="small fw-medium text-truncate ms-2" style="max-width: 60%;">
                                @(hardware?.cpu_model as string ?? string.Empty)
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">核心數</span>
                            <span class="small fw-medium">@($"{cpuCores} 核心 {cpuThreads} 執行緒")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">時脈</span>
                            <span class="small fw-medium">
                                @(string.IsNullOrEmpty(FormatRange(cpuBaseClock, cpuBoostClock)) ? string.Empty : $"{FormatRange(cpuBaseClock, cpuBoostClock)} GHz")
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">健康度</span>
                            <span class="small fw-medium @(HealthClass(cpuHealth))">
                                @FormatPercentage(cpuHealth)
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="monitor" style="width: 1rem; height: 1rem;"></i>
                        GPU 資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">型號</span>
                            <span class="small fw-medium text-truncate ms-2" style="max-width: 60%;">
                                @(hardware?.gpu_model as string ?? string.Empty)
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">記憶體</span>
                            <span class="small fw-medium">@((hardware?.gpu_memory_size as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">製造商</span>
                            <span class="small fw-medium">@((hardware?.gpu_manufacturer as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">溫度</span>
                            <span class="small fw-medium @(TemperatureClass(gpuTemperature))">
                                @FormatTemperature(gpuTemperature)
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="memory-stick" style="width: 1rem; height: 1rem;"></i>
                        記憶體資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">總容量</span>
                            <span class="small fw-medium">@((hardware?.memory_total_capacity as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">速度</span>
                            <span class="small fw-medium">@((hardware?.memory_speed as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">通道數</span>
                            <span class="small fw-medium">@memoryChannelText</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">已使用</span>
                            <span class="small fw-medium">
                                @(memoryUsed.HasValue && memoryTotal.HasValue
                                    ? $"{memoryUsed.Value:F1} / {memoryTotal.Value:F1} GB"
                                    : string.Empty)
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">健康度</span>
                            <span class="small fw-medium @(HealthClass(memoryHealth))">
                                @FormatPercentage(memoryHealth)
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="border rounded p-3">
                    <h6 class="fw-medium mb-3 d-flex align-items-center gap-2">
                        <i data-lucide="server" style="width: 1rem; height: 1rem;"></i>
                        系統資訊
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">主機名稱</span>
                            <span class="small fw-medium">@((hardware?.host_name as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">作業系統</span>
                            <span class="small fw-medium text-truncate ms-2" style="max-width: 60%;">
                                @(hardware?.operating_system as string ?? string.Empty)
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">系統版本</span>
                            <span class="small fw-medium">@((hardware?.kernel_version as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">運行時間</span>
                            <span class="small fw-medium">@((hardware?.uptime as string) ?? string.Empty)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">電源狀態</span>
                            <span class="small fw-medium @((hardware?.power_efficiency as string) == "正常" ? "text-success" : "text-danger")">
                                @((hardware?.power_efficiency as string) ?? string.Empty)
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

