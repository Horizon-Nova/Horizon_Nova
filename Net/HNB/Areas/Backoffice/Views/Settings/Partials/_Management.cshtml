@{
    Layout = null;

    var errorLogsCount = ViewBag.ErrorLogsCount as int? ?? 0;
    var accessLogsCount = ViewBag.AccessLogsCount as int? ?? 0;
    var systemLogsCount = ViewBag.SystemLogsCount as int? ?? accessLogsCount;

    var memoryCacheSizeBytes = ViewBag.MemoryCacheSize as long?;
    var cacheEntries = ViewBag.CacheEntries as int? ?? 0;
    var lastCacheCleared = ViewBag.LastCacheCleared as DateTime?;

    var memoryCacheSizeText = memoryCacheSizeBytes.HasValue
        ? $"{(memoryCacheSizeBytes.Value / (1024m * 1024m)):F1} MB"
        : string.Empty;

    var lastCacheClearedText = lastCacheCleared?.ToString("yyyy-MM-dd HH:mm") ?? string.Empty;
}

<div class="row g-3 mb-3">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="card-title mb-0 fw-semibold d-flex align-items-center gap-2">
                        <i data-lucide="file-text" style="width: 1.25rem; height: 1.25rem;"></i>
                        日誌管理
                    </h5>
                    <button type="button" class="btn btn-link btn-sm p-0 text-primary js-refresh-logs">
                        <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;"></i>
                        <span class="ms-1">刷新</span>
                    </button>
                </div>

                <div class="d-flex flex-column gap-2">
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-medium">錯誤日誌</p>
                            <p class="small text-muted mb-0" id="errorLogCount">@($"{errorLogsCount} 條記錄")</p>
                        </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-danger btn-sm js-clear-logs" data-type="error" data-days="all">全部清理</button>
                            <button type="button" class="btn btn-warning btn-sm js-clear-logs" data-type="error" data-days="30">30天清理</button>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-medium">系統日誌</p>
                            <p class="small text-muted mb-0" id="systemLogCount">@($"{systemLogsCount} 條記錄")</p>
                        </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-primary btn-sm js-clear-logs" data-type="system" data-days="all">全部清理</button>
                            <button type="button" class="btn btn-info btn-sm js-clear-logs" data-type="system" data-days="30">30天清理</button>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-medium">存取日誌</p>
                            <p class="small text-muted mb-0" id="accessLogCount">@($"{accessLogsCount} 條記錄")</p>
                        </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-success btn-sm js-clear-logs" data-type="access" data-days="all">全部清理</button>
                            <button type="button" class="btn btn-outline-success btn-sm js-clear-logs" data-type="access" data-days="30">30天清理</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="card-title mb-0 fw-semibold d-flex align-items-center gap-2">
                        <i data-lucide="database" style="width: 1.25rem; height: 1.25rem;"></i>
                        快取管理
                    </h5>
                    <button type="button" class="btn btn-link btn-sm p-0 text-primary js-refresh-cache">
                        <i data-lucide="refresh-cw" style="width: 1rem; height: 1rem;"></i>
                        <span class="ms-1">刷新</span>
                    </button>
                </div>

                <div class="d-flex flex-column gap-2">
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-medium">記憶體快取</p>
                            <p class="small text-muted mb-0" id="memoryCacheSize">@memoryCacheSizeText</p>
                        </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-primary btn-sm js-clear-cache" data-type="memory" data-days="all">全部清理</button>
                            <button type="button" class="btn btn-outline-primary btn-sm js-clear-cache" data-type="memory" data-days="30">30天清理</button>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-medium">資料庫快取</p>
                            <p class="small text-muted mb-0" id="databaseCacheSize">@($"{cacheEntries} 個條目")</p>
                        </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-info btn-sm js-clear-cache" data-type="database" data-days="all">全部清理</button>
                            <button type="button" class="btn btn-outline-info btn-sm js-clear-cache" data-type="database" data-days="30">30天清理</button>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between p-3 bg-light rounded gap-2">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-medium">檔案快取</p>
                            <p class="small text-muted mb-0" id="fileCacheSize">
                                @(string.IsNullOrEmpty(lastCacheClearedText) ? string.Empty : $"最後清理：{lastCacheClearedText}")
                            </p>
                        </div>
                        <div class="d-flex gap-2 ms-lg-auto">
                            <button type="button" class="btn btn-success btn-sm js-clear-cache" data-type="file" data-days="all">全部清理</button>
                            <button type="button" class="btn btn-outline-success btn-sm js-clear-cache" data-type="file" data-days="30">30天清理</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

