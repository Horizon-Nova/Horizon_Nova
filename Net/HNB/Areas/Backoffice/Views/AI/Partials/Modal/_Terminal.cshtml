@{
    Layout = null;
}

<div class="modal fade" id="terminalModal" tabindex="-1" aria-labelledby="terminalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-lg-down modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-dark text-light border-0">
                <h5 class="modal-title d-flex align-items-center gap-2" id="terminalModalLabel">
                    <i data-lucide="terminal" style="width: 1.25rem; height: 1.25rem;"></i>
                    <span>AI 模型啟動日誌</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-dark text-light p-0" style="min-height: 60vh;">
                <div id="terminalContent" class="p-3" style="font-family: 'Courier New', monospace; font-size: 0.875rem; white-space: pre-wrap; word-wrap: break-word; min-height: 60vh; max-height: 70vh; overflow-y: auto;">
                    <div class="text-muted small">等待日誌輸出...</div>
                </div>
            </div>
            <div class="modal-footer bg-dark border-0">
                <button type="button" class="btn btn-secondary btn-sm" id="terminalClearBtn">
                    <i data-lucide="trash-2" style="width: 1rem; height: 1rem;"></i>
                    <span class="ms-1">清除日誌</span>
                </button>
                <button type="button" class="btn btn-secondary btn-sm" id="terminalAutoScrollBtn">
                    <i data-lucide="arrow-down" style="width: 1rem; height: 1rem;"></i>
                    <span class="ms-1">自動捲動</span>
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

