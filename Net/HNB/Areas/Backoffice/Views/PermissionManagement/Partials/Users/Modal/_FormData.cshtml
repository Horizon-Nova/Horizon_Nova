@model Models.HnbBackoffice.vw_permission_user?
@{
    Layout = null;
}

<div id="userFormDataModal" class="modal fade" tabindex="-1" aria-labelledby="userFormDataModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content" id="userFormDataModalContent">
            <div class="modal-header">
                <h5 class="modal-title" id="userFormDataModalLabel">@(Model?.id > 0 ? "編輯帳號" : "新增帳號")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body p-4">
                <form id="FormDataUser" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@(Model?.id ?? 0)" />

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="full_name">姓名<span class="text-danger">*</span></label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control" id="full_name" name="full_name" value="@(Model?.full_name ?? "")" placeholder="請輸入完整姓名" required>
                        </div>
                        <label class="col-lg-2 col-form-label" for="email">電子郵件<span class="text-danger">*</span></label>
                        <div class="col-lg-4">
                            <input type="email" class="form-control" id="email" name="email" value="@(Model?.email ?? "")" placeholder="example@email.com" required>
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="phone">電話</label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control" id="phone" name="phone" value="@(Model?.phone ?? "")" placeholder="請輸入聯絡電話">
                        </div>
                        <label class="col-lg-2 col-form-label" for="gender">性別<span class="text-danger">*</span></label>
                        <div class="col-lg-4">
                            <select class="form-select" id="gender" name="gender" required>
                                <option value="">請選擇性別</option>
                                <option value="male" @(Model?.gender == "male" ? "selected" : "")>男性</option>
                                <option value="female" @(Model?.gender == "female" ? "selected" : "")>女性</option>
                                <option value="other" @(Model?.gender == "other" ? "selected" : "")>其他</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="name">使用者名稱<span class="text-danger">*</span></label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control @(Model?.id > 0 ? "bg-light" : "")" id="name" name="name" value="@(Model?.name ?? "")" placeholder="請輸入使用者名稱" @(Model?.id > 0 ? "readonly" : "required")>
                        </div>
                        <label class="col-lg-2 col-form-label" for="password_hash">密碼@(Model?.id > 0 ? "" : Html.Raw("<span class=\"text-danger\">*</span>"))</label>
                        <div class="col-lg-4">
                            <input type="password" class="form-control @(Model?.id > 0 ? "bg-light" : "")" id="password_hash" name="password_hash" placeholder="@(Model?.id > 0 ? "**********" : "請輸入密碼")" @(Model?.id > 0 ? "readonly" : "required")>
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="nickname">暱稱</label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control" id="nickname" name="nickname" value="@(Model?.nickname ?? "")" placeholder="請輸入暱稱">
                        </div>
                        <label class="col-lg-2 col-form-label" for="zodiac_sign">星座</label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control" id="zodiac_sign" name="zodiac_sign" value="@(Model?.zodiac_sign ?? "")" placeholder="請輸入星座">
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="favorite_color">喜歡顏色</label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control" id="favorite_color" name="favorite_color" value="@(Model?.favorite_color ?? "")" placeholder="請輸入喜歡的顏色">
                        </div>
                        <label class="col-lg-2 col-form-label" for="location">常駐地點</label>
                        <div class="col-lg-4">
                            <input type="text" class="form-control" id="location" name="location" value="@(Model?.location ?? "")" placeholder="請輸入常駐地點">
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="bio">個人簡介</label>
                        <div class="col-lg-10">
                            <textarea class="form-control" id="bio" name="bio" rows="2" placeholder="請輸入個人簡介或工作描述">@(Model?.bio ?? "")</textarea>
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label">角色<span class="text-danger">*</span></label>
                        <div class="col-lg-10">
                            <div class="d-flex flex-wrap gap-2">
                                @if (ViewBag.Roles != null)
                                {
                                    @foreach (var role in ViewBag.Roles)
                                    {
                                        var isChecked = Model?.roles != null && Model.roles.Contains(role.id.ToString());
                                        <div>
                                            <input type="checkbox" name="role_ids" value="@role.id" @(isChecked ? "checked" : "") class="btn-check" id="role_@role.id" autocomplete="off">
                                            <label class="btn btn-outline-primary btn-sm" for="role_@role.id">@role.name</label>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="form-group row mt-2">
                        <label class="col-lg-2 col-form-label" for="parent_id">組織<span class="text-danger">*</span></label>
                        <div class="col-lg-4">
                            <select class="form-select" id="parent_id" name="parent_id" required>
                                <option value="">請選擇組織</option>
                                @if (ViewBag.Organizations != null)
                                {
                                    @foreach (var org in ViewBag.Organizations)
                                    {
                                        <option value="@org.id" @(Model?.parent_id == org.id ? "selected" : "")>@org.organization_name</option>
                                    }
                                }
                            </select>
                        </div>
                        <label class="col-lg-2 col-form-label" for="is_active">帳號狀態</label>
                        <div class="col-lg-4">
                            <select class="form-select" id="is_active" name="is_active">
                                <option value="true" @(Model?.is_active == true ? "selected" : "")>啟用</option>
                                <option value="false" @(Model?.is_active == false ? "selected" : "")>停用</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="Submit()">@(Model?.id > 0 ? "儲存變更" : "新增帳號")</button>
            </div>
        </div>
    </div>
</div>
