@{
    Layout = null;
}

<div class="bg-white border rounded-3 p-3 p-lg-4">
    <h3 class="fs-6 fw-semibold mb-3">圖例說明</h3>
    <div class="row g-3 g-lg-4">
        <div class="col-12 col-lg-4">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 border border-2 border-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width: 3rem; height: 3rem;">
                    <i data-lucide="building" class="text-primary" style="width: 1.25rem; height: 1.25rem;"></i>
                </div>
                <div>
                    <p class="fw-medium mb-0">組織單位</p>
                    <p class="small text-muted mb-0">公司部門或團隊</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 border border-2 border-success rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width: 3rem; height: 3rem;">
                    <i data-lucide="users" class="text-success" style="width: 1.25rem; height: 1.25rem;"></i>
                </div>
                <div>
                    <p class="fw-medium mb-0">人員數量</p>
                    <p class="small text-muted mb-0">該組織下的人員數</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-info bg-opacity-10 border border-2 border-info rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width: 3rem; height: 3rem;">
                    <i data-lucide="shield" class="text-info" style="width: 1.25rem; height: 1.25rem;"></i>
                </div>
                <div>
                    <p class="fw-medium mb-0">角色數量</p>
                    <p class="small text-muted mb-0">該組織下的角色數</p>
                </div>
            </div>
        </div>
    </div>
</div>

