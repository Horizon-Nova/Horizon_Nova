@{
    Layout = null;
}

<section class="relative flex h-full min-h-0 flex-1 flex-col overflow-hidden md:flex-row">
    <!-- LEFT -->
    <aside class="relative w-full shrink-0 overflow-hidden bg-[#141210] px-6 py-10 md:w-[460px] md:px-12 md:py-12">
        <div class="pointer-events-none absolute -right-16 -top-20 h-[320px] w-[340px] rounded-[63%_37%_54%_46%/55%_48%_52%_45%] bg-[rgba(215,103,54,0.16)]"></div>
        <div class="pointer-events-none absolute -bottom-16 -left-10 h-[300px] w-[280px] rounded-[44%_56%_38%_62%/58%_42%_58%_42%] bg-[rgba(157,186,181,0.10)]"></div>
        <div class="pointer-events-none absolute left-[32%] top-[42%] h-[160px] w-[180px] rounded-[52%_48%_62%_38%/42%_58%_42%_58%] bg-[rgba(215,103,54,0.08)]"></div>

        <div class="relative z-[1] flex h-full flex-col">
            <div class="flex items-center gap-[11px]">
                <div class="flex h-[38px] w-[38px] items-center justify-center rounded-[11px] bg-[#d76736] shadow-[0_4px_14px_rgba(215,103,54,0.5)]">
                    <img class="block h-[26px] w-[26px] object-contain" src="~/ww/image/logo.png" alt="" width="26" height="26" asp-append-version="true" />
                </div>
                <div class="text-[16px] font-black text-white">
                    Whatever the <em class="[font-family:var(--font-serif)] font-medium italic text-[#d76736]">Weather.</em>
                </div>
            </div>

            <div class="mt-10">
                <h1 class="text-[42px] font-black leading-[1.04] tracking-[-0.025em] text-white">
                    Your AI<br />
                    stylist is<br />
                    <em class="[font-family:var(--font-serif)] font-medium italic text-[#d76736]">waiting.</em>
                </h1>
                <p class="mt-[14px] text-[15px] leading-[1.72] text-white/40">
                    Upload your clothes once. Get a perfect outfit every morning: weather-aware, occasion-perfect, always from your own wardrobe.
                </p>

                <div class="mt-10 flex flex-col gap-4">
                    <div class="flex items-center gap-[13px]">
                        <div class="flex h-[38px] w-[38px] items-center justify-center rounded-[11px] border border-white/10 bg-white/5">
                            <i data-lucide="upload" class="h-[17px] w-[17px] text-[#d76736]" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="text-[13px] font-bold text-white">Upload once, styled forever</div>
                            <div class="mt-[1px] text-[11.5px] text-white/30">AI builds your digital closet automatically</div>
                        </div>
                    </div>
                    <div class="flex items-center gap-[13px]">
                        <div class="flex h-[38px] w-[38px] items-center justify-center rounded-[11px] border border-white/10 bg-white/5">
                            <i data-lucide="map-pin" class="h-[17px] w-[17px] text-[#d76736]" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="text-[13px] font-bold text-white">Weather-aware every day</div>
                            <div class="mt-[1px] text-[11.5px] text-white/30">Auto-detects your location and conditions</div>
                        </div>
                    </div>
                    <div class="flex items-center gap-[13px]">
                        <div class="flex h-[38px] w-[38px] items-center justify-center rounded-[11px] border border-white/10 bg-white/5">
                            <i data-lucide="heart" class="h-[17px] w-[17px] text-[#d76736]" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="text-[13px] font-bold text-white">Gets smarter every use</div>
                            <div class="mt-[1px] text-[11.5px] text-white/30">Learns your style and preferences</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-auto pt-10 text-[11px] text-white/20">
                &copy; 2026 Whatever the Weather. All rights reserved.
            </div>
        </div>
    </aside>

    <!-- RIGHT -->
    <main class="relative flex min-h-0 flex-1 items-center justify-center overflow-hidden px-6 py-10 md:px-12 md:py-12">
        <div class="pointer-events-none absolute -right-16 -top-20 h-[340px] w-[380px] rounded-[60%_40%_55%_45%/50%_60%_40%_50%] bg-[#d3a38c]/60"></div>
        <div class="pointer-events-none absolute -bottom-20 -left-10 h-[320px] w-[300px] rounded-[44%_56%_38%_62%/58%_42%_58%_42%] bg-[#9dbab5]/50"></div>
        <div class="pointer-events-none absolute left-[16%] top-[32%] h-[200px] w-[220px] rounded-[52%_48%_62%_38%/42%_58%_42%_58%] bg-[#f2e0d5]/60"></div>

        <div class="relative z-[1] w-full max-w-[424px] rounded-[24px] border border-white/90 bg-white/65 p-8 shadow-[0_24px_64px_rgba(0,0,0,0.12)] backdrop-blur-[20px] md:p-10">
            <div class="mb-5 inline-flex items-center gap-[7px] rounded-full border border-[#d76736]/25 bg-[#f2e0d5] px-[13px] py-[5px] text-[11px] font-bold text-[#d76736] hidden" id="ctx-pill">
                <svg class="h-[12px] w-[12px] fill-none stroke-[#d76736] stroke-[2] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-hidden="true">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
                <span id="ctx-text">Save your look - sign up free</span>
            </div>

            <div class="mb-7 flex rounded-[12px] bg-black/5 p-1">
                <button type="button" id="tab-su"
                        class="flex-1 rounded-[9px] bg-white px-3 py-[9px] text-[13px] font-bold text-[#1e1b18] shadow-[0_2px_8px_rgba(0,0,0,0.08)]"
                        onclick="wwAuthSwitchTab('signup')">
                    Create account
                </button>
                <button type="button" id="tab-li"
                        class="flex-1 rounded-[9px] px-3 py-[9px] text-[13px] font-bold text-black/35"
                        onclick="wwAuthSwitchTab('login')">
                    Log in
                </button>
            </div>

            <!-- SIGN UP -->
            <div id="view-signup">
                <div class="text-[23px] font-black tracking-[-0.02em] text-[#1e1b18]" id="su-title">
                    Start for <em class="[font-family:var(--font-serif)] font-medium italic text-[#d76736]">free.</em>
                </div>
                <div class="mb-6 mt-[5px] text-[13px] leading-[1.55] text-black/35" id="su-sub">No credit card required. Cancel anytime.</div>

                <div class="flex flex-col gap-[10px]">
                    <button type="button" class="flex w-full items-center justify-center gap-3 rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] shadow-[0_2px_10px_rgba(0,0,0,0.05)] transition hover:-translate-y-px hover:bg-white/85">
                        <span class="inline-flex h-[18px] w-[18px] items-center justify-center">
                            <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" aria-hidden="true">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
                            </svg>
                        </span>
                        Continue with Google
                    </button>
                    <button type="button" class="flex w-full items-center justify-center gap-3 rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] shadow-[0_2px_10px_rgba(0,0,0,0.05)] transition hover:-translate-y-px hover:bg-white/85">
                        <span class="inline-flex h-[18px] w-[18px] items-center justify-center text-black/80">
                            <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
                                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
                            </svg>
                        </span>
                        Continue with Apple
                    </button>
                </div>

                <div class="my-6 flex items-center gap-3">
                    <div class="h-px flex-1 bg-black/10"></div>
                    <div class="text-[11px] font-bold uppercase tracking-[0.08em] text-black/35">or sign up with email</div>
                    <div class="h-px flex-1 bg-black/10"></div>
                </div>

                <div class="flex flex-col gap-4">
                    <div>
                        <label class="mb-[6px] block text-[11px] font-bold text-black/45">Email address</label>
                        <input class="w-full rounded-[14px] border border-black/10 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] outline-none placeholder:text-black/25 focus:border-[#d76736]/35"
                               type="email" placeholder="you@example.com" />
                    </div>

                    <div>
                        <label class="mb-[6px] block text-[11px] font-bold text-black/45">Password</label>
                        <div class="relative">
                            <input class="w-full rounded-[14px] border border-black/10 bg-white/70 px-4 py-[12px] pr-[72px] text-[13px] font-bold text-[#1e1b18] outline-none placeholder:text-black/25 focus:border-[#d76736]/35"
                                   type="password" id="pw-input" placeholder="At least 8 characters"
                                   oninput="wwAuthCheckPw(this.value)" />
                            <button type="button" id="pw-toggle"
                                    class="absolute right-[14px] top-1/2 -translate-y-1/2 text-[11px] font-black text-black/35 hover:text-[#d76736]"
                                    onclick="wwAuthTogglePw('pw-input','pw-toggle')">
                                Show
                            </button>
                        </div>
                        <div class="mt-[10px] flex items-center gap-2">
                            <div class="flex flex-1 gap-2">
                                <div class="h-[6px] flex-1 rounded-full bg-black/10 transition" id="pb1"></div>
                                <div class="h-[6px] flex-1 rounded-full bg-black/10 transition" id="pb2"></div>
                                <div class="h-[6px] flex-1 rounded-full bg-black/10 transition" id="pb3"></div>
                            </div>
                            <div class="min-w-[70px] text-right text-[11px] font-bold text-black/35" id="pw-label"></div>
                        </div>
                    </div>

                    <div>
                        <label class="mb-[6px] block text-[11px] font-bold text-black/45">Confirm password</label>
                        <input class="w-full rounded-[14px] border border-black/10 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] outline-none placeholder:text-black/25 focus:border-[#d76736]/35"
                               type="password" placeholder="Repeat your password" />
                    </div>
                </div>

                <div class="mt-5 text-[12px] leading-relaxed text-black/35">
                    By creating an account you agree to our <a class="font-bold text-[#d76736] hover:underline" href="#">Terms of Service</a> and <a class="font-bold text-[#d76736] hover:underline" href="#">Privacy Policy</a>.
                </div>

                <button type="button"
                        class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-[16px] bg-[#d76736] px-5 py-[14px] text-[14px] font-black text-white shadow-[0_10px_26px_rgba(215,103,54,0.38)] transition hover:-translate-y-px hover:bg-[#b8522a]">
                    Create my account
                    <svg class="h-[16px] w-[16px] fill-none stroke-white stroke-[2.6] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-hidden="true">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>

                <div class="mt-4 text-center text-[12px] text-black/35">
                    Already have an account?
                    <button type="button" class="font-black text-[#d76736] hover:underline" onclick="wwAuthSwitchTab('login')">Log in</button>
                </div>
            </div>

            <!-- LOGIN -->
            <div id="view-login" class="hidden">
                <div class="text-[23px] font-black tracking-[-0.02em] text-[#1e1b18]">
                    Welcome <em class="[font-family:var(--font-serif)] font-medium italic text-[#d76736]">back.</em>
                </div>
                <div class="mb-6 mt-[5px] text-[13px] leading-[1.55] text-black/35">Good to see you again. Let's find your outfit.</div>

                <div class="flex flex-col gap-[10px]">
                    <button type="button" class="flex w-full items-center justify-center gap-3 rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] shadow-[0_2px_10px_rgba(0,0,0,0.05)] transition hover:-translate-y-px hover:bg-white/85">
                        <span class="inline-flex h-[18px] w-[18px] items-center justify-center">
                            <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" aria-hidden="true">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
                            </svg>
                        </span>
                        Continue with Google
                    </button>
                    <button type="button" class="flex w-full items-center justify-center gap-3 rounded-[14px] border border-black/5 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] shadow-[0_2px_10px_rgba(0,0,0,0.05)] transition hover:-translate-y-px hover:bg-white/85">
                        <span class="inline-flex h-[18px] w-[18px] items-center justify-center text-black/80">
                            <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
                                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
                            </svg>
                        </span>
                        Continue with Apple
                    </button>
                </div>

                <div class="my-6 flex items-center gap-3">
                    <div class="h-px flex-1 bg-black/10"></div>
                    <div class="text-[11px] font-bold uppercase tracking-[0.08em] text-black/35">or log in with email</div>
                    <div class="h-px flex-1 bg-black/10"></div>
                </div>

                <div class="flex flex-col gap-4">
                    <div>
                        <label class="mb-[6px] block text-[11px] font-bold text-black/45">Email address</label>
                        <input class="w-full rounded-[14px] border border-black/10 bg-white/70 px-4 py-[12px] text-[13px] font-bold text-[#1e1b18] outline-none placeholder:text-black/25 focus:border-[#d76736]/35"
                               type="email" placeholder="you@example.com" />
                    </div>
                    <div>
                        <label class="mb-[6px] block text-[11px] font-bold text-black/45">Password</label>
                        <div class="relative">
                            <input class="w-full rounded-[14px] border border-black/10 bg-white/70 px-4 py-[12px] pr-[72px] text-[13px] font-bold text-[#1e1b18] outline-none placeholder:text-black/25 focus:border-[#d76736]/35"
                                   type="password" id="li-pw" placeholder="Your password" />
                            <button type="button" id="li-pw-toggle"
                                    class="absolute right-[14px] top-1/2 -translate-y-1/2 text-[11px] font-black text-black/35 hover:text-[#d76736]"
                                    onclick="wwAuthTogglePw('li-pw','li-pw-toggle')">
                                Show
                            </button>
                        </div>
                    </div>
                </div>

                <a class="mt-3 inline-block text-[12px] font-bold text-black/35 hover:text-[#d76736] hover:underline" href="#">Forgot password?</a>

                <button type="button"
                        class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-[16px] bg-[#d76736] px-5 py-[14px] text-[14px] font-black text-white shadow-[0_10px_26px_rgba(215,103,54,0.38)] transition hover:-translate-y-px hover:bg-[#b8522a]">
                    Log in
                    <svg class="h-[16px] w-[16px] fill-none stroke-white stroke-[2.6] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-hidden="true">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>

                <div class="mt-4 text-center text-[12px] text-black/35">
                    Don't have an account?
                    <button type="button" class="font-black text-[#d76736] hover:underline" onclick="wwAuthSwitchTab('signup')">Sign up free</button>
                </div>
            </div>
        </div>

        <!-- Demo controls (預設隱藏) -->
        <div class="absolute bottom-[16px] left-[16px] hidden gap-2 rounded-[14px] border border-white/70 bg-white/50 p-2 shadow-[0_8px_18px_rgba(0,0,0,0.08)] backdrop-blur-[10px]" aria-hidden="true">
            <button type="button" id="btn-1" class="rounded-[10px] bg-white px-3 py-[8px] text-[11px] font-black text-black/55 shadow-[0_2px_10px_rgba(0,0,0,0.06)]" onclick="wwAuthSetCtx('landing')">From Landing (Login)</button>
            <button type="button" id="btn-2" class="rounded-[10px] bg-white/70 px-3 py-[8px] text-[11px] font-black text-black/55 shadow-[0_2px_10px_rgba(0,0,0,0.06)]" onclick="wwAuthSetCtx('trial')">From Trial (Sign up)</button>
        </div>
    </main>
</section>

