@{
    Layout = null;
}

<script>
// Closet interactions: based on wtw_closet_desktop.html.

let activeCard = null;
let importTimerIds = [];
let importIsRunning = false;

function wwClosetImportInit() {
  const zone = document.getElementById("ww-closet-import-zone");
  const input = document.getElementById("ww-closet-import-input");
  const chooseBtn = document.getElementById("ww-closet-import-btn");
  const againBtn = document.getElementById("ww-closet-import-again-btn");

  if (!zone || !input) return;

  const openPicker = () => input.click();

  zone.addEventListener("click", (e) => {
    if (importIsRunning) return;
    if (e.target?.closest?.("button")) return;
    openPicker();
  });

  zone.addEventListener("dragover", (e) => {
    e.preventDefault();
    if (importIsRunning) return;
    zone.classList.add("drag-over");
  });

  zone.addEventListener("dragleave", () => {
    zone.classList.remove("drag-over");
  });

  zone.addEventListener("drop", (e) => {
    e.preventDefault();
    zone.classList.remove("drag-over");
    if (importIsRunning) return;
    const files = Array.from(e.dataTransfer?.files || []).filter(f => (f.type || "").startsWith("image/"));
    if (files.length <= 0) return;
    wwClosetImportStart(files);
  });

  input.addEventListener("change", () => {
    if (importIsRunning) return;
    const files = Array.from(input.files || []);
    if (files.length <= 0) return;
    wwClosetImportStart(files);
  });

  chooseBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    if (importIsRunning) return;
    openPicker();
  });

  againBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    wwClosetImportReset();
  });
}

function wwClosetImportStart(files) {
  const idle = document.getElementById("ww-closet-iz-idle");
  const scanning = document.getElementById("ww-closet-iz-scanning");
  const done = document.getElementById("ww-closet-iz-done");
  const input = document.getElementById("ww-closet-import-input");

  if (!idle || !scanning || !done) return;

  importIsRunning = true;
  wwClosetImportClearTimers();

  idle.style.display = "none";
  done.style.display = "none";
  scanning.style.display = "flex";

  const steps = [
    { dot: "ww-closet-ss1", txt: "ww-closet-st1", dl: 450 },
    { dot: "ww-closet-ss2", txt: "ww-closet-st2", dl: 1050 },
    { dot: "ww-closet-ss3", txt: "ww-closet-st3", dl: 1650 },
    { dot: "ww-closet-ss4", txt: "ww-closet-st4", dl: 2250 },
  ];

  steps.forEach(({ dot, txt, dl }) => {
    importTimerIds.push(window.setTimeout(() => {
      document.getElementById(dot)?.classList.add("cur");
      document.getElementById(txt)?.classList.add("cur");
    }, dl));

    importTimerIds.push(window.setTimeout(() => {
      const dotEl = document.getElementById(dot);
      const txtEl = document.getElementById(txt);
      dotEl?.classList.remove("cur");
      txtEl?.classList.remove("cur");
      dotEl?.classList.add("done");
      txtEl?.classList.add("done");
    }, dl + 550));
  });

  importTimerIds.push(window.setTimeout(() => {
    scanning.style.display = "none";
    done.style.display = "flex";
    wwClosetImportRenderDone(files);
    if (input) input.value = "";
    importIsRunning = false;
  }, 3300));
}

function wwClosetImportRenderDone(files) {
  const chips = document.getElementById("ww-closet-import-done-chips");
  if (!chips) return;

  const count = Math.min(20, files?.length || 0);
  const labels = [
    `已接收 ${count} 張`,
    "辨識完成",
    "已加入衣櫥"
  ];

  chips.innerHTML = labels.map(text => `<div class="done-chip">${escapeHtml(text)}</div>`).join("");
}

function wwClosetImportReset() {
  const idle = document.getElementById("ww-closet-iz-idle");
  const scanning = document.getElementById("ww-closet-iz-scanning");
  const done = document.getElementById("ww-closet-iz-done");

  if (!idle || !scanning || !done) return;

  wwClosetImportClearTimers();
  importIsRunning = false;

  scanning.style.display = "none";
  done.style.display = "none";
  idle.style.display = "flex";

  ["ww-closet-ss1", "ww-closet-ss2", "ww-closet-ss3", "ww-closet-ss4"].forEach(id => {
    const el = document.getElementById(id);
    el?.classList.remove("cur");
    el?.classList.remove("done");
  });
  ["ww-closet-st1", "ww-closet-st2", "ww-closet-st3", "ww-closet-st4"].forEach(id => {
    const el = document.getElementById(id);
    el?.classList.remove("cur");
    el?.classList.remove("done");
  });
}

function wwClosetImportClearTimers() {
  importTimerIds.forEach(id => window.clearTimeout(id));
  importTimerIds = [];
}

function wwClosetSearch(query) {
  const q = (query || "").trim().toLowerCase();
  document.querySelectorAll(".item-card").forEach(card => {
    const name = (card.dataset.name || "").toLowerCase();
    const tag = (card.dataset.tag || "").toLowerCase();
    const color = (card.dataset.color || "").toLowerCase();
    const season = (card.dataset.season || "").toLowerCase();
    const occasion = (card.dataset.occasion || "").toLowerCase();
    const hay = [name, tag, color, season, occasion].join(" ");
    card.style.display = !q || hay.includes(q) ? "" : "none";
  });
}

function openDetail(card) {
  if (!card) return;
  if (activeCard) activeCard.classList.remove("active");
  card.classList.add("active");
  activeCard = card;

  document.getElementById("detail-col")?.classList.add("open");
  document.getElementById("drawer-overlay")?.classList.add("open");

  const name = card.dataset.name || "";
  const tag = card.dataset.tag || "";
  const color = card.dataset.color || "";
  const season = card.dataset.season || "";
  const occasion = card.dataset.occasion || "";
  const emoji = card.dataset.emoji || "👕";
  const gradient = card.dataset.gradient || "";
  const wornCount = Number(card.dataset.wornCount || "0");
  const isFewUsed = (card.dataset.fewUsed || "") === "true";
  const dates = (card.dataset.dates || "").split("|").filter(Boolean);
  const dna = (card.dataset.dna || "")
    .split("|")
    .filter(Boolean)
    .map(entry => {
      const [label, value] = entry.split("~");
      return { label: label || "", value: Number(value || "0") };
    });
  const outfits = (card.dataset.outfits || "")
    .split("|")
    .filter(Boolean)
    .map(entry => {
      const [date, outfitName, outfitOccasion] = entry.split("~");
      return { date: date || "", name: outfitName || "", occasion: outfitOccasion || "" };
    });

  const content = document.getElementById("detail-content");
  if (content) {
    const chips = [
      { cls: "cat", text: tag },
      { cls: isFewUsed ? "few" : "worn", text: isFewUsed ? "Few used" : `Worn ${wornCount}×` },
      { cls: "color", text: color }
    ].filter(x => (x.text || "").trim().length > 0);

    content.innerHTML = `
      <div class="detail-name">${escapeHtml(name)}</div>
      <div class="detail-tags">
        ${chips.map(c => `<span class="d-tag ${c.cls}">${escapeHtml(c.text)}</span>`).join("")}
      </div>
      <div class="detail-sec">
        <div class="detail-sec-label">Wear frequency this month</div>
        <div class="freq-bar"><div class="freq-fill" style="width:${Math.min(100, wornCount * 10)}%"></div></div>
        <div class="worn-dates">${dates.map(date => `<span class="worn-chip">${escapeHtml(date)}</span>`).join("")}</div>
      </div>
      <div class="detail-sec">
        <div class="detail-sec-label">Style profile</div>
        <div class="style-dna">
          ${dna.map(profile => `
            <div class="dna-row">
              <span class="dna-label">${escapeHtml(profile.label)}</span>
              <div class="dna-bar-wrap"><div class="dna-bar" style="width:${profile.value}%"></div></div>
              <span class="dna-val">${profile.value}%</span>
            </div>`).join("")}
        </div>
      </div>
      <div class="detail-sec">
        <div class="detail-sec-label">Recent outfits</div>
        <div class="outfit-chips">
          ${outfits.map(outfit => `
            <div class="outfit-chip">
              <div><div class="oc-date">${escapeHtml(outfit.date)}</div><div class="oc-name">${escapeHtml(outfit.name)}</div></div>
              <span class="oc-occ">${escapeHtml(outfit.occasion)}</span>
            </div>`).join("")}
        </div>
      </div>
    `;
  }

  const emojiEl = document.getElementById("detail-emoji");
  if (emojiEl) {
    emojiEl.textContent = emoji;
  }

  const img = document.getElementById("detail-img");
  if (img) {
    const parts = String(gradient).split(",");
    const from = parts[0] ? `#${parts[0].trim()}` : "rgba(242,224,213,0.92)";
    const to = parts[1] ? `#${parts[1].trim()}` : "rgba(211,206,184,0.78)";
    img.style.background = `linear-gradient(145deg,${from},${to})`;
  }

  document.getElementById("detail-scroll")?.scrollTo?.({ top: 0 });
}

function closeDetail() {
  document.getElementById("detail-col")?.classList.remove("open");
  document.getElementById("drawer-overlay")?.classList.remove("open");
  if (activeCard) {
    activeCard.classList.remove("active");
    activeCard = null;
  }
}

function removeCard(ev) {
  ev?.stopPropagation?.();
  const card = ev?.target?.closest?.(".item-card");
  if (!card) return;
  card.style.transition = "all .2s";
  card.style.opacity = "0";
  card.style.transform = "scale(.9)";
  setTimeout(() => { card.remove(); closeDetail(); }, 200);
}

function removeActive() {
  if (!activeCard) return;
  activeCard.style.transition = "all .2s";
  activeCard.style.opacity = "0";
  activeCard.style.transform = "scale(.9)";
  setTimeout(() => { activeCard.remove(); closeDetail(); }, 200);
}

function styleWithThis() {
  alert("Generating outfit with this item...");
}

function escapeHtml(str) {
  return String(str || "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll("\"", "&quot;")
    .replaceAll("'", "&#39;");
}

document.addEventListener("click", (e) => {
  const card = e.target?.closest?.(".item-card");
  if (!card) return;
  openDetail(card);
});

document.addEventListener("DOMContentLoaded", () => {
  wwClosetImportInit();
});
</script>
