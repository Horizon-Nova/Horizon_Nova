@{
    Layout = null;
}

<script>
let activeCard = null;
let importTimerIds = [];
let importIsRunning = false;

function wwClosetImportInit() {
  const zone = document.getElementById("ww-closet-import-zone");
  const input = document.getElementById("ww-closet-import-input");
  const chooseBtn = document.getElementById("ww-closet-import-btn");
  const againBtn = document.getElementById("ww-closet-import-again-btn");

  if (!zone || !input) return;

  const openPicker = () => input.click();

  zone.addEventListener("click", (e) => {
    if (importIsRunning) return;
    if (e.target?.closest?.("button")) return;
    openPicker();
  });

  zone.addEventListener("dragover", (e) => {
    e.preventDefault();
    if (importIsRunning) return;
    zone.classList.add("drag-over");
  });

  zone.addEventListener("dragleave", () => {
    zone.classList.remove("drag-over");
  });

  zone.addEventListener("drop", (e) => {
    e.preventDefault();
    zone.classList.remove("drag-over");
    if (importIsRunning) return;
    const files = Array.from(e.dataTransfer?.files || []).filter(f => (f.type || "").startsWith("image/"));
    if (files.length <= 0) return;
    wwClosetImportStart(files);
  });

  input.addEventListener("change", () => {
    if (importIsRunning) return;
    const files = Array.from(input.files || []);
    if (files.length <= 0) return;
    wwClosetImportStart(files);
  });

  chooseBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    if (importIsRunning) return;
    openPicker();
  });

  againBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    wwClosetImportReset();
  });
}

async function wwClosetImportStart(files) {
  const idle = document.getElementById("ww-closet-iz-idle");
  const scanning = document.getElementById("ww-closet-iz-scanning");
  const done = document.getElementById("ww-closet-iz-done");
  const input = document.getElementById("ww-closet-import-input");

  if (!idle || !scanning || !done) return;

  importIsRunning = true;
  wwClosetImportClearTimers();

  idle.style.display = "none";
  done.style.display = "none";
  scanning.style.display = "flex";

  // 步驟 1–3：固定時序過渡（cur → done）
  const earlySteps = [
    { dot: "ww-closet-ss1", txt: "ww-closet-st1", curAt: 400,  doneAt: 950  },
    { dot: "ww-closet-ss2", txt: "ww-closet-st2", curAt: 1050, doneAt: 1600 },
    { dot: "ww-closet-ss3", txt: "ww-closet-st3", curAt: 1700, doneAt: 2250 },
  ];

  earlySteps.forEach(({ dot, txt, curAt, doneAt }) => {
    importTimerIds.push(window.setTimeout(() => {
      document.getElementById(dot)?.classList.add("cur");
      document.getElementById(txt)?.classList.add("cur");
    }, curAt));
    importTimerIds.push(window.setTimeout(() => {
      const dotEl = document.getElementById(dot);
      const txtEl = document.getElementById(txt);
      dotEl?.classList.remove("cur");
      txtEl?.classList.remove("cur");
      dotEl?.classList.add("done");
      txtEl?.classList.add("done");
    }, doneAt));
  });

  // 步驟 4：進入 cur（脈衝）後一直等，直到 API 回應後才 done
  importTimerIds.push(window.setTimeout(() => {
    document.getElementById("ww-closet-ss4")?.classList.add("cur");
    document.getElementById("ww-closet-st4")?.classList.add("cur");
  }, 2400));

  // 等待實際上傳完成
  let importResult = null;
  let importError = null;
  try {
    importResult = await wwClosetImportUpload(files);
  } catch (err) {
    importError = err;
  }

  // API 完成後才把步驟 4 標為 done
  const ss4 = document.getElementById("ww-closet-ss4");
  const st4 = document.getElementById("ww-closet-st4");
  ss4?.classList.remove("cur");
  st4?.classList.remove("cur");
  ss4?.classList.add("done");
  st4?.classList.add("done");

  // 短暫停留讓使用者看到「全部完成」後切換畫面
  await new Promise(resolve => importTimerIds.push(window.setTimeout(resolve, 350)));

  scanning.style.display = "none";
  done.style.display = "flex";
  wwClosetImportRenderDone(files, importResult, importError);
  if (importResult?.items?.length) {
    wwClosetAppendImportedItems(importResult.items);
  }
  if (input) input.value = "";
  importIsRunning = false;
}

async function wwClosetImportUpload(files) {
  const form = new FormData();
  Array.from(files || []).forEach(file => form.append("image[]", file));

  const response = await fetch("/WW/Closet/ImportImages", {
    method: "POST",
    body: form
  });

  const payload = await response.json().catch(() => null);
  if (!response.ok) {
    if (payload?.items?.length) {
      return payload;
    }

    const message = payload?.message || payload?.errors?.[0] || "Import failed";
    throw new Error(message);
  }

  return payload;
}

function wwClosetImportRenderDone(files, result, error) {
  const chips = document.getElementById("ww-closet-import-done-chips");
  if (!chips) return;

  const labels = error
    ? [error.message || "Import failed"]
    : ["匯入完成"];

  chips.innerHTML = labels.map(text => `<div class="done-chip">${escapeHtml(text)}</div>`).join("");
}

function wwClosetAppendImportedItems(items) {
  const categoryGridMap = {
    tops: "tops-grid",
    bottoms: "bottoms-grid",
    outerwear: "outerwear-grid",
    shoes: "shoes-grid",
    accessories: "acc-grid",
    uncategorized: "uncategorized-grid",
    unconfirmed: "review-grid"
  };

  let reviewGrid = document.getElementById("review-grid");
  let grid = reviewGrid;
  if (!grid) {
    const closet = document.getElementById("closet-col");
    if (!closet) return;
    const section = document.createElement("div");
    section.innerHTML = `
      <div class="sec-header">
        <span class="sec-label">Review</span>
        <span class="sec-count" id="review-count">0</span>
      </div>
      <div style="margin-top:10px;" class="item-grid cols-4" id="review-grid"></div>`;
    closet.prepend(section);
    grid = document.getElementById("review-grid");
    reviewGrid = grid;
  }

  if (!grid) return;

  items.forEach(item => {
    const targetCategory = item.categoryKey && item.categoryKey !== "uncategorized"
      ? item.categoryKey
      : "unconfirmed";
    const targetGrid = document.getElementById(categoryGridMap[targetCategory] || "review-grid") || reviewGrid;
    if (!targetGrid) return;

    const card = document.createElement("div");
    const label = item.label || item.categoryKey || "AI item";
    const imageUrl = item.generatedImageUrl || item.imageUrl || item.croppedImageUrl || "";
    card.className = "item-card";
    card.dataset.cat = targetCategory;
    card.dataset.name = label;
    card.dataset.tag = targetCategory === "unconfirmed" ? "Review" : targetCategory;
    card.dataset.color = "Unknown";
    card.dataset.season = "Unknown";
    card.dataset.occasion = "";
    card.dataset.gradient = "f5ede0,#ead8c0";
    card.dataset.emoji = "";
    card.dataset.wornCount = "0";
    card.dataset.fewUsed = "true";
    card.dataset.dates = "";
    card.dataset.dna = "";
    card.dataset.outfits = "";
    card.innerHTML = `
      <div class="item-x" onclick="removeCard(event)">
        <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
      </div>
      <div class="item-img" style="${imageUrl ? `background-image:url('${escapeHtml(imageUrl)}');background-size:cover;background-position:center;` : "background:linear-gradient(145deg,#f5ede0,#ead8c0);"}"></div>
      <div class="item-info">
        <div class="item-name">${escapeHtml(label)}</div>
        <div class="item-worn few">Few used</div>
      </div>`;
    targetGrid.prepend(card);
  });

  const countEl = document.getElementById("review-count");
  if (countEl && reviewGrid) countEl.textContent = String(reviewGrid.querySelectorAll(".item-card").length);
}

function wwClosetImportReset() {
  const idle = document.getElementById("ww-closet-iz-idle");
  const scanning = document.getElementById("ww-closet-iz-scanning");
  const done = document.getElementById("ww-closet-iz-done");

  if (!idle || !scanning || !done) return;

  wwClosetImportClearTimers();
  importIsRunning = false;

  scanning.style.display = "none";
  done.style.display = "none";
  idle.style.display = "flex";

  ["ww-closet-ss1", "ww-closet-ss2", "ww-closet-ss3", "ww-closet-ss4"].forEach(id => {
    const el = document.getElementById(id);
    el?.classList.remove("cur");
    el?.classList.remove("done");
  });
  ["ww-closet-st1", "ww-closet-st2", "ww-closet-st3", "ww-closet-st4"].forEach(id => {
    const el = document.getElementById(id);
    el?.classList.remove("cur");
    el?.classList.remove("done");
  });
}

function wwClosetImportClearTimers() {
  importTimerIds.forEach(id => window.clearTimeout(id));
  importTimerIds = [];
}

function wwClosetSearch(query) {
  const q = (query || "").trim().toLowerCase();
  document.querySelectorAll(".item-card").forEach(card => {
    const name = (card.dataset.name || "").toLowerCase();
    const tag = (card.dataset.tag || "").toLowerCase();
    const color = (card.dataset.color || "").toLowerCase();
    const season = (card.dataset.season || "").toLowerCase();
    const occasion = (card.dataset.occasion || "").toLowerCase();
    const hay = [name, tag, color, season, occasion].join(" ");
    card.style.display = !q || hay.includes(q) ? "" : "none";
  });
}

function openDetail(card) {
  if (!card) return;
  if (activeCard) activeCard.classList.remove("active");
  card.classList.add("active");
  activeCard = card;

  document.getElementById("detail-col")?.classList.add("open");
  document.getElementById("drawer-overlay")?.classList.add("open");

  const name = card.dataset.name || "";
  const tag = card.dataset.tag || "";
  const color = card.dataset.color || "";
  const season = card.dataset.season || "";
  const occasion = card.dataset.occasion || "";
  const emoji = card.dataset.emoji || "";
  const gradient = card.dataset.gradient || "";
  const wornCount = Number(card.dataset.wornCount || "0");
  const isFewUsed = (card.dataset.fewUsed || "") === "true";
  const dates = (card.dataset.dates || "").split("|").filter(Boolean);
  const dna = (card.dataset.dna || "")
    .split("|")
    .filter(Boolean)
    .map(entry => {
      const [label, value] = entry.split("~");
      return { label: label || "", value: Number(value || "0") };
    });
  const outfits = (card.dataset.outfits || "")
    .split("|")
    .filter(Boolean)
    .map(entry => {
      const [date, outfitName, outfitOccasion] = entry.split("~");
      return { date: date || "", name: outfitName || "", occasion: outfitOccasion || "" };
    });

  const content = document.getElementById("detail-content");
  if (content) {
    const chips = [
      { cls: "cat", text: tag },
      { cls: isFewUsed ? "few" : "worn", text: isFewUsed ? "Few used" : `Worn ${wornCount}` },
      { cls: "color", text: color }
    ].filter(x => (x.text || "").trim().length > 0);

    content.innerHTML = `
      <div class="detail-name">${escapeHtml(name)}</div>
      <div class="detail-tags">
        ${chips.map(c => `<span class="d-tag ${c.cls}">${escapeHtml(c.text)}</span>`).join("")}
      </div>
      <div class="detail-sec">
        <div class="detail-sec-label">Wear frequency this month</div>
        <div class="freq-bar"><div class="freq-fill" style="width:${Math.min(100, wornCount * 10)}%"></div></div>
        <div class="worn-dates">${dates.map(date => `<span class="worn-chip">${escapeHtml(date)}</span>`).join("")}</div>
      </div>
      <div class="detail-sec">
        <div class="detail-sec-label">Style profile</div>
        <div class="style-dna">
          ${dna.map(profile => `
            <div class="dna-row">
              <span class="dna-label">${escapeHtml(profile.label)}</span>
              <div class="dna-bar-wrap"><div class="dna-bar" style="width:${profile.value}%"></div></div>
              <span class="dna-val">${profile.value}%</span>
            </div>`).join("")}
        </div>
      </div>
      <div class="detail-sec">
        <div class="detail-sec-label">Recent outfits</div>
        <div class="outfit-chips">
          ${outfits.map(outfit => `
            <div class="outfit-chip">
              <div><div class="oc-date">${escapeHtml(outfit.date)}</div><div class="oc-name">${escapeHtml(outfit.name)}</div></div>
              <span class="oc-occ">${escapeHtml(outfit.occasion)}</span>
            </div>`).join("")}
        </div>
      </div>
    `;
  }

  const emojiEl = document.getElementById("detail-emoji");
  if (emojiEl) {
    emojiEl.textContent = emoji;
  }

  const img = document.getElementById("detail-img");
  if (img) {
    const cardImage = card.querySelector(".item-img");
    const imageBackground = cardImage?.style?.backgroundImage || "";
    if (imageBackground) {
      img.style.backgroundImage = imageBackground;
      img.style.backgroundSize = "cover";
      img.style.backgroundPosition = "center";
    } else {
      const parts = String(gradient).split(",");
      const from = parts[0] ? `#${parts[0].trim()}` : "rgba(242,224,213,0.92)";
      const to = parts[1] ? `#${parts[1].trim()}` : "rgba(211,206,184,0.78)";
      img.style.background = `linear-gradient(145deg,${from},${to})`;
    }
  }

  document.getElementById("detail-scroll")?.scrollTo?.({ top: 0 });
}

function closeDetail() {
  document.getElementById("detail-col")?.classList.remove("open");
  document.getElementById("drawer-overlay")?.classList.remove("open");
  if (activeCard) {
    activeCard.classList.remove("active");
    activeCard = null;
  }
}

function removeCard(ev) {
  ev?.stopPropagation?.();
  const card = ev?.target?.closest?.(".item-card");
  if (!card) return;
  card.style.transition = "all .2s";
  card.style.opacity = "0";
  card.style.transform = "scale(.9)";
  setTimeout(() => { card.remove(); closeDetail(); }, 200);
}

function removeActive() {
  if (!activeCard) return;
  activeCard.style.transition = "all .2s";
  activeCard.style.opacity = "0";
  activeCard.style.transform = "scale(.9)";
  setTimeout(() => { activeCard.remove(); closeDetail(); }, 200);
}

function styleWithThis() {
  if (!activeCard) return;

  const selectedItem = {
    name: activeCard.dataset.name || "",
    categoryKey: activeCard.dataset.cat || "",
    tag: activeCard.dataset.tag || "",
    color: activeCard.dataset.color || "",
    imageUrl: activeCard.querySelector(".item-img")?.style?.backgroundImage || ""
  };

  sessionStorage.setItem("wwStyleWithItem", JSON.stringify(selectedItem));
  window.location.href = "/WW/Today";
}

function escapeHtml(str) {
  return String(str || "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll("\"", "&quot;")
    .replaceAll("'", "&#39;");
}

document.addEventListener("click", (e) => {
  const card = e.target?.closest?.(".item-card");
  if (!card) return;
  openDetail(card);
});

document.addEventListener("DOMContentLoaded", () => {
  wwClosetImportInit();
});
</script>
