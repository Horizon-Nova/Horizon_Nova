@using System.Linq
@model HNB.Areas.WW.Models.WardrobeIndexModel

@{
    Layout = null;

    var items = Model?.Items ?? Enumerable.Empty<HNB.Areas.WW.Models.WardrobeItemModel>();

    int CountByCategory(string key)
        => items.Count(i => (i.IsPendingReview ? "unconfirmed" : i.CategoryKey) == key);

    string CategoryShortTag(string key)
        => key switch
        {
            "tops" => "Tops",
            "bottoms" => "Bottoms",
            "outerwear" => "Outerwear",
            "shoes" => "Shoes",
            "accessories" => "Accessories",
            "unconfirmed" => "Review",
            "uncategorized" => "Uncategorized",
            _ => "Item"
        };

    string StableCardGradient(string categoryKey, string itemName)
    {
        var palette = categoryKey switch
        {
            "tops" => new[] { "f0ebe2,#e5ddd0", "e8edf2,#d8e2ec", "2a2a2a,#1a1a1a", "f5ede0,#ead8c0" },
            "outerwear" => new[] { "2c3a4a,#1e2c3a", "c8b898,#b8a880" },
            "bottoms" => new[] { "1a1a2e,#16213e", "e8e0d0,#d8d0c0" },
            "shoes" => new[] { "3a2e22,#2a1e12", "f5f5f5,#e8e8e8" },
            "accessories" => new[] { "e9dccf,#dcc8b5", "d4c7ba,#c8b8aa" },
            "unconfirmed" => new[] { "f5ede0,#ead8c0", "e8e0d8,#d8d0c8" },
            _ => new[] { "f5efe6,#ece5d8" }
        };

        var idx = Math.Abs((itemName ?? string.Empty).GetHashCode()) % palette.Length;
        return palette[idx];
    }

    var confirmedItems = items.Where(i => i.IsPendingReview == false).ToList();
    var tops = confirmedItems.Where(i => (i.IsUncategorized ? "uncategorized" : i.CategoryKey) == "tops").ToList();
    var bottoms = confirmedItems.Where(i => (i.IsUncategorized ? "uncategorized" : i.CategoryKey) == "bottoms").ToList();
    var outerwear = confirmedItems.Where(i => (i.IsUncategorized ? "uncategorized" : i.CategoryKey) == "outerwear").ToList();
    var shoes = confirmedItems.Where(i => (i.IsUncategorized ? "uncategorized" : i.CategoryKey) == "shoes").ToList();
    var accessories = confirmedItems.Where(i => (i.IsUncategorized ? "uncategorized" : i.CategoryKey) == "accessories").ToList();
    var uncategorized = confirmedItems.Where(i => i.IsUncategorized).ToList();
    var unconfirmed = items.Where(i => i.IsPendingReview).ToList();
}

<div class="cols">
    <!-- CLOSET GRID -->
    <div class="closet-col" id="closet-col">
        <!-- Tops -->
        <div>
            <div class="sec-header">
                <span class="sec-label">Tops</span>
                <span class="sec-count">@CountByCategory("tops")</span>
            </div>
            <div style="margin-top:10px;" class="item-grid cols-4" id="tops-grid">
                @foreach (var item in tops)
                {
                    var cat = item.IsPendingReview ? "unconfirmed" : (item.CategoryKey ?? "tops");
                    var tag = CategoryShortTag(cat);
                    var gradient = StableCardGradient(cat, item.Name);
                    @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                }
            </div>
        </div>

        <!-- Bottoms -->
        <div>
            <div class="sec-header">
                <span class="sec-label">Bottoms</span>
                <span class="sec-count">@CountByCategory("bottoms")</span>
            </div>
            <div style="margin-top:10px;" class="item-grid cols-4" id="bottoms-grid">
                @foreach (var item in bottoms)
                {
                    var cat = item.IsPendingReview ? "unconfirmed" : (item.CategoryKey ?? "bottoms");
                    var tag = CategoryShortTag(cat);
                    var gradient = StableCardGradient(cat, item.Name);
                    @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                }
            </div>
        </div>

        <!-- Shoes -->
        <div>
            <div class="sec-header">
                <span class="sec-label">Shoes</span>
                <span class="sec-count">@CountByCategory("shoes")</span>
            </div>
            <div style="margin-top:10px;" class="item-grid cols-4" id="shoes-grid">
                @foreach (var item in shoes)
                {
                    var cat = item.IsPendingReview ? "unconfirmed" : (item.CategoryKey ?? "shoes");
                    var tag = CategoryShortTag(cat);
                    var gradient = StableCardGradient(cat, item.Name);
                    @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                }
            </div>
        </div>

        <!-- Outerwear -->
        <div>
            <div class="sec-header">
                <span class="sec-label">Outerwear</span>
                <span class="sec-count">@CountByCategory("outerwear")</span>
            </div>
            <div style="margin-top:10px;" class="item-grid cols-4" id="outerwear-grid">
                @foreach (var item in outerwear)
                {
                    var cat = item.IsPendingReview ? "unconfirmed" : (item.CategoryKey ?? "outerwear");
                    var tag = CategoryShortTag(cat);
                    var gradient = StableCardGradient(cat, item.Name);
                    @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                }
            </div>
        </div>

        <!-- Accessories -->
        <div>
            <div class="sec-header">
                <span class="sec-label">Accessories</span>
                <span class="sec-count">@CountByCategory("accessories")</span>
            </div>
            <div style="margin-top:10px;" class="item-grid cols-4" id="acc-grid">
                @foreach (var item in accessories)
                {
                    var cat = item.IsPendingReview ? "unconfirmed" : (item.CategoryKey ?? "accessories");
                    var tag = CategoryShortTag(cat);
                    var gradient = StableCardGradient(cat, item.Name);
                    @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                }
            </div>
        </div>

        <!-- Uncategorized -->
        @if (uncategorized.Any())
        {
            <div>
                <div class="sec-header">
                    <span class="sec-label">Uncategorized</span>
                    <span class="sec-count">@uncategorized.Count</span>
                </div>
                <div style="margin-top:10px;" class="item-grid cols-4" id="uncategorized-grid">
                    @foreach (var item in uncategorized)
                    {
                        var cat = "uncategorized";
                        var tag = CategoryShortTag(cat);
                        var gradient = StableCardGradient(cat, item.Name);
                        @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                    }
                </div>
            </div>
        }

        <!-- Review (pending) -->
        @if (unconfirmed.Any())
        {
            <div>
                <div class="sec-header">
                    <span class="sec-label">Review</span>
                    <span class="sec-count">@unconfirmed.Count</span>
                </div>
                <div style="margin-top:10px;" class="item-grid cols-4" id="review-grid">
                    @foreach (var item in unconfirmed)
                    {
                        var cat = "unconfirmed";
                        var tag = CategoryShortTag(cat);
                        var gradient = StableCardGradient(cat, item.Name);
                        @await Html.PartialAsync("Partials/_ClothingCard", (item, cat, tag, gradient))
                    }
                </div>
            </div>
        }
    </div>

    <!-- OVERLAY -->
    <div class="drawer-overlay" id="drawer-overlay" onclick="closeDetail()"></div>

    <!-- DETAIL DRAWER -->
    <div class="detail-col" id="detail-col">
        <div class="detail-scroll" id="detail-scroll">
            <div class="detail-img" id="detail-img">
                <button type="button" class="detail-close" onclick="closeDetail()" aria-label="Close detail">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
                <span id="detail-emoji" style="font-size:72px;">👕</span>
            </div>

            <div class="detail-content" id="detail-content"></div>

            <div class="detail-actions" id="detail-actions">
                <button type="button" class="act-btn primary" onclick="styleWithThis()">
                    <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                    Style with this item
                </button>
                <button type="button" class="act-btn danger" onclick="removeActive()">
                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" /><path d="M10 11v6M14 11v6" /></svg>
                    Remove from closet
                </button>
            </div>
        </div>
    </div>
</div>
