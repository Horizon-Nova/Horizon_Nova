@using System.Globalization
@using System.Linq
@model (HNB.Areas.WW.Models.WardrobeItemModel Item, string Cat, string Tag, string Gradient)

@{
    var item = Model.Item;
    var cat = Model.Cat;
    var tag = Model.Tag;
    var gradient = Model.Gradient;

    int QueryWornCount()
    {
        var seed = Math.Abs($"{item.Id}|{item.Name}|{cat}".GetHashCode());
        return (seed % 10) + 1;
    }

    bool QueryFewUsed()
        => QueryWornCount() <= 2;

    string QueryDatesData()
    {
        var limit = Math.Min(QueryWornCount(), 5);
        var seed = Math.Abs((item.Id ?? string.Empty).GetHashCode());
        var baseDate = new DateOnly(2026, 4, 20);

        return string.Join("|", Enumerable.Range(0, limit)
            .Select(index => baseDate.AddDays(-((seed + (index * 3)) % 24)).ToString("MMM d", CultureInfo.InvariantCulture)));
    }

    string QueryStyleProfileData()
    {
        var labels = cat switch
        {
            "tops" => new[] { "Versatility", "Formality", "Layerability" },
            "bottoms" => new[] { "Versatility", "Formality", "Seasonality" },
            "outerwear" => new[] { "Versatility", "Formality", "Layerability" },
            "shoes" => new[] { "Versatility", "Formality", "Comfort" },
            "accessories" => new[] { "Versatility", "Formality", "Capacity" },
            _ => new[] { "Versatility", "Formality", "Seasonality" }
        };

        var seed = Math.Abs($"{item.Name}|{item.PrimaryColor}|{cat}".GetHashCode());
        return string.Join("|", labels.Select((label, index) =>
        {
            var value = 45 + ((seed + (index * 17)) % 51);
            return $"{label}~{value}";
        }));
    }

    string QueryRecentOutfitsData()
    {
        var occasion = string.IsNullOrWhiteSpace(item.Occasion) ? "Casual" : item.Occasion;
        var lookNames = occasion switch
        {
            "上班" => new[] { "Office Classic", "Board Meeting", "Workday Layers" },
            "約會" => new[] { "Dinner Date", "Evening Glow", "Weekend Dress Up" },
            "通勤" => new[] { "City Commute", "Rainy Commute", "Early Train" },
            _ => new[] { "Weekend Glow", "Sunday Easy", "Casual Friday" }
        };

        return string.Join("|", QueryDatesData()
            .Split('|', StringSplitOptions.RemoveEmptyEntries)
            .Take(3)
            .Select((date, index) => $"{date}~{lookNames[index % lookNames.Length]}~{occasion}"));
    }

    var wornCount = QueryWornCount();
    var fewUsed = QueryFewUsed();
    var datesData = QueryDatesData();
    var styleProfileData = QueryStyleProfileData();
    var recentOutfitsData = QueryRecentOutfitsData();

    var emoji = cat switch
    {
        "bottoms" => "👖",
        "outerwear" => "🧥",
        "shoes" => "👟",
        "accessories" => "👜",
        "unconfirmed" => "🧷",
        "uncategorized" => "🧺",
        _ => "👕"
    };
}

<div class="item-card"
     data-cat="@cat"
     data-name="@item.Name"
     data-tag="@tag"
     data-color="@item.PrimaryColor"
     data-season="@item.Season"
     data-occasion="@item.Occasion"
     data-gradient="@gradient"
     data-emoji="@emoji"
     data-worn-count="@wornCount"
     data-few-used="@fewUsed.ToString().ToLowerInvariant()"
     data-dates="@datesData"
     data-dna="@styleProfileData"
     data-outfits="@recentOutfitsData">

    <div class="item-x" onclick="removeCard(event)">
        <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
    </div>

    <div class="item-img" style="background:linear-gradient(145deg,#@gradient);">@emoji</div>

    <div class="item-info">
        <div class="item-name">@item.Name</div>
        @if (fewUsed)
        {
            <div class="item-worn few">Few used</div>
        }
        else
        {
            <div class="item-worn">Worn @wornCount×</div>
        }
    </div>
</div>
