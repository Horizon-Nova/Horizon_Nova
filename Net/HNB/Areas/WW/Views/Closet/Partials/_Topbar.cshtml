@using System.Linq
@model HNB.Areas.WW.Models.WardrobeIndexModel
@{
    Layout = null;

    var totalItems = Model?.Items?.Count(i => i.IsPendingReview == false) ?? 0;
    var pendingItems = Model?.Items?.Count(i => i.IsPendingReview) ?? 0;
}

<!-- TOPBAR (wtw_closet_desktop.html) -->
<div class="tb">
    <div class="tb-left">
        <span class="tb-brand">My <em>Closet</em></span>
        <span class="tb-count" id="stat-total">@totalItems items</span>
    </div>
    <div class="tb-search" aria-label="Search items">
        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
        <input type="text" id="closet-search" placeholder="Search items..." oninput="wwClosetSearch(this.value)" />
    </div>
</div>
