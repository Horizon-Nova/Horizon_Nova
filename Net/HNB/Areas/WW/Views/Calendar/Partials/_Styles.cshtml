@{
    Layout = null;
}

<style>
    /* 只保留 Tailwind 不好處理的細節：動畫與 scrollbar */
    @@keyframes wwFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .ww-fade-up {
        animation: wwFadeUp .22s ease;
    }

    /* Webkit scrollbar（設計圖是細 scrollbar） */
    .ww-calendar-scroll::-webkit-scrollbar {
        width: 3px;
        height: 3px;
    }

    .ww-calendar-scroll::-webkit-scrollbar-thumb {
        background: rgba(211,206,184,.95);
        border-radius: 2px;
    }
</style>
