@{
    Layout = null;
}

<script>
    (function () {
        "use strict";

        var MONTHS = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

        // 示範資料：先對齊設計圖互動；後續可再接 API/Model
        var dayData = {
            "Apr 18": {
                cards: [
                    {
                        tag: "Work", weather: "22\u00B0 Partly cloudy", name: "Office Classic", hasPhoto: true,
                        items: [
                            { name: "White Button-Down", cat: "Top", bg: "#f5f5f5", icon: "shirt" },
                            { name: "Beige Chinos", cat: "Bottom", bg: "#d8c8a8", icon: "pants" },
                            { name: "Derby Shoes", cat: "Shoes", bg: "#8a7060", icon: "shoes" }
                        ]
                    },
                    {
                        tag: "Work", weather: "22\u00B0 Partly cloudy", name: "Smart Casual Friday", hasPhoto: false,
                        items: [
                            { name: "Merino Sweater", cat: "Top", bg: "#c8b898", icon: "shirt" },
                            { name: "Dark Jeans", cat: "Bottom", bg: "#3a4858", icon: "pants" },
                            { name: "Chelsea Boots", cat: "Shoes", bg: "#5a4838", icon: "shoes" }
                        ]
                    }
                ]
            },
            "Apr 19": {
                cards: [
                    {
                        tag: "Date", weather: "20\u00B0 Rain", name: "Rainy Evening", hasPhoto: false,
                        items: [
                            { name: "Navy Jacket", cat: "Outer", bg: "#3a4a5a", icon: "shirt" },
                            { name: "Silk Top", cat: "Top", bg: "#e8d8c8", icon: "shirt" },
                            { name: "Slim Trousers", cat: "Bottom", bg: "#5a5050", icon: "pants" }
                        ]
                    },
                    {
                        tag: "Date", weather: "20\u00B0 Rain", name: "Date Night Dark", hasPhoto: false,
                        items: [
                            { name: "Black Coat", cat: "Outer", bg: "#2a2a2a", icon: "shirt" },
                            { name: "Turtleneck", cat: "Top", bg: "#4a4040", icon: "shirt" },
                            { name: "Tapered Pants", cat: "Bottom", bg: "#3a3030", icon: "pants" }
                        ]
                    }
                ]
            },
            "Apr 20": {
                cards: [
                    {
                        tag: "Casual", weather: "24\u00B0 Clear", name: "Weekend Glow", hasPhoto: true,
                        items: [
                            { name: "Linen Shirt", cat: "Top", bg: "#f0ebe2", icon: "shirt" },
                            { name: "White Shorts", cat: "Bottom", bg: "#f5f0e8", icon: "pants" },
                            { name: "Sneakers", cat: "Shoes", bg: "#f5f5f5", icon: "shoes" },
                            { name: "Tote Bag", cat: "Bag", bg: "#c8b070", icon: "bag" }
                        ]
                    },
                    {
                        tag: "Casual", weather: "24\u00B0 Clear", name: "Sunny Alternative", hasPhoto: false,
                        items: [
                            { name: "Striped Tee", cat: "Top", bg: "#e8ecf0", icon: "shirt" },
                            { name: "Linen Pants", cat: "Bottom", bg: "#f0ebe2", icon: "pants" },
                            { name: "Loafers", cat: "Shoes", bg: "#b8a888", icon: "shoes" }
                        ]
                    }
                ]
            }
        };

        var outfitDays = [1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 13, 14, 15, 16, 17, 18, 19, 20]; // April mock
        var _now = new Date();
        var currentYear = _now.getFullYear();
        var currentMonth = _now.getMonth();
        var _todayNum = _now.getDate();
        var currentDayKey = MONTHS[currentMonth].slice(0, 3) + " " + _todayNum;
        var pendingUploadTarget = null;
        var realLookDates = new Set(); // ISO yyyy-MM-dd strings from API

        function byId(id) {
            return document.getElementById(id);
        }

        function safeText(el, text) {
            if (!el) return;
            el.textContent = text;
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function getIconSvg(type) {
            var icons = {
                shirt: '<path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/>',
                pants: '<path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z"/>',
                shoes: '<ellipse cx="8" cy="14" rx="7" ry="5"/><ellipse cx="24" cy="14" rx="7" ry="5"/><path d="M1 14V8a6 6 0 0 1 12 0v2h6V8a6 6 0 0 1 12 0v6"/>',
                bag: '<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>'
            };

            var vb = type === "shoes" ? "0 0 32 20" : "0 0 24 24";
            var sz = type === "shoes" ? 'width="18" height="12"' : 'width="16" height="16"';
            var p = icons[type] || icons.shirt;
            return '<svg ' + sz + ' viewBox="' + vb + '" class="fill-none stroke-black/20 stroke-[1.6] [stroke-linecap:round] [stroke-linejoin:round]">' + p + "</svg>";
        }

        function weatherIconName(text) {
            var t = String(text || "").toLowerCase();
            if (t.indexOf("rain") >= 0) return "cloud-rain";
            if (t.indexOf("storm") >= 0 || t.indexOf("thunder") >= 0) return "cloud-lightning";
            if (t.indexOf("snow") >= 0) return "cloud-snow";
            if (t.indexOf("clear") >= 0 || t.indexOf("sun") >= 0) return "sun";
            if (t.indexOf("cloud") >= 0) return "cloud-sun";
            return "cloud";
        }

        function toIsoDate(year, month, day) {
            return year + "-" + String(month + 1).padStart(2, "0") + "-" + String(day).padStart(2, "0");
        }

        function buildApiCard(look, index) {
            var id = "api-" + (look.id || index);
            var itemsHtml = (look.itemLabels || []).map(function (lbl) {
                return '<span class="inline-flex items-center gap-[4px] rounded-full bg-white/70 px-[10px] py-[4px] text-[10px] font-bold text-black/55">' + escapeHtml(lbl) + "</span>";
            }).join("");

            var leftPanel = look.generatedImageUrl
                ? '<div class="absolute inset-0 overflow-hidden rounded-[inherit]">' +
                  '  <img src="' + escapeHtml(look.generatedImageUrl) + '" alt="Outfit" style="width:100%;height:100%;object-fit:contain;background:linear-gradient(150deg,rgba(242,224,213,0.95),rgba(211,206,184,0.85));" />' +
                  '</div>'
                : '<div class="flex items-end gap-[10px]">' +
                  '  <div class="flex flex-col items-center gap-[4px]"><div class="flex items-center justify-center rounded-[9px] bg-black/10" style="width:44px;height:58px"><svg class="h-[22px] w-[22px] fill-none stroke-black/15 stroke-[1.2]" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg></div><div class="text-[9px] font-bold uppercase tracking-[0.2px] text-black/35">TOP</div></div>' +
                  '  <div class="flex flex-col items-center gap-[4px]"><div class="flex items-center justify-center rounded-[9px] bg-black/10" style="width:36px;height:64px"><svg class="h-[18px] w-[18px] fill-none stroke-black/15 stroke-[1.2]" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z"/></svg></div><div class="text-[9px] font-bold uppercase tracking-[0.2px] text-black/35">BOTTOM</div></div>' +
                  '  <div class="flex flex-col items-center gap-[4px]"><div class="flex items-center justify-center rounded-[9px] bg-black/10" style="width:44px;height:44px"><svg class="h-[22px] w-[22px] fill-none stroke-black/15 stroke-[1.2]" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5"/><ellipse cx="24" cy="14" rx="7" ry="5"/><path d="M1 14V8a6 6 0 0 1 12 0v2h6V8a6 6 0 0 1 12 0v6"/></svg></div><div class="text-[9px] font-bold uppercase tracking-[0.2px] text-black/35">SHOES</div></div>' +
                  '</div>';

            return '<div class="ww-fade-up overflow-hidden rounded-[18px] border border-white/85 bg-white/55 shadow-[0_4px_20px_rgba(0,0,0,0.07)] backdrop-blur-[12px]" id="card-' + id + '">' +
                '  <div class="relative flex min-h-[200px] flex-col items-center justify-center gap-2 bg-[linear-gradient(150deg,rgba(242,224,213,0.95),rgba(211,206,184,0.85))] py-5">' +
                '    <div class="absolute left-[12px] top-[12px] rounded-full bg-white/70 px-3 py-[4px] text-[10px] font-bold uppercase tracking-[0.08em] text-black/35">AI look</div>' +
                '    <div class="absolute right-[12px] top-[12px] rounded-full bg-white/75 px-[10px] py-[4px] text-[11px] font-bold text-black/60">' + escapeHtml(look.weatherSummary || "") + '</div>' +
                '    <div class="absolute left-[14px] top-[40px] inline-flex items-center rounded-full border border-[#d76736]/25 bg-[#f2e0d5] px-[12px] py-[4px] text-[12px] font-bold text-[#d76736]">' + escapeHtml(look.occasion || "") + '</div>' +
                     leftPanel +
                '  </div>' +
                '  <div class="px-[16px] pb-[14px] pt-[14px]">' +
                '    <div class="text-[17px] font-medium italic text-[#1e1b18] [font-family:var(--font-serif)]">' + escapeHtml(look.name || "AI Look") + '</div>' +
                '    <div class="mt-[10px] flex flex-wrap gap-[6px]">' + itemsHtml + '</div>' +
                '  </div>' +
                '</div>';
        }

        function buildCard(card, index, dayKey) {
            var id = dayKey.replace(/ /g, "") + "-" + index;

            var itemsHTML = (card.items || []).map(function (it) {
                var bg = (it && it.bg) ? String(it.bg) : "#f5f0e8";
                var name = (it && it.name) ? String(it.name) : "";
                var cat = (it && it.cat) ? String(it.cat) : "Item";
                var icon = (it && it.icon) ? String(it.icon) : "shirt";

                return '' +
                    '<div class="flex-1 cursor-pointer rounded-[10px] border border-white/85 bg-white/70 px-[10px] py-[10px] shadow-[0_2px_10px_rgba(0,0,0,0.04)] transition hover:border-[#e8b89e] hover:-translate-y-px">' +
                    '  <div class="mx-auto flex h-[40px] w-[36px] items-center justify-center rounded-[8px]" style="background:' + escapeHtml(bg) + '">' +
                    getIconSvg(icon) +
                    "  </div>" +
                    '  <div class="mt-[6px] text-center text-[9.5px] font-bold leading-[1.25] text-[#1e1b18]">' + escapeHtml(name) + "</div>" +
                    '  <div class="mt-[2px] text-center text-[8.5px] font-bold uppercase tracking-[0.03em] text-black/35">' + escapeHtml(cat) + "</div>" +
                    "</div>";
            }).join("");

            return '' +
                '<div class="ww-fade-up overflow-hidden rounded-[18px] border border-white/85 bg-white/55 shadow-[0_4px_20px_rgba(0,0,0,0.07)] backdrop-blur-[12px]" id="card-' + id + '">' +
                '  <div class="flex">' +
                '    <div class="relative flex min-h-[230px] flex-1 flex-col items-center justify-center gap-2 border-r border-white/60 bg-[linear-gradient(150deg,rgba(242,224,213,0.95),rgba(211,206,184,0.85))] py-5">' +
                '      <div class="absolute left-[12px] top-[12px] rounded-full bg-white/70 px-3 py-[4px] text-[10px] font-bold uppercase tracking-[0.08em] text-black/35">What I picked</div>' +
                '      <div class="flex items-end gap-[10px]">' +
                '        <div class="flex flex-col items-center gap-[4px]">' +
                '          <div class="flex items-center justify-center rounded-[9px] bg-black/10" style="width:44px;height:58px"><svg class="h-[22px] w-[22px] fill-none stroke-black/15 stroke-[1.2] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg></div>' +
                '          <div class="text-[9px] font-bold uppercase tracking-[0.2px] text-black/35">TOP</div>' +
                '        </div>' +
                '        <div class="flex flex-col items-center gap-[4px]">' +
                '          <div class="flex items-center justify-center rounded-[9px] bg-black/10" style="width:36px;height:64px"><svg class="h-[18px] w-[18px] fill-none stroke-black/15 stroke-[1.2] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z"/></svg></div>' +
                '          <div class="text-[9px] font-bold uppercase tracking-[0.2px] text-black/35">BOTTOM</div>' +
                '        </div>' +
                '        <div class="flex flex-col items-center gap-[4px]">' +
                '          <div class="flex items-center justify-center rounded-[9px] bg-black/10" style="width:44px;height:44px"><svg class="h-[22px] w-[22px] fill-none stroke-black/15 stroke-[1.2] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5"/><ellipse cx="24" cy="14" rx="7" ry="5"/><path d="M1 14V8a6 6 0 0 1 12 0v2h6V8a6 6 0 0 1 12 0v6"/></svg></div>' +
                '          <div class="text-[9px] font-bold uppercase tracking-[0.2px] text-black/35">SHOES</div>' +
                '        </div>' +
                '      </div>' +
                '    </div>' +
                '    <div class="relative flex min-h-[230px] flex-1 cursor-pointer flex-col items-center justify-center bg-[rgba(240,236,228,0.4)] transition hover:bg-[rgba(215,103,54,0.06)]" id="yp-' + id + '" data-action="upload" data-card-id="' + id + '" data-card-idx="' + index + '">' +
                '      <div class="absolute left-[12px] top-[12px] rounded-full bg-white/70 px-3 py-[4px] text-[10px] font-bold uppercase tracking-[0.08em] text-black/35">Your look that day</div>' +
                '      <div class="flex flex-col items-center justify-center gap-[10px]" id="upl-' + id + '">' +
                '        <div class="flex h-[96px] w-[96px] items-center justify-center rounded-[26px] border border-white/90 bg-white/80 shadow-[0_8px_22px_rgba(0,0,0,0.06)]">' +
                '          <svg class="h-[28px] w-[28px] fill-none stroke-[#d76736] stroke-[1.7] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>' +
                '        </div>' +
                '        <div class="text-[15px] font-black text-[#d76736]">Upload photo</div>' +
                '        <div class="text-[12px] font-bold text-black/35">Did you wear this?</div>' +
                '      </div>' +
                '      <div class="hidden w-full" id="pf-' + id + '">' +
                '        <div class="relative flex min-h-[230px] w-full flex-1 flex-col overflow-hidden">' +
                '          <div class="relative flex-1 bg-[linear-gradient(150deg,rgba(157,186,181,0.45),rgba(211,163,140,0.35))]">' +
                '            <div class="flex h-full w-full items-center justify-center">' +
                '              <i data-lucide="user" class="h-[18px] w-[18px] text-black/25" aria-hidden="true"></i>' +
                '            </div>' +
                '            <button type="button" class="absolute right-[14px] top-[14px] flex h-[44px] w-[44px] items-center justify-center rounded-full bg-black/55 text-white shadow-[0_10px_22px_rgba(0,0,0,0.18)]" data-action="remove-photo" data-card-id="' + id + '" data-card-idx="' + index + '" aria-label="Remove photo">' +
                '              <svg class="h-[18px] w-[18px] fill-none stroke-white stroke-[2.4] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                '            </button>' +
                '            <button type="button" class="absolute bottom-[14px] right-[14px] hidden items-center gap-[10px] rounded-[16px] bg-[#d76736] px-[18px] py-[12px] text-[13px] font-black leading-none text-white shadow-[0_10px_24px_rgba(215,103,54,0.45)] transition hover:-translate-y-px hover:bg-[#b8522a] sm:text-[14px]" id="share-' + id + '" data-action="share" data-card-id="' + id + '">' +
                '              <svg class="h-[16px] w-[16px] fill-none stroke-white stroke-[1.9] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>' +
                '              <span class="leading-[1.05]"><span class="block">This worked.</span><span class="block">Share it.</span></span>' +
                '            </button>' +
                '          </div>' +
                '        </div>' +
                '      </div>' +
                '    </div>' +
                '  </div>' +
                '  <div class="px-[14px] pb-[10px] pt-[12px]">' +
                '    <div class="mb-2 flex items-center justify-between gap-3">' +
                '      <div class="text-[15px] font-medium italic text-[#1e1b18] [font-family:var(--font-serif)]">' + escapeHtml(card.name || "") + '</div>' +
                '      <div class="flex items-center gap-[5px]">' +
                '        <span class="inline-flex items-center gap-[6px] whitespace-nowrap rounded-full bg-white/70 px-[10px] py-[3px] text-[10px] font-bold text-black/60">' +
                '          <i data-lucide="' + escapeHtml(weatherIconName(card.weather)) + '" class="h-[12px] w-[12px] text-black/40" aria-hidden="true"></i>' +
                '          <span>' + escapeHtml(card.weather || "") + '</span>' +
                '        </span>' +
                '        <span class="whitespace-nowrap rounded-full bg-[#f2e0d5] px-[10px] py-[3px] text-[10px] font-bold text-[#d76736]">' + escapeHtml(card.tag || "") + '</span>' +
                '      </div>' +
                '    </div>' +
                '    <button type="button" class="group flex items-center gap-[6px] bg-transparent p-0 text-left" data-action="toggle-items" data-card-id="' + id + '">' +
                '      <span class="flex h-[14px] w-[14px] items-center justify-center transition-transform" id="arr-' + id + '">' +
                '        <svg class="h-[10px] w-[10px] fill-none stroke-black/35 stroke-[2.5] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>' +
                '      </span>' +
                '      <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] text-black/35 transition-colors group-hover:text-[#d76736]">Items worn</span>' +
                '      <span class="ml-1 rounded-full bg-black/5 px-[7px] py-[1px] text-[10px] font-bold text-black/35">' + String((card.items || []).length) + '</span>' +
                '    </button>' +
                '    <div class="hidden flex gap-[7px] pt-[10px] mt-[10px] border-t border-black/10" id="iw-' + id + '">' + itemsHTML + '</div>' +
                '  </div>' +
                '</div>';
        }

        async function renderCards(dayKey, isoDate) {
            var scroll = byId("log-scroll");
            if (!scroll) return;

            // 先顯示 mock 資料（如果有）
            var data = dayData[dayKey];
            var mockHtml = data ? (data.cards || []).map(function (c, i) { return buildCard(c, i, dayKey); }).join("") : "";
            scroll.innerHTML = mockHtml || '<div class="flex flex-1 items-center justify-center py-16 text-[13px] font-bold text-black/30">Loading...</div>';

            if (data) {
                (data.cards || []).forEach(function (c, i) {
                    if (!c.hasPhoto) return;
                    var id = dayKey.replace(/ /g, "") + "-" + i;
                    var yp = byId("yp-" + id);
                    var upl = byId("upl-" + id);
                    var pf = byId("pf-" + id);
                    var share = byId("share-" + id);
                    yp && yp.classList.add("cursor-default");
                    upl && upl.classList.add("hidden");
                    pf && pf.classList.remove("hidden");
                    share && share.classList.remove("hidden");
                });
            }

            // 若有 ISO 日期，向 API 取真實 looks
            if (isoDate) {
                try {
                    var resp = await fetch("/WW/Calendar/OutfitLooks?date=" + encodeURIComponent(isoDate));
                    if (resp.ok) {
                        var looks = await resp.json();
                        if (Array.isArray(looks) && looks.length > 0) {
                            var apiHtml = looks.map(function (look, i) { return buildApiCard(look, i); }).join("");
                            scroll.innerHTML = apiHtml + (mockHtml ? '<div class="mt-[6px] text-[9px] font-bold uppercase tracking-[0.08em] text-black/30 px-1">Archive</div>' + mockHtml : "");
                        } else if (!data) {
                            scroll.innerHTML = '<div class="flex flex-1 items-center justify-center py-16 text-[13px] font-bold text-black/30">No looks recorded for this day.</div>';
                        }
                    }
                } catch (_) {}
            } else if (!data) {
                scroll.innerHTML = '<div class="flex flex-1 items-center justify-center py-16 text-[13px] font-bold text-black/30">No looks recorded for this day.</div>';
            }

            window.lucide?.createIcons?.();
        }

        function renderCalendar() {
            safeText(byId("month-label"), MONTHS[currentMonth] + " " + currentYear);
            var grid = byId("cal-grid");
            if (!grid) return;
            grid.innerHTML = "";

            ["S", "M", "T", "W", "T", "F", "S"].forEach(function (d) {
                var el = document.createElement("div");
                el.className = "pb-[6px] text-center text-[9px] font-bold uppercase tracking-[0.05em] text-black/35";
                el.textContent = d;
                grid.appendChild(el);
            });

            var firstDay = new Date(currentYear, currentMonth, 1).getDay();
            var daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
            var nowDate = new Date();
            var isCurrentMonthYear = currentMonth === nowDate.getMonth() && currentYear === nowDate.getFullYear();
            var todayNum = isCurrentMonthYear ? nowDate.getDate() : -1;

            // April 2026 mock map
            var mockDayMap = { 18: "Apr 18", 19: "Apr 19", 20: "Apr 20" };
            var mockDayMeta = {
                "Apr 18": { weekday: "Friday",   weather: "22\u00B0 Partly cloudy", occ: "Work" },
                "Apr 19": { weekday: "Saturday", weather: "20\u00B0 Rain",           occ: "Date" },
                "Apr 20": { weekday: "Sunday",   weather: "24\u00B0 Clear",          occ: "Casual" }
            };
            var isAprilMock = currentMonth === 3 && currentYear === 2026;

            for (var i = 0; i < firstDay; i++) {
                var pad = document.createElement("div");
                pad.className = "aspect-square rounded-[8px] opacity-30";
                grid.appendChild(pad);
            }

            for (var dnum = 1; dnum <= daysInMonth; dnum++) {
                var dayEl = document.createElement("div");
                var iso = toIsoDate(currentYear, currentMonth, dnum);
                var hasRealLook = realLookDates.has(iso);
                var hasMockOutfit = isAprilMock && outfitDays.indexOf(dnum) >= 0;
                var hasOutfit = hasRealLook || hasMockOutfit;
                var isToday = dnum === todayNum;
                var isFuture = isCurrentMonthYear && dnum > todayNum;

                dayEl.className =
                    "aspect-square select-none rounded-[8px] transition " +
                    (isFuture ? "pointer-events-none opacity-30 " : "cursor-pointer hover:bg-[#f2e0d5] ") +
                    (isToday ? "bg-[#d76736] shadow-[0_3px_10px_rgba(215,103,54,0.35)] " : "") +
                    "flex flex-col items-center justify-center gap-[2px]";

                dayEl.innerHTML =
                    '<span class="cal-num text-[11px] font-bold leading-none ' + (isToday ? "text-white" : "text-[#1e1b18]") + '">' + dnum + "</span>" +
                    (hasOutfit ? '<div class="h-1 w-1 rounded-full ' + (isToday ? "bg-white/80" : "bg-[#d76736]") + '"></div>' : "");

                dayEl.setAttribute("data-cal-day", "1");
                dayEl.setAttribute("data-cal-num", String(dnum));
                dayEl.setAttribute("data-cal-iso", iso);

                if (!isFuture) {
                    dayEl.addEventListener("click", function (ev) {
                        var target = ev.currentTarget;
                        if (!target) return;

                        document.querySelectorAll("[data-cal-day='1']").forEach(function (c) {
                            c.classList.remove("outline", "outline-2", "outline-[#d76736]", "bg-[#f2e0d5]");
                        });
                        target.classList.add("outline", "outline-2", "outline-[#d76736]", "bg-[#f2e0d5]");

                        var selectedNum = parseInt(target.getAttribute("data-cal-num") || "0", 10);
                        var clickedIso = target.getAttribute("data-cal-iso") || "";
                        var mockKey = isAprilMock ? mockDayMap[selectedNum] : null;
                        var meta = mockKey ? mockDayMeta[mockKey] : null;
                        var weekdayName = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"][new Date(currentYear, currentMonth, selectedNum).getDay()];

                        wwCalendarSelectDay(
                            mockKey || (MONTHS[currentMonth].slice(0,3) + " " + selectedNum),
                            weekdayName,
                            meta ? meta.weather : "",
                            meta ? meta.occ : "",
                            clickedIso
                        );
                    });
                }

                if (isToday) {
                    dayEl.classList.add("outline", "outline-2", "outline-[#d76736]", "bg-[#f2e0d5]");
                }

                grid.appendChild(dayEl);
            }

            safeText(byId("ms-outfits"), String(realLookDates.size || (isAprilMock ? 18 : 0)));
            safeText(byId("ms-avg"), "22\u00B0");
            safeText(byId("ms-topocc"), "Work");
        }

        async function loadRealLookDates() {
            try {
                var resp = await fetch("/WW/Calendar/OutfitLookDates");
                if (!resp.ok) return;
                var dates = await resp.json();
                if (Array.isArray(dates)) {
                    realLookDates = new Set(dates);
                    renderCalendar(); // \u91CD\u7E6A\u4EE5\u88DC\u4E0A\u5713\u9EDE
                }
            } catch (_) {}
        }

        // ====== 全域 API（供 Razor onclick 呼叫）======
        window.wwCalendarChangeMonth = function (dir) {
            currentMonth += dir;
            if (currentMonth < 0) { currentMonth = 11; currentYear--; }
            if (currentMonth > 11) { currentMonth = 0; currentYear++; }
            renderCalendar();
        };

        window.wwCalendarSelectDay = function (date, weekday, weather, occ, isoDate) {
            var dayNum = (date.split(" ")[1] || "").trim();
            safeText(byId("log-date-big"), weekday + ", " + MONTHS[currentMonth] + " " + dayNum);
            safeText(byId("log-weather-txt"), weather);
            var ico = byId("log-weather-ico");
            if (ico) {
                ico.setAttribute("data-lucide", weatherIconName(weather));
                window.lucide?.createIcons?.();
            }
            safeText(byId("log-occ"), occ);
            currentDayKey = date;
            renderCards(date, isoDate || "");
        };

        window.wwCalendarToggleItems = function (id) {
            var worn = byId("iw-" + id);
            var arrow = byId("arr-" + id);
            if (!worn) return;
            worn.classList.toggle("hidden");
            arrow && arrow.classList.toggle("rotate-90");
        };

        window.wwCalendarHandleUpload = function (id, cardIdx) {
            var data = dayData[currentDayKey];
            if (!data || !data.cards || !data.cards[cardIdx]) return;
            if (data.cards[cardIdx].hasPhoto) return;

            pendingUploadTarget = { id: id, cardIdx: cardIdx };
            ensureCalendarUploadInput().click();
        };

        function ensureCalendarUploadInput() {
            var input = byId("ww-calendar-look-upload-input");
            if (input) return input;

            input = document.createElement("input");
            input.type = "file";
            input.accept = "image/*";
            input.id = "ww-calendar-look-upload-input";
            input.className = "hidden";
            input.addEventListener("change", function () {
                if (!pendingUploadTarget || !input.files || input.files.length === 0) {
                    input.value = "";
                    return;
                }

                uploadCalendarLookPhoto(input.files[0], pendingUploadTarget.id, pendingUploadTarget.cardIdx)
                    .finally(function () {
                        input.value = "";
                        pendingUploadTarget = null;
                    });
            });

            document.body.appendChild(input);
            return input;
        }

        async function uploadCalendarLookPhoto(file, id, cardIdx) {
            var data = dayData[currentDayKey];
            if (!data || !data.cards || !data.cards[cardIdx]) return;

            var form = new FormData();
            form.append("Image", file);
            form.append("OutfitId", id);
            form.append("Occasion", data.cards[cardIdx].tag || "");
            form.append("WeatherSummary", data.cards[cardIdx].weather || "");

            var response = await fetch("/WW/Calendar/SaveLookPhoto", {
                method: "POST",
                body: form
            });

            var payload = await response.json().catch(function () { return null; });
            if (!response.ok) {
                alert(payload?.message || payload?.error || "Photo upload failed");
                return;
            }

            data.cards[cardIdx].hasPhoto = true;

            var upl = byId("upl-" + id);
            var pf = byId("pf-" + id);
            var yp = byId("yp-" + id);
            var share = byId("share-" + id);

            upl && upl.classList.add("hidden");
            pf && pf.classList.remove("hidden");
            yp && yp.classList.add("cursor-default");
            share && share.classList.remove("hidden");
        }

        window.wwCalendarRemovePhoto = function (e, id, cardIdx) {
            e && e.stopPropagation && e.stopPropagation();
            var data = dayData[currentDayKey];
            if (!data || !data.cards || !data.cards[cardIdx]) return;
            data.cards[cardIdx].hasPhoto = false;

            var upl = byId("upl-" + id);
            var pf = byId("pf-" + id);
            var yp = byId("yp-" + id);
            var share = byId("share-" + id);

            upl && upl.classList.remove("hidden");
            pf && pf.classList.add("hidden");
            yp && yp.classList.remove("cursor-default");
            share && share.classList.add("hidden");
        };

        window.wwCalendarHandleShare = function (e, id) {
            e && e.stopPropagation && e.stopPropagation();
            // 藍圖為占位流程：目前不實作任何行為（避免出現草稿提示/對話框）。
            return;
        };

        window.wwCalendarToggleLike = function () {
            var btn = byId("like-btn");
            if (!btn) return;

            btn.classList.toggle("bg-[#d76736]/10");
            btn.classList.toggle("border-[#d76736]/25");

            var svg = btn.querySelector("svg");
            if (svg) {
                svg.classList.toggle("stroke-[#d76736]");
                svg.classList.toggle("fill-[#d76736]/10");
            }
        };

        function bindLogActions() {
            var scroll = byId("log-scroll");
            if (!scroll) return;

            scroll.addEventListener("click", function (ev) {
                var target = ev.target;
                if (!target) return;

                var el = target.closest ? target.closest("[data-action]") : null;
                if (!el) return;

                var action = el.getAttribute("data-action");

                if (action === "upload") {
                    var id = el.getAttribute("data-card-id") || "";
                    var idx = parseInt(el.getAttribute("data-card-idx") || "0", 10);
                    window.wwCalendarHandleUpload(id, idx);
                    return;
                }

                if (action === "remove-photo") {
                    var rid = el.getAttribute("data-card-id") || "";
                    var ridx = parseInt(el.getAttribute("data-card-idx") || "0", 10);
                    window.wwCalendarRemovePhoto(ev, rid, ridx);
                    return;
                }

                if (action === "share") {
                    var sid = el.getAttribute("data-card-id") || "";
                    window.wwCalendarHandleShare(ev, sid);
                    return;
                }

                if (action === "toggle-items") {
                    var tid = el.getAttribute("data-card-id") || "";
                    window.wwCalendarToggleItems(tid);
                    return;
                }
            });
        }

        // init
        bindLogActions();
        loadRealLookDates(); // 非同步：取回 API 日期後重繪月曆
        renderCalendar();
        var todayIso = toIsoDate(currentYear, currentMonth, _todayNum);
        var todayWeekday = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"][_now.getDay()];
        wwCalendarSelectDay(currentDayKey, todayWeekday, "", "", todayIso);
    })();
</script>
