                <div class="icard" id="ic0"><div class="ibox" style="width:52px;height:64px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z"/></svg><div class="ichk" id="ck0"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div></div><span class="ilbl">Top</span></div>
                <div class="icard" id="ic1"><div class="ibox" style="width:44px;height:72px;"><svg width="22" height="22" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z"/></svg><div class="ichk" id="ck1"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div></div><span class="ilbl">Bottom</span></div>
                <div class="icard" id="ic2"><div class="ibox" style="width:54px;height:64px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M4 9l8-7 8 7v11a2 2 0 01-2 2H6a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg><div class="ichk" id="ck2"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div></div><span class="ilbl">Jacket</span></div>
                <div class="icard" id="ic3"><div class="ibox" style="width:52px;height:44px;"><svg width="24" height="24" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5"/><ellipse cx="24" cy="14" rx="7" ry="5"/><path d="M1 14V8a6 6 0 0112 0v2h6V8a6 6 0 0112 0v6"/></svg><div class="ichk" id="ck3"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div></div><span class="ilbl">Shoes</span></div>
            </div>
        </div>

        <div class="r-result hidden" id="r-result">
            <div class="r-topbar">
                <div class="r-back" onclick="backToEmpty()">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                    Change occasion
                </div>
                <div class="r-icons">
                    <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                    <svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                </div>
            </div>
            <div class="r-scroll">
                <div class="outfit-hero">
                    <div class="obadge" id="r-occ-badge">Work</div>
                    <div class="owbadge">22&deg; <span id="r-weather-ico" aria-hidden="true">@todayWeatherEmoji</span></div>
                    <div class="outfit-full" id="outfit-full">
                        <div class="of-item"><div class="of-box" style="width:48px;height:60px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z"/></svg></div><span class="of-lbl">Top</span></div>
                        <div class="of-item"><div class="of-box" style="width:40px;height:70px;"><svg width="20" height="20" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z"/></svg></div><span class="of-lbl">Bottom</span></div>
                        <div class="of-item"><div class="of-box" style="width:54px;height:64px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M4 9l8-7 8 7v11a2 2 0 01-2 2H6a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg></div><span class="of-lbl">Jacket</span></div>
                        <div class="of-item"><div class="of-box" style="width:44px;height:34px;"><svg width="22" height="15" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5"/><ellipse cx="24" cy="14" rx="7" ry="5"/><path d="M1 14V8a6 6 0 0112 0v2h6V8a6 6 0 0112 0v6"/></svg></div><span class="of-lbl">Shoes</span></div>
                    </div>
                </div>

                <div class="ai-name" id="ai-name">Polished Rain-Ready</div>
                <div class="ai-text" id="ai-text"></div>

                <div class="ractions" id="r-actions">
                    <button class="rab"><svg viewBox="0 0 24 24"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg>Redo</button>
                    <button class="rab pri"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>Save look</button>
                </div>

                <div class="tweak" id="r-tweak">
                    <div class="chips">
                        <div class="chip">Warmer</div>
                        <div class="chip">More formal</div>
                        <div class="chip">No jacket</div>
                        <div class="chip">Swap shoes</div>
                    </div>
                    <div class="tinp-row">
                        <input class="tinp" placeholder="Or ask anything..." />
                        <button class="tsend" type="button"><svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></button>
                    </div>
                </div>

                <div class="shop-wrap" id="shop-wrap">
                    <div class="shop-divider"></div>
                    <div class="shop-hdr">
                        <div class="shop-title">From your closet</div>
                    </div>
                    <div class="shop-row">
                        <div class="pcard"><div class="pimg"><div class="ptag">NEW</div><svg viewBox="0 0 24 24"><path d="M20 21V19a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div><div class="pinfo"><div class="pname">Rain Jacket</div><div class="pwhy">Water-resistant layer</div><div class="pprice">$120 &middot; A&Co</div></div></div>
                        <div class="pcard"><div class="pimg"><svg viewBox="0 0 24 24"><path d="M4 4h16v6H4z"/><path d="M6 10v10h12V10"/><path d="M8 14h8"/></svg></div><div class="pinfo"><div class="pname">Chelsea Boots</div><div class="pwhy">Water-resistant sole</div><div class="pprice">$89 &middot; Cole Haan</div></div></div>
                        <div class="pcard"><div class="pimg"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg></div><div class="pinfo"><div class="pname">Canvas Tote</div><div class="pwhy">Waterproof canvas</div><div class="pprice">$45 &middot; Muji</div></div></div>
                        <div class="pcard"><div class="pimg"><svg viewBox="0 0 24 24"><path d="M23 12a11.05 11.05 0 00-22 0zm-5 7a3 3 0 01-6 0v-7"/></svg></div><div class="pinfo"><div class="pname">Compact Umbrella</div><div class="pwhy">Windproof, fits in bag</div><div class="pprice">$28 &middot; Blunt</div></div></div>
                        <div class="pcard"><div class="pimg"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg></div><div class="pinfo"><div class="pname">Slim Chinos</div><div class="pwhy">Lighter than jeans</div><div class="pprice">$65 &middot; Uniqlo</div></div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="r-record hidden" id="r-record">
            <div class="rec-topbar"><div class="rec-date" id="rec-date">Apr 19</div><div class="rec-meta" id="rec-meta">Work &middot; 23&deg;</div></div>
            <div class="rec-scroll">
                <div class="rec-hero">
                    <div class="obadge" id="rec-badge">Work</div><div class="owbadge" id="rec-weather">23&deg;</div>
                    <div style="display:flex;gap:11px;align-items:flex-end;">
                        <div class="of-item"><div class="of-box" style="width:48px;height:60px;"><svg width="24" height="24" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z"/></svg></div><span class="of-lbl">Top</span></div>
                        <div class="of-item"><div class="of-box" style="width:40px;height:70px;"><svg width="20" height="20" viewBox="0 0 24 24"><path d="M6 2l-3 8h5v12h8V10h5l-3-8H6z"/></svg></div><span class="of-lbl">Bottom</span></div>
                        <div class="of-item"><div class="of-box" style="width:44px;height:34px;"><svg width="22" height="15" viewBox="0 0 32 20"><ellipse cx="8" cy="14" rx="7" ry="5"/><ellipse cx="24" cy="14" rx="7" ry="5"/><path d="M1 14V8a6 6 0 0112 0v2h6V8a6 6 0 0112 0v6"/></svg></div><span class="of-lbl">Shoes</span></div>
                    </div>
                </div>
                <div class="rec-name" id="rec-name">Smart Casual</div>
                <div class="rec-reason" id="rec-reason">Mild and partly cloudy &mdash; picked your beige chino + white button-down. Light enough for the temperature, smart enough for the office.</div>
            </div>
        </div>

        <div class="r-future hidden" id="r-future">
            <div class="fut-scroll">
                <div class="fut-hero">
                    <div>
                        <div class="fut-hero-day" id="fut-day-label">Tuesday</div>
                        <div class="fut-hero-date" id="fut-date">Apr 22</div>
                    </div>
                    <div class="fut-hero-weather">
                        <div class="fut-hero-ico" id="fut-ico">&#9925;</div>
                        <div>
                            <div class="fut-hero-temp" id="fut-temp">24&deg;</div>
                            <div class="fut-hero-desc" id="fut-desc">Partly cloudy</div>
                        </div>
                    </div>
                </div>

                <div id="fut-input-section">
                    <div class="fut-input-label">What's happening that day?</div>
                    <div class="fut-input-sub">One line is enough. We'll take it from there.</div>

                    <div class="fut-textarea-wrap">
                        <textarea class="fut-inp" id="fut-note-inp" rows="2"
                                  placeholder='e.g. "job interview downtown", "friends dinner"'
                                  oninput="handleFutInp(this)"></textarea>
                        <div class="fut-quick-chips">
                            <button type="button" class="fut-chip" onclick="setFutChip(this,'💼 Work day')">💼 Work day</button>
                            <button type="button" class="fut-chip" onclick="setFutChip(this,'✨ Date night')">✨ Date night</button>
                            <button type="button" class="fut-chip" onclick="setFutChip(this,'☕ Casual day')">☕ Casual day</button>
                            <button type="button" class="fut-chip" onclick="setFutChip(this,'🌿 Outdoor plans')">🌿 Outdoor plans</button>
                        </div>
                    </div>

                    <div class="fut-notif">
                        <div class="fut-notif-ico">
                            <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
                        </div>
                        <div class="fut-notif-text">
                            <strong>Outfit ready the night before, 9 PM.</strong><br />
                            Tell us what's happening. We'll check the forecast and pick from your closet.
                        </div>
                    </div>

                    <button type="button" class="fut-save-btn" id="fut-save-btn" disabled onclick="saveFuturePlan()">
                        <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Save plan
                    </button>
                </div>

                <div id="fut-saved-section" class="hidden">
                    <div class="fut-saved-state">
                        <div class="fut-saved-check">
                            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <div class="fut-saved-title">Saved.</div>
                        <div class="fut-saved-sub" id="fut-saved-note-display">Outfit coming the night before at 9 PM.</div>
                        <div class="fut-saved-edit" onclick="editFuturePlan()">Edit plan</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
