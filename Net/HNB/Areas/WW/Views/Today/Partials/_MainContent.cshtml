@using System.Linq
@model HNB.Areas.WW.Models.TodayIndexModel

@{
    var futureDays = Model?.WeatherDays?
        .Where(day => string.Equals(day.DayType, "future", System.StringComparison.OrdinalIgnoreCase))
        .Take(7)
        .ToList() ?? [];

    string BuildNowLocationText(string? rawText)
    {
        var text = string.IsNullOrWhiteSpace(rawText) ? string.Empty : rawText.Trim();

        if (string.IsNullOrWhiteSpace(text))
        {
            return "CHICAGO &bull; NOW";
        }

        if (text.Contains("&middot;", System.StringComparison.OrdinalIgnoreCase))
        {
            text = text.Split(new[] { "&middot;" }, StringSplitOptions.RemoveEmptyEntries)[0].Trim();
        }
        else if (text.Contains("·", System.StringComparison.OrdinalIgnoreCase))
        {
            text = text.Split('·', StringSplitOptions.RemoveEmptyEntries)[0].Trim();
        }
        else if (text.Contains("繚", System.StringComparison.OrdinalIgnoreCase))
        {
            text = text.Split(new[] { "繚" }, StringSplitOptions.RemoveEmptyEntries)[0].Trim();
        }

        if (string.IsNullOrWhiteSpace(text) ||
            text.Contains("auto-detected", System.StringComparison.OrdinalIgnoreCase) ||
            text.Contains("now", System.StringComparison.OrdinalIgnoreCase))
        {
            return "CHICAGO &bull; NOW";
        }

        return $"{text} &bull; NOW";
    }

    char ResolveTemperatureUnit()
    {
        var wind = Model?.CurrentWindSpeedText ?? string.Empty;
        if (wind.Contains("mph", System.StringComparison.OrdinalIgnoreCase)) return 'F';
        if (wind.Contains("km/h", System.StringComparison.OrdinalIgnoreCase)) return 'C';

        var location = Model?.CurrentLocationText ?? string.Empty;
        if (location.Contains("belize", System.StringComparison.OrdinalIgnoreCase)) return 'F';
        if (location.Contains("bahamas", System.StringComparison.OrdinalIgnoreCase)) return 'F';
        if (location.Contains("united states", System.StringComparison.OrdinalIgnoreCase)) return 'F';
        if (location.Contains("usa", System.StringComparison.OrdinalIgnoreCase)) return 'F';
        if (location.Contains("u.s.", System.StringComparison.OrdinalIgnoreCase)) return 'F';

        return 'C';
    }

    string FormatTemperatureTextWithUnit(string? rawText, char unit)
    {
        var text = string.IsNullOrWhiteSpace(rawText) ? string.Empty : rawText.Trim();
        if (string.IsNullOrWhiteSpace(text)) return $"22&deg;{unit}";

        text = text.Replace("°", "&deg;", System.StringComparison.OrdinalIgnoreCase);
        text = text.Replace("簞", "&deg;", System.StringComparison.OrdinalIgnoreCase);

        if (text.Contains("&deg;C", System.StringComparison.OrdinalIgnoreCase) ||
            text.Contains("&deg;F", System.StringComparison.OrdinalIgnoreCase))
        {
            return text;
        }

        if (text.Contains("&deg;", System.StringComparison.OrdinalIgnoreCase))
        {
            return $"{text}{unit}";
        }

        return $"{text}&deg;{unit}";
    }

    string FormatSummaryPartWithUnit(string part, char unit)
    {
        if (string.IsNullOrWhiteSpace(part)) return part;

        var text = part
            .Replace("°", "&deg;", System.StringComparison.OrdinalIgnoreCase)
            .Replace("簞", "&deg;", System.StringComparison.OrdinalIgnoreCase);

        if (!text.Contains("Feels like", System.StringComparison.OrdinalIgnoreCase))
        {
            return text;
        }

        if (text.Contains("&deg;C", System.StringComparison.OrdinalIgnoreCase) ||
            text.Contains("&deg;F", System.StringComparison.OrdinalIgnoreCase))
        {
            return text;
        }

        return text.Replace("&deg;", $"&deg;{unit}", System.StringComparison.OrdinalIgnoreCase);
    }

    var tempUnit = ResolveTemperatureUnit();
    var tempText = FormatTemperatureTextWithUnit(Model?.CurrentTemperatureText, tempUnit);
    var weatherSummaryParts = (Model?.CurrentWeatherSummaryText ?? "Light rain &middot; Feels like 20&deg;")
        .Split(new[] { "&middot;", "·", "繚" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(text => text.Trim())
        .Where(text => !string.IsNullOrWhiteSpace(text))
        .Select(text => FormatSummaryPartWithUnit(text, tempUnit))
        .ToList();
    var windText = Model?.CurrentWindSpeedText ?? "Wind 12 km/h";
    var locationText = BuildNowLocationText(Model?.CurrentLocationText);
    var todayWeatherEmoji = string.IsNullOrWhiteSpace(Model?.CurrentWeatherEmoji) ? "☁️" : Model.CurrentWeatherEmoji;
}

<div class="cols">
    <div class="lp">
        <div class="lp-scroll">
            <div class="wcard">
                <div class="wl">
                    <div class="city" id="wcard-location">@Html.Raw(locationText)</div>
                    <div class="tmp" id="wcard-temp">@Html.Raw(tempText)</div>
                    <div class="desc">
                        @foreach (var part in weatherSummaryParts)
                        {
                            <div>@Html.Raw(part)</div>
                        }
                    </div>
                </div>
                <div class="wr">
                    <div class="ico" aria-hidden="true">@todayWeatherEmoji</div>
                    <div class="feel">@windText</div>
                </div>
            </div>

            <div class="week-strip">
                <div class="week-hdr">This Week</div>
                <div class="week-row">
                    <div class="wday today sel" id="day-today" data-type="today" onclick="clickDay(this)">
                        <div class="wd-lbl">Today</div>
                        <div class="wd-ico" aria-hidden="true">@todayWeatherEmoji</div>
                        <div class="wd-circle"></div>
                    </div>

                    @foreach (var weatherDay in futureDays)
                    {
                        <div class="wday"
                             data-type="future"
                             data-date="@weatherDay.DateFullText"
                             data-temp="@weatherDay.TemperatureText"
                             data-desc="@weatherDay.WeatherDescriptionText"
                             data-icon="@weatherDay.WeatherIconEmoji"
                             onclick="clickDay(this)">
                            <div class="wd-lbl">@weatherDay.WeekdayText</div>
                            <div class="wd-ico" aria-hidden="true">@weatherDay.WeatherIconEmoji</div>
                            <div class="wd-circle"></div>
                        </div>
                    }
                </div>
            </div>

            <div class="occ-section" id="occ-section">
                <div>
                    <div class="occ-title" id="occ-title">Where are we going?</div>
                    <div class="occ-sub">Quick pick, or describe below</div>
                </div>
                <div class="occ-grid">
                    <div class="ocard" onclick="pickOcc(this,'Work')"><div class="em">💼</div><div class="nm">Work</div><div class="ht">Office or meetings</div></div>
                    <div class="ocard" onclick="pickOcc(this,'Casual')"><div class="em">☕</div><div class="nm">Casual</div><div class="ht">Errands or chill</div></div>
                    <div class="ocard" onclick="pickOcc(this,'Date')"><div class="em">✨</div><div class="nm">Date</div><div class="ht">Dinner or night out</div></div>
                    <div class="ocard" onclick="pickOcc(this,'Outdoor')"><div class="em">🌿</div><div class="nm">Outdoor</div><div class="ht">Parks or activities</div></div>
                </div>

                <div class="free-block">
                    <div class="free-block-label">Or describe your day</div>
                    <textarea class="free-inp" id="free-occ" rows="2" placeholder='e.g. "rooftop dinner date", "startup job interview"' oninput="handleFree(this)"></textarea>
                    <div class="free-examples">
                        <span class="free-ex" onclick="setEx('beach wedding as a guest')">Beach wedding</span>
                        <span class="free-ex" onclick="setEx('casual Friday at the office')">Casual Friday</span>
                        <span class="free-ex" onclick="setEx('first date at a rooftop bar')">Rooftop date</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lp-foot">
            <button class="gbtn" id="gbtn" disabled onclick="startGen()">
                <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                <span id="gbtn-label">Let's go.</span>
            </button>
        </div>
    </div>

    <div class="rp">
        <div class="r-empty" id="r-empty">
            <div class="r-empty-ico">
                <svg viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z"/></svg>
            </div>
