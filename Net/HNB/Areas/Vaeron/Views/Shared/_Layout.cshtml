@{
    Layout = null;
    var pageTitle = ViewData["Title"] as string ?? "Helix Studio";
    var pageDescription = ViewData["Description"] as string ?? "";
    var bodyClass = ViewData["BodyClass"] as string ?? "d-flex flex-column min-vh-100";
}
<!DOCTYPE html>
<html lang="zh-Hant" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="@Url.Content("~/Vaeron/image/horizon-nova.svg")" />
    <link rel="shortcut icon" type="image/svg+xml" href="@Url.Content("~/Vaeron/image/horizon-nova.svg")" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@bodyClass">
    @RenderBody()
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
