@* 共用：Downloads\index.html 風格的 shell-frame（Hero 預覽／Demo 區可重用） *@
<div class="shell-frame">
      <div class="shell-titlebar">
        <div class="tl-dot" style="background:#FF5F57"></div>
        <div class="tl-dot" style="background:#FEBC2E"></div>
        <div class="tl-dot" style="background:#28C840"></div>
        <span class="tl-text">Helix Studio — v2.4.1  ·  HELIX-WS-01</span>
      </div>
      <div class="shell-main">
        <div class="shell-sb">
          <div class="sb-logo-area">
            <div class="sb-ws">
              <div class="sb-ws-icon">
                <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
              </div>
              <div>
                <div class="sb-ws-label">WORKSPACE</div>
                <div class="sb-ws-name">HN-Production</div>
              </div>
            </div>
          </div>
          <div class="sb-sec-label">WORKSPACE</div>
          <div class="sb-item"><div class="sb-dot"></div>Home</div>
          <hr class="sb-divider">
          <div class="sb-sec-label">MODULES</div>
          <div class="sb-item active"><div class="sb-dot"></div>ProductionMonitor</div>
          <div class="sb-item"><div class="sb-dot"></div>DeployManager</div>
          <hr class="sb-divider">
          <div class="sb-sec-label">SYSTEM</div>
          <div class="sb-item"><div class="sb-dot"></div>Event Log <span style="font-size:9px;color:var(--text3);margin-left:3px">日誌</span></div>
          <div class="sb-item"><div class="sb-dot"></div>Modules <span style="font-size:9px;color:var(--text3);margin-left:3px">模組</span></div>
          <div class="sb-item"><div class="sb-dot"></div>Settings <span style="font-size:9px;color:var(--text3);margin-left:3px">設定</span></div>
          <div class="sb-ver">
            <div class="sb-ver-text">v2.4.1+build.847<br><span style="opacity:.5">HELIX-WS-01</span></div>
          </div>
        </div>
        <div style="width:1px;background:var(--border)"></div>
        <div class="sh-content">
          <div class="sh-topbar">
            <div class="sh-breadcrumb">HN-Production &nbsp;/&nbsp; <span>ProductionMonitor</span></div>
            <div class="sh-search">
              <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="m21 21-4.35-4.35"/></svg>
              搜尋頁面、模組或指令
            </div>
          </div>
          <div class="sh-page">
            <div class="sh-page-hd">ProductionMonitor</div>
            <div class="sh-page-sub">產線機台即時監控  ·  v1.3.0  ·  Vaeron Studio</div>
            <div class="stat-row">
              <div class="stat-card">
                <div class="stat-lbl">RUNNING</div>
                <div class="stat-val g">3 <span style="font-size:12px;font-weight:400;color:var(--text3)">/ 5</span></div>
              </div>
              <div class="stat-card">
                <div class="stat-lbl">TODAY OUTPUT</div>
                <div class="stat-val">3,134 <span style="font-size:11px;font-weight:400;color:var(--text3)">件</span></div>
              </div>
              <div class="stat-card">
                <div class="stat-lbl">ALERTS</div>
                <div class="stat-val r">1</div>
              </div>
            </div>
            <div class="tbl-head">
              <div class="th">機台</div>
              <div class="th">狀態</div>
              <div class="th">今日產量</div>
              <div class="th">最後事件</div>
            </div>
            <div class="tbl-row">
              <div class="td">組裝線 A</div>
              <div class="td"><span class="badge b-ok">運行中</span></div>
              <div class="td mono">842</div>
              <div class="td mono">14:01:22 正常</div>
            </div>
            <div class="tbl-row">
              <div class="td">組裝線 B</div>
              <div class="td"><span class="badge b-err">異常</span></div>
              <div class="td mono">310</div>
              <div class="td mono" style="color:var(--danger)">14:03:41 感測器異常</div>
            </div>
            <div class="tbl-row">
              <div class="td">品檢站 1</div>
              <div class="td"><span class="badge b-ok">運行中</span></div>
              <div class="td mono">1,204</div>
              <div class="td mono">14:05:02 正常</div>
            </div>
            <div class="tbl-row">
              <div class="td">包裝線 C</div>
              <div class="td"><span class="badge b-warn">待機</span></div>
              <div class="td mono">—</div>
              <div class="td mono">13:58:10 排班待機</div>
            </div>
          </div>
          <div class="sh-statusbar">
            <span class="sb-ws-tag">HN-Production</span>
            <span style="opacity:.25;margin-right:12px">|</span>
            <span class="sb-status-dot"></span>
            <span>模組：2 loaded</span>
            <span style="margin-left:auto;font-size:8px">v2.4.1</span>
          </div>
        </div>
      </div>
    </div>
