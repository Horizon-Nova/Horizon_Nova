<link rel="stylesheet" href="~/HNB_WEB/NovaHome/Card_Swap.css" asp-append-version="true" />
<style>
    .darkveil-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: block;
    }
    @@keyframes hnDotFloat {
        0% { transform: translate3d(0,0,0); opacity: .22; }
        50% { transform: translate3d(0,-10px,0); opacity: .38; }
        100% { transform: translate3d(0,0,0); opacity: .22; }
    }
    @@keyframes hnDotScan {
        0% { transform: translateX(-40%); opacity: .0; }
        15% { opacity: .55; }
        50% { opacity: .35; }
        85% { opacity: .55; }
        100% { transform: translateX(40%); opacity: .0; }
    }

    /* 服務區塊：Card Swap 樣式改由 Tailwind 類別套用（與 React 版本一致），此區塊已移除避免衝突 */

    /* Typewriter 效果：閃爍游標 */
    .hn-typewriter-cursor {
        animation: hnCursorBlink 1s step-end infinite;
    }
    .hn-typewriter-done .hn-typewriter-cursor {
        display: none;
    }
    @@keyframes hnCursorBlink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0; }
    }

    /* 合作流程：互動式流程圖（n8n / Railway 風格） */
    #hn-flow {
        --hn-flow-accent: rgba(var(--hn-flow-accent-rgb), 1);
        --hn-flow-accent-soft: rgba(var(--hn-flow-accent-rgb), .24);
        --hn-flow-edge: rgba(255,255,255,.22);
        --hn-flow-edge-active: rgba(var(--hn-flow-accent-rgb), .85);
    }

    .hn-flow-surface {
        position: relative;
        isolation: isolate;
    }
    .hn-flow-surface::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px);
        background-size: 22px 22px;
        background-position: center;
        opacity: .10;
        pointer-events: none;
        z-index: 0;
    }
    .hn-flow-surface::after {
        content: "";
        position: absolute;
        inset: -40%;
        background: radial-gradient(circle at 30% 30%, var(--hn-flow-accent-soft), transparent 60%);
        filter: blur(38px);
        opacity: .9;
        pointer-events: none;
        z-index: 0;
    }

    .hn-flow-viewport {
        position: relative;
        z-index: 10;
        height: 380px;
        overflow: hidden;
        border-radius: 18px;
    }

    .hn-flow-stage {
        position: absolute;
        inset: 0;
        transform-origin: 0 0;
        will-change: transform;
        transition: transform .78s cubic-bezier(.2,.95,.2,1);
    }

    .hn-flow-popover {
        position: absolute;
        left: 14px;
        top: 14px;
        width: min(420px, calc(100% - 28px));
        max-height: calc(100% - 28px);
        overflow: auto;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(2,6,23,0.55);
        backdrop-filter: blur(12px);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.08),
            0 26px 90px rgba(2,6,23,0.70);
        padding: 14px 14px;
        transition: opacity .18s ease, transform .18s ease;
        opacity: 1;
    }

    .hn-flow-edge {
        stroke: var(--hn-flow-edge);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        transition: stroke .18s ease, opacity .18s ease;
        opacity: .85;
    }
    .hn-flow-edge.is-active {
        stroke: var(--hn-flow-edge-active);
        opacity: 1;
        stroke-dasharray: 8 12;
        animation: hnFlowDash 1.1s linear infinite;
        filter: drop-shadow(0 0 12px rgba(var(--hn-flow-accent-rgb), .28));
    }
    @@keyframes hnFlowDash {
        to { stroke-dashoffset: -20; }
    }

    .hn-flow-node {
        position: absolute;
        transform: translate(-50%, -50%);
        display: grid;
        grid-template-columns: 34px 1fr;
        gap: 10px;
        align-items: center;
        min-width: 180px;
        max-width: 240px;
        padding: 10px 12px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(2,6,23,0.35);
        backdrop-filter: blur(10px);
        color: rgba(255,255,255,0.92);
        text-align: left;
        transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease, background-color .16s ease;
        z-index: 2;
    }
    .hn-flow-node:hover {
        border-color: rgba(255,255,255,0.18);
        background: rgba(2,6,23,0.46);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.10),
            0 22px 60px rgba(2,6,23,0.65);
        transform: translate(-50%, -50%) scale(1.01);
    }
    .hn-flow-node.is-active {
        border-color: rgba(var(--hn-flow-accent-rgb), .55);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.10),
            0 26px 90px rgba(2,6,23,0.75),
            0 0 28px rgba(var(--hn-flow-accent-rgb), .30);
    }

    .hn-flow-badge {
        display: inline-flex;
        height: 34px;
        width: 34px;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(var(--hn-flow-accent-rgb), .18);
        color: rgba(255,255,255,0.95);
        box-shadow: 0 0 0 1px rgba(var(--hn-flow-accent-rgb), .22);
    }

    .hn-flow-title {
        display: block;
        font-weight: 800;
        letter-spacing: .02em;
        font-size: 13px;
        line-height: 1.2;
    }
    .hn-flow-sub {
        display: block;
        margin-top: 2px;
        font-size: 11px;
        line-height: 1.3;
        color: rgba(255,255,255,0.70);
    }

    /* 無動畫偏好：停用線條流動 */
    #hn-flow.is-reduced-motion .hn-flow-edge.is-active {
        animation: none;
        stroke-dasharray: none;
    }
    #hn-flow.is-reduced-motion .hn-flow-stage {
        transition: none;
    }
</style>

