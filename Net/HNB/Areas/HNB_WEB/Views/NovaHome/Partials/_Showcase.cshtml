@{
    var imageBase = "~/HNB_WEB/NovaHome/image/";
    var services = new[]
    {
        new
        {
            Label = "網站與平台",
            Image = "App-Shell-2.svg",
            Summary = "從企業形象站到營運平台：前後端、資料庫與第三方服務整合，確保可上線、可維運。",
            Points = new[]
            {
                "交付：原始碼、部署設定/說明、必要文件與權限清單",
                "常見情境：會員/SSO、表單流程、CMS、金流/物流/通知",
                "資料整合：SQL 設計/查詢最佳化、報表與匯入匯出",
                "驗收交接：里程碑驗收、環境可重建、可長期迭代"
            }
        },
        new
        {
            Label = "行動應用",
            Image = "Kanban-2.svg",
            Summary = "行動 App 與後端串接：以穩定上架與持續更新為目標，提供可維運的版本與交付節奏。",
            Points = new[]
            {
                "交付：App 專案原始碼、建置/上架流程、版本管理與變更紀錄",
                "常見功能：推播、離線資料、登入權限、表單/掃碼、相機/定位",
                "場域整合：必要時串接藍牙/Tag/裝置資料（IoT）",
                "維護：錯誤回報與修復流程、版本迭代與需求追蹤"
            }
        },
        new
        {
            Label = "企業系統",
            Image = "Split-Pages-2.svg",
            Summary = "企業內部系統與流程落地：以可稽核、可控權限、可交接為核心，支援長期維運。",
            Points = new[]
            {
                "常見模組：簽核流程、角色權限、報表、稽核軌跡、通知",
                "部署維運：IIS 部署、參數化設定、備份/還原與上線移轉",
                "資料處理：批次匯入匯出、權限分層、資料一致性控管",
                "交付：文件、操作手冊、管理者帳號與權限規範"
            }
        },
        new
        {
            Label = "架構與基礎設施",
            Image = "Step-Form-2.svg",
            Summary = "把專案變成「能穩定跑、好接手、可擴充」：環境、流程與治理一起到位。",
            Points = new[]
            {
                "環境與流程：CI/CD、容器化、k8s、環境分流（Dev/Staging/Prod）",
                "可觀測性：監控告警、日誌/追蹤、效能與容量規劃",
                "導入：外來專案接手、風險盤點、逐步重構與技術債管理",
                "整合：依需求支援 AI/資料串接與自動化流程落地"
            }
        }
    };
}

<!-- 服務項目區 -->
<section id="services" class="relative overflow-hidden bg-black py-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0">
        <div class="absolute inset-0 opacity-[0.08]"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1.6px); background-size: 22px 22px; background-position: center;">
        </div>
    </div>

    <div id="hn-services-showcase" class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1fr_560px] lg:items-center">
            <div class="relative z-20 text-white">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold tracking-widest text-white/80">
                    服務總覽
                </span>
                <h2 class="mt-4 text-4xl font-extrabold tracking-tight text-white">專業服務項目</h2>
                <div class="mt-6 h-px w-24 bg-white/35"></div>
                <p class="mt-4 text-lg leading-relaxed text-white/70">
                    Horizon Nova 專注軟體開發外包與系統整合，承接各類資訊專案，服務範圍不受限於特定類型。合作可依需求採專案制報價或維護迭代，從需求釐清、設計開發到上線部署與後續維運，提供可驗收、可交接、可長期演進的成果。右側依服務類型列出適用情境與交付內容，方便快速比對。
                </p>
                <ul class="mt-6 space-y-3 text-sm text-white/70">
                    <li class="flex items-start gap-2">
                        <i data-lucide="sparkles" class="mt-0.5 h-4 w-4 text-indigo-400"></i>
                        <span>合作模式彈性：專案制／選配模組／維護迭代，可依需求組合。</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i data-lucide="package" class="mt-0.5 h-4 w-4 text-white/50"></i>
                        <span>交付物清楚：程式碼、文件、權限與部署流程可交接。</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i data-lucide="layers" class="mt-0.5 h-4 w-4 text-white/50"></i>
                        <span>實務涵蓋廣：AI/監控、AprilTag/IoT、行動 APP、企業系統、部署維運與量測串接。</span>
                    </li>
                </ul>
                <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                    <a href='@Url.Action("Index", "Consultation", new { area = "HNB_WEB" })'
                       class="inline-flex items-center justify-center rounded-full bg-slate-100 px-6 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-200">
                        立即諮詢
                        <i data-lucide="arrow-right" class="ml-2 h-4 w-4"></i>
                    </a>
                </div>
            </div>

            <div class="relative z-10">
                <div id="CardSwap">
                    @foreach (var s in services)
                    {
                        <div class="hn-card">
                            <h3>@s.Label</h3>
                            <div class="hn-card-text">
                                <p class="hn-card-summary">@s.Summary</p>
                                <ul class="hn-card-points">
                                    @foreach (var item in s.Points)
                                    {
                                        <li>@item</li>
                                    }
                                </ul>
                            </div>
                            <img src="@Url.Content(imageBase + s.Image)" alt="@s.Label" class="hn-card-img" loading="lazy" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
